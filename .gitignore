# File: .gitignore
**/.vs/
**/bin/
**/obj/
*.user
*.suo
*.cache
*.nupkg
*.snupkg
TestResults/
artifacts/
**/logs/
**/.DS_Store
**/.idea/
.idea/
*.DS_Store

# Local editor and machine-specific files
**/.vscode/
.vscode/
*.rsuser
*.userosscache
*.sln.docstates
*.DotSettings.user
Thumbs.db
Desktop.ini
*.coverage
*.coveragexml
coverage/

# Temporary and backup files
*.tmp
*.temp
*.bak
*.orig
*.rej
*.swp
*.swo
/scripts/tmp

# Machine- and environment-specific deployment settings
/scripts/deployment/*.local.psd1

# Public sample installer runner. The source-controlled files are the neutral
# host profile and documentation; generated runner/data is rebuilt locally.
/installer/OpenModulePlatform.Bootstrapper.exe
/installer/data/
/installer/payload/
/installer/sql/
/installer/tools/
/installer/configs/
/installer/*.json
/installer/*.cmd
/installer/*.ps1
/installer/*.log
!/installer/README.md
!/installer/hosts/
!/installer/hosts/**
