@using OpenModulePlatform.Web.Shared.Navigation
@using OpenModulePlatform.Web.Shared.Options
@using OpenModulePlatform.Web.Shared.Localization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Http
@using Microsoft.Extensions.Logging
@using Microsoft.JSInterop
@inject Microsoft.Extensions.Options.IOptions<WebAppOptions> WebAppOptionsAccessor
@inject PortalTopBarService PortalTopBarService
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject Microsoft.JSInterop.IJSRuntime JS
@inject Microsoft.Extensions.Logging.ILogger<PortalTopBar> Logger
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> L
@inject IHttpContextAccessor HttpContextAccessor
@implements IDisposable

@if (_portalTopBar.IsVisible && _portalTopBar.PortalLink is not null)
{
    <div class="portal-topbar"
         data-portal-topbar-root
         data-favorite-toggle-url="@_portalTopBar.FavoriteToggleUrl"
         data-add-favorite-text="@L[_portalTopBar.AddFavoriteTextKey]"
         data-remove-favorite-text="@L[_portalTopBar.RemoveFavoriteTextKey]"
         data-expand-text="@L["Expand"]"
         data-collapse-text="@L["Collapse"]"
         data-shortcuts-enabled="@_portalTopBar.ShortcutsEnabled.ToString().ToLowerInvariant()"
         data-shortcut-all-modules="@_portalTopBar.AllModulesShortcut"
         data-shortcut-favorites="@_portalTopBar.FavoritesShortcut"
         data-open-on-hover="@_portalTopBar.DropdownsOpenOnHover.ToString().ToLowerInvariant()"
         data-session-status-enabled="@_portalTopBar.SessionStatusCheckEnabled.ToString().ToLowerInvariant()"
         data-session-status-url="@_portalTopBar.SessionStatusUrl"
         data-session-login-url="@_portalTopBar.SessionLoginUrl"
         data-session-status-visible-interval="@_portalTopBar.SessionStatusVisibleIntervalSeconds"
         data-session-status-hidden-interval="@_portalTopBar.SessionStatusHiddenIntervalSeconds"
         data-session-lost-text="@L["Your session appears to have expired. Sign in again before continuing."]"
         data-session-network-lost-text="@L["The server could not be reached. Check the connection."]"
         data-session-login-text="@L["Sign in again"]"
         data-session-reload-text="@L["Reload"]">
        <nav class="portal-topbar__nav" aria-label="@_portalTopBar.PortalLink.TextKey" data-portal-topbar>
            <a class="portal-topbar__portal-link" href="@_portalTopBar.PortalLink.Href">@_portalTopBar.PortalLink.TextKey</a>

            @if (_portalTopBar.IsPortalAdmin && _portalTopBar.PortalAdminSections.Count > 0)
            {
                <details class="portal-topbar__admin" data-portal-topbar-overlay data-portal-topbar-hover-menu>
                    <summary title="@L[_portalTopBar.PortalAdminToggleTextKey]" aria-label="@L[_portalTopBar.PortalAdminToggleTextKey]">
                        <span class="portal-topbar__icon portal-topbar__icon--admin-gears" aria-hidden="true"></span>
                        <span class="visually-hidden">@L[_portalTopBar.PortalAdminToggleTextKey]</span>
                    </summary>
                    <div class="portal-topbar__admin-menu" data-portal-topbar-admin-menu>
                        @foreach (var section in _portalTopBar.PortalAdminSections)
                        {
                            <details class="portal-topbar__admin-submenu" data-portal-topbar-admin-submenu data-portal-topbar-overlay>
                                <summary class="portal-topbar__admin-submenu-trigger">
                                    <span>@L[section.TextKey]</span>
                                </summary>
                                <div class="portal-topbar__admin-submenu-menu">
                                    @foreach (var item in section.Items)
                                    {
                                        if (item.SeparatorBefore)
                                        {
                                            <div class="portal-topbar__admin-separator" role="separator" aria-hidden="true"></div>
                                        }
                                        <a class="portal-topbar__admin-link" href="@item.Href">@L[item.TextKey]</a>
                                    }
                                </div>
                            </details>
                        }
                    </div>
                </details>
            }

            @if (_portalTopBar.NavigationGroups.Count > 0)
            {
                <span class="portal-topbar__pipe" aria-hidden="true">|</span>

                <details class="portal-topbar__nav-dropdown" data-portal-topbar-overlay data-portal-topbar-hover-menu data-portal-topbar-all-modules>
                    <summary title="@L[_portalTopBar.AllModulesToggleTextKey]" aria-label="@L[_portalTopBar.AllModulesToggleTextKey]">
                        @L[_portalTopBar.AllModulesToggleTextKey]
                    </summary>
                    <div class="portal-topbar__nav-menu" data-portal-topbar-entry-menu>
                        <input class="portal-topbar__nav-filter"
                               type="search"
                               placeholder="@L[_portalTopBar.NavigationFilterPlaceholderTextKey]"
                               aria-label="@L[_portalTopBar.NavigationFilterPlaceholderTextKey]"
                               data-portal-topbar-entry-filter />
                        @foreach (var group in _portalTopBar.NavigationGroups)
                        {
                            var groupFavoriteLabel = L[group.IsFavorite ? _portalTopBar.RemoveFavoriteTextKey : _portalTopBar.AddFavoriteTextKey];
                            <div class="portal-topbar__nav-group" data-portal-topbar-entry-group>
                                <div class="portal-topbar__nav-group-header"
                                     data-portal-topbar-entry-row
                                     data-entry-key="@group.EntryKey"
                                     data-app-instance-id="@(group.AppInstanceId?.ToString("D") ?? string.Empty)"
                                     data-favorite-label="@group.Title"
                                     data-favorite-group-title=""
                                     data-favorite-entry-title="@group.Title"
                                     data-favorite-href="@group.Href"
                                     data-search="@GroupSearchText(group)">
                                    @if (group.HasLink)
                                    {
                                        <a class="portal-topbar__nav-group-link" href="@group.Href">@group.Title</a>
                                    }
                                    else
                                    {
                                        <span class="portal-topbar__nav-group-link" aria-disabled="true">@group.Title</span>
                                    }
                                    <span class="portal-topbar__nav-group-actions">
                                        @if (group.Entries.Count > 0)
                                        {
                                            <button type="button"
                                                    class="portal-topbar__nav-group-toggle"
                                                    title="@L["Expand"]"
                                                    aria-label="@L["Expand"]"
                                                    aria-expanded="false"
                                                    data-portal-topbar-entry-group-toggle>
                                                <span aria-hidden="true">▸</span>
                                            </button>
                                        }
                                        @if (_portalTopBar.CanUsePersistentFavorites && group.IsFavoritable)
                                        {
                                            <form method="post" action="@_portalTopBar.FavoriteToggleUrl" class="portal-topbar__favorite-form" data-portal-topbar-favorite-form data-enhance="false">
                                                <input type="hidden" name="entryKey" value="@group.EntryKey" />
                                                <input type="hidden" name="appInstanceId" value="@(group.AppInstanceId?.ToString("D") ?? string.Empty)" />
                                                <button type="submit"
                                                        class="portal-topbar__favorite-toggle@(group.IsFavorite ? " is-favorite" : string.Empty)"
                                                        title="@groupFavoriteLabel"
                                                        aria-label="@groupFavoriteLabel"
                                                        data-portal-topbar-favorite-button>
                                                    <span aria-hidden="true">@(group.IsFavorite ? "★" : "☆")</span>
                                                </button>
                                            </form>
                                        }
                                    </span>
                                </div>
                                <div class="portal-topbar__nav-group-entries" data-portal-topbar-entry-group-entries hidden>
                                @foreach (var entry in group.Entries)
                                {
                                    var favoriteToggleLabel = L[entry.IsFavorite ? _portalTopBar.RemoveFavoriteTextKey : _portalTopBar.AddFavoriteTextKey];
                                    var entryText = EntryText(entry);
                                    var entryFavoriteLabel = EntryFavoriteLabel(entry);
                                    <div class="portal-topbar__nav-entry-row"
                                         data-portal-topbar-entry-row
                                         data-entry-key="@entry.EntryKey"
                                         data-app-instance-id="@(entry.AppInstanceId?.ToString("D") ?? string.Empty)"
                                         data-favorite-label="@entryFavoriteLabel"
                                         data-favorite-group-title="@entry.GroupTitle"
                                         data-favorite-entry-title="@entryText"
                                         data-favorite-href="@entry.Href"
                                         data-search="@EntrySearchText(group, entry)">
                                        <a class="portal-topbar__nav-entry-link" href="@entry.Href">@entryText</a>
                                        @if (_portalTopBar.CanUsePersistentFavorites && entry.IsFavoritable)
                                        {
                                            <form method="post" action="@_portalTopBar.FavoriteToggleUrl" class="portal-topbar__favorite-form" data-portal-topbar-favorite-form data-enhance="false">
                                                <input type="hidden" name="entryKey" value="@entry.EntryKey" />
                                                <input type="hidden" name="appInstanceId" value="@(entry.AppInstanceId?.ToString("D") ?? string.Empty)" />
                                                <button type="submit"
                                                        class="portal-topbar__favorite-toggle@(entry.IsFavorite ? " is-favorite" : string.Empty)"
                                                        title="@favoriteToggleLabel"
                                                        aria-label="@favoriteToggleLabel"
                                                        data-portal-topbar-favorite-button>
                                                    <span aria-hidden="true">@(entry.IsFavorite ? "★" : "☆")</span>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                }
                                </div>
                            </div>
                        }
                    </div>
                </details>

                @if (_portalTopBar.CanUsePersistentFavorites)
                {
                    <details class="portal-topbar__nav-dropdown" data-portal-topbar-overlay data-portal-topbar-hover-menu data-portal-topbar-favorites>
                        <summary title="@L[_portalTopBar.FavoritesToggleTextKey]" aria-label="@L[_portalTopBar.FavoritesToggleTextKey]">
                            @L[_portalTopBar.FavoritesToggleTextKey]
                        </summary>
                        <div class="portal-topbar__favorites-menu">
                            <div class="portal-topbar__favorites-list" data-portal-topbar-favorites-list>
                                @foreach (var entry in _portalTopBar.FavoriteEntries)
                                {
                                    var removeFavoriteLabel = L[_portalTopBar.RemoveFavoriteTextKey];
                                    <div class="portal-topbar__favorite-row"
                                         data-portal-topbar-favorite-row
                                         data-favorite-entry-key="@entry.EntryKey"
                                         data-favorite-app-instance-id="@(entry.AppInstanceId?.ToString("D") ?? string.Empty)">
                                        <a class="portal-topbar__favorite-link" href="@entry.Href">
                                            @if (!string.IsNullOrWhiteSpace(entry.GroupTitle))
                                            {
                                                <span class="portal-topbar__favorite-module">@entry.GroupTitle</span>
                                                <span> / </span>
                                            }
                                            <span>@EntryText(entry)</span>
                                        </a>
                                        <form method="post" action="@_portalTopBar.FavoriteToggleUrl" class="portal-topbar__favorite-form" data-portal-topbar-favorite-form data-enhance="false">
                                            <input type="hidden" name="entryKey" value="@entry.EntryKey" />
                                            <input type="hidden" name="appInstanceId" value="@(entry.AppInstanceId?.ToString("D") ?? string.Empty)" />
                                            <button type="submit"
                                                    class="portal-topbar__favorite-toggle is-favorite"
                                                    title="@removeFavoriteLabel"
                                                    aria-label="@removeFavoriteLabel"
                                                    data-portal-topbar-favorite-button>
                                                <span aria-hidden="true">★</span>
                                            </button>
                                        </form>
                                    </div>
                                }
                            </div>
                            <div class="portal-topbar__favorites-empty" data-portal-topbar-favorites-empty @attributes="HiddenWhen(_portalTopBar.FavoriteEntries.Count > 0)">
                                @L[_portalTopBar.NoFavoritesTextKey]
                            </div>
                        </div>
                    </details>
                }
            }
        </nav>

        <div class="portal-topbar__actions">
            @if (_portalTopBar.LanguageOptions.Count > 1)
            {
                <details class="portal-topbar__language" data-portal-topbar-overlay data-portal-topbar-hover-menu>
                    <summary title="@L[_portalTopBar.LanguageToggleTextKey]" aria-label="@L[_portalTopBar.LanguageToggleTextKey]">
                        <span class="portal-topbar__summary-icon">
                            <span class="portal-topbar__icon portal-topbar__icon--language" aria-hidden="true"></span>
                            @if (_portalTopBar.IsCultureFallback)
                            {
                                <span class="portal-topbar__fallback-indicator" title="@FallbackNotice" aria-hidden="true">i</span>
                            }
                        </span>
                        <span class="visually-hidden">@L[_portalTopBar.LanguageToggleTextKey]</span>
                        @if (_portalTopBar.IsCultureFallback)
                        {
                            <span class="visually-hidden">@FallbackNotice</span>
                        }
                    </summary>
                    <div class="portal-topbar__language-menu">
                        <div class="portal-topbar__language-heading">
                            <span class="portal-topbar__language-row-icon portal-topbar__icon portal-topbar__icon--language" aria-hidden="true"></span>
                            <span>@L[_portalTopBar.LanguageToggleTextKey]</span>
                        </div>
                        <div class="portal-topbar__language-separator" role="separator" aria-hidden="true"></div>
                        @foreach (var language in SortedLanguageOptions())
                        {
                            @if (language.IsCurrent)
                            {
                                <div class="portal-topbar__language-row portal-topbar__language-current" aria-current="true" title="@language.Culture">
                                    <span class="portal-topbar__language-badge" aria-hidden="true">@LanguageBadgeText(language.Culture)</span>
                                    <span>@CultureText(language.DisplayText)</span>
                                    <span class="portal-topbar__language-check" aria-hidden="true"></span>
                                </div>
                            }
                            else
                            {
                                <a class="portal-topbar__language-row portal-topbar__language-link" href="@BuildLanguageHref(language.Culture)" title="@language.Culture" data-enhance-nav="false">
                                    <span class="portal-topbar__language-badge" aria-hidden="true">@LanguageBadgeText(language.Culture)</span>
                                    <span>@CultureText(language.DisplayText)</span>
                                </a>
                            }
                        }
                    </div>
                </details>
            }

            @if (_portalTopBar.CanUseNotifications)
            {
                <details class="portal-topbar__notifications" data-portal-topbar-overlay data-portal-topbar-hover-menu data-portal-topbar-notifications>
                    <summary title="@L[_portalTopBar.NotificationsToggleTextKey]" aria-label="@L[_portalTopBar.NotificationsToggleTextKey]">
                        <span class="portal-topbar__summary-icon">
                            <span class="portal-topbar__icon portal-topbar__icon--notifications" aria-hidden="true"></span>
                            <span class="portal-topbar__notification-badge" data-portal-topbar-notification-badge @attributes="HiddenWhen(_portalTopBar.UnreadNotificationCount == 0)">
                                @NotificationBadgeText(_portalTopBar.UnreadNotificationCount)
                            </span>
                        </span>
                        <span class="visually-hidden">@L[_portalTopBar.NotificationsToggleTextKey]</span>
                    </summary>
                    <div class="portal-topbar__notifications-menu portal-topbar__tray portal-topbar__tray--notifications">
                        <div class="portal-topbar__tray-header">
                            <span class="portal-topbar__tray-icon portal-topbar__icon portal-topbar__icon--notifications" aria-hidden="true"></span>
                            <span>@L[_portalTopBar.NotificationsToggleTextKey]</span>
                        </div>
                        <div class="portal-topbar__tray-separator" role="separator" aria-hidden="true"></div>
                        <div class="portal-topbar__tray-body">
                            <div class="portal-topbar__notifications-list"
                                 data-portal-topbar-notifications-list
                                 data-load-url="@_portalTopBar.NotificationRecentUrl"
                                 data-mark-read-url="@_portalTopBar.NotificationMarkReadUrl"
                                 data-page-size="10"
                                 data-no-notifications-text="@L[_portalTopBar.NoNotificationsTextKey]"
                                 data-loading-text="@L["Loading"]"
                                 data-end-text="@L["No more notifications"]">
                                @foreach (var notification in _portalTopBar.Notifications)
                                {
                                    <form method="post"
                                          action="@_portalTopBar.NotificationMarkReadUrl"
                                          class="portal-topbar__notification-form@(notification.IsUnread ? " is-unread" : " is-read")"
                                          data-portal-topbar-notification-form
                                          data-notification-id="@notification.NotificationId"
                                          data-notification-created-at="@notification.CreatedAt.ToUniversalTime().ToString("O", System.Globalization.CultureInfo.InvariantCulture)"
                                          data-enhance="false">
                                        <input type="hidden" name="notificationId" value="@notification.NotificationId" />
                                        <button type="submit"
                                                class="portal-topbar__notification-row portal-topbar__notification-row--@notification.Level"
                                                data-destination-url="@(notification.DestinationUrl ?? string.Empty)">
                                            <span class="portal-topbar__notification-caller-icon" aria-hidden="true">
                                                @if (!string.IsNullOrWhiteSpace(notification.CallerIcon))
                                                {
                                                    <img src="@notification.CallerIcon" alt="" />
                                                }
                                                else
                                                {
                                                    <span>@NotificationCallerText(notification)</span>
                                                }
                                            </span>
                                            <span class="portal-topbar__notification-copy">
                                                <span class="portal-topbar__notification-title">@notification.Title</span>
                                                <span class="portal-topbar__notification-content">@notification.Content</span>
                                            </span>
                                        </button>
                                    </form>
                                }
                            </div>
                            <div class="portal-topbar__notifications-empty" data-portal-topbar-notifications-empty @attributes="HiddenWhen(_portalTopBar.Notifications.Count > 0)">
                                @L[_portalTopBar.NoNotificationsTextKey]
                            </div>
                            <div class="portal-topbar__notifications-loading" data-portal-topbar-notifications-loading hidden>@L["Loading"]</div>
                            <div class="portal-topbar__notifications-end" data-portal-topbar-notifications-end hidden>@L["No more notifications"]</div>
                        </div>
                        <div class="portal-topbar__tray-separator" role="separator" aria-hidden="true"></div>
                        <div class="portal-topbar__tray-footer">
                            <form method="post"
                                  action="@_portalTopBar.NotificationMarkAllReadUrl"
                                  class="portal-topbar__notifications-mark-all-form"
                                  data-portal-topbar-notification-mark-all-form
                                  data-enhance="false"
                                  @attributes="HiddenWhen(_portalTopBar.Notifications.Count == 0)">
                                <button type="submit" class="portal-topbar__tray-action portal-topbar__notifications-mark-all">
                                    @L[_portalTopBar.MarkAllNotificationsReadTextKey]
                                </button>
                            </form>
                            <a class="portal-topbar__tray-action portal-topbar__notifications-link" href="@_portalTopBar.NotificationsUrl" data-enhance-nav="false">
                                @L[_portalTopBar.ViewAllNotificationsTextKey]
                            </a>
                        </div>
                    </div>
                </details>
            }

            @if (_portalTopBar.CanUseMessages)
            {
                <details class="portal-topbar__messages" data-portal-topbar-overlay data-portal-topbar-hover-menu>
                    <summary title="@L[_portalTopBar.MessagesToggleTextKey]" aria-label="@L[_portalTopBar.MessagesToggleTextKey]">
                        <span class="portal-topbar__summary-icon">
                            <span class="portal-topbar__icon portal-topbar__icon--messages" aria-hidden="true"></span>
                            <span class="portal-topbar__message-badge" @attributes="HiddenWhen(_portalTopBar.UnreadMessageCount == 0)">
                                @NotificationBadgeText(_portalTopBar.UnreadMessageCount)
                            </span>
                        </span>
                        <span class="visually-hidden">@L[_portalTopBar.MessagesToggleTextKey]</span>
                    </summary>
                    <div class="portal-topbar__messages-menu portal-topbar__tray portal-topbar__tray--messages">
                        <div class="portal-topbar__tray-header">
                            <span class="portal-topbar__tray-icon portal-topbar__icon portal-topbar__icon--messages" aria-hidden="true"></span>
                            <span>@L[_portalTopBar.MessagesToggleTextKey]</span>
                        </div>
                        <div class="portal-topbar__tray-separator" role="separator" aria-hidden="true"></div>
                        <div class="portal-topbar__tray-body">
                            <div class="portal-topbar__messages-list">
                                @foreach (var conversation in _portalTopBar.MessageConversations)
                                {
                                    <a class="portal-topbar__message-row@(conversation.UnreadCount > 0 ? " is-unread" : string.Empty)"
                                       href="@conversation.Href"
                                       data-enhance-nav="false">
                                        <span class="portal-topbar__message-avatar" aria-hidden="true">
                                            @if (!string.IsNullOrWhiteSpace(conversation.AvatarUrl))
                                            {
                                                <img src="@conversation.AvatarUrl" alt="" />
                                            }
                                            else
                                            {
                                                @UserInitials(conversation.DisplayTitle)
                                            }
                                        </span>
                                        <span class="portal-topbar__message-copy">
                                            <span class="portal-topbar__message-title">@conversation.DisplayTitle</span>
                                            <span class="portal-topbar__message-preview">@(conversation.LastMessagePreview ?? L["No messages"].Value)</span>
                                            @if (conversation.LastMessageAt is not null)
                                            {
                                                <span class="portal-topbar__message-meta">@MessageTimeText(conversation.LastMessageAt)</span>
                                            }
                                        </span>
                                        <span class="portal-topbar__message-row-badge" @attributes="HiddenWhen(conversation.UnreadCount == 0)">
                                            @NotificationBadgeText(conversation.UnreadCount)
                                        </span>
                                    </a>
                                }
                            </div>
                            @if (_portalTopBar.MessageConversations.Count == 0)
                            {
                                <div class="portal-topbar__messages-empty">@L[_portalTopBar.NoMessagesTextKey]</div>
                            }
                        </div>
                        <div class="portal-topbar__tray-separator" role="separator" aria-hidden="true"></div>
                        <div class="portal-topbar__tray-footer">
                            <form method="post"
                                  action="@_portalTopBar.MessageMarkAllReadUrl"
                                  class="portal-topbar__messages-mark-all-form"
                                  data-enhance="false"
                                  @attributes="HiddenWhen(_portalTopBar.UnreadMessageCount == 0)">
                                <input type="hidden" name="returnUrl" value="@CurrentReturnUrl()" />
                                <button type="submit" class="portal-topbar__tray-action portal-topbar__messages-action">
                                    @L[_portalTopBar.MarkAllMessagesReadTextKey]
                                </button>
                            </form>
                            <a class="portal-topbar__tray-action portal-topbar__messages-footer-link" href="@_portalTopBar.MessagesUrl" data-enhance-nav="false">
                                @L[_portalTopBar.ViewAllMessagesTextKey]
                            </a>
                        </div>
                    </div>
                </details>
            }

            @if (!string.IsNullOrWhiteSpace(_portalTopBar.CurrentUserName))
            {
                <details class="portal-topbar__profile" data-portal-topbar-overlay data-portal-topbar-hover-menu>
                    <summary title="@L["User"]" aria-label="@L["User"]">
                        <span class="portal-topbar__icon portal-topbar__icon--user" aria-hidden="true"></span>
                        <span class="visually-hidden">@L["User"]</span>
                    </summary>
                    <div class="portal-topbar__profile-menu">
                        <div class="portal-topbar__profile-heading">
                            <span class="portal-topbar__profile-row-icon portal-topbar__icon portal-topbar__icon--user" aria-hidden="true"></span>
                            <span>@L["User"]</span>
                        </div>

                        <div class="portal-topbar__profile-separator" role="separator" aria-hidden="true"></div>

                        <div class="portal-topbar__profile-info">
                            <div class="portal-topbar__profile-row portal-topbar__profile-status-row">
                                <span class="portal-topbar__profile-avatar" aria-hidden="true">
                                    @if (!string.IsNullOrWhiteSpace(_portalTopBar.CurrentUserProfileImageUrl))
                                    {
                                        <img src="@_portalTopBar.CurrentUserProfileImageUrl" alt="" />
                                    }
                                    else
                                    {
                                        @UserInitials(_portalTopBar.CurrentUserName)
                                    }
                                </span>
                                <span class="portal-topbar__profile-current-user" title="@_portalTopBar.CurrentUserName">@DisplayUserName(_portalTopBar.CurrentUserName)</span>
                            </div>
                            <div class="portal-topbar__profile-row portal-topbar__profile-status-row portal-topbar__profile-active-role" aria-label="@L["Active role"]">
                                <span class="portal-topbar__profile-row-icon portal-topbar__icon portal-topbar__icon--badge" aria-hidden="true"></span>
                                <span class="portal-topbar__profile-current-role" title="@(_roleContext.ActiveRoleName ?? L["No roles assigned."])">@(_roleContext.ActiveRoleName ?? L["No roles assigned."])</span>
                            </div>
                        </div>

                        <div class="portal-topbar__profile-separator" role="separator" aria-hidden="true"></div>

                        @if (_roleContext.AvailableRoles.Count > 1)
                        {
                            <details class="portal-topbar__profile-switch" data-portal-topbar-overlay>
                                <summary class="portal-topbar__profile-row portal-topbar__profile-action-row">
                                    <span class="portal-topbar__profile-row-icon portal-topbar__icon portal-topbar__icon--switch" aria-hidden="true"></span>
                                    <span>@L["SwitchRole"]</span>
                                </summary>
                                <div class="portal-topbar__profile-switch-menu">
                                    @foreach (var role in _roleContext.AvailableRoles.Where(role => role.RoleId != _roleContext.ActiveRoleId))
                                    {
                                        <a class="portal-topbar__profile-role-link" href="@BuildRoleHref(role.RoleId)" data-enhance-nav="false">@role.Name</a>
                                    }
                                </div>
                            </details>
                        }

                        <a class="portal-topbar__profile-row portal-topbar__profile-action-row" href="@_portalTopBar.SettingsUrl" data-enhance-nav="false">
                            <span class="portal-topbar__profile-row-icon portal-topbar__icon portal-topbar__icon--settings" aria-hidden="true"></span>
                            <span>@L["Settings"]</span>
                        </a>

                        <div class="portal-topbar__profile-separator portal-topbar__profile-separator--logout" role="separator" aria-hidden="true"></div>

                        <form method="post" action="@_portalTopBar.LogoutUrl" class="portal-topbar__logout-form" data-enhance="false">
                            <button type="submit"
                                    class="portal-topbar__profile-row portal-topbar__profile-action-row portal-topbar__profile-logout-row">
                                <span class="portal-topbar__profile-row-icon portal-topbar__icon portal-topbar__icon--logout" aria-hidden="true"></span>
                                <span>@L["Log out"]</span>
                            </button>
                        </form>
                    </div>
                </details>
            }
        </div>
        @if (_portalTopBar.Banners.Count > 0)
        {
            <div class="portal-topbar__notification-banners" data-portal-topbar-notification-banners>
                @foreach (var banner in _portalTopBar.Banners)
                {
                    <div class="portal-topbar__notification-banner portal-topbar__notification-banner--@banner.LevelName" role="status">
                        <span class="portal-topbar__notification-banner-icon" aria-hidden="true">
                            <img src="@banner.IconUrl" alt="" />
                        </span>
                        <span class="portal-topbar__notification-banner-copy">
                            <span class="portal-topbar__notification-banner-title">@banner.Title</span>
                            <span class="portal-topbar__notification-banner-content">@banner.Content</span>
                        </span>
                    </div>
                }
            </div>
        }
    </div>
}

@code {
    private PortalTopBarModel _portalTopBar = PortalTopBarModel.Hidden;
    private OpenModulePlatform.Web.Shared.Services.UserRoleContext _roleContext = OpenModulePlatform.Web.Shared.Services.UserRoleContext.Empty;

    [CascadingParameter]
    private HttpContext? CascadedHttpContext { get; set; }

    private string FallbackNotice => string.Format(
        L["LanguageFallbackNotice"],
        CultureText(_portalTopBar.PreferredCultureDisplayText),
        CultureText(_portalTopBar.EffectiveCultureDisplayText));

    private static readonly IReadOnlyDictionary<string, object> HiddenAttribute =
        new Dictionary<string, object>
        {
            ["hidden"] = "hidden"
        };

    private static IReadOnlyDictionary<string, object>? HiddenWhen(bool condition)
        => condition ? HiddenAttribute : null;

    protected override async Task OnInitializedAsync()
    {
        NavigationManager.LocationChanged += HandleLocationChanged;

        try
        {
            var httpContext = CascadedHttpContext ?? HttpContextAccessor.HttpContext;
            if (httpContext is not null)
            {
                ApplyTopBarModel(await PortalTopBarService.CreateAsync(
                    WebAppOptionsAccessor.Value,
                    httpContext,
                    httpContext.RequestAborted));
                return;
            }

            var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authenticationState.User;

            if (Uri.TryCreate(NavigationManager.Uri, UriKind.Absolute, out var currentUri))
            {
                ApplyTopBarModel(await PortalTopBarService.CreateAsync(
                    WebAppOptionsAccessor.Value,
                    currentUri,
                    user,
                    CancellationToken.None));
                return;
            }

            ApplyTopBarModel(PortalTopBarModelFactory.Create(WebAppOptionsAccessor.Value));
        }
        catch (Exception ex) when (ex is not OperationCanceledException)
        {
            Logger.LogError(ex, "Failed to initialize the portal top bar. Falling back to the configured top bar model.");
            ApplyTopBarModel(PortalTopBarModelFactory.Create(WebAppOptionsAccessor.Value));
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_portalTopBar.IsVisible)
        {
            try
            {
                await JS.InvokeVoidAsync("ompPortalTopBar.initAll");
            }
            catch (Microsoft.JSInterop.JSException ex)
            {
                Logger.LogDebug(ex, "Could not initialize the portal top bar JavaScript.");
            }
            catch (InvalidOperationException ex)
            {
                Logger.LogDebug(ex, "Portal top bar JavaScript initialization was skipped.");
            }
            catch (OperationCanceledException ex)
            {
                Logger.LogDebug(ex, "Portal top bar JavaScript initialization was canceled.");
            }
        }
    }

    private string BuildLanguageHref(string culture)
    {
        var baseUri = new Uri(NavigationManager.BaseUri, UriKind.Absolute);
        var basePath = baseUri.AbsolutePath.TrimEnd('/');
        var endpointPath = string.IsNullOrWhiteSpace(basePath)
            ? "/localization/set-language"
            : $"{basePath}/localization/set-language";

        var relativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        var returnUrl = string.IsNullOrWhiteSpace(relativePath)
            ? (string.IsNullOrWhiteSpace(basePath) ? "/" : $"{basePath}/")
            : $"{(string.IsNullOrWhiteSpace(basePath) ? string.Empty : basePath)}/{relativePath.TrimStart('/')}";

        return $"{endpointPath}?culture={Uri.EscapeDataString(culture)}&returnUrl={Uri.EscapeDataString(returnUrl)}";
    }


    private string BuildAppBaseRelativePath(string relativePath)
    {
        var baseUri = new Uri(NavigationManager.BaseUri, UriKind.Absolute);
        var basePath = baseUri.AbsolutePath.TrimEnd('/');
        return string.IsNullOrWhiteSpace(basePath)
            ? $"/{relativePath.TrimStart('/')}"
            : $"{basePath}/{relativePath.TrimStart('/')}";
    }

    private string BuildRoleHref(int? roleId)
    {
        var currentUri = new Uri(NavigationManager.Uri, UriKind.Absolute);
        var returnUrl = $"{currentUri.AbsolutePath}{currentUri.Query}";
        return $"{BuildAppBaseRelativePath("security/set-active-role")}?roleId={Uri.EscapeDataString(roleId?.ToString() ?? string.Empty)}&returnUrl={Uri.EscapeDataString(returnUrl)}";
    }

    private void HandleLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
        => _ = InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        NavigationManager.LocationChanged -= HandleLocationChanged;
    }

    private void ApplyTopBarModel(PortalTopBarModel model)
    {
        _portalTopBar = model;
        _roleContext = new OpenModulePlatform.Web.Shared.Services.UserRoleContext
        {
            AvailableRoles = model.AvailableRoles,
            ActiveRoleId = model.ActiveRoleId,
            ActiveRoleName = model.ActiveRoleName
        };
    }

    private string CultureText(string? text)
        => string.IsNullOrWhiteSpace(text) ? string.Empty : L[text];

    private IReadOnlyList<PortalTopBarCultureOption> SortedLanguageOptions()
        => _portalTopBar.LanguageOptions
            .OrderBy(language => CultureText(language.DisplayText), StringComparer.CurrentCultureIgnoreCase)
            .ThenBy(language => language.Culture, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private string EntryText(PortalTopBarNavigationEntry entry)
        => L[entry.TextKey].Value;

    private string EntryFavoriteLabel(PortalTopBarNavigationEntry entry)
        => string.IsNullOrWhiteSpace(entry.GroupTitle)
            ? EntryText(entry)
            : $"{entry.GroupTitle} / {EntryText(entry)}";

    private string EntrySearchText(
        PortalTopBarNavigationGroup group,
        PortalTopBarNavigationEntry entry)
    {
        var text = EntryText(entry);
        return $"{entry.SearchText} {group.Title} {text} {group.Title}/{text} {group.GroupKey}/{text} {entry.Href.Trim('/')}";
    }

    private static string GroupSearchText(PortalTopBarNavigationGroup group)
        => $"{group.SearchText} {group.Title} {group.Href.Trim('/')}";

    private static string NotificationBadgeText(int count)
        => count > 99 ? "99+" : count.ToString(System.Globalization.CultureInfo.InvariantCulture);

    private string CurrentReturnUrl()
    {
        if (Uri.TryCreate(NavigationManager.Uri, UriKind.Absolute, out var currentUri))
        {
            return $"{currentUri.AbsolutePath}{currentUri.Query}";
        }

        return "/";
    }

    private static string MessageTimeText(DateTime? value)
        => value is null
            ? string.Empty
            : value.Value.ToLocalTime().ToString("g", System.Globalization.CultureInfo.CurrentCulture);

    private static string NotificationCallerText(PortalTopBarNotification notification)
    {
        var source = string.IsNullOrWhiteSpace(notification.CallerDisplayName)
            ? notification.CallerKey
            : notification.CallerDisplayName;
        return string.IsNullOrWhiteSpace(source)
            ? "!"
            : source.Trim()[0].ToString().ToUpperInvariant();
    }

    private static string LanguageBadgeText(string? culture)
    {
        if (string.IsNullOrWhiteSpace(culture))
        {
            return "?";
        }

        var trimmed = culture.Trim();
        var separatorIndex = trimmed.IndexOfAny(new[] { '-', '_' });
        var language = separatorIndex > 0 ? trimmed[..separatorIndex] : trimmed;
        return language.Length <= 3
            ? language.ToUpperInvariant()
            : trimmed.ToUpperInvariant();
    }

    private static string DisplayUserName(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        var separatorIndex = value.LastIndexOf('\\');
        return separatorIndex >= 0 && separatorIndex < value.Length - 1
            ? value[(separatorIndex + 1)..]
            : value;
    }

    private static string UserInitials(string? value)
    {
        var displayName = DisplayUserName(value);
        if (string.IsNullOrWhiteSpace(displayName))
        {
            return "?";
        }

        var parts = displayName
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length >= 2)
        {
            return string.Concat(parts[0][0], parts[^1][0]).ToUpperInvariant();
        }

        return displayName[..Math.Min(displayName.Length, 2)].ToUpperInvariant();
    }
}
