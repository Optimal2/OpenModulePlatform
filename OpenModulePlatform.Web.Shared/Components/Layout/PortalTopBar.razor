@using OpenModulePlatform.Web.Shared.Navigation
@using OpenModulePlatform.Web.Shared.Options
@using OpenModulePlatform.Web.Shared.Localization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Http
@inject Microsoft.Extensions.Options.IOptions<WebAppOptions> WebAppOptionsAccessor
@inject PortalTopBarService PortalTopBarService
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject Microsoft.JSInterop.IJSRuntime JS
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> L
@inject IHttpContextAccessor HttpContextAccessor
@inject OpenModulePlatform.Web.Shared.Services.RbacService RbacService
@implements IDisposable

@if (_portalTopBar.IsVisible && _portalTopBar.PortalLink is not null)
{
    <div class="portal-topbar"
         data-portal-topbar-root
         data-favorite-toggle-url="@_portalTopBar.FavoriteToggleUrl"
         data-add-favorite-text="@L[_portalTopBar.AddFavoriteTextKey]"
         data-remove-favorite-text="@L[_portalTopBar.RemoveFavoriteTextKey]"
         data-expand-text="@L["Expand"]"
         data-collapse-text="@L["Collapse"]"
         data-shortcuts-enabled="@_portalTopBar.ShortcutsEnabled.ToString().ToLowerInvariant()"
         data-shortcut-all-modules="@_portalTopBar.AllModulesShortcut"
         data-shortcut-favorites="@_portalTopBar.FavoritesShortcut"
         data-open-on-hover="@_portalTopBar.DropdownsOpenOnHover.ToString().ToLowerInvariant()">
        <nav class="portal-topbar__nav" aria-label="@_portalTopBar.PortalLink.TextKey" data-portal-topbar>
            <a class="portal-topbar__portal-link" href="@_portalTopBar.PortalLink.Href">@_portalTopBar.PortalLink.TextKey</a>

            @if (_portalTopBar.IsPortalAdmin && _portalTopBar.PortalAdminSections.Count > 0)
            {
                <details class="portal-topbar__admin" data-portal-topbar-overlay data-portal-topbar-hover-menu>
                    <summary title="@L[_portalTopBar.PortalAdminToggleTextKey]" aria-label="@L[_portalTopBar.PortalAdminToggleTextKey]">
                        <span class="portal-topbar__icon portal-topbar__icon--admin-gears" aria-hidden="true"></span>
                        <span class="visually-hidden">@L[_portalTopBar.PortalAdminToggleTextKey]</span>
                    </summary>
                    <div class="portal-topbar__admin-menu" data-portal-topbar-admin-menu>
                        @foreach (var section in _portalTopBar.PortalAdminSections)
                        {
                            <details class="portal-topbar__admin-submenu" data-portal-topbar-admin-submenu data-portal-topbar-overlay>
                                <summary class="portal-topbar__admin-submenu-trigger">
                                    <span>@L[section.TextKey]</span>
                                </summary>
                                <div class="portal-topbar__admin-submenu-menu">
                                    @foreach (var item in section.Items)
                                    {
                                        if (item.SeparatorBefore)
                                        {
                                            <div class="portal-topbar__admin-separator" role="separator" aria-hidden="true"></div>
                                        }
                                        <a class="portal-topbar__admin-link" href="@item.Href">@L[item.TextKey]</a>
                                    }
                                </div>
                            </details>
                        }
                    </div>
                </details>
            }

            @if (_portalTopBar.NavigationGroups.Count > 0)
            {
                <span class="portal-topbar__pipe" aria-hidden="true">|</span>

                <details class="portal-topbar__nav-dropdown" data-portal-topbar-overlay data-portal-topbar-hover-menu data-portal-topbar-all-modules>
                    <summary title="@L[_portalTopBar.AllModulesToggleTextKey]" aria-label="@L[_portalTopBar.AllModulesToggleTextKey]">
                        @L[_portalTopBar.AllModulesToggleTextKey]
                    </summary>
                    <div class="portal-topbar__nav-menu" data-portal-topbar-entry-menu>
                        <input class="portal-topbar__nav-filter"
                               type="search"
                               placeholder="@L[_portalTopBar.NavigationFilterPlaceholderTextKey]"
                               aria-label="@L[_portalTopBar.NavigationFilterPlaceholderTextKey]"
                               data-portal-topbar-entry-filter />
                        @foreach (var group in _portalTopBar.NavigationGroups)
                        {
                            var groupFavoriteLabel = L[group.IsFavorite ? _portalTopBar.RemoveFavoriteTextKey : _portalTopBar.AddFavoriteTextKey];
                            <div class="portal-topbar__nav-group" data-portal-topbar-entry-group>
                                <div class="portal-topbar__nav-group-header"
                                     data-portal-topbar-entry-row
                                     data-entry-key="@group.EntryKey"
                                     data-app-instance-id="@(group.AppInstanceId?.ToString("D") ?? string.Empty)"
                                     data-favorite-label="@group.Title"
                                     data-favorite-group-title=""
                                     data-favorite-entry-title="@group.Title"
                                     data-favorite-href="@group.Href"
                                     data-search="@GroupSearchText(group)">
                                    @if (group.HasLink)
                                    {
                                        <a class="portal-topbar__nav-group-link" href="@group.Href">@group.Title</a>
                                    }
                                    else
                                    {
                                        <span class="portal-topbar__nav-group-link" aria-disabled="true">@group.Title</span>
                                    }
                                    <span class="portal-topbar__nav-group-actions">
                                        @if (group.Entries.Count > 0)
                                        {
                                            <button type="button"
                                                    class="portal-topbar__nav-group-toggle"
                                                    title="@L["Expand"]"
                                                    aria-label="@L["Expand"]"
                                                    aria-expanded="false"
                                                    data-portal-topbar-entry-group-toggle>
                                                <span aria-hidden="true">▸</span>
                                            </button>
                                        }
                                        @if (_portalTopBar.CanUsePersistentFavorites && group.IsFavoritable)
                                        {
                                            <form method="post" action="@_portalTopBar.FavoriteToggleUrl" class="portal-topbar__favorite-form" data-portal-topbar-favorite-form data-enhance="false">
                                                <input type="hidden" name="entryKey" value="@group.EntryKey" />
                                                <input type="hidden" name="appInstanceId" value="@(group.AppInstanceId?.ToString("D") ?? string.Empty)" />
                                                <button type="submit"
                                                        class="portal-topbar__favorite-toggle@(group.IsFavorite ? " is-favorite" : string.Empty)"
                                                        title="@groupFavoriteLabel"
                                                        aria-label="@groupFavoriteLabel"
                                                        data-portal-topbar-favorite-button>
                                                    <span aria-hidden="true">@(group.IsFavorite ? "★" : "☆")</span>
                                                </button>
                                            </form>
                                        }
                                    </span>
                                </div>
                                <div class="portal-topbar__nav-group-entries" data-portal-topbar-entry-group-entries hidden>
                                @foreach (var entry in group.Entries)
                                {
                                    var favoriteLabel = L[entry.IsFavorite ? _portalTopBar.RemoveFavoriteTextKey : _portalTopBar.AddFavoriteTextKey];
                                    var entryText = EntryText(entry);
                                    var entryFavoriteLabel = EntryFavoriteLabel(entry);
                                    <div class="portal-topbar__nav-entry-row"
                                         data-portal-topbar-entry-row
                                         data-entry-key="@entry.EntryKey"
                                         data-app-instance-id="@(entry.AppInstanceId?.ToString("D") ?? string.Empty)"
                                         data-favorite-label="@entryFavoriteLabel"
                                         data-favorite-group-title="@entry.GroupTitle"
                                         data-favorite-entry-title="@entryText"
                                         data-favorite-href="@entry.Href"
                                         data-search="@EntrySearchText(group, entry)">
                                        <a class="portal-topbar__nav-entry-link" href="@entry.Href">@entryText</a>
                                        @if (_portalTopBar.CanUsePersistentFavorites && entry.IsFavoritable)
                                        {
                                            <form method="post" action="@_portalTopBar.FavoriteToggleUrl" class="portal-topbar__favorite-form" data-portal-topbar-favorite-form data-enhance="false">
                                                <input type="hidden" name="entryKey" value="@entry.EntryKey" />
                                                <input type="hidden" name="appInstanceId" value="@(entry.AppInstanceId?.ToString("D") ?? string.Empty)" />
                                                <button type="submit"
                                                        class="portal-topbar__favorite-toggle@(entry.IsFavorite ? " is-favorite" : string.Empty)"
                                                        title="@favoriteLabel"
                                                        aria-label="@favoriteLabel"
                                                        data-portal-topbar-favorite-button>
                                                    <span aria-hidden="true">@(entry.IsFavorite ? "★" : "☆")</span>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                }
                                </div>
                            </div>
                        }
                    </div>
                </details>

                @if (_portalTopBar.CanUsePersistentFavorites)
                {
                    <details class="portal-topbar__nav-dropdown" data-portal-topbar-overlay data-portal-topbar-hover-menu data-portal-topbar-favorites>
                        <summary title="@L[_portalTopBar.FavoritesToggleTextKey]" aria-label="@L[_portalTopBar.FavoritesToggleTextKey]">
                            @L[_portalTopBar.FavoritesToggleTextKey]
                        </summary>
                        <div class="portal-topbar__favorites-menu">
                            <div class="portal-topbar__favorites-list" data-portal-topbar-favorites-list>
                                @foreach (var entry in _portalTopBar.FavoriteEntries)
                                {
                                    var removeFavoriteLabel = L[_portalTopBar.RemoveFavoriteTextKey];
                                    <div class="portal-topbar__favorite-row"
                                         data-portal-topbar-favorite-row
                                         data-favorite-entry-key="@entry.EntryKey"
                                         data-favorite-app-instance-id="@(entry.AppInstanceId?.ToString("D") ?? string.Empty)">
                                        <a class="portal-topbar__favorite-link" href="@entry.Href">
                                            @if (!string.IsNullOrWhiteSpace(entry.GroupTitle))
                                            {
                                                <span class="portal-topbar__favorite-module">@entry.GroupTitle</span>
                                                <span> / </span>
                                            }
                                            <span>@EntryText(entry)</span>
                                        </a>
                                        <form method="post" action="@_portalTopBar.FavoriteToggleUrl" class="portal-topbar__favorite-form" data-portal-topbar-favorite-form data-enhance="false">
                                            <input type="hidden" name="entryKey" value="@entry.EntryKey" />
                                            <input type="hidden" name="appInstanceId" value="@(entry.AppInstanceId?.ToString("D") ?? string.Empty)" />
                                            <button type="submit"
                                                    class="portal-topbar__favorite-toggle is-favorite"
                                                    title="@removeFavoriteLabel"
                                                    aria-label="@removeFavoriteLabel"
                                                    data-portal-topbar-favorite-button>
                                                <span aria-hidden="true">★</span>
                                            </button>
                                        </form>
                                    </div>
                                }
                            </div>
                            <div class="portal-topbar__favorites-empty" data-portal-topbar-favorites-empty hidden="@(_portalTopBar.FavoriteEntries.Count > 0)">
                                @L[_portalTopBar.NoFavoritesTextKey]
                            </div>
                        </div>
                    </details>
                }
            }
        </nav>

        <div class="portal-topbar__actions">
            @if (_portalTopBar.LanguageOptions.Count > 1)
            {
                <details class="portal-topbar__language" data-portal-topbar-overlay data-portal-topbar-hover-menu>
                    <summary title="@L[_portalTopBar.LanguageToggleTextKey]" aria-label="@L[_portalTopBar.LanguageToggleTextKey]">
                        <span class="portal-topbar__summary-icon">
                            <span class="portal-topbar__icon portal-topbar__icon--language" aria-hidden="true"></span>
                            @if (_portalTopBar.IsCultureFallback)
                            {
                                <span class="portal-topbar__fallback-indicator" title="@FallbackNotice" aria-hidden="true">i</span>
                            }
                        </span>
                        <span class="visually-hidden">@L[_portalTopBar.LanguageToggleTextKey]</span>
                        @if (_portalTopBar.IsCultureFallback)
                        {
                            <span class="visually-hidden">@FallbackNotice</span>
                        }
                    </summary>
                    <div class="portal-topbar__language-menu">
                        @if (_portalTopBar.IsCultureFallback)
                        {
                            <div class="portal-topbar__language-note">
                                <div class="portal-topbar__language-note-title">@L["LanguageFallback"]</div>
                                <div class="portal-topbar__language-note-body">@FallbackNotice</div>
                            </div>
                        }
                        @foreach (var language in _portalTopBar.LanguageOptions)
                        {
                            <a class="portal-topbar__language-link@(language.IsCurrent ? " is-current" : string.Empty)" href="@BuildLanguageHref(language.Culture)" data-enhance-nav="false">@CultureText(language.DisplayText)</a>
                        }
                    </div>
                </details>
            }

            @if (!string.IsNullOrWhiteSpace(_portalTopBar.CurrentUserName))
            {
                <details class="portal-topbar__profile" data-portal-topbar-overlay data-portal-topbar-hover-menu>
                    <summary title="@L["User"]" aria-label="@L["User"]">
                        <span class="portal-topbar__icon portal-topbar__icon--user" aria-hidden="true"></span>
                        <span class="visually-hidden">@L["User"]</span>
                    </summary>
                    <div class="portal-topbar__profile-menu">
                        <div class="portal-topbar__profile-identity">
                            <span class="portal-topbar__profile-roles-heading">@L["User"]</span>
                            <div class="portal-topbar__profile-user-row">
                                @if (_portalTopBar.IsPortalAdmin)
                                {
                                    <button type="button"
                                            class="portal-topbar__profile-copy-name"
                                            title="@L["Copy full user name"]"
                                            aria-label="@L["Copy full user name"]"
                                            data-copy-to-clipboard="true"
                                            data-copy-text="@_portalTopBar.CurrentUserName">
                                        <span class="portal-topbar__profile-current-user" title="@_portalTopBar.CurrentUserName">@DisplayUserName(_portalTopBar.CurrentUserName)</span>
                                        <span class="portal-topbar__profile-copy-inline-icon portal-topbar__icon--copy" aria-hidden="true"></span>
                                    </button>
                                }
                                else
                                {
                                    <span class="portal-topbar__profile-name">
                                        <span class="portal-topbar__profile-current-user">@DisplayUserName(_portalTopBar.CurrentUserName)</span>
                                    </span>
                                }
                                <form method="post" action="@_portalTopBar.LogoutUrl" class="portal-topbar__logout-form" data-enhance="false">
                                    <button type="submit"
                                            class="portal-topbar__profile-action-button"
                                            title="@L["Log out"]"
                                            aria-label="@L["Log out"]">
                                        <span class="portal-topbar__icon portal-topbar__icon--logout" aria-hidden="true"></span>
                                    </button>
                                </form>
                            </div>
                            <a class="portal-topbar__profile-settings-link" href="@_portalTopBar.SettingsUrl" data-enhance-nav="false">@L["Settings"]</a>
                        </div>
                        <div class="portal-topbar__profile-section">
                            <span class="portal-topbar__profile-roles-heading">@L["Roles"]</span>
                            <div class="portal-topbar__profile-role-row">
                                <div class="portal-topbar__profile-current-role" title="@(_roleContext.ActiveRoleName ?? L["No roles assigned."])">@(_roleContext.ActiveRoleName ?? L["No roles assigned."])</div>
                                @if (_roleContext.AvailableRoles.Count > 1)
                                {
                                    <details class="portal-topbar__profile-switch" data-portal-topbar-overlay>
                                        <summary class="portal-topbar__profile-switch-button" title="@L["SwitchRole"]" aria-label="@L["SwitchRole"]">
                                            <span class="portal-topbar__icon portal-topbar__icon--switch" aria-hidden="true"></span>
                                            <span class="visually-hidden">@L["SwitchRole"]</span>
                                        </summary>
                                        <div class="portal-topbar__profile-switch-menu">
                                            @foreach (var role in _roleContext.AvailableRoles.Where(role => role.RoleId != _roleContext.ActiveRoleId))
                                            {
                                                <a class="portal-topbar__profile-role-link" href="@BuildRoleHref(role.RoleId)" data-enhance-nav="false">@role.Name</a>
                                            }
                                        </div>
                                    </details>
                                }
                            </div>
                        </div>
                    </div>
                </details>
            }
        </div>
    </div>
}

@code {
    private PortalTopBarModel _portalTopBar = PortalTopBarModel.Hidden;
    private OpenModulePlatform.Web.Shared.Services.UserRoleContext _roleContext = OpenModulePlatform.Web.Shared.Services.UserRoleContext.Empty;

    private string FallbackNotice => string.Format(
        L["LanguageFallbackNotice"],
        CultureText(_portalTopBar.PreferredCultureDisplayText),
        CultureText(_portalTopBar.EffectiveCultureDisplayText));

    protected override async Task OnInitializedAsync()
    {
        NavigationManager.LocationChanged += HandleLocationChanged;

        var httpContext = HttpContextAccessor.HttpContext;
        if (httpContext is not null)
        {
            _portalTopBar = await PortalTopBarService.CreateAsync(
                WebAppOptionsAccessor.Value,
                httpContext.Request,
                httpContext.User,
                httpContext.RequestAborted);
            _roleContext = await RbacService.GetUserRoleContextAsync(httpContext.User, httpContext.RequestAborted);
            return;
        }

        var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authenticationState.User;
        _roleContext = await RbacService.GetUserRoleContextAsync(user, CancellationToken.None);

        if (Uri.TryCreate(NavigationManager.Uri, UriKind.Absolute, out var currentUri))
        {
            _portalTopBar = await PortalTopBarService.CreateAsync(
                WebAppOptionsAccessor.Value,
                currentUri,
                user,
                CancellationToken.None);
            return;
        }

        _portalTopBar = PortalTopBarModelFactory.Create(WebAppOptionsAccessor.Value);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_portalTopBar.IsVisible)
        {
            await JS.InvokeAsync<object>("ompPortalTopBar.initAll", Array.Empty<object>());
        }
    }

    private string BuildLanguageHref(string culture)
    {
        var baseUri = new Uri(NavigationManager.BaseUri, UriKind.Absolute);
        var basePath = baseUri.AbsolutePath.TrimEnd('/');
        var endpointPath = string.IsNullOrWhiteSpace(basePath)
            ? "/localization/set-language"
            : $"{basePath}/localization/set-language";

        var relativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        var returnUrl = string.IsNullOrWhiteSpace(relativePath)
            ? (string.IsNullOrWhiteSpace(basePath) ? "/" : $"{basePath}/")
            : $"{(string.IsNullOrWhiteSpace(basePath) ? string.Empty : basePath)}/{relativePath.TrimStart('/')}";

        return $"{endpointPath}?culture={Uri.EscapeDataString(culture)}&returnUrl={Uri.EscapeDataString(returnUrl)}";
    }


    private string BuildAppBaseRelativePath(string relativePath)
    {
        var baseUri = new Uri(NavigationManager.BaseUri, UriKind.Absolute);
        var basePath = baseUri.AbsolutePath.TrimEnd('/');
        return string.IsNullOrWhiteSpace(basePath)
            ? $"/{relativePath.TrimStart('/')}"
            : $"{basePath}/{relativePath.TrimStart('/')}";
    }

    private string BuildRoleHref(int? roleId)
    {
        var currentUri = new Uri(NavigationManager.Uri, UriKind.Absolute);
        var returnUrl = $"{currentUri.AbsolutePath}{currentUri.Query}";
        return $"{BuildAppBaseRelativePath("rbac/set-active-role")}?roleId={Uri.EscapeDataString(roleId?.ToString() ?? string.Empty)}&returnUrl={Uri.EscapeDataString(returnUrl)}";
    }

    private void HandleLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
        => _ = InvokeAsync(StateHasChanged);

    public void Dispose()
        => NavigationManager.LocationChanged -= HandleLocationChanged;

    private string CultureText(string? text)
        => string.IsNullOrWhiteSpace(text) ? string.Empty : L[text];

    private string EntryText(PortalTopBarNavigationEntry entry)
        => L[entry.TextKey].Value;

    private string EntryFavoriteLabel(PortalTopBarNavigationEntry entry)
        => string.IsNullOrWhiteSpace(entry.GroupTitle)
            ? EntryText(entry)
            : $"{entry.GroupTitle} / {EntryText(entry)}";

    private string EntrySearchText(
        PortalTopBarNavigationGroup group,
        PortalTopBarNavigationEntry entry)
    {
        var text = EntryText(entry);
        return $"{entry.SearchText} {group.Title} {text} {group.Title}/{text} {group.GroupKey}/{text} {entry.Href.Trim('/')}";
    }

    private static string GroupSearchText(PortalTopBarNavigationGroup group)
        => $"{group.SearchText} {group.Title} {group.Href.Trim('/')}";

    private static string DisplayUserName(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        var separatorIndex = value.LastIndexOf('\\');
        return separatorIndex >= 0 && separatorIndex < value.Length - 1
            ? value[(separatorIndex + 1)..]
            : value;
    }
}
