@model OpenModulePlatform.Web.Shared.Navigation.PortalTopBarModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<OpenModulePlatform.Web.Shared.Localization.SharedResource> L
@{
    var returnUrl = $"{Context.Request.PathBase}{Context.Request.Path}{Context.Request.QueryString}";
    string BuildLanguageHref(string culture) => $"{Context.Request.PathBase}/localization/set-language?culture={Uri.EscapeDataString(culture)}&returnUrl={Uri.EscapeDataString(returnUrl)}";
    string BuildRoleHref(int? roleId) => $"{Context.Request.PathBase}/security/set-active-role?roleId={(roleId?.ToString() ?? string.Empty)}&returnUrl={Uri.EscapeDataString(returnUrl)}";
    string CultureText(string? value) => string.IsNullOrWhiteSpace(value) ? string.Empty : L[value];
    string EntryText(OpenModulePlatform.Web.Shared.Navigation.PortalTopBarNavigationEntry entry) => L[entry.TextKey].Value;
    string EntryFavoriteLabel(OpenModulePlatform.Web.Shared.Navigation.PortalTopBarNavigationEntry entry)
        => string.IsNullOrWhiteSpace(entry.GroupTitle)
            ? EntryText(entry)
            : $"{entry.GroupTitle} / {EntryText(entry)}";
    string EntrySearchText(OpenModulePlatform.Web.Shared.Navigation.PortalTopBarNavigationGroup group, OpenModulePlatform.Web.Shared.Navigation.PortalTopBarNavigationEntry entry)
    {
        var text = EntryText(entry);
        return $"{entry.SearchText} {group.Title} {text} {group.Title}/{text} {group.GroupKey}/{text} {entry.Href.Trim('/')}";
    }
    string GroupSearchText(OpenModulePlatform.Web.Shared.Navigation.PortalTopBarNavigationGroup group)
        => $"{group.SearchText} {group.Title} {group.Href.Trim('/')}";
    string NotificationBadgeText(int count)
        => count > 99 ? "99+" : count.ToString(System.Globalization.CultureInfo.InvariantCulture);
    string MessageTimeText(DateTime? value)
        => value is null
            ? string.Empty
            : value.Value.ToLocalTime().ToString("g", System.Globalization.CultureInfo.CurrentCulture);
    string NotificationCallerText(OpenModulePlatform.Web.Shared.Navigation.PortalTopBarNotification notification)
    {
        var source = string.IsNullOrWhiteSpace(notification.CallerDisplayName)
            ? notification.CallerKey
            : notification.CallerDisplayName;
        return string.IsNullOrWhiteSpace(source)
            ? "!"
            : source.Trim()[0].ToString().ToUpperInvariant();
    }
    string LanguageBadgeText(string? culture)
    {
        if (string.IsNullOrWhiteSpace(culture))
        {
            return "?";
        }

        var trimmed = culture.Trim();
        var separatorIndex = trimmed.IndexOfAny(new[] { '-', '_' });
        var language = separatorIndex > 0 ? trimmed[..separatorIndex] : trimmed;
        return language.Length <= 3
            ? language.ToUpperInvariant()
            : trimmed.ToUpperInvariant();
    }
    string DisplayUserName(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        var separatorIndex = value.LastIndexOf('\\');
        return separatorIndex >= 0 && separatorIndex < value.Length - 1
            ? value[(separatorIndex + 1)..]
            : value;
    }
    string UserInitials(string? value)
    {
        var displayName = DisplayUserName(value);
        if (string.IsNullOrWhiteSpace(displayName))
        {
            return "?";
        }

        var parts = displayName
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length >= 2)
        {
            return string.Concat(parts[0][0], parts[^1][0]).ToUpperInvariant();
        }

        return displayName[..Math.Min(displayName.Length, 2)].ToUpperInvariant();
    }
    var fallbackNotice = string.Format(L["LanguageFallbackNotice"], CultureText(Model.PreferredCultureDisplayText), CultureText(Model.EffectiveCultureDisplayText));
    var currentUserDisplayName = DisplayUserName(Model.CurrentUserName);
    var currentUserInitials = UserInitials(Model.CurrentUserName);
    var currentLanguage = Model.LanguageOptions.FirstOrDefault(language => language.IsCurrent);
}

@if (Model.IsVisible && Model.PortalLink is not null)
{
    <div class="portal-topbar"
         data-portal-topbar-root
         data-favorite-toggle-url="@Model.FavoriteToggleUrl"
         data-add-favorite-text="@L[Model.AddFavoriteTextKey]"
         data-remove-favorite-text="@L[Model.RemoveFavoriteTextKey]"
         data-expand-text="@L["Expand"]"
         data-collapse-text="@L["Collapse"]"
         data-shortcuts-enabled="@Model.ShortcutsEnabled.ToString().ToLowerInvariant()"
         data-shortcut-all-modules="@Model.AllModulesShortcut"
         data-shortcut-favorites="@Model.FavoritesShortcut"
         data-open-on-hover="@Model.DropdownsOpenOnHover.ToString().ToLowerInvariant()"
         data-session-status-enabled="@Model.SessionStatusCheckEnabled.ToString().ToLowerInvariant()"
         data-session-status-url="@Model.SessionStatusUrl"
         data-session-login-url="@Model.SessionLoginUrl"
         data-session-status-visible-interval="@Model.SessionStatusVisibleIntervalSeconds"
         data-session-status-hidden-interval="@Model.SessionStatusHiddenIntervalSeconds"
         data-session-lost-text="@L["Your session appears to have expired. Sign in again before continuing."]"
         data-session-network-lost-text="@L["The server could not be reached. Check the connection."]"
         data-session-login-text="@L["Sign in again"]"
         data-session-reload-text="@L["Reload"]">
        <nav class="portal-topbar__nav" aria-label="@Model.PortalLink.TextKey" data-portal-topbar>
            <a class="portal-topbar__portal-link" href="@Model.PortalLink.Href">@Model.PortalLink.TextKey</a>

            @if (Model.IsPortalAdmin && Model.PortalAdminSections.Count > 0)
            {
                <details class="portal-topbar__admin" data-portal-topbar-overlay data-portal-topbar-hover-menu>
                    <summary title="@L[Model.PortalAdminToggleTextKey]" aria-label="@L[Model.PortalAdminToggleTextKey]">
                        <span class="portal-topbar__icon portal-topbar__icon--admin-gears" aria-hidden="true"></span>
                        <span class="visually-hidden">@L[Model.PortalAdminToggleTextKey]</span>
                    </summary>
                    <div class="portal-topbar__admin-menu" data-portal-topbar-admin-menu>
                        @foreach (var section in Model.PortalAdminSections)
                        {
                            <details class="portal-topbar__admin-submenu" data-portal-topbar-admin-submenu data-portal-topbar-overlay>
                                <summary class="portal-topbar__admin-submenu-trigger">
                                    <span>@L[section.TextKey]</span>
                                </summary>
                                <div class="portal-topbar__admin-submenu-menu">
                                    @foreach (var item in section.Items)
                                    {
                                        if (item.SeparatorBefore)
                                        {
                                            <div class="portal-topbar__admin-separator" role="separator" aria-hidden="true"></div>
                                        }
                                        <a class="portal-topbar__admin-link" href="@item.Href">@L[item.TextKey]</a>
                                    }
                                </div>
                            </details>
                        }
                    </div>
                </details>
            }

            @if (Model.NavigationGroups.Count > 0)
            {
                <span class="portal-topbar__pipe" aria-hidden="true">|</span>

                <details class="portal-topbar__nav-dropdown" data-portal-topbar-overlay data-portal-topbar-hover-menu data-portal-topbar-all-modules>
                    <summary title="@L[Model.AllModulesToggleTextKey]" aria-label="@L[Model.AllModulesToggleTextKey]">
                        @L[Model.AllModulesToggleTextKey]
                    </summary>
                    <div class="portal-topbar__nav-menu" data-portal-topbar-entry-menu>
                        <input class="portal-topbar__nav-filter"
                               type="search"
                               placeholder="@L[Model.NavigationFilterPlaceholderTextKey]"
                               aria-label="@L[Model.NavigationFilterPlaceholderTextKey]"
                               data-portal-topbar-entry-filter />
                        @foreach (var group in Model.NavigationGroups)
                        {
                            var groupFavoriteLabel = L[group.IsFavorite ? Model.RemoveFavoriteTextKey : Model.AddFavoriteTextKey];
                            <div class="portal-topbar__nav-group" data-portal-topbar-entry-group>
                                <div class="portal-topbar__nav-group-header"
                                     data-portal-topbar-entry-row
                                     data-entry-key="@group.EntryKey"
                                     data-app-instance-id="@(group.AppInstanceId?.ToString("D") ?? string.Empty)"
                                     data-favorite-label="@group.Title"
                                     data-favorite-group-title=""
                                     data-favorite-entry-title="@group.Title"
                                     data-favorite-href="@group.Href"
                                     data-search="@GroupSearchText(group)">
                                    @if (group.HasLink)
                                    {
                                        <a class="portal-topbar__nav-group-link" href="@group.Href">@group.Title</a>
                                    }
                                    else
                                    {
                                        <span class="portal-topbar__nav-group-link" aria-disabled="true">@group.Title</span>
                                    }
                                    <span class="portal-topbar__nav-group-actions">
                                        @if (group.Entries.Count > 0)
                                        {
                                            <button type="button"
                                                    class="portal-topbar__nav-group-toggle"
                                                    title="@L["Expand"]"
                                                    aria-label="@L["Expand"]"
                                                    aria-expanded="false"
                                                    data-portal-topbar-entry-group-toggle>
                                                <span aria-hidden="true">▸</span>
                                            </button>
                                        }
                                        @if (Model.CanUsePersistentFavorites && group.IsFavoritable)
                                        {
                                            <form method="post" action="@Model.FavoriteToggleUrl" class="portal-topbar__favorite-form" data-portal-topbar-favorite-form data-enhance="false">
                                                <input type="hidden" name="entryKey" value="@group.EntryKey" />
                                                <input type="hidden" name="appInstanceId" value="@(group.AppInstanceId?.ToString("D") ?? string.Empty)" />
                                                <button type="submit"
                                                        class="portal-topbar__favorite-toggle@(group.IsFavorite ? " is-favorite" : string.Empty)"
                                                        title="@groupFavoriteLabel"
                                                        aria-label="@groupFavoriteLabel"
                                                        data-portal-topbar-favorite-button>
                                                    <span aria-hidden="true">@(group.IsFavorite ? "★" : "☆")</span>
                                                </button>
                                            </form>
                                        }
                                    </span>
                                </div>
                                <div class="portal-topbar__nav-group-entries" data-portal-topbar-entry-group-entries hidden>
                                @foreach (var entry in group.Entries)
                                {
                                    var favoriteLabel = L[entry.IsFavorite ? Model.RemoveFavoriteTextKey : Model.AddFavoriteTextKey];
                                    var entryText = EntryText(entry);
                                    var entryFavoriteLabel = EntryFavoriteLabel(entry);
                                    <div class="portal-topbar__nav-entry-row"
                                         data-portal-topbar-entry-row
                                         data-entry-key="@entry.EntryKey"
                                         data-app-instance-id="@(entry.AppInstanceId?.ToString("D") ?? string.Empty)"
                                         data-favorite-label="@entryFavoriteLabel"
                                         data-favorite-group-title="@entry.GroupTitle"
                                         data-favorite-entry-title="@entryText"
                                         data-favorite-href="@entry.Href"
                                         data-search="@EntrySearchText(group, entry)">
                                        <a class="portal-topbar__nav-entry-link" href="@entry.Href">@entryText</a>
                                        @if (Model.CanUsePersistentFavorites && entry.IsFavoritable)
                                        {
                                            <form method="post" action="@Model.FavoriteToggleUrl" class="portal-topbar__favorite-form" data-portal-topbar-favorite-form data-enhance="false">
                                                <input type="hidden" name="entryKey" value="@entry.EntryKey" />
                                                <input type="hidden" name="appInstanceId" value="@(entry.AppInstanceId?.ToString("D") ?? string.Empty)" />
                                                <button type="submit"
                                                        class="portal-topbar__favorite-toggle@(entry.IsFavorite ? " is-favorite" : string.Empty)"
                                                        title="@favoriteLabel"
                                                        aria-label="@favoriteLabel"
                                                        data-portal-topbar-favorite-button>
                                                    <span aria-hidden="true">@(entry.IsFavorite ? "★" : "☆")</span>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                }
                                </div>
                            </div>
                        }
                    </div>
                </details>

                @if (Model.CanUsePersistentFavorites)
                {
                    <details class="portal-topbar__nav-dropdown" data-portal-topbar-overlay data-portal-topbar-hover-menu data-portal-topbar-favorites>
                        <summary title="@L[Model.FavoritesToggleTextKey]" aria-label="@L[Model.FavoritesToggleTextKey]">
                            @L[Model.FavoritesToggleTextKey]
                        </summary>
                        <div class="portal-topbar__favorites-menu">
                            <div class="portal-topbar__favorites-list" data-portal-topbar-favorites-list>
                                @foreach (var entry in Model.FavoriteEntries)
                                {
                                    var removeFavoriteLabel = L[Model.RemoveFavoriteTextKey];
                                    <div class="portal-topbar__favorite-row"
                                         data-portal-topbar-favorite-row
                                         data-favorite-entry-key="@entry.EntryKey"
                                         data-favorite-app-instance-id="@(entry.AppInstanceId?.ToString("D") ?? string.Empty)">
                                        <a class="portal-topbar__favorite-link" href="@entry.Href">
                                            @if (!string.IsNullOrWhiteSpace(entry.GroupTitle))
                                            {
                                                <span class="portal-topbar__favorite-module">@entry.GroupTitle</span>
                                                <span> / </span>
                                            }
                                            <span>@EntryText(entry)</span>
                                        </a>
                                        <form method="post" action="@Model.FavoriteToggleUrl" class="portal-topbar__favorite-form" data-portal-topbar-favorite-form data-enhance="false">
                                            <input type="hidden" name="entryKey" value="@entry.EntryKey" />
                                            <input type="hidden" name="appInstanceId" value="@(entry.AppInstanceId?.ToString("D") ?? string.Empty)" />
                                            <button type="submit"
                                                    class="portal-topbar__favorite-toggle is-favorite"
                                                    title="@removeFavoriteLabel"
                                                    aria-label="@removeFavoriteLabel"
                                                    data-portal-topbar-favorite-button>
                                                <span aria-hidden="true">★</span>
                                            </button>
                                        </form>
                                    </div>
                                }
                            </div>
                            <div class="portal-topbar__favorites-empty" data-portal-topbar-favorites-empty hidden="@(Model.FavoriteEntries.Count > 0)">
                                @L[Model.NoFavoritesTextKey]
                            </div>
                        </div>
                    </details>
                }
            }
        </nav>

        <div class="portal-topbar__actions">
            @if (Model.LanguageOptions.Count > 1)
            {
                <details class="portal-topbar__language" data-portal-topbar-overlay data-portal-topbar-hover-menu>
                    <summary title="@L[Model.LanguageToggleTextKey]" aria-label="@L[Model.LanguageToggleTextKey]">
                        <span class="portal-topbar__summary-icon">
                            <span class="portal-topbar__icon portal-topbar__icon--language" aria-hidden="true"></span>
                            @if (Model.IsCultureFallback)
                            {
                                <span class="portal-topbar__fallback-indicator" title="@fallbackNotice" aria-hidden="true">i</span>
                            }
                        </span>
                        <span class="visually-hidden">@L[Model.LanguageToggleTextKey]</span>
                        @if (Model.IsCultureFallback)
                        {
                            <span class="visually-hidden">@fallbackNotice</span>
                        }
                    </summary>
                    <div class="portal-topbar__language-menu">
                        <div class="portal-topbar__language-heading">
                            <span class="portal-topbar__language-row-icon portal-topbar__icon portal-topbar__icon--language" aria-hidden="true"></span>
                            <span>@L[Model.LanguageToggleTextKey]</span>
                        </div>
                        <div class="portal-topbar__language-separator" role="separator" aria-hidden="true"></div>
                        @if (currentLanguage is not null)
                        {
                            <div class="portal-topbar__language-row portal-topbar__language-current" aria-current="true" title="@currentLanguage.Culture">
                                <span class="portal-topbar__language-badge" aria-hidden="true">@LanguageBadgeText(currentLanguage.Culture)</span>
                                <span>@CultureText(currentLanguage.DisplayText)</span>
                            </div>
                        }
                        @if (Model.IsCultureFallback)
                        {
                            <div class="portal-topbar__language-note">
                                <div class="portal-topbar__language-note-title">@L["LanguageFallback"]</div>
                                <div class="portal-topbar__language-note-body">@fallbackNotice</div>
                            </div>
                        }
                        <div class="portal-topbar__language-separator" role="separator" aria-hidden="true"></div>
                        @foreach (var language in Model.LanguageOptions.Where(language => !language.IsCurrent))
                        {
                            <a class="portal-topbar__language-row portal-topbar__language-link" href="@BuildLanguageHref(language.Culture)" title="@language.Culture" data-enhance-nav="false">
                                <span class="portal-topbar__language-badge" aria-hidden="true">@LanguageBadgeText(language.Culture)</span>
                                <span>@CultureText(language.DisplayText)</span>
                            </a>
                        }
                    </div>
                </details>
            }

            @if (Model.CanUseNotifications)
            {
                <details class="portal-topbar__notifications" data-portal-topbar-overlay data-portal-topbar-hover-menu data-portal-topbar-notifications>
                    <summary title="@L[Model.NotificationsToggleTextKey]" aria-label="@L[Model.NotificationsToggleTextKey]">
                        <span class="portal-topbar__summary-icon">
                            <span class="portal-topbar__icon portal-topbar__icon--notifications" aria-hidden="true"></span>
                            <span class="portal-topbar__notification-badge" data-portal-topbar-notification-badge hidden="@(Model.UnreadNotificationCount == 0)">
                                @NotificationBadgeText(Model.UnreadNotificationCount)
                            </span>
                        </span>
                        <span class="visually-hidden">@L[Model.NotificationsToggleTextKey]</span>
                    </summary>
                    <div class="portal-topbar__notifications-menu">
                        <div class="portal-topbar__notifications-header">
                            <span>@L[Model.NotificationsToggleTextKey]</span>
                            <span class="portal-topbar__notifications-header-actions">
                                <a class="portal-topbar__notifications-link" href="@Model.NotificationsUrl" data-enhance-nav="false">
                                    @L[Model.ViewAllNotificationsTextKey]
                                </a>
                                <form method="post"
                                      action="@Model.NotificationMarkAllReadUrl"
                                      class="portal-topbar__notifications-mark-all-form"
                                      data-portal-topbar-notification-mark-all-form
                                      data-enhance="false"
                                      hidden="@(Model.Notifications.Count == 0)">
                                    <button type="submit" class="portal-topbar__notifications-mark-all">
                                        @L[Model.MarkAllNotificationsReadTextKey]
                                    </button>
                                </form>
                            </span>
                        </div>
                        <div class="portal-topbar__notifications-list"
                             data-portal-topbar-notifications-list
                             data-load-url="@Model.NotificationRecentUrl"
                             data-mark-read-url="@Model.NotificationMarkReadUrl"
                             data-page-size="10"
                             data-no-notifications-text="@L[Model.NoNotificationsTextKey]"
                             data-loading-text="@L["Loading"]"
                             data-end-text="@L["No more notifications"]">
                            @foreach (var notification in Model.Notifications)
                            {
                                <form method="post"
                                      action="@Model.NotificationMarkReadUrl"
                                      class="portal-topbar__notification-form@(notification.IsUnread ? " is-unread" : " is-read")"
                                      data-portal-topbar-notification-form
                                      data-notification-id="@notification.NotificationId"
                                      data-notification-created-at="@notification.CreatedAt.ToUniversalTime().ToString("O", System.Globalization.CultureInfo.InvariantCulture)"
                                      data-enhance="false">
                                    <input type="hidden" name="notificationId" value="@notification.NotificationId" />
                                    <button type="submit"
                                            class="portal-topbar__notification-row portal-topbar__notification-row--@notification.Level"
                                            data-destination-url="@(notification.DestinationUrl ?? string.Empty)">
                                        <span class="portal-topbar__notification-caller-icon" aria-hidden="true">
                                            @if (!string.IsNullOrWhiteSpace(notification.CallerIcon))
                                            {
                                                <img src="@notification.CallerIcon" alt="" />
                                            }
                                            else
                                            {
                                                <span>@NotificationCallerText(notification)</span>
                                            }
                                        </span>
                                        <span class="portal-topbar__notification-copy">
                                            <span class="portal-topbar__notification-title">@notification.Title</span>
                                            <span class="portal-topbar__notification-content">@notification.Content</span>
                                        </span>
                                    </button>
                                </form>
                            }
                        </div>
                        <div class="portal-topbar__notifications-empty" data-portal-topbar-notifications-empty hidden="@(Model.Notifications.Count > 0)">
                            @L[Model.NoNotificationsTextKey]
                        </div>
                        <div class="portal-topbar__notifications-loading" data-portal-topbar-notifications-loading hidden>@L["Loading"]</div>
                        <div class="portal-topbar__notifications-end" data-portal-topbar-notifications-end hidden>@L["No more notifications"]</div>
                    </div>
                </details>
            }

            @if (Model.CanUseMessages)
            {
                <details class="portal-topbar__messages" data-portal-topbar-overlay data-portal-topbar-hover-menu>
                    <summary title="@L[Model.MessagesToggleTextKey]" aria-label="@L[Model.MessagesToggleTextKey]">
                        <span class="portal-topbar__summary-icon">
                            <span class="portal-topbar__icon portal-topbar__icon--messages" aria-hidden="true"></span>
                            <span class="portal-topbar__message-badge" hidden="@(Model.UnreadMessageCount == 0)">
                                @NotificationBadgeText(Model.UnreadMessageCount)
                            </span>
                        </span>
                        <span class="visually-hidden">@L[Model.MessagesToggleTextKey]</span>
                    </summary>
                    <div class="portal-topbar__messages-menu">
                        <div class="portal-topbar__messages-header">
                            <span>@L[Model.MessagesToggleTextKey]</span>
                            <span class="portal-topbar__messages-header-actions">
                                <a class="portal-topbar__messages-action" href="@Model.MessagesUrl" data-enhance-nav="false">
                                    @L[Model.ViewAllMessagesTextKey]
                                </a>
                                <form method="post"
                                      action="@Model.MessageMarkAllReadUrl"
                                      class="portal-topbar__messages-mark-all-form"
                                      data-enhance="false"
                                      hidden="@(Model.UnreadMessageCount == 0)">
                                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                                    <button type="submit" class="portal-topbar__messages-action">
                                        @L[Model.MarkAllMessagesReadTextKey]
                                    </button>
                                </form>
                            </span>
                        </div>
                        <div class="portal-topbar__messages-list">
                            @foreach (var conversation in Model.MessageConversations)
                            {
                                <a class="portal-topbar__message-row@(conversation.UnreadCount > 0 ? " is-unread" : string.Empty)"
                                   href="@conversation.Href"
                                   data-enhance-nav="false">
                                    <span class="portal-topbar__message-copy">
                                        <span class="portal-topbar__message-title">@conversation.DisplayTitle</span>
                                        <span class="portal-topbar__message-preview">@(conversation.LastMessagePreview ?? L["No messages"].Value)</span>
                                        @if (conversation.LastMessageAt is not null)
                                        {
                                            <span class="portal-topbar__message-meta">@MessageTimeText(conversation.LastMessageAt)</span>
                                        }
                                    </span>
                                    <span class="portal-topbar__message-row-badge" hidden="@(conversation.UnreadCount == 0)">
                                        @NotificationBadgeText(conversation.UnreadCount)
                                    </span>
                                </a>
                            }
                        </div>
                        @if (Model.MessageConversations.Count == 0)
                        {
                            <div class="portal-topbar__messages-empty">@L[Model.NoMessagesTextKey]</div>
                        }
                        <a class="portal-topbar__messages-footer-link" href="@Model.MessagesUrl" data-enhance-nav="false">
                            @L[Model.ViewAllMessagesTextKey]
                        </a>
                    </div>
                </details>
            }

            @if (!string.IsNullOrWhiteSpace(Model.CurrentUserName))
            {
                <details class="portal-topbar__profile" data-portal-topbar-overlay data-portal-topbar-hover-menu>
                    <summary title="@L["User"]" aria-label="@L["User"]">
                        <span class="portal-topbar__icon portal-topbar__icon--user" aria-hidden="true"></span>
                        <span class="visually-hidden">@L["User"]</span>
                    </summary>
                    <div class="portal-topbar__profile-menu">
                        <div class="portal-topbar__profile-heading">
                            <span class="portal-topbar__profile-row-icon portal-topbar__icon portal-topbar__icon--user" aria-hidden="true"></span>
                            <span>@L["User"]</span>
                        </div>

                        <div class="portal-topbar__profile-separator" role="separator" aria-hidden="true"></div>

                        <div class="portal-topbar__profile-row portal-topbar__profile-status-row">
                            <span class="portal-topbar__profile-avatar" aria-hidden="true">@currentUserInitials</span>
                            <span class="portal-topbar__profile-current-user" title="@Model.CurrentUserName">@currentUserDisplayName</span>
                        </div>
                        <div class="portal-topbar__profile-row portal-topbar__profile-status-row portal-topbar__profile-active-role" aria-label="@L["Active role"]">
                            <span class="portal-topbar__profile-row-icon portal-topbar__icon portal-topbar__icon--badge" aria-hidden="true"></span>
                            <span class="portal-topbar__profile-current-role" title="@(Model.ActiveRoleName ?? L["No roles assigned."])">@(Model.ActiveRoleName ?? L["No roles assigned."])</span>
                        </div>

                        <div class="portal-topbar__profile-separator" role="separator" aria-hidden="true"></div>

                        @if (Model.AvailableRoles.Count > 1)
                        {
                            <details class="portal-topbar__profile-switch" data-portal-topbar-overlay>
                                <summary class="portal-topbar__profile-row portal-topbar__profile-action-row">
                                    <span class="portal-topbar__profile-row-icon portal-topbar__icon portal-topbar__icon--switch" aria-hidden="true"></span>
                                    <span>@L["SwitchRole"]</span>
                                </summary>
                                <div class="portal-topbar__profile-switch-menu">
                                    @foreach (var role in Model.AvailableRoles.Where(role => role.RoleId != Model.ActiveRoleId))
                                    {
                                        <a class="portal-topbar__profile-role-link" href="@BuildRoleHref(role.RoleId)" data-enhance-nav="false">@role.Name</a>
                                    }
                                </div>
                            </details>
                        }

                        <a class="portal-topbar__profile-row portal-topbar__profile-action-row" href="@Model.SettingsUrl" data-enhance-nav="false">
                            <span class="portal-topbar__profile-row-icon portal-topbar__icon portal-topbar__icon--settings" aria-hidden="true"></span>
                            <span>@L["Settings"]</span>
                        </a>

                        <div class="portal-topbar__profile-separator portal-topbar__profile-separator--logout" role="separator" aria-hidden="true"></div>

                        <form method="post" action="@Model.LogoutUrl" class="portal-topbar__logout-form" data-enhance="false">
                            <button type="submit"
                                    class="portal-topbar__profile-row portal-topbar__profile-action-row portal-topbar__profile-logout-row">
                                <span class="portal-topbar__profile-row-icon portal-topbar__icon portal-topbar__icon--logout" aria-hidden="true"></span>
                                <span>@L["Log out"]</span>
                            </button>
                        </form>
                    </div>
                </details>
            }
        </div>
        @if (Model.Banners.Count > 0)
        {
            <div class="portal-topbar__notification-banners" data-portal-topbar-notification-banners>
                @foreach (var banner in Model.Banners)
                {
                    <div class="portal-topbar__notification-banner portal-topbar__notification-banner--@banner.LevelName" role="status">
                        <span class="portal-topbar__notification-banner-icon" aria-hidden="true">
                            <img src="@banner.IconUrl" alt="" />
                        </span>
                        <span class="portal-topbar__notification-banner-copy">
                            <span class="portal-topbar__notification-banner-title">@banner.Title</span>
                            <span class="portal-topbar__notification-banner-content">@banner.Content</span>
                        </span>
                    </div>
                }
            </div>
        }
    </div>
}
