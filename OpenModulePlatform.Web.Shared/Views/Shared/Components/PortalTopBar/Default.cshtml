@model OpenModulePlatform.Web.Shared.Navigation.PortalTopBarModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<OpenModulePlatform.Web.Shared.Localization.SharedResource> L
@{
    var returnUrl = $"{Context.Request.PathBase}{Context.Request.Path}{Context.Request.QueryString}";
    string BuildLanguageHref(string culture) => $"{Context.Request.PathBase}/localization/set-language?culture={Uri.EscapeDataString(culture)}&returnUrl={Uri.EscapeDataString(returnUrl)}";
    string BuildRoleHref(int? roleId) => $"{Context.Request.PathBase}/security/set-active-role?roleId={(roleId?.ToString() ?? string.Empty)}&returnUrl={Uri.EscapeDataString(returnUrl)}";
    string CultureText(string? value) => string.IsNullOrWhiteSpace(value) ? string.Empty : L[value];
    string DisplayUserName(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        var separatorIndex = value.LastIndexOf('\\');
        return separatorIndex >= 0 && separatorIndex < value.Length - 1
            ? value[(separatorIndex + 1)..]
            : value;
    }
    var fallbackNotice = string.Format(L["LanguageFallbackNotice"], CultureText(Model.PreferredCultureDisplayText), CultureText(Model.EffectiveCultureDisplayText));
    var currentUserDisplayName = DisplayUserName(Model.CurrentUserName);
}

@if (Model.IsVisible && Model.PortalLink is not null)
{
    <div class="portal-topbar" data-portal-topbar-root>
        <nav class="portal-topbar__nav" aria-label="@L["Portal"]" data-portal-topbar>
            <a class="portal-topbar__portal-link" href="@Model.PortalLink.Href">@L[Model.PortalLink.TextKey]</a>

            @if (Model.IsPortalAdmin && Model.PortalAdminSections.Count > 0)
            {
                <details class="portal-topbar__admin" data-portal-topbar-overlay data-portal-topbar-hover-menu>
                    <summary title="@L[Model.PortalAdminToggleTextKey]" aria-label="@L[Model.PortalAdminToggleTextKey]">
                        <span aria-hidden="true">&#9881;</span>
                        <span class="visually-hidden">@L[Model.PortalAdminToggleTextKey]</span>
                    </summary>
                    <div class="portal-topbar__admin-menu" data-portal-topbar-admin-menu>
                        @foreach (var section in Model.PortalAdminSections)
                        {
                            <details class="portal-topbar__admin-submenu" data-portal-topbar-admin-submenu data-portal-topbar-overlay>
                                <summary class="portal-topbar__admin-submenu-trigger">
                                    <span>@L[section.TextKey]</span>
                                </summary>
                                <div class="portal-topbar__admin-submenu-menu">
                                    @foreach (var item in section.Items)
                                    {
                                        if (item.SeparatorBefore)
                                        {
                                            <div class="portal-topbar__admin-separator" role="separator" aria-hidden="true"></div>
                                        }
                                        <a class="portal-topbar__admin-link" href="@item.Href">@L[item.TextKey]</a>
                                    }
                                </div>
                            </details>
                        }
                    </div>
                </details>
            }

            @if (Model.ModuleLinks.Count > 0)
            {
                <span class="portal-topbar__pipe" aria-hidden="true">|</span>

                <div class="portal-topbar__modules" data-portal-topbar-modules>
                    @for (var i = 0; i < Model.ModuleLinks.Count; i++)
                    {
                        var link = Model.ModuleLinks[i];
                        <a class="portal-topbar__module-link" href="@link.Href" data-portal-topbar-item data-index="@i">@link.TextKey</a>
                    }
                </div>

                <details class="portal-topbar__collapsed" data-portal-topbar-overlay>
                    <summary title="@L[Model.CollapsedToggleTextKey]" aria-label="@L[Model.CollapsedToggleTextKey]">
                        @L[Model.CollapsedToggleTextKey]
                    </summary>
                    <div class="portal-topbar__collapsed-menu">
                        @foreach (var link in Model.ModuleLinks)
                        {
                            <a class="portal-topbar__collapsed-link" href="@link.Href">@link.TextKey</a>
                        }
                    </div>
                </details>

                <details class="portal-topbar__overflow" data-portal-topbar-overflow data-portal-topbar-overlay hidden>
                    <summary>@L[Model.OverflowToggleTextKey]</summary>
                    <div class="portal-topbar__menu" data-portal-topbar-menu></div>
                </details>
            }
        </nav>

        <div class="portal-topbar__actions">
            @if (Model.LanguageOptions.Count > 1)
            {
                <details class="portal-topbar__language" data-portal-topbar-overlay data-portal-topbar-hover-menu>
                    <summary title="@L[Model.LanguageToggleTextKey]" aria-label="@L[Model.LanguageToggleTextKey]">
                        <span class="portal-topbar__summary-icon">
                            <span class="portal-topbar__icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                                    <circle cx="12" cy="12" r="9"></circle>
                                    <path d="M3 12h18"></path>
                                    <path d="M12 3a14 14 0 0 1 0 18"></path>
                                    <path d="M12 3a14 14 0 0 0 0 18"></path>
                                </svg>
                            </span>
                            @if (Model.IsCultureFallback)
                            {
                                <span class="portal-topbar__fallback-indicator" title="@fallbackNotice" aria-hidden="true">i</span>
                            }
                        </span>
                        <span class="visually-hidden">@L[Model.LanguageToggleTextKey]</span>
                        @if (Model.IsCultureFallback)
                        {
                            <span class="visually-hidden">@fallbackNotice</span>
                        }
                    </summary>
                    <div class="portal-topbar__language-menu">
                        @if (Model.IsCultureFallback)
                        {
                            <div class="portal-topbar__language-note">
                                <div class="portal-topbar__language-note-title">@L["LanguageFallback"]</div>
                                <div class="portal-topbar__language-note-body">@fallbackNotice</div>
                            </div>
                        }
                        @foreach (var language in Model.LanguageOptions)
                        {
                            <a class="portal-topbar__language-link@(language.IsCurrent ? " is-current" : string.Empty)" href="@BuildLanguageHref(language.Culture)">@CultureText(language.DisplayText)</a>
                        }
                    </div>
                </details>
            }

            @if (!string.IsNullOrWhiteSpace(Model.CurrentUserName))
            {
                <details class="portal-topbar__profile" data-portal-topbar-overlay data-portal-topbar-hover-menu>
                    <summary title="@L["User"]" aria-label="@L["User"]">
                        <span class="portal-topbar__icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                                <path d="M18 20a6 6 0 0 0-12 0"></path>
                                <circle cx="12" cy="8" r="4"></circle>
                            </svg>
                        </span>
                        <span class="visually-hidden">@L["User"]</span>
                    </summary>
                    <div class="portal-topbar__profile-menu">
                        <div class="portal-topbar__profile-identity">
                            <span class="portal-topbar__profile-roles-heading">@L["User"]</span>
                            <div class="portal-topbar__profile-user-row">
                                @if (Model.IsPortalAdmin)
                                {
                                    <button type="button"
                                            class="portal-topbar__profile-copy-name"
                                            title="@L["Copy full user name"]"
                                            aria-label="@L["Copy full user name"]"
                                            data-copy-to-clipboard="true"
                                            data-copy-text="@Model.CurrentUserName">
                                        <span class="portal-topbar__profile-current-user" title="@Model.CurrentUserName">@currentUserDisplayName</span>
                                        <span class="portal-topbar__profile-copy-inline-icon" aria-hidden="true">
                                            <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                                                <rect x="9" y="9" width="10" height="10" rx="2"></rect>
                                                <path d="M7 15H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h7a2 2 0 0 1 2 2v1"></path>
                                            </svg>
                                        </span>
                                    </button>
                                }
                                else
                                {
                                    <span class="portal-topbar__profile-name">
                                        <span class="portal-topbar__profile-current-user">@currentUserDisplayName</span>
                                    </span>
                                }
                                <form method="post" action="@Model.LogoutUrl" class="portal-topbar__logout-form">
                                    <button type="submit"
                                            class="portal-topbar__profile-action-button"
                                            title="@L["Log out"]"
                                            aria-label="@L["Log out"]">
                                        <span class="portal-topbar__icon" aria-hidden="true">
                                            <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                                                <path d="M14 8l4 4-4 4"></path>
                                                <path d="M18 12H9"></path>
                                                <path d="M11 4H6a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h5"></path>
                                            </svg>
                                        </span>
                                    </button>
                                </form>
                            </div>
                            <a class="portal-topbar__profile-settings-link" href="@Model.SettingsUrl">@L["Settings"]</a>
                        </div>
                        <div class="portal-topbar__profile-section">
                            <span class="portal-topbar__profile-roles-heading">@L["Roles"]</span>
                            <div class="portal-topbar__profile-role-row">
                                <div class="portal-topbar__profile-current-role" title="@(Model.ActiveRoleName ?? L["No roles assigned."])">@(Model.ActiveRoleName ?? L["No roles assigned."])</div>
                                @if (Model.AvailableRoles.Count > 1)
                                {
                                    <details class="portal-topbar__profile-switch" data-portal-topbar-overlay>
                                        <summary class="portal-topbar__profile-switch-button" title="@L["SwitchRole"]" aria-label="@L["SwitchRole"]">
                                            <span aria-hidden="true">⇄</span>
                                            <span class="visually-hidden">@L["SwitchRole"]</span>
                                        </summary>
                                        <div class="portal-topbar__profile-switch-menu">
                                            @foreach (var role in Model.AvailableRoles.Where(role => role.RoleId != Model.ActiveRoleId))
                                            {
                                                <a class="portal-topbar__profile-role-link" href="@BuildRoleHref(role.RoleId)" data-enhance-nav="false">@role.Name</a>
                                            }
                                        </div>
                                    </details>
                                }
                            </div>
                        </div>
                    </div>
                </details>
            }
        </div>
    </div>
}
