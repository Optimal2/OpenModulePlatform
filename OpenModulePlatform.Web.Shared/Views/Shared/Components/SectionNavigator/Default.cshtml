@model OpenModulePlatform.Web.Shared.Navigation.SectionNavigatorModel

@if (Model.Items.Count > 0)
{
    <aside class="section-navigator" aria-label="@Model.Label">
        <nav class="section-navigator__nav">
            <div class="section-navigator__heading">@Model.Label</div>
            @await Html.PartialAsync("~/Views/Shared/Components/SectionNavigator/_SectionNavigatorList.cshtml", Model.Items)
        </nav>
    </aside>
}
