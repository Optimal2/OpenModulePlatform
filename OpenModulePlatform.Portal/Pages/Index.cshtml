@page
@model OpenModulePlatform.Portal.Pages.IndexModel
@using System.Globalization
@using OpenModulePlatform.Portal.Services

<section class="portal-dashboard is-expanded-canvas"
         data-dashboard-root
         data-can-edit="@Model.CanEditDashboard.ToString().ToLowerInvariant()"
         data-is-portal-admin="@Model.IsPortalAdmin.ToString().ToLowerInvariant()"
         data-dashboard-draft-key="@Model.DashboardDraftKey"
         data-add-url="@Url.Page("/Index", "AddWidget")"
         data-save-url="@Url.Page("/Index", "SaveDashboard")"
         data-preference-url="@Url.Page("/Index", "SaveDashboardPreference")"
         data-remove-url="@Url.Page("/Index", "RemoveWidget")"
         data-blank-widget-images-url="@Url.Page("/Index", "BlankWidgetImages")"
         data-blank-widget-image-url-template="@Url.Page("/Index", "BlankWidgetImage", new { id = "__id__" })"
         data-upload-blank-widget-image-url="@Url.Page("/Index", "UploadBlankWidgetImage")"
         data-upload-blank-widget-images-zip-url="@Url.Page("/Index", "UploadBlankWidgetImagesZip")"
         data-favorite-toggle-url="@Url.Content("~/navigation/favorites/toggle")"
         data-align-to-grid="@Model.DashboardAlignToGrid.ToString().ToLowerInvariant()"
         data-expanded-canvas="true"
         data-grid-size="32"
         data-min-canvas-height="640"
         data-canvas-bottom-padding="64"
         data-canvas-view-bottom-padding="32"
         data-empty-canvas-height="220"
         data-done-label="@L["Exit edit mode"]"
         data-edit-label="@L["Edit dashboard"]"
         data-remove-label="@L["Remove widget"]"
         data-done-fallback-confirm="@L["You have unsaved dashboard changes. Save them before leaving edit mode?"]"
         data-draft-available-label="@L["Unsaved local dashboard changes were found. Restore them?"]"
         data-draft-restore-label="@L["Restore draft"]"
         data-draft-discard-label="@L["Discard draft"]"
         data-draft-save-failed-label="@L["Dashboard changes could not be saved. Your local draft was kept."]"
         data-draft-session-lost-label="@L["Your session appears to have expired. Sign in again before saving dashboard changes."]"
         data-draft-network-lost-label="@L["The server could not be reached. Your local dashboard draft was kept."]"
         data-add-favorite-label="@L["Add favorite"]"
         data-remove-favorite-label="@L["Remove favorite"]"
         data-widget-settings-label="@L["Widget settings"]"
         data-week-number-label="@L["Week number"]"
         data-show-week-number-label="@L["Show week number"]"
         data-hide-week-number-label="@L["Hide week number"]"
         data-column-count-label="@L["Column count"]"
         data-default-columns-label="@L["Default"]"
         data-one-column-label="@L["1 column"]"
         data-two-columns-label="@L["2 columns"]"
         data-three-columns-label="@L["3 columns"]"
         data-content-scale-label="@L["Zoom"]"
         data-content-scale-value-label="@L["Zoom value"]"
         data-content-scale-reset-label="@L["Reset zoom"]"
         data-blank-widget-style-label="@L["Blank widget style"]"
         data-blank-widget-default-label="@L["Default"]"
         data-blank-widget-one-label="@L["Variant 1"]"
         data-blank-widget-two-label="@L["Variant 2"]"
         data-blank-widget-custom-label="@L["Custom image"]"
         data-blank-widget-no-custom-images-label="@L["No custom images"]"
         data-blank-widget-image-file-label="@L["Image or GIF file"]"
         data-blank-widget-display-name-label="@L["Display name"]"
         data-blank-widget-upload-label="@L["Upload image"]"
         data-blank-widget-import-zip-label="@L["Import ZIP"]"
         data-blank-widget-select-image-label="@L["Select an image or GIF file."]"
         data-blank-widget-uploading-label="@L["Uploading image..."]"
         data-blank-widget-upload-success-label="@L["Blank widget image library updated."]"
         data-blank-widget-upload-error-label="@L["Could not update blank widget image library."]"
         data-blank-widget-upload-too-large-label="@L["The selected image is too large."]"
         data-blank-widget-max-image-bytes="@PortalBlankWidgetService.MaxImageBytes.ToString(CultureInfo.InvariantCulture)"
         data-blank-widget-max-zip-bytes="@PortalBlankWidgetService.MaxZipBytes.ToString(CultureInfo.InvariantCulture)">
    <form class="visually-hidden" method="post" data-dashboard-token-form>
        @Html.AntiForgeryToken()
    </form>

    <div class="portal-dashboard__canvas" data-dashboard-canvas aria-label="@L["Dashboard canvas"]">
        @if (Model.ActiveWidgets.Count == 0)
        {
            <div class="portal-dashboard__empty" data-dashboard-empty>
                @if (Model.CanEditDashboard)
                {
                    <span>@L["No widgets have been added yet."]</span>
                }
                else
                {
                    <span>@L["Dashboard widgets require an OMP user."]</span>
                }
            </div>
        }
        else
        {
            <div class="portal-dashboard__empty is-hidden" data-dashboard-empty>@L["No widgets have been added yet."]</div>
        }

        @foreach (var widget in Model.ActiveWidgets)
        {
            var widgetContentScale = Math.Clamp(widget.ContentScale, -100, 100);
            var widgetContentScaleFactor = Math.Max(0.1, (100 + widgetContentScale) / 100.0);
            var isBlankWidget = string.Equals(widget.Payload, "blank-rectangle", StringComparison.OrdinalIgnoreCase);
            var blankWidgetVariant = isBlankWidget && widget.IntData is 1 or 2 ? widget.IntData.Value : 0;
            var blankWidgetImageId = isBlankWidget
                && long.TryParse(widget.StringData, NumberStyles.Integer, CultureInfo.InvariantCulture, out var parsedBlankWidgetImageId)
                && parsedBlankWidgetImageId > 0
                    ? parsedBlankWidgetImageId
                    : (long?)null;
            <article class="dashboard-widget"
                     data-dashboard-widget
                     data-user-active-widget-id="@widget.UserActiveWidgetId"
                     data-widget-id="@widget.WidgetId"
                     data-widget-type="@widget.WidgetType"
                     data-widget-payload="@widget.Payload"
                     data-widget-int-data="@(widget.IntData?.ToString(CultureInfo.InvariantCulture) ?? string.Empty)"
                     data-widget-string-data="@widget.StringData"
                     data-widget-content-scale="@widgetContentScale.ToString(CultureInfo.InvariantCulture)"
                     style="top: @(widget.OffsetTop)px; left: @(widget.OffsetLeft)px; width: @(widget.Width)px; height: @(widget.Height)px; z-index: @(widget.OrderPriority); --dashboard-widget-content-scale-factor: @widgetContentScaleFactor.ToString("0.###", CultureInfo.InvariantCulture);">
                @if (!string.IsNullOrWhiteSpace(widget.EffectiveTitle))
                {
                    <div class="dashboard-widget__titlebar" data-widget-titlebar>@L[widget.EffectiveTitle]</div>
                }
                <div class="dashboard-widget__body">
                    <div class="dashboard-widget__content" data-widget-content>
                        @if (widget.Payload == "admin-overview")
                        {
                            <div class="dashboard-widget__admin-overview">
                                <partial name="_AdminOverviewMetrics" model="Model.Metrics" />
                            </div>
                        }
                        else if (widget.Payload == "portal-entry-favorites")
                        {
                            <partial name="_PortalEntryWidgetList" model="new DashboardPortalEntryWidgetList(Model.FavoritePortalEntries, true)" />
                        }
                        else if (widget.Payload == "portal-entry-list")
                        {
                            <partial name="_PortalEntryWidgetList" model="new DashboardPortalEntryWidgetList(Model.AllPortalEntries, false, true)" />
                        }
                        else if (widget.Payload == "portal-entry-combolist")
                        {
                            <partial name="_PortalEntryComboWidgetList" model="new DashboardPortalEntryComboWidgetList(Model.FavoritePortalEntries, Model.AllPortalEntries)" />
                        }
                        else if (widget.Payload == "portal-navbar-links")
                        {
                            <partial name="_DashboardNavbarWidgetList" model="new DashboardNavbarWidgetList(Model.DashboardNavbarSections)" />
                        }
                        else if (widget.Payload == "user-roles")
                        {
                            <partial name="_DashboardRoleWidgetList" model="new DashboardRoleWidgetList(Model.DashboardRoles)" />
                        }
                        else if (widget.Payload == "content-pages")
                        {
                            <partial name="_DashboardContentPageWidgetList" model="new DashboardContentPageWidgetList(Model.ContentPages)" />
                        }
                        else if (widget.Payload == "weekday-date")
                        {
                            <partial name="_DashboardDateWidget" model="widget.IntData == 1" />
                        }
                        else if (widget.Payload == "music-player")
                        {
                            <partial name="_DashboardMusicPlayerWidget" />
                        }
                        else if (blankWidgetImageId.HasValue)
                        {
                            <div class="dashboard-widget__blank dashboard-widget__blank--image" data-blank-widget data-blank-widget-image-id="@blankWidgetImageId.Value">
                                <img src="@Url.Page("/Index", "BlankWidgetImage", new { id = blankWidgetImageId.Value })" alt="" />
                            </div>
                        }
                        else if (blankWidgetVariant > 0)
                        {
                            <div class="dashboard-widget__blank dashboard-widget__blank--image" data-blank-widget>
                                <img src="~/img/blank-widget/@(blankWidgetVariant).gif" alt="" />
                            </div>
                        }
                        else
                        {
                            <div class="dashboard-widget__blank" data-blank-widget></div>
                        }
                    </div>
                </div>
                @if (Model.CanEditDashboard)
                {
                    <button type="button"
                            class="dashboard-widget__remove"
                            data-widget-remove
                            title="@L["Remove widget"]"
                            aria-label="@L["Remove widget"]">
                        <span class="dashboard-widget__remove-icon" aria-hidden="true"></span>
                    </button>
                    <button type="button"
                            class="dashboard-widget__settings-toggle"
                            data-widget-settings-toggle
                            title="@L["Widget settings"]"
                            aria-label="@L["Widget settings"]"
                            aria-expanded="false">
                        <span class="dashboard-widget__settings-icon" aria-hidden="true"></span>
                    </button>
                    <div class="dashboard-widget__settings-panel" data-widget-settings-panel hidden>
                        <div class="dashboard-widget__settings-field">
                            <span>@L["Zoom"]</span>
                            <div class="dashboard-widget__zoom-control" data-widget-content-scale-control>
                                <input type="range"
                                       min="-100"
                                       max="100"
                                       value="@widgetContentScale.ToString(CultureInfo.InvariantCulture)"
                                       aria-label="@L["Zoom"]"
                                       data-widget-content-scale-range />
                                <div class="dashboard-widget__zoom-value">
                                    <input type="number"
                                           min="-100"
                                           max="100"
                                           value="@widgetContentScale.ToString(CultureInfo.InvariantCulture)"
                                           aria-label="@L["Zoom value"]"
                                           data-widget-content-scale-input />
                                    <span>%</span>
                                </div>
                                <button type="button" class="btn-link" data-widget-content-scale-reset>@L["Reset zoom"]</button>
                            </div>
                        </div>
                        @if (widget.Payload == "weekday-date")
                        {
                            <label>
                                <span>@L["Week number"]</span>
                                <select data-widget-int-data-control>
                                    <option value="0" selected="@(widget.IntData != 1)">@L["Show week number"]</option>
                                    <option value="1" selected="@(widget.IntData == 1)">@L["Hide week number"]</option>
                                </select>
                            </label>
                        }
                        else if (widget.Payload == "portal-entry-list")
                        {
                            var columnCount = widget.IntData is >= 1 and <= 3 ? widget.IntData.Value : 0;
                            <label>
                                <span>@L["Column count"]</span>
                                <select data-widget-int-data-control>
                                    <option value="0" selected="@(columnCount == 0)">@L["Default"]</option>
                                    <option value="1" selected="@(columnCount == 1)">@L["1 column"]</option>
                                    <option value="2" selected="@(columnCount == 2)">@L["2 columns"]</option>
                                    <option value="3" selected="@(columnCount == 3)">@L["3 columns"]</option>
                                </select>
                            </label>
                        }
                        else if (isBlankWidget)
                        {
                            <label>
                                <span>@L["Blank widget style"]</span>
                                <select data-blank-widget-style-control>
                                    <option value="static:0" selected="@(blankWidgetVariant == 0 && !blankWidgetImageId.HasValue)">@L["Default"]</option>
                                    <option value="static:1" selected="@(blankWidgetVariant == 1 && !blankWidgetImageId.HasValue)">@L["Variant 1"]</option>
                                    <option value="static:2" selected="@(blankWidgetVariant == 2 && !blankWidgetImageId.HasValue)">@L["Variant 2"]</option>
                                    @if (blankWidgetImageId.HasValue)
                                    {
                                        <option value="image:@blankWidgetImageId.Value" selected>@L["Custom image"] #@blankWidgetImageId.Value</option>
                                    }
                                </select>
                            </label>
                            @if (Model.IsPortalAdmin)
                            {
                                <div class="dashboard-widget__blank-admin" data-blank-widget-admin>
                                    <label>
                                        <span>@L["Image or GIF file"]</span>
                                        <input type="file" accept="image/gif,image/png,image/jpeg,.gif,.png,.jpg,.jpeg" data-blank-widget-file />
                                    </label>
                                    <label>
                                        <span>@L["Display name"]</span>
                                        <input type="text" maxlength="200" data-blank-widget-display-name />
                                    </label>
                                    <div class="dashboard-widget__blank-admin-actions">
                                        <button type="button" class="btn btn-primary" data-blank-widget-upload>@L["Upload image"]</button>
                                        <label class="btn dashboard-widget__blank-admin-zip">
                                            <input type="file" accept=".zip,application/zip" data-blank-widget-zip />
                                            @L["Import ZIP"]
                                        </label>
                                    </div>
                                    <div class="dashboard-widget__blank-admin-status" data-blank-widget-status></div>
                                </div>
                            }
                        }
                    </div>
                    <span class="dashboard-widget__resize" data-widget-resize aria-hidden="true"></span>
                }
            </article>
        }
    </div>

    @if (Model.CanEditDashboard)
    {
        <div class="dashboard-edit-menu">
            <div class="dashboard-edit-menu__actions" aria-label="@L["Dashboard actions"]">
                <button type="button" class="dashboard-add-button" data-dashboard-add-open>
                    <span class="dashboard-action-icon dashboard-action-icon--add" aria-hidden="true"></span>
                    @L["Add widget"]
                </button>

                <button type="button" class="dashboard-save-button" data-dashboard-save disabled aria-disabled="true">
                    <span class="dashboard-action-icon dashboard-action-icon--save" aria-hidden="true"></span>
                    @L["Save"]
                </button>

                <button type="button" class="dashboard-reset-changes-button" data-dashboard-reset-changes>
                    <span class="dashboard-action-icon dashboard-action-icon--reset-history" aria-hidden="true"></span>
                    @L["Reset changes"]
                </button>
            </div>
            <button type="button"
                    class="dashboard-floating-button"
                    data-dashboard-edit-toggle
                    aria-pressed="false"
                    aria-label="@L["Edit dashboard"]"
                    title="@L["Edit dashboard"]">
                <span class="dashboard-floating-button__icon" aria-hidden="true"></span>
                <span data-dashboard-edit-label></span>
            </button>
        </div>

        @if (Model.IsPortalAdmin)
        {
            <template data-dashboard-widget-template="admin-overview">
                <div class="dashboard-widget__admin-overview">
                    <partial name="_AdminOverviewMetrics" model="Model.Metrics" />
                </div>
            </template>
        }

        <template data-dashboard-widget-template="portal-entry-favorites">
            <partial name="_PortalEntryWidgetList" model="new DashboardPortalEntryWidgetList(Model.FavoritePortalEntries, true)" />
        </template>

        <template data-dashboard-widget-template="portal-entry-list">
            <partial name="_PortalEntryWidgetList" model="new DashboardPortalEntryWidgetList(Model.AllPortalEntries, false, true)" />
        </template>

        <template data-dashboard-widget-template="portal-entry-combolist">
            <partial name="_PortalEntryComboWidgetList" model="new DashboardPortalEntryComboWidgetList(Model.FavoritePortalEntries, Model.AllPortalEntries)" />
        </template>

        <template data-dashboard-widget-template="portal-navbar-links">
            <partial name="_DashboardNavbarWidgetList" model="new DashboardNavbarWidgetList(Model.DashboardNavbarSections)" />
        </template>

        <template data-dashboard-widget-template="user-roles">
            <partial name="_DashboardRoleWidgetList" model="new DashboardRoleWidgetList(Model.DashboardRoles)" />
        </template>

        <template data-dashboard-widget-template="content-pages">
            <partial name="_DashboardContentPageWidgetList" model="new DashboardContentPageWidgetList(Model.ContentPages)" />
        </template>

        <template data-dashboard-widget-template="weekday-date">
            <partial name="_DashboardDateWidget" model="false" />
        </template>

        <template data-dashboard-widget-template="music-player">
            <partial name="_DashboardMusicPlayerWidget" />
        </template>

        <dialog class="dashboard-widget-picker" data-widget-picker aria-labelledby="dashboard-widget-picker-title">
            <div class="dashboard-widget-picker__header">
                <h3 id="dashboard-widget-picker-title">@L["Add widget"]</h3>
                <button type="button" class="icon-button dashboard-widget-picker__close" data-widget-picker-close aria-label="@L["Close"]"></button>
            </div>
            @if (Model.AvailableWidgets.Count == 0)
            {
                <div class="empty-state">@L["No widgets are available."]</div>
            }
            else
            {
                <div class="dashboard-widget-picker__list">
                    @foreach (var widget in Model.AvailableWidgets)
                    {
                        <div role="button"
                             tabindex="0"
                             class="dashboard-widget-option"
                             data-widget-option
                             data-widget-id="@widget.WidgetId"
                             data-widget-title="@L[widget.Title]"
                             data-widget-type="@widget.WidgetType"
                             data-widget-payload="@widget.Payload">
                            <span class="dashboard-widget-option__title">@L[widget.Title]</span>
                            <span class="dashboard-widget-option__meta">@L["Portal widget"]</span>
                        </div>
                    }
                </div>
            }
        </dialog>

        <dialog class="dashboard-unsaved-dialog unsaved-dialog" data-dashboard-unsaved-dialog aria-labelledby="dashboard-unsaved-title">
            <form method="dialog" class="unsaved-dialog__body">
                <h3 id="dashboard-unsaved-title">@L["Unsaved changes"]</h3>
                <p class="muted">@L["You have unsaved dashboard changes. Save them before leaving edit mode?"]</p>
                <div class="toolbar">
                    <button type="button" class="btn btn-primary" data-dashboard-unsaved-save>@L["Save changes"]</button>
                    <button type="button" class="btn" data-dashboard-unsaved-discard>@L["Discard changes"]</button>
                    <button type="button" class="btn" data-dashboard-unsaved-cancel>@L["Keep editing"]</button>
                </div>
            </form>
        </dialog>
    }
</section>

@section Scripts {
    <script src="~/js/portal-dashboard.js"></script>
}
