@page
@using OpenModulePlatform.Portal.Services
@model OpenModulePlatform.Portal.Pages.IndexModel

<h2>@L["OMP Portal"]</h2>

<p class="muted">@L["This portal is the shared entry point for an OMP instance."]</p>

<div class="card">
    <div><b>@L["Current user"]</b>: @User?.Identity?.Name</div>
    <div><b>@L["Portal admin"]</b>: @(Model.IsPortalAdmin ? L["Yes"] : L["No"])</div>
</div>

<div class="card">
    <h3>@L["Available OMP web app instances"]</h3>
    @if (Model.Apps.Count == 0)
    {
        <div class="muted">@L["No accessible web app instances are currently registered."]</div>
    }
    else
    {
        <div class="table-scroll">
            <table class="grid portal-apps-grid">
                <thead>
                    <tr>
                        <th>@L["Display name"]</th>
                        <th>@L["App instance key"]</th>
                        <th>@L["App key"]</th>
                        <th>@L["Route"]</th>
                        <th>@L["Description"]</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var app in Model.Apps)
                {
                    string? href = null;
                    string? configuredAddress = null;
                    string? displayAddress = null;
                    var showResolvedHref = false;

                    href = AppLinkBuilder.ResolveHref(Request, app);
                    configuredAddress = AppLinkBuilder.ResolveDisplayAddress(Request, app);
                    displayAddress = configuredAddress ?? href;
                    showResolvedHref = !string.IsNullOrWhiteSpace(href)
                        && !string.IsNullOrWhiteSpace(configuredAddress)
                        && !string.Equals(configuredAddress, href, System.StringComparison.OrdinalIgnoreCase);

                    <tr>
                        <td>@app.DisplayName</td>
                        <td><code>@app.AppInstanceKey</code></td>
                        <td><code>@app.AppKey</code></td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(href))
                            {
                                <a href="@href">@displayAddress</a>

                                @if (showResolvedHref)
                                {
                                    <div class="muted"><code>@href</code></div>
                                }
                            }
                            else if (!string.IsNullOrWhiteSpace(configuredAddress))
                            {
                                <code>@configuredAddress</code>
                                <div class="muted">@L["Set Host base URL to make this route clickable from the Portal."]</div>
                            }
                        </td>
                        <td>@app.Description</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>
