@page
@using OpenModulePlatform.Portal.Services
@model OpenModulePlatform.Portal.Pages.IndexModel
@{
    var ompBranding = await OmpBrandingService.GetBrandingAsync(ViewContext.HttpContext.RequestAborted);
}

<h2>@ompBranding.PortalDisplayName</h2>

<p class="muted">@ompBranding.ApplyPlatformName(L["This portal is the shared entry point for an OMP instance."].Value)</p>

<div class="card">
    <div><b>@L["Current user"]</b>: @User?.Identity?.Name</div>
    <div><b>@ompBranding.ApplyTerms(L["Portal admin"].Value)</b>: @(Model.IsPortalAdmin ? L["Yes"] : L["No"])</div>
</div>

@if (Model.IsPortalAdmin)
{
    <section class="card top-gap portal-overview-panel">
        <details class="portal-overview" open="@(!Model.AdminMetricsCollapsed)">
            <summary class="portal-overview__summary">
                <div class="page-header portal-overview__header">
                    <h3>@L["Overview"]</h3>
                    <span class="portal-overview__toggle" aria-hidden="true">
                        <span class="portal-overview__toggle-icon portal-overview__toggle-icon--open">&#9660;</span>
                        <span class="portal-overview__toggle-icon portal-overview__toggle-icon--closed">&#9664;</span>
                    </span>
                </div>
            </summary>

            <div class="portal-overview__body">
                <div class="card-grid portal-admin-metrics">
                    <a class="card metric-card" href="~/admin/instances">
                        <div class="metric">@Model.Metrics.InstanceCount</div>
                        <div>@L["Instances"]</div>
                    </a>
                    <a class="card metric-card" href="~/admin/hosts">
                        <div class="metric">@Model.Metrics.HostCount</div>
                        <div>@L["Hosts"]</div>
                    </a>
                    <a class="card metric-card" href="~/admin/modules">
                        <div class="metric">@Model.Metrics.ModuleCount</div>
                        <div>@L["Module definitions"]</div>
                    </a>
                    <a class="card metric-card" href="~/admin/moduleinstances">
                        <div class="metric">@Model.Metrics.ModuleInstanceCount</div>
                        <div>@L["Module instances"]</div>
                    </a>
                    <a class="card metric-card" href="~/admin/apps">
                        <div class="metric">@Model.Metrics.AppCount</div>
                        <div>@L["App definitions"]</div>
                    </a>
                    <a class="card metric-card" href="~/admin/appinstances">
                        <div class="metric">@Model.Metrics.AppInstanceCount</div>
                        <div>@L["App instances"]</div>
                    </a>
                    <a class="card metric-card" href="~/admin/workers">
                        <div class="metric">@Model.Metrics.AppWorkerDefinitionCount</div>
                        <div>@L["App workers"]</div>
                    </a>
                    <a class="card metric-card" href="~/admin/workers">
                        <div class="metric">@Model.Metrics.AppInstanceRuntimeStateCount</div>
                        <div>@L["Worker runtime states"]</div>
                    </a>
                    <a class="card metric-card" href="~/admin/artifacts">
                        <div class="metric">@Model.Metrics.ArtifactCount</div>
                        <div>@L["Artifacts"]</div>
                    </a>
                </div>
            </div>
        </details>
    </section>
}

<section class="portal-entries portal-entries--framed top-gap" data-portal-entries-root data-manage-mode="@Model.ManageList.ToString().ToLowerInvariant()">
    <div class="portal-entries__toolbar">
        <div>
            <h3>@L["Portal entries"]</h3>
            <p class="muted">@L["Portal entries are curated start points for the destinations you can access."]</p>
        </div>
        @if (Model.CanPersonalizeEntries || Model.IsPortalAdmin)
        {
            <div class="portal-entries__toolbar-actions">
                @if (Model.CanPersonalizeEntries && Model.ManageList)
                {
                    <a class="button secondary" href="@Url.Page("/Index", new { fullList = Model.ShowFullList })">@L["Done"]</a>
                }
                else if (Model.CanPersonalizeEntries)
                {
                    <a class="button secondary" href="@Url.Page("/Index", new { manage = true, fullList = Model.ShowFullList })">@L["Manage list"]</a>
                }

                @if (Model.CanPersonalizeEntries && Model.ShowFullList)
                {
                    <a class="button secondary" href="@Url.Page("/Index", new { manage = Model.ManageList })">@L["Show normal list"]</a>
                }
                else if (Model.CanPersonalizeEntries)
                {
                    <a class="button secondary" href="@Url.Page("/Index", new { manage = Model.ManageList, fullList = true })">@L["Show full list"]</a>
                }

                @if (Model.IsPortalAdmin)
                {
                    <a class="button secondary" href="~/admin/portalentries">@L["Administer portal entries"]</a>
                }
            </div>
        }
    </div>

    @if (Model.CanPersonalizeEntries && Model.ManageList && Model.PinnedEntries.Count > 1)
    {
        <form class="visually-hidden" method="post" asp-page-handler="SortPinned" data-portal-entry-sort-form>
            @Html.AntiForgeryToken()
        </form>
    }

    <div class="portal-entry-section">
        <div class="portal-entry-section__label">
            <span>@L["Pinned"]</span>
        </div>
        @if (Model.PinnedEntries.Count == 0)
        {
            <div class="empty-state">@L["No pinned entries"]</div>
        }
        else
        {
            <div class="portal-entry-list portal-entry-list--pinned" data-portal-pinned-list>
                @foreach (var entry in Model.PinnedEntries)
                {
                    <article class="portal-entry-card"
                             data-portal-entry-card
                             data-portal-entry-id="@entry.PortalEntryId"
                             draggable="@(Model.CanPersonalizeEntries && Model.ManageList ? "true" : "false")">
                        @if (Model.CanPersonalizeEntries && Model.ManageList)
                        {
                            <span class="portal-entry-card__drag-handle" title="@L["Drag to sort"]" aria-hidden="true">⋮⋮</span>
                        }
                        <a class="portal-entry-card__main" href="@entry.TargetHref">
                            <span class="portal-entry-card__logo">
                                @if (!string.IsNullOrWhiteSpace(entry.LogoUrl))
                                {
                                    <img src="@entry.LogoUrl" alt="" />
                                }
                                else
                                {
                                    <span>@entry.LogoFallbackText</span>
                                }
                            </span>
                            <span class="portal-entry-card__text">
                                <span class="portal-entry-card__title">@entry.DisplayName</span>
                                @if (!string.IsNullOrWhiteSpace(entry.Description))
                                {
                                    <span class="portal-entry-card__description">@entry.Description</span>
                                }
                            </span>
                        </a>
                        @if (Model.CanPersonalizeEntries || Model.IsPortalAdmin)
                        {
                            <div class="portal-entry-card__actions">
                                @if (Model.CanPersonalizeEntries)
                                {
                                    <form method="post" asp-page-handler="Unpin" class="inline-form">
                                        <input type="hidden" name="portalEntryId" value="@entry.PortalEntryId" />
                                        <input type="hidden" name="manage" value="@Model.ManageList.ToString().ToLowerInvariant()" />
                                        <input type="hidden" name="fullList" value="@Model.ShowFullList.ToString().ToLowerInvariant()" />
                                        <button type="submit" class="icon-button is-active" title="@L["Unpin"]" aria-label="@L["Unpin"]">★</button>
                                    </form>
                                }
                                <details class="portal-entry-options">
                                    <summary class="icon-button" title="@L["Options"]" aria-label="@L["Options"]">⋯</summary>
                                    <div class="portal-entry-options__menu">
                                        @if (Model.IsPortalAdmin)
                                        {
                                            <a href="@Url.Page("/Admin/PortalEntryEdit", new { portalEntryId = entry.PortalEntryId })">@L["Edit"]</a>
                                        }
                                        @if (Model.CanPersonalizeEntries)
                                        {
                                            <form method="post" asp-page-handler="Hide">
                                                <input type="hidden" name="portalEntryId" value="@entry.PortalEntryId" />
                                                <input type="hidden" name="manage" value="@Model.ManageList.ToString().ToLowerInvariant()" />
                                                <input type="hidden" name="fullList" value="@Model.ShowFullList.ToString().ToLowerInvariant()" />
                                                <button type="submit">@L["Hide"]</button>
                                            </form>
                                        }
                                    </div>
                                </details>
                            </div>
                        }
                    </article>
                }
            </div>
        }
    </div>

    <div class="portal-entry-section">
        <div class="portal-entry-section__label">
            <span>@L["All entries"]</span>
        </div>
        @if (Model.AllEntries.Count == 0)
        {
            <div class="empty-state">@L["No entries to show"]</div>
        }
        else
        {
            <div class="portal-entry-list">
                @foreach (var entry in Model.AllEntries)
                {
                    <article class="portal-entry-card@(entry.IsHidden ? " is-hidden" : string.Empty)" data-portal-entry-card data-portal-entry-id="@entry.PortalEntryId">
                        <a class="portal-entry-card__main" href="@entry.TargetHref" aria-disabled="@(entry.IsHidden ? "true" : "false")">
                            <span class="portal-entry-card__logo">
                                @if (!string.IsNullOrWhiteSpace(entry.LogoUrl))
                                {
                                    <img src="@entry.LogoUrl" alt="" />
                                }
                                else
                                {
                                    <span>@entry.LogoFallbackText</span>
                                }
                            </span>
                            <span class="portal-entry-card__text">
                                <span class="portal-entry-card__title">
                                    @entry.DisplayName
                                    @if (entry.IsHidden)
                                    {
                                        <span class="portal-entry-card__badge">@L["Hidden"]</span>
                                    }
                                </span>
                                @if (!string.IsNullOrWhiteSpace(entry.Description))
                                {
                                    <span class="portal-entry-card__description">@entry.Description</span>
                                }
                            </span>
                        </a>
                        @if (Model.CanPersonalizeEntries || Model.IsPortalAdmin)
                        {
                            <div class="portal-entry-card__actions">
                                @if (Model.CanPersonalizeEntries && entry.IsHidden)
                                {
                                    <form method="post" asp-page-handler="Unhide" class="inline-form">
                                        <input type="hidden" name="portalEntryId" value="@entry.PortalEntryId" />
                                        <input type="hidden" name="manage" value="@Model.ManageList.ToString().ToLowerInvariant()" />
                                        <input type="hidden" name="fullList" value="@Model.ShowFullList.ToString().ToLowerInvariant()" />
                                        <button type="submit" class="button secondary">@L["Undo"]</button>
                                    </form>
                                }
                                else if (Model.CanPersonalizeEntries)
                                {
                                    <form method="post" asp-page-handler="Pin" class="inline-form">
                                        <input type="hidden" name="portalEntryId" value="@entry.PortalEntryId" />
                                        <input type="hidden" name="manage" value="@Model.ManageList.ToString().ToLowerInvariant()" />
                                        <input type="hidden" name="fullList" value="@Model.ShowFullList.ToString().ToLowerInvariant()" />
                                        <button type="submit" class="icon-button" title="@L["Pin"]" aria-label="@L["Pin"]">☆</button>
                                    </form>
                                }

                                @if (Model.IsPortalAdmin || (Model.CanPersonalizeEntries && !entry.IsHidden))
                                {
                                    <details class="portal-entry-options">
                                        <summary class="icon-button" title="@L["Options"]" aria-label="@L["Options"]">⋯</summary>
                                        <div class="portal-entry-options__menu">
                                            @if (Model.IsPortalAdmin)
                                            {
                                                <a href="@Url.Page("/Admin/PortalEntryEdit", new { portalEntryId = entry.PortalEntryId })">@L["Edit"]</a>
                                            }
                                            @if (Model.CanPersonalizeEntries && !entry.IsHidden)
                                            {
                                                <form method="post" asp-page-handler="Hide">
                                                    <input type="hidden" name="portalEntryId" value="@entry.PortalEntryId" />
                                                    <input type="hidden" name="manage" value="@Model.ManageList.ToString().ToLowerInvariant()" />
                                                    <input type="hidden" name="fullList" value="@Model.ShowFullList.ToString().ToLowerInvariant()" />
                                                    <button type="submit">@L["Hide"]</button>
                                                </form>
                                            }
                                        </div>
                                    </details>
                                }
                            </div>
                        }
                    </article>
                }
            </div>
        }
    </div>
</section>
