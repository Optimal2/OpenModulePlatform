@*
    Discreet quick-access row to admin list pages that are not in the main menu yet.
    `L` (IStringLocalizer<PortalResource>) comes from Pages/_ViewImports.cshtml; missing keys fall
    back to the key text. Edit this ONE file to add/remove a link. Routes are the default Razor Pages
    routes for Pages/Admin/<Name>.cshtml → /admin/<name>.
*@
<nav class="admin-quicklinks" aria-label="@L["Admin quick links"]"
     style="display:flex;flex-wrap:wrap;align-items:center;gap:.3rem 1rem;font-size:.85rem;margin:.25rem 0 1rem;opacity:.85">
    <a class="action-link" href="~/admin/overview">@L["Overview"]</a>
    <a class="action-link" href="~/admin/instancetemplateedit?id=1">@L["Installation"]</a>
    <a class="action-link" href="~/admin/instances">@L["Instances"]</a>
    <a class="action-link" href="~/admin/appinstances">@L["App instances"]</a>
    <a class="action-link" href="~/admin/moduleinstances">@L["Module instances"]</a>
    <a class="action-link" href="~/admin/hosts">@L["Hosts"]</a>
    <a class="action-link" href="~/admin/hostresources">@L["Host resources"]</a>
    <a class="action-link" href="~/admin/hostdeployments">@L["Host deployments"]</a>
    <a class="action-link" href="~/admin/modules">@L["Modules"]</a>
    <a class="action-link" href="~/admin/moduledefinitions">@L["Module definitions"]</a>
    <a class="action-link" href="~/admin/apps">@L["Apps"]</a>
    <a class="action-link" href="~/admin/workers">@L["Workers"]</a>
    <a class="action-link" href="~/admin/maintenance">@L["Maintenance"]</a>
</nav>
