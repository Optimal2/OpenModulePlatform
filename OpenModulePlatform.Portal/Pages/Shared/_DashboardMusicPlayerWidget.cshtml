@using OpenModulePlatform.Portal.Localization
@using OpenModulePlatform.Portal.Options
@inject Microsoft.Extensions.Localization.IStringLocalizer<PortalResource> L
@inject Microsoft.Extensions.Options.IOptions<ArtifactUploadOptions> UploadOptions
@{
    var isPortalAdmin = ViewData["IsPortalAdmin"] is bool value && value;
    var maxUploadBytes = UploadOptions.Value.MaxUploadBytes > 0
        ? UploadOptions.Value.MaxUploadBytes
        : ArtifactUploadOptions.DefaultMaxUploadBytes;
}

<div class="dashboard-music-player"
     data-dashboard-music-player
     data-playlist-url="@Url.Page("/Index", "MusicPlaylist")"
     data-upload-url="@Url.Page("/Index", "UploadMusicTrack")"
     data-zip-upload-url="@Url.Page("/Index", "UploadMusicPlaylistZip")"
     data-loading-label="@L["Loading playlist"]"
     data-no-tracks-label="@L["No tracks available"]"
     data-error-label="@L["Could not play track"]"
     data-upload-success-label="@L["Music library updated."]"
     data-upload-error-label="@L["Could not update music library."]"
     data-uploading-label="@L["Uploading music..."]"
     data-upload-too-large-label="@L["The selected file is too large for this upload surface."]"
     data-select-mp3-label="@L["Select an MP3 file."]"
     data-select-zip-label="@L["Select a ZIP package."]"
     data-local-artist-label="@L["Local file"]"
     data-max-upload-bytes="@maxUploadBytes">
    <audio preload="metadata" data-music-audio></audio>
    <div class="dashboard-music-player__track">
        <div class="dashboard-music-player__cover" aria-hidden="true">
            <span></span>
        </div>
        <div class="dashboard-music-player__metadata">
            <div class="dashboard-music-player__title" data-music-title>@L["No track selected"]</div>
            <div class="dashboard-music-player__artist" data-music-artist>@L["Music player"]</div>
            <div class="dashboard-music-player__attribution" data-music-attribution></div>
        </div>
    </div>
    <div class="dashboard-music-player__progress">
        <span data-music-current>0:00</span>
        <input type="range" min="0" max="100" step="0.1" value="0" data-music-seek aria-label="@L["Seek"]" />
        <span data-music-duration>0:00</span>
    </div>
    <div class="dashboard-music-player__controls">
        <button type="button" class="dashboard-music-player__button" data-music-previous aria-label="@L["Previous track"]" title="@L["Previous track"]">
            <span class="dashboard-music-player__icon dashboard-music-player__icon--previous" aria-hidden="true"></span>
        </button>
        <button type="button" class="dashboard-music-player__button dashboard-music-player__button--primary" data-music-play aria-label="@L["Play"]" title="@L["Play"]" data-play-label="@L["Play"]" data-pause-label="@L["Pause"]">
            <span class="dashboard-music-player__icon dashboard-music-player__icon--play" aria-hidden="true"></span>
            <span class="dashboard-music-player__icon dashboard-music-player__icon--pause" aria-hidden="true"></span>
        </button>
        <button type="button" class="dashboard-music-player__button" data-music-next aria-label="@L["Next track"]" title="@L["Next track"]">
            <span class="dashboard-music-player__icon dashboard-music-player__icon--next" aria-hidden="true"></span>
        </button>
        <button type="button" class="dashboard-music-player__button" data-music-shuffle aria-label="@L["Shuffle"]" title="@L["Shuffle"]" aria-pressed="false">S</button>
        <button type="button" class="dashboard-music-player__button" data-music-loop aria-label="@L["Loop"]" title="@L["Loop"]" aria-pressed="false">L</button>
        <label class="dashboard-music-player__button dashboard-music-player__file" title="@L["Add local MP3 files"]" aria-label="@L["Add local MP3 files"]">
            <input type="file" accept="audio/mpeg,.mp3" multiple data-music-files />
            <span class="dashboard-music-player__icon dashboard-music-player__icon--add" aria-hidden="true"></span>
        </label>
        @if (isPortalAdmin)
        {
            <button type="button" class="dashboard-music-player__button" data-music-admin-open aria-label="@L["Manage music library"]" title="@L["Manage music library"]" aria-expanded="false">
                <span class="dashboard-music-player__icon dashboard-music-player__icon--library" aria-hidden="true"></span>
            </button>
        }
    </div>
    <div class="dashboard-music-player__status" data-music-status>@L["Loading playlist"]</div>
    @if (isPortalAdmin)
    {
        <div class="dashboard-music-player__admin" data-music-admin-panel role="dialog" aria-modal="false" aria-label="@L["Music library"]" hidden>
            <div class="dashboard-music-player__admin-header">
                <strong>@L["Music library"]</strong>
                <button type="button" class="dashboard-music-player__admin-close" data-music-admin-close aria-label="@L["Close"]"></button>
            </div>
            <div class="dashboard-music-player__admin-tabs" role="tablist" aria-label="@L["Music library"]">
                <button type="button" class="is-active" data-music-admin-tab="mp3" role="tab" aria-selected="true">@L["Single MP3"]</button>
                <button type="button" data-music-admin-tab="zip" role="tab" aria-selected="false">@L["ZIP package"]</button>
            </div>
            <div class="dashboard-music-player__admin-pane" data-music-admin-pane="mp3">
                <div class="dashboard-music-player__admin-fields">
                    <label>
                        <span>@L["MP3 file"]</span>
                        <input type="file" accept="audio/mpeg,.mp3" data-music-admin-file />
                    </label>
                    <label>
                        <span>@L["Track title"]</span>
                        <input type="text" maxlength="200" data-music-admin-title />
                    </label>
                    <label>
                        <span>@L["Artist"]</span>
                        <input type="text" maxlength="200" data-music-admin-artist />
                    </label>
                    <label>
                        <span>@L["Attribution"]</span>
                        <input type="text" maxlength="500" data-music-admin-attribution />
                    </label>
                    <label>
                        <span>@L["Source URL"]</span>
                        <input type="url" maxlength="1000" data-music-admin-source />
                    </label>
                    <label>
                        <span>@L["Description"]</span>
                        <input type="text" maxlength="1000" data-music-admin-description />
                    </label>
                </div>
                <div class="dashboard-music-player__admin-actions">
                    <button type="button" class="btn btn-primary" data-music-admin-upload>@L["Save track"]</button>
                </div>
            </div>
            <div class="dashboard-music-player__admin-pane" data-music-admin-pane="zip" hidden>
                <div class="dashboard-music-player__admin-fields dashboard-music-player__admin-fields--single">
                    <label>
                        <span>@L["ZIP package"]</span>
                        <input type="file" accept=".zip,application/zip" data-music-admin-zip />
                    </label>
                </div>
                <div class="dashboard-music-player__admin-actions">
                    <button type="button" class="btn btn-primary" data-music-admin-zip-upload>@L["Import ZIP"]</button>
                </div>
            </div>
        </div>
    }
</div>
