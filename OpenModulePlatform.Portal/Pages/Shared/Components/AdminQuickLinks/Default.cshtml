@using OpenModulePlatform.Portal.ViewComponents
@using OpenModulePlatform.Web.Shared.Navigation
@model IReadOnlyList<AdminPaneBox>
@*
    The admin pane's link boxes, straight from storage (curated at
    /admin/navigation, where each box's gear leads). Titles and labels are
    localization keys resolved resx-first: seeded entries localize, free-text
    entries render as-is. Boxes stack vertically in the pane, always.
*@
@{
    string currentPath = (ViewContext.HttpContext.Request.Path.Value ?? string.Empty).TrimEnd('/');

    bool IsActive(string relativePath)
        => string.Equals(currentPath, relativePath.Split('?')[0], StringComparison.OrdinalIgnoreCase);
}
@foreach (var paneBox in Model)
{
    var boxModel = new LinkBoxModel
    {
        Label = L[paneBox.Box.Title].Value,
        Heading = L[paneBox.Box.Title].Value,
        BoxKey = paneBox.Box.BoxKey,
        EditUrl = Url.Content("~/admin/navigation?box=" + Uri.EscapeDataString(paneBox.Box.BoxKey)),
        EditLabel = L["Edit links"].Value,
        Items = paneBox.Links
            .Select(link => new LinkBoxItem(L[link.Label].Value, Url.Content("~" + link.Url), link.GroupKey, IsActive(link.Url)))
            .ToArray()
    };

    @await Component.InvokeAsync("LinkBox", new { model = boxModel })
}
