@using OpenModulePlatform.Portal.Localization
@using OpenModulePlatform.Portal.Models
@model DashboardRoleWidgetList
@inject Microsoft.Extensions.Localization.IStringLocalizer<PortalResource> L

@{
    var returnUrl = string.Concat(Context.Request.PathBase, Context.Request.Path, Context.Request.QueryString);
    string BuildRoleActionUrl() => $"{Context.Request.PathBase}/security/set-active-role";
}

<div class="dashboard-role-list">
    @if (Model.Roles.Count == 0)
    {
        <div class="dashboard-role-list__empty">@L["No roles assigned."]</div>
    }
    else
    {
        @foreach (var role in Model.Roles)
        {
            <div class="dashboard-role-list__row@(role.IsActive ? " is-active" : string.Empty)">
                @if (role.IsActive)
                {
                    <div class="dashboard-role-list__item" aria-current="true">
                        <span class="dashboard-role-list__name">@role.Name</span>
                        @if (!string.IsNullOrWhiteSpace(role.Description))
                        {
                            <span class="dashboard-role-list__description">@role.Description</span>
                        }
                        <span class="dashboard-role-list__active">@L["Active role"]</span>
                    </div>
                }
                else
                {
                    <form method="post"
                          action="@BuildRoleActionUrl()"
                          class="dashboard-role-list__form"
                          data-dashboard-role-switch
                          data-confirm-message="@L["Switch active role to {0}?", role.Name]"
                          data-enhance="false">
                        <input type="hidden" name="roleId" value="@role.RoleId" />
                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                        @Html.AntiForgeryToken()
                        <button type="submit" class="dashboard-role-list__item">
                            <span class="dashboard-role-list__name">@role.Name</span>
                            @if (!string.IsNullOrWhiteSpace(role.Description))
                            {
                                <span class="dashboard-role-list__description">@role.Description</span>
                            }
                        </button>
                    </form>
                }
            </div>
        }
    }
</div>
