@using OpenModulePlatform.Web.Shared.Navigation
@using OpenModulePlatform.Web.Shared.Options
@inject OpenModulePlatform.Portal.Services.PortalUserSettingsService PortalUserSettingsService
@inject OpenModulePlatform.Web.Shared.Services.OmpConfigurationService OmpConfigurationService
@inject Microsoft.Extensions.Options.IOptions<WebAppOptions> WebAppOptions
@* File: OpenModulePlatform.Portal/Pages/Shared/_Layout.cshtml *@
@{
    var ompBranding = await OmpBrandingService.GetBrandingAsync(Context.RequestAborted);
    var configuredPortalTitle = ViewData["PortalTitle"]?.ToString();
    var documentTitle = ViewData["Title"]?.ToString();
    var showPortalNavbar = true;
    var requestPath = Context.Request.Path.Value ?? "/";
    string BrandingAssetUrl(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        var trimmed = value.Trim();
        if (trimmed.StartsWith("~/", System.StringComparison.Ordinal))
        {
            return Url.Content(trimmed);
        }

        if (trimmed.StartsWith("/", System.StringComparison.Ordinal)
            && !trimmed.StartsWith("//", System.StringComparison.Ordinal))
        {
            return Url.Content("~" + trimmed);
        }

        return trimmed;
    }

    var heroLogoUrl = BrandingAssetUrl(ompBranding.HeroLogoUrl);
    var faviconUrl = BrandingAssetUrl(ompBranding.FaviconUrl);
    var brandWrapClass = string.IsNullOrWhiteSpace(heroLogoUrl)
        ? "brand-wrap brand-wrap--link"
        : "brand-wrap brand-wrap--link brand-wrap--image";
    var isDashboardPage = string.IsNullOrEmpty(requestPath)
        || string.Equals(requestPath, "/", System.StringComparison.OrdinalIgnoreCase)
        || string.Equals(requestPath.TrimEnd('/'), "/Index", System.StringComparison.OrdinalIgnoreCase);
    var isMessagesPage = string.Equals(requestPath.TrimEnd('/'), "/messages", System.StringComparison.OrdinalIgnoreCase)
        || requestPath.StartsWith("/messages/", System.StringComparison.OrdinalIgnoreCase);
    var userIdClaim = User.FindFirst(OpenModulePlatform.Web.Shared.Security.OmpAuthDefaults.UserIdClaimType)?.Value;
    OpenModulePlatform.Portal.Services.PortalUserSettings? portalLayoutSettings = null;
    if (int.TryParse(userIdClaim, System.Globalization.NumberStyles.Integer, System.Globalization.CultureInfo.InvariantCulture, out var portalLayoutUserId))
    {
        portalLayoutSettings = await PortalUserSettingsService.GetForUserAsync(portalLayoutUserId, Context.RequestAborted);
    }

    if (isDashboardPage && portalLayoutSettings is not null)
    {
        showPortalNavbar = portalLayoutSettings.ShowPortalNavbar;
    }
    else if (isMessagesPage)
    {
        showPortalNavbar = false;
    }

    var notificationToastsConfigValue = await OmpConfigurationService.GetGlobalStringAsync(
        OpenModulePlatform.Portal.Services.PortalUserSettingsService.NotificationToastsConfigCategory,
        OpenModulePlatform.Portal.Services.PortalUserSettingsService.NotificationToastsEnabledConfigSetting,
        Context.RequestAborted);
    var notificationToastsGloballyEnabled = OpenModulePlatform.Portal.Services.PortalUserSettingsService.ParseNotificationToastsEnabled(notificationToastsConfigValue);
    var notificationToastsEnabled = User.Identity?.IsAuthenticated == true
        && notificationToastsGloballyEnabled
        && portalLayoutSettings?.NotificationToastsMuted != true;
    var notificationSoundsEnabled = portalLayoutSettings?.NotificationSoundsEnabled ?? true;

    if (string.IsNullOrWhiteSpace(documentTitle))
    {
        documentTitle = ompBranding.PortalDisplayName;
    }
    else if (!string.IsNullOrWhiteSpace(configuredPortalTitle)
        && documentTitle.StartsWith(configuredPortalTitle, System.StringComparison.Ordinal))
    {
        documentTitle = ompBranding.PortalDisplayName + documentTitle[configuredPortalTitle.Length..];
    }
}
<!doctype html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>@documentTitle</title>
    @if (!string.IsNullOrWhiteSpace(faviconUrl))
    {
        <link rel="icon" href="@faviconUrl" />
    }
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/_content/OpenModulePlatform.Web.Shared/css/column-list-picker.css" />
    <link rel="stylesheet" href="~/_content/OpenModulePlatform.Web.Shared/css/omp-toasts.css" />
    <link rel="stylesheet" href="~/_content/OpenModulePlatform.Web.Shared/css/section-navigator.css" />
    <link rel="stylesheet" href="~/_content/OpenModulePlatform.Web.Shared/css/omp-lists.css" />
    <link rel="stylesheet" href="~/_content/OpenModulePlatform.Web.Shared/css/omp-forms.css" />
    <link rel="stylesheet" href="~/_content/OpenModulePlatform.Web.Shared/css/portal-topbar.css" />
    <link rel="stylesheet" href="~/_content/OpenModulePlatform.Web.Shared/css/omp-error-view.css" />
    @if (ViewData["OmpPreventBackCache"] is true)
    {
        <meta name="omp-prevent-back-cache" content="true" />
    }
</head>
<body>
    <header class="app-header">
        @await Component.InvokeAsync("PortalTopBar")
        @if (showPortalNavbar)
        {
        <div class="topbar">
        <a class="@brandWrapClass" href="~/" aria-label="@L["Home"]">
            @if (!string.IsNullOrWhiteSpace(heroLogoUrl))
            {
                <img class="brand-logo" src="@heroLogoUrl" alt="@ompBranding.PortalDisplayName" />
            }
            else
            {
                <div class="brand">@ompBranding.PortalDisplayName</div>
                <div class="brand-subtitle">@ompBranding.PortalName</div>
            }
        </a>
        <nav class="nav nav--primary">
            <a href="~/">@L["Home"]</a>
            @if (ViewData["IsPortalAdmin"] is bool isPortalAdmin && isPortalAdmin)
            {
                var adminSections = PortalAdminNavigation.CreateSections(relativePath => Url.Content($"~{relativePath}"));

                foreach (var section in adminSections)
                {
                    <details class="nav-dropdown">
                        <summary>@L[section.TextKey]</summary>
                        <div class="nav-dropdown__menu">
                            @foreach (var item in section.Items)
                            {
                                if (item.SeparatorBefore)
                                {
                                    <div class="nav-dropdown__separator" role="separator" aria-hidden="true"></div>
                                }
                                <a href="@item.Href">@L[item.TextKey]</a>
                            }
                        </div>
                    </details>
                }
            }
        </nav>
        </div>
        }
    </header>
    <main class="content-shell">
        @RenderBody()
    </main>
    @if (notificationToastsEnabled)
    {
        <div data-omp-toasts="true"
             data-sounds-enabled="@notificationSoundsEnabled.ToString().ToLowerInvariant()"
             data-summary-url="@Url.Content("~/topbar/summary")"
             data-notifications-url="@Url.Content("~/notifications")"
             data-messages-url="@Url.Content("~/messages")"
             data-visible-interval="@(WebAppOptions.Value.ToastPolling.VisibleIntervalSeconds * 1000)"
             data-hidden-interval="@(WebAppOptions.Value.ToastPolling.HiddenIntervalSeconds * 1000)"
             data-toast-duration="7000"
             data-close-label="@L["Close notification"]"
             data-summary-title="@L["New notifications"]"
             data-summary-template="@L["{0} new notifications"]"
             data-message-summary-title="@L["New messages"]"
             data-message-summary-template="@L["{0} new messages"]"></div>
    }
    <script src="~/js/portal-nav-dropdowns.js"></script>
    <script src="~/js/site.js"></script>
    <script src="~/_content/OpenModulePlatform.Web.Shared/js/omp-lists.js"></script>
    <script src="~/_content/OpenModulePlatform.Web.Shared/js/omp-forms.js"></script>
    <script src="~/_content/OpenModulePlatform.Web.Shared/js/omp-toasts.js"></script>
    <script src="~/_content/OpenModulePlatform.Web.Shared/js/portal-topbar.js"></script>
    <script src="~/_content/OpenModulePlatform.Web.Shared/js/section-navigator.js"></script>
    <script src="~/_content/OpenModulePlatform.Web.Shared/js/omp-secure-page-navigation.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
