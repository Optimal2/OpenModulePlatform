@* File: OpenModulePlatform.Portal/Pages/Shared/_Layout.cshtml *@
<!doctype html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/_content/OpenModulePlatform.Web.Shared/css/portal-topbar.css" />
    <link rel="stylesheet" href="~/_content/OpenModulePlatform.Web.Shared/css/omp-error-view.css" />
    @if (ViewData["OmpPreventBackCache"] is true)
    {
        <meta name="omp-prevent-back-cache" content="true" />
    }
</head>
<body>
    <header class="app-header">
        @await Component.InvokeAsync("PortalTopBar")
        <div class="topbar">
        <div class="brand-wrap">
            <div class="brand">@ViewData["PortalTitle"]</div>
            <div class="brand-subtitle">@L["Portal"]</div>
        </div>
        <nav class="nav nav--primary">
            <a href="~/">@L["Home"]</a>
            @if (ViewData["IsPortalAdmin"] is bool isPortalAdmin && isPortalAdmin)
            {
                <a href="~/admin/overview">@L["Admin"]</a>
                <a href="~/admin/instances">@L["Instances"]</a>
                <a href="~/admin/hosts">@L["Hosts"]</a>
                <a href="~/admin/modules">@L["Modules"]</a>
                <a href="~/admin/apps">@L["Apps"]</a>
                <a href="~/admin/moduleinstances">@L["Module instances"]</a>
                <a href="~/admin/appinstances">@L["App instances"]</a>
                <a href="~/admin/appworkers">@L["App workers"]</a>
                <a href="~/admin/workerruntime">@L["Worker runtime"]</a>
                <a href="~/admin/artifacts">@L["Artifacts"]</a>
                <a href="~/admin/automation">@L["Automation"]</a>
                <a href="~/admin/security">@L["Security"]</a>
            }
        </nav>
        </div>
    </header>
    <main class="content-shell">
        @RenderBody()
    </main>
    <script src="~/_content/OpenModulePlatform.Web.Shared/js/portal-topbar.js"></script>
    <script src="~/_content/OpenModulePlatform.Web.Shared/js/omp-secure-page-navigation.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
