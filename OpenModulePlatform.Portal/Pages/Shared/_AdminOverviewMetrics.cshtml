@using OpenModulePlatform.Portal.Localization
@using OpenModulePlatform.Portal.Models
@model OverviewMetrics
@inject Microsoft.Extensions.Localization.IStringLocalizer<PortalResource> L

<div class="card-grid portal-admin-metrics">
    <a class="card metric-card" href="~/admin/instances">
        <div class="metric">@Model.InstanceCount</div>
        <div>@L["Instances"]</div>
    </a>
    <a class="card metric-card" href="~/admin/hosts">
        <div class="metric">@Model.HostCount</div>
        <div>@L["Hosts"]</div>
    </a>
    <a class="card metric-card" href="~/admin/modules">
        <div class="metric">@Model.ModuleCount</div>
        <div>@L["Module definitions"]</div>
    </a>
    <a class="card metric-card" href="~/admin/moduleinstances">
        <div class="metric">@Model.ModuleInstanceCount</div>
        <div>@L["Module instances"]</div>
    </a>
    <a class="card metric-card" href="~/admin/apps">
        <div class="metric">@Model.AppCount</div>
        <div>@L["App definitions"]</div>
    </a>
    <a class="card metric-card" href="~/admin/appinstances">
        <div class="metric">@Model.AppInstanceCount</div>
        <div>@L["App instances"]</div>
    </a>
    <a class="card metric-card" href="~/admin/workers">
        <div class="metric">@Model.AppWorkerDefinitionCount</div>
        <div>@L["App workers"]</div>
    </a>
    <a class="card metric-card" href="~/admin/workers">
        <div class="metric">@Model.AppInstanceRuntimeStateCount</div>
        <div>@L["Worker runtime states"]</div>
    </a>
    <a class="card metric-card" href="~/admin/artifacts">
        <div class="metric">@Model.ArtifactCount</div>
        <div>@L["Artifacts"]</div>
    </a>
</div>
