@page "/messages"
@model OpenModulePlatform.Portal.Pages.Messages.IndexModel
@using OpenModulePlatform.Web.Shared.Web

<div data-messages-live-content>
<section class="page-header">
    <div>
        <div class="eyebrow">@L["Portal"]</div>
        <h2>@L["Messages"]</h2>
        <p class="lede">@L["Internal conversations between OMP users."]</p>
    </div>
    @if (Model.CanUseMessages)
    {
        <div class="toolbar">
            <a class="action-link" asp-page="/Messages/New">@L["New conversation"]</a>
        </div>
    }
</section>

@if (!Model.CanUseMessages)
{
    <section class="card top-gap">
        <div class="empty-state">@(Model.MessagesDisabled ? L["Messages are disabled"].Value : L["Messages require an OMP user"].Value)</div>
    </section>
}
else if (Model.Rows.Count == 0)
{
    <section class="card top-gap">
        <div class="empty-state">@L["No conversations"]</div>
    </section>
}
else
{
    <section class="card top-gap portal-messages-list">
        @foreach (var row in Model.Rows)
        {
            var avatarUrl = OmpAvatarHelper.BuildUserAvatarPath(row.OtherUserId, row.OtherProfileImageStorageKey);
            <a class="portal-messages-list__row@(row.UnreadCount > 0 ? " is-unread" : string.Empty)"
               asp-page="/Messages/Thread"
               asp-route-conversationId="@row.ConversationId">
                <span class="portal-messages-list__avatar" aria-hidden="true">
                    @if (!string.IsNullOrWhiteSpace(avatarUrl))
                    {
                        <img src="@avatarUrl" alt="" />
                    }
                    else
                    {
                        @OmpAvatarHelper.GetInitials(row.DisplayTitle)
                    }
                </span>
                <span class="portal-messages-list__copy">
                    <span class="portal-messages-list__title">
                        @row.DisplayTitle
                        @if (row.UnreadCount > 0)
                        {
                            <span class="portal-messages-list__badge">@row.UnreadCount</span>
                        }
                    </span>
                    <span class="portal-messages-list__preview">@(row.LastMessagePreview ?? L["No messages"].Value)</span>
                    @if (row.LastMessageAt.HasValue)
                    {
                        <span class="portal-messages-list__meta">@row.LastMessageAt.Value.ToLocalTime().ToString("g", System.Globalization.CultureInfo.CurrentCulture)</span>
                    }
                </span>
            </a>
        }
    </section>
}
</div>

@section Scripts {
    <script>
        (() => {
            const PUSH_EVENT_NAME = 'omp:push-event';
            const MESSAGE_PUSH_CATEGORY = 'topbar.message-state-changed';
            const REFRESH_DEBOUNCE_MS = 250;

            let refreshTimer = 0;
            let refreshRunning = false;
            let pendingRefresh = false;

            const isPushMode = () => {
                const topbar = document.querySelector('[data-portal-topbar-root]');
                return (topbar?.getAttribute('data-notification-update-mode') || '').toLowerCase() === 'push';
            };

            const replaceLiveContent = (html) => {
                const current = document.querySelector('[data-messages-live-content]');
                if (!current) {
                    return false;
                }

                const template = document.createElement('template');
                template.innerHTML = (html || '').trim();
                const next = template.content.querySelector('[data-messages-live-content]');
                if (!next) {
                    return false;
                }

                current.replaceWith(next);
                return true;
            };

            const refresh = async () => {
                if (refreshRunning) {
                    pendingRefresh = true;
                    return;
                }

                refreshRunning = true;
                try {
                    const response = await fetch(window.location.href, {
                        method: 'GET',
                        credentials: 'same-origin',
                        cache: 'no-store',
                        headers: {
                            'Accept': 'text/html',
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });

                    if (!response.ok) {
                        return;
                    }

                    replaceLiveContent(await response.text());
                } catch (error) {
                    if (window.console && typeof window.console.warn === 'function') {
                        window.console.warn('OMP messages page refresh failed.', error);
                    }
                } finally {
                    refreshRunning = false;
                    if (pendingRefresh) {
                        pendingRefresh = false;
                        scheduleRefresh(REFRESH_DEBOUNCE_MS);
                    }
                }
            };

            function scheduleRefresh(delay) {
                if (refreshTimer) {
                    window.clearTimeout(refreshTimer);
                }

                refreshTimer = window.setTimeout(() => {
                    refreshTimer = 0;
                    refresh();
                }, Math.max(0, delay));
            }

            window.addEventListener(PUSH_EVENT_NAME, (event) => {
                const detail = event?.detail || {};
                const category = (detail.category || detail.envelope?.category || '').toString().toLowerCase();
                if (category === MESSAGE_PUSH_CATEGORY && isPushMode()) {
                    scheduleRefresh(REFRESH_DEBOUNCE_MS);
                }
            });
        })();
    </script>
}
