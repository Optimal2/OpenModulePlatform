@page
@model OpenModulePlatform.Portal.Pages.Account.SettingsModel
@{
    var ompBranding = await OmpBrandingService.GetBrandingAsync(ViewContext.HttpContext.RequestAborted);
}

<section class="page-header">
    <div>
        <div class="eyebrow">@L["Settings"]</div>
        <h2>@L["Settings"]</h2>
        <p class="lede">@ompBranding.ApplyPlatformName(L["Manage your OMP user profile and portal defaults."].Value)</p>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="card status-banner">@Model.StatusMessage</div>
}

@if (!ViewContext.ModelState.IsValid)
{
    <div class="card validation-summary-errors" asp-validation-summary="All"></div>
}

<nav class="settings-tabs" aria-label="@L["Settings"]">
    <a class="settings-tabs__link@(Model.IsActiveTab(SettingsModel.UserTab) ? " is-active" : string.Empty)"
       asp-page="/Account/Settings"
       asp-route-tab="@SettingsModel.UserTab">@L["User"]</a>
    @if (Model.HasOmpUser)
    {
        <a class="settings-tabs__link@(Model.IsActiveTab(SettingsModel.PortalTab) ? " is-active" : string.Empty)"
           asp-page="/Account/Settings"
           asp-route-tab="@SettingsModel.PortalTab">@ompBranding.PortalName</a>
        @if (Model.IsPortalAdmin)
        {
            <a class="settings-tabs__link@(Model.IsActiveTab(SettingsModel.AdminTab) ? " is-active" : string.Empty)"
               asp-page="/Account/Settings"
               asp-route-tab="@SettingsModel.AdminTab">@L["Admin"]</a>
        }
    }
</nav>

@if (Model.IsActiveTab(SettingsModel.UserTab))
{
    @if (Model.CanCreateOmpUser)
    {
        <form method="post" asp-page-handler="CreateAccount" class="card form-grid settings-panel">
            <h3>@ompBranding.ApplyPlatformName(L["Create your OMP account"].Value)</h3>
            <p class="lede">@ompBranding.ApplyPlatformName(L["You are signed in with Windows/AD, but this sign-in is not linked to an OMP user account yet."].Value)</p>
            <p>@ompBranding.ApplyPlatformName(L["Create an OMP account to save profile settings and link this AD sign-in to your account."].Value)</p>

            <div class="form-field">
                <label asp-for="UserInput.DisplayName">@L["Display name"]</label>
                <input asp-for="UserInput.DisplayName" maxlength="@OpenModulePlatform.Portal.Services.PortalUserSettingsService.DisplayNameMaxLength" />
                <span asp-validation-for="UserInput.DisplayName" class="field-validation-error"></span>
            </div>

            <div class="toolbar">
                <button type="submit">@ompBranding.ApplyPlatformName(L["Create OMP account"].Value)</button>
            </div>
        </form>
    }
    else if (!Model.HasOmpUser)
    {
        <section class="card form-grid settings-panel">
            <h3>@ompBranding.ApplyPlatformName(L["OMP account creation is disabled."].Value)</h3>
            <p class="lede">@ompBranding.ApplyPlatformName(L["You are signed in with Windows/AD, but creating your own OMP account is disabled for this installation."].Value)</p>
        </section>
    }
    else
    {
        <form method="post" asp-page-handler="User" class="card form-grid settings-panel">
            <div class="form-field">
                <label asp-for="UserInput.DisplayName">@L["Display name"]</label>
                <input asp-for="UserInput.DisplayName" maxlength="@OpenModulePlatform.Portal.Services.PortalUserSettingsService.DisplayNameMaxLength" />
                <span asp-validation-for="UserInput.DisplayName" class="field-validation-error"></span>
            </div>

            <div class="toolbar">
                <button type="submit">@L["Save"]</button>
            </div>
        </form>

        <section class="card form-grid settings-panel settings-profile-image">
            <h3>@L["Profile image"]</h3>
            <div class="settings-profile-image__preview">
                @if (!string.IsNullOrWhiteSpace(Model.ProfileImageUrl))
                {
                    <img src="@Model.ProfileImageUrl" alt="" />
                }
                else
                {
                    <span aria-hidden="true">@Model.ProfileImageInitials</span>
                }
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.ProfileImageFileName))
            {
                <p class="muted">@Model.ProfileImageFileName</p>
            }
            <p class="muted">@L["Use a PNG, JPEG, or WebP image up to 2 MB."]</p>

            <form method="post" asp-page-handler="ProfileImage" enctype="multipart/form-data" class="settings-profile-image__form">
                <input type="hidden" asp-for="UserInput.DisplayName" />
                <div class="form-field">
                    <label asp-for="ProfileImageUpload">@L["Upload profile image"]</label>
                    <input asp-for="ProfileImageUpload" type="file" accept="image/png,image/jpeg,image/webp" />
                    <span asp-validation-for="ProfileImageUpload" class="field-validation-error"></span>
                </div>
                <div class="toolbar">
                    <button type="submit">@L["Save"]</button>
                </div>
            </form>

            @if (!string.IsNullOrWhiteSpace(Model.ProfileImageUrl))
            {
                <form method="post" asp-page-handler="RemoveProfileImage">
                    <div class="toolbar">
                        <button type="submit" class="btn btn-danger">@L["Remove profile image"]</button>
                    </div>
                </form>
            }
        </section>
    }
}
else if (Model.IsActiveTab(SettingsModel.PortalTab))
{
    <form method="post" asp-page-handler="Portal" class="card form-grid settings-panel">
        <h3>@ompBranding.PortalName</h3>
        <div class="form-field checkbox-row checkbox-row--boxed">
            <input asp-for="PortalInput.TopbarDropdownsOpenOnHover" type="checkbox" />
            <label for="PortalInput_TopbarDropdownsOpenOnHover">@L["Open topbar menus on hover"]</label>
        </div>
        <p class="muted">@L["When this is turned off, menus open only by click or keyboard shortcut."]</p>

        <div class="form-field checkbox-row checkbox-row--boxed">
            <input asp-for="PortalInput.ShowPortalNavbar" type="checkbox" />
            <label for="PortalInput_ShowPortalNavbar">@L["Show dashboard navbar"]</label>
        </div>
        <p class="muted">@L["When this is turned off, the dashboard navbar below the topbar is hidden."]</p>

        @if (Model.NotificationToastsGloballyEnabled)
        {
            <div class="form-field checkbox-row checkbox-row--boxed">
                <input asp-for="PortalInput.NotificationToastsMuted" type="checkbox" />
                <label for="PortalInput_NotificationToastsMuted">@L["Mute toast notifications"]</label>
            </div>
            <p class="muted">@L["When this is turned on, notification and message toasts are not shown."]</p>
        }

        <div class="toolbar">
            <button type="submit">@L["Save"]</button>
        </div>
    </form>

    <form method="post"
          asp-page-handler="ResetDashboard"
          class="card danger-zone"
          onsubmit="return confirm('@L["This resets your dashboard to the shared default layout. Continue?"]');">
        <h3>@L["Dashboard"]</h3>
        <p class="muted">@L["Reset to the shared default dashboard layout."]</p>
        <div class="toolbar">
            <button type="submit" class="btn btn-danger">@L["Reset to default"]</button>
        </div>
    </form>

    <form method="post"
          asp-page-handler="ClearDashboard"
          class="card danger-zone"
          onsubmit="return confirm('@L["This removes all widgets from your dashboard. Continue?"]');">
        <h3>@L["Dashboard"]</h3>
        <p class="muted">@L["Clear your dashboard and keep it empty until you add widgets again."]</p>
        <div class="toolbar">
            <button type="submit" class="btn btn-danger">@L["Clear dashboard"]</button>
        </div>
    </form>
}
else if (Model.IsPortalAdmin)
{
    <section class="card form-grid settings-panel">
        <h3>@L["Dashboard"]</h3>
        <p class="muted">@L["Default dashboard layout"]</p>

        <form method="post"
              asp-page-handler="SaveDefaultDashboard"
              onsubmit="return confirm('@L["This replaces the shared default dashboard layout with your current dashboard layout. Continue?"]');">
            <p>@L["Users without a personal dashboard layout use the shared default layout."]</p>
            <div class="toolbar">
                <button type="submit" class="btn btn-danger">@L["Save current layout as default"]</button>
            </div>
        </form>
    </section>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
