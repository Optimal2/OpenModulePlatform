@page
@model OpenModulePlatform.Portal.Pages.Admin.Users.IndexModel
@{
    var ompBranding = await OmpBrandingService.GetBrandingAsync(ViewContext.HttpContext.RequestAborted);
}

<section class="page-header">
    <div>
        <div class="eyebrow">@L["Security and access"]</div>
        <h2>@L["Users"]</h2>
        <p class="lede">@ompBranding.ApplyPlatformName(L["Manage OMP users and their authentication links. Users can exist before they are linked to an AD account."].Value)</p>
    </div>
    <div class="toolbar">
        <a class="action-link" href="~/admin/users/create">@L["Create user"]</a>
    </div>
</section>

@if (Model.Rows.Count == 0)
{
    <div class="card empty-state">@ompBranding.ApplyPlatformName(L["No OMP users have been created yet."].Value)</div>
}
else
{
    var authProviders = Model.Rows
        .SelectMany(r => r.AuthLinks)
        .Select(l => l.ProviderDisplayName)
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(p => p, StringComparer.OrdinalIgnoreCase)
        .ToList();

    <div class="toolbar top-gap">
        <details class="list-filter" data-list-filter="users-list">
            <summary class="btn btn-ghost">@L["Filter"]<span class="list-filter__count" data-filter-count hidden></span></summary>
            <div class="list-filter__menu">
                <fieldset class="list-filter__group" data-filter-group="status">
                    <legend>@L["Account status"]</legend>
                    <label class="list-filter__option"><input type="checkbox" data-filter-column="2" data-filter-equals="1" /> @L["Active"]</label>
                    <label class="list-filter__option"><input type="checkbox" data-filter-column="2" data-filter-equals="2" /> @L["Disabled"]</label>
                    <label class="list-filter__option"><input type="checkbox" data-filter-column="2" data-filter-equals="3" /> @L["Deleted/reserved"]</label>
                </fieldset>
                <fieldset class="list-filter__group" data-filter-group="authlinks">
                    <legend>@L["Auth links"]</legend>
                    @foreach (var provider in authProviders)
                    {
                        <label class="list-filter__option"><input type="checkbox" data-filter-column="4" data-filter-includes="@provider" /> @provider</label>
                    }
                    <label class="list-filter__option"><input type="checkbox" data-filter-column="4" data-filter-equals="none" /> @L["No auth links"]</label>
                </fieldset>
                <button type="button" class="btn btn-ghost btn-sm" data-filter-clear>@L["Clear filters"]</button>
            </div>
        </details>
        <input type="search" class="list-search" data-list-search="users-list" placeholder="@L["Search rows"]" aria-label="@L["Search rows"]" />
        <span class="list-count" data-list-count="users-list" data-template="@L["Showing {0} of {1} rows."]"></span>
    </div>
    <div class="empty-state" data-list-empty="users-list" hidden>@L["No rows match the current filters."]</div>
    <table id="users-list" class="grid sortable-list" data-sortable-list data-page-size="50">
        <thead>
            <tr>
                <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["Display name"]</button></th>
                <th scope="col" data-sort-type="number"><button type="button" class="sortable-list__button">@L["User ID"]</button></th>
                <th scope="col" data-sort-type="number"><button type="button" class="sortable-list__button">@L["Account status"]</button></th>
                <th scope="col" data-sort-type="date"><button type="button" class="sortable-list__button">@L["Last login UTC"]</button></th>
                <th scope="col">@L["Auth links"]</th>
                <th scope="col"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Model.Rows)
            {
                <tr>
                    <td>
                        <a href="~/admin/users/edit/@row.UserId">@row.DisplayName</a>
                    </td>
                    <td>@row.UserId</td>
                    <td data-sort-value="@row.AccountStatus"><span class="pill">@Model.AccountStatusText(row.AccountStatus)</span></td>
                    <td data-sort-value="@(row.LastLoginAt?.ToString("yyyy-MM-dd'T'HH:mm:ss'Z'", System.Globalization.CultureInfo.InvariantCulture) ?? "")">@Model.FormatUtc(row.LastLoginAt)</td>
                    <td data-sort-value="@(row.AuthLinks.Count == 0 ? "none" : string.Join(" ", row.AuthLinks.Select(l => l.ProviderDisplayName)))">
                        @if (row.AuthLinks.Count == 0)
                        {
                            <span class="muted">@L["No auth links"]</span>
                        }
                        else
                        {
                            @foreach (var link in row.AuthLinks)
                            {
                                <div><span class="example-token">@link.ProviderDisplayName</span> @link.ProviderUserKey <span class="pill">@link.AuthStatus</span></div>
                            }
                        }
                    </td>
                    <td class="admin-action-cell">
                        <a class="action-link admin-icon-button admin-icon-button--edit"
                           href="~/admin/users/edit/@row.UserId"
                           title="@L["Edit"]"
                           aria-label="@L["Edit"]">
                            <span class="visually-hidden">@L["Edit"]</span>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div class="list-show-more">
        <button type="button" class="btn btn-secondary btn-sm" data-list-show-more="users-list" hidden>@L["Show more"]</button>
    </div>
}
