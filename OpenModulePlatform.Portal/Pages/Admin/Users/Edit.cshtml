@page "{userId:int}"
@using OpenModulePlatform.Web.Shared.Navigation
@model OpenModulePlatform.Portal.Pages.Admin.Users.EditModel
@{
    var ompBranding = await OmpBrandingService.GetBrandingAsync(ViewContext.HttpContext.RequestAborted);

    const string StatusSectionId = "user-edit-status";
    const string DetailsSectionId = "user-edit-details";
    const string RolesSectionId = "user-edit-roles";
    const string PortalSettingsSectionId = "user-edit-portal-settings";
    const string AuthLinksSectionId = "user-edit-auth-links";
    const string LocalLoginSectionId = "user-edit-local-login";
    const string LinkAdSectionId = "user-edit-link-ad";

    var sectionNavigatorItems = new List<SectionNavigatorItem>();
    if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        sectionNavigatorItems.Add(new SectionNavigatorItem(L["Status"].Value, StatusSectionId));
    }

    if (Model.UserRow is not null)
    {
        sectionNavigatorItems.Add(new SectionNavigatorItem(L["User details"].Value, DetailsSectionId));
        sectionNavigatorItems.Add(new SectionNavigatorItem(L["Roles"].Value, RolesSectionId));
        sectionNavigatorItems.Add(new SectionNavigatorItem(ompBranding.ApplyTerms(L["Portal settings"].Value), PortalSettingsSectionId));
        sectionNavigatorItems.Add(new SectionNavigatorItem(L["Auth links"].Value, AuthLinksSectionId));
        sectionNavigatorItems.Add(new SectionNavigatorItem(L["Local login"].Value, LocalLoginSectionId));
        sectionNavigatorItems.Add(new SectionNavigatorItem(L["Link AD account"].Value, LinkAdSectionId));
    }

    var sectionNavigator = new SectionNavigatorModel
    {
        Label = L["Page sections"].Value,
        RootText = L["Edit user"].Value,
        Items = sectionNavigatorItems
    };
}

<div class="section-navigator-layout">
    <div class="section-navigator-layout__header">
        <section class="page-header">
            <div>
                <div class="eyebrow">@L["Security and access"]</div>
                <h2>@L["Edit user"]</h2>
                <p class="lede">@ompBranding.ApplyPlatformName(L["Update the OMP user record and link AD identities that Windows sign-in can resolve."].Value)</p>
            </div>
        </section>
    </div>

    @await Component.InvokeAsync("SectionNavigator", new { model = sectionNavigator })
    <div class="section-navigator-layout__content">

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div id="@StatusSectionId" class="card status-banner section-navigator-target">@Model.StatusMessage</div>
}

@if (!ViewContext.ModelState.IsValid)
{
    <div class="card validation-summary-errors" asp-validation-summary="All"></div>
}

@if (Model.UserRow is not null)
{
    <section id="@DetailsSectionId" class="card form-grid bottom-gap section-navigator-target">
        <div class="field-grid field-grid--3">
            <div class="form-field">
                <label>@L["User ID"]</label>
                <input value="@Model.UserRow.UserId" readonly />
            </div>
            <div class="form-field">
                <label>@L["Created UTC"]</label>
                <input value="@Model.FormatUtc(Model.UserRow.CreatedAt)" readonly />
            </div>
            <div class="form-field">
                <label>@L["Updated UTC"]</label>
                <input value="@Model.FormatUtc(Model.UserRow.UpdatedAt)" readonly />
            </div>
        </div>
        <div class="field-grid field-grid--2">
            <div class="form-field">
                <label>@L["Last login UTC"]</label>
                <input value="@Model.FormatUtc(Model.UserRow.LastLoginAt)" readonly />
            </div>
            <div class="form-field">
                <label>@L["Current account status"]</label>
                <input value="@Model.AccountStatusText(Model.UserRow.AccountStatus)" readonly />
            </div>
        </div>
    </section>

    <form method="post" class="card form-grid bottom-gap">
        <input type="hidden" asp-for="Input.UserId" />

        <div class="field-grid field-grid--2">
            <div class="form-field">
                <label asp-for="Input.DisplayName"></label>
                <input asp-for="Input.DisplayName" />
                <span asp-validation-for="Input.DisplayName" class="field-validation-error"></span>
            </div>

            <div class="form-field">
                <label asp-for="Input.AccountStatus"></label>
                <select asp-for="Input.AccountStatus">
                    @foreach (var option in Model.AccountStatusOptions)
                    {
                        <option value="@option.Value">@option.Label</option>
                    }
                </select>
                <span asp-validation-for="Input.AccountStatus" class="field-validation-error"></span>
            </div>
        </div>

        <div class="toolbar">
            <button type="submit">@L["Save user"]</button>
            <a class="action-link" href="~/admin/users">@L["Back to users"]</a>
        </div>
    </form>

    <section id="@RolesSectionId" class="card section-card bottom-gap section-navigator-target">
        <div class="eyebrow">@L["Security and access"]</div>
        <h3>@L["Roles"]</h3>
        <p class="muted">@ompBranding.ApplyPlatformName(L["Roles assigned directly to this OMP user or to one of its linked AD accounts are shown here."].Value)</p>

        @if (Model.UserRow.Roles.Count == 0)
        {
            <div class="empty-state top-gap">@L["No roles are assigned directly to this user."]</div>
        }
        else
        {
            <table class="grid compact-grid">
                <thead>
                    <tr>
                        <th>@L["Role"]</th>
                        <th>@L["Source"]</th>
                        <th>@L["Principal"]</th>
                        <th>@L["Description"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var role in Model.UserRow.Roles)
                    {
                        <tr>
                            <td>
                                <a href="~/admin/security/role?roleId=@role.RoleId">@role.Name</a>
                            </td>
                            <td>@Model.RoleSourceText(role)</td>
                            <td><code>@role.Principal</code></td>
                            <td>@(string.IsNullOrWhiteSpace(role.Description) ? L["None"] : role.Description)</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>

    <section id="@PortalSettingsSectionId" class="card section-card bottom-gap section-navigator-target">
        <div class="eyebrow">@ompBranding.PortalName</div>
        <h3>@ompBranding.ApplyTerms(L["Portal settings"].Value)</h3>
        <p class="muted">@ompBranding.ApplyTerms(L["Portal setting definitions are installed by the Portal. This page stores only values that override defaults for this user."].Value)</p>

        @{
            var selectedPortalSetting = Model.SelectedPortalSettingDefinition;
        }

        <form method="post" asp-page-handler="SavePortalSetting" class="form-grid">
            <input type="hidden" asp-for="PortalSettingInput.OriginalUserSettingDefinitionId" />
            <input type="hidden" asp-for="PortalSettingInput.ValueKind" />

            <div class="field-grid field-grid--2">
                @if (Model.IsPortalSettingEdit)
                {
                    <input type="hidden" asp-for="PortalSettingInput.UserSettingDefinitionId" />
                    <div class="form-field">
                        <label>@ompBranding.ApplyTerms(L["Portal setting"].Value)</label>
                        <input value="@(selectedPortalSetting?.Key ?? string.Empty)" readonly />
                    </div>
                }
                else
                {
                    <div class="form-field">
                        <label asp-for="PortalSettingInput.UserSettingDefinitionId">@ompBranding.ApplyTerms(L["Portal setting"].Value)</label>
                        <select asp-for="PortalSettingInput.UserSettingDefinitionId">
                            <option value="">@L["Select portal setting"]</option>
                            @foreach (var option in Model.PortalSettingOptions)
                            {
                                <option value="@option.Value">@option.Label</option>
                            }
                        </select>
                        <span asp-validation-for="PortalSettingInput.UserSettingDefinitionId" class="field-validation-error"></span>
                    </div>
                }

                <div class="form-field">
                    <label>@L["Default value"]</label>
                    <input value="@(selectedPortalSetting is null ? string.Empty : Model.PortalSettingDefaultText(selectedPortalSetting))" readonly />
                </div>
            </div>

            <div class="form-field">
                <label asp-for="PortalSettingInput.SettingValue"></label>
                <textarea asp-for="PortalSettingInput.SettingValue" rows="3"></textarea>
                <span asp-validation-for="PortalSettingInput.SettingValue" class="field-validation-error"></span>
                <small>@L["Use an integer for int-backed settings. Use text for string-backed settings. Saving the default value removes the user override."]</small>
            </div>

            <div class="toolbar">
                <button type="submit">@(Model.IsPortalSettingEdit ? L["Save portal setting"] : L["Add portal setting"])</button>
                @if (Model.IsPortalSettingEdit)
                {
                    <a class="action-link" href="~/admin/users/edit/@Model.UserRow.UserId">@L["Cancel edit"]</a>
                }
            </div>
        </form>

        <h4 class="top-gap">@L["Configured portal setting values"]</h4>

        @if (Model.PortalSettingRows.Count == 0)
        {
            <div class="empty-state top-gap">@L["No portal setting values have been configured for this user."]</div>
        }
        else
        {
            <table class="grid compact-grid">
                <thead>
                    <tr>
                        <th>@L["Setting"]</th>
                        <th>@L["Type"]</th>
                        <th>@L["Default value"]</th>
                        <th>@L["User value"]</th>
                        <th>@L["Updated UTC"]</th>
                        <th>@L["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var setting in Model.PortalSettingRows)
                    {
                        <tr>
                            <td>
                                <strong>@setting.Key</strong>
                                @if (!string.IsNullOrWhiteSpace(setting.Description))
                                {
                                    <br />
                                    <span class="muted">@setting.Description</span>
                                }
                            </td>
                            <td>@Model.PortalSettingValueKindText(setting.ValueKind)</td>
                            <td>@Model.PortalSettingDefaultText(setting)</td>
                            <td><code>@Model.PortalSettingValueText(setting)</code></td>
                            <td>@Model.FormatUtc(setting.UpdatedAt)</td>
                            <td>
                                <div class="toolbar compact-toolbar">
                                    <a class="action-link" href="~/admin/users/edit/@Model.UserRow.UserId?portalSettingDefinitionId=@setting.UserSettingDefinitionId">@L["Edit"]</a>
                                    <form method="post" asp-page-handler="DeletePortalSetting" asp-route-userSettingDefinitionId="@setting.UserSettingDefinitionId" class="inline-form">
                                        <button type="submit" class="btn-danger-subtle" onclick="return confirm('@L["Delete this portal setting value?"]');">@L["Delete"]</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>

    <section id="@AuthLinksSectionId" class="card section-card bottom-gap section-navigator-target">
        <div class="eyebrow">@L["Authentication"]</div>
        <h3>@L["Auth links"]</h3>
        <p class="muted">@ompBranding.ApplyPlatformName(L["These provider identities are linked to this OMP user. Removing all links prevents sign-in until another link is added."].Value)</p>

        @if (Model.UserRow.AuthLinks.Count == 0)
        {
            <div class="empty-state top-gap">@ompBranding.ApplyPlatformName(L["This OMP user has no auth links."].Value)</div>
        }
        else
        {
            <table class="grid compact-grid">
                <thead>
                    <tr>
                        <th>@L["Provider"]</th>
                        <th>@L["Provider user key"]</th>
                        <th>@L["Status"]</th>
                        <th>@L["Created UTC"]</th>
                        <th>@L["Last used UTC"]</th>
                        <th>@L["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var link in Model.UserRow.AuthLinks)
                    {
                        <tr>
                            <td>@link.ProviderDisplayName</td>
                            <td>@link.ProviderUserKey</td>
                            <td><span class="pill">@link.AuthStatus</span></td>
                            <td>@Model.FormatUtc(link.CreatedAt)</td>
                            <td>@Model.FormatUtc(link.LastUsedAt)</td>
                            <td>
                                <form method="post" asp-page-handler="RemoveAuthLink" class="inline-form">
                                    <input type="hidden" name="userAuthId" value="@link.UserAuthId" />
                                    <button type="submit" class="btn-danger-subtle">@L["Remove link"]</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        @if (Model.HasAdAuthLink)
        {
            <div class="top-gap">
                <h4>@L["AD rights migration"]</h4>

                @if (Model.UserRow.MigratableAdUserRoleAssignmentCount > 0)
                {
                    <p class="muted">
                        @string.Format(
                            System.Globalization.CultureInfo.CurrentCulture,
                            ompBranding.ApplyPlatformName(L["There are {0} direct AD-user role assignments that can be moved to this OMP user."].Value),
                            Model.UserRow.MigratableAdUserRoleAssignmentCount)
                    </p>
                    <form method="post" asp-page-handler="MigrateAdRights" class="inline-form">
                        <button type="submit">@ompBranding.ApplyPlatformName(L["Move AD rights to OMP user"].Value)</button>
                    </form>
                }
                else
                {
                    <div class="empty-state top-gap">@L["No direct AD-user rights are available to move."]</div>
                }
            </div>
        }

        <div class="top-gap">
            <h4>@L["Repair duplicate ADFS user"]</h4>
            <p class="muted">@L["Preview a duplicate ADFS-created user repair before making changes. The repair moves enabled ADFS auth links to the target user, disables this duplicate user, and does not move user-owned content."]</p>

            <form method="post" asp-page-handler="PreviewMergeAdfsDuplicate" class="form-grid">
                <div class="field-grid field-grid--2">
                    <div class="form-field">
                        <label asp-for="MergeAdfsDuplicate.TargetUserId">@L["Target user ID to keep"]</label>
                        <input asp-for="MergeAdfsDuplicate.TargetUserId" type="number" min="1" autocomplete="off" />
                        <span asp-validation-for="MergeAdfsDuplicate.TargetUserId" class="field-validation-error"></span>
                        <small>@L["This page's user is treated as the duplicate user that will be disabled if the repair succeeds."]</small>
                    </div>
                </div>

                <div class="toolbar">
                    <button type="submit">@L["Preview ADFS repair"]</button>
                </div>
            </form>

            @if (Model.MergeAdfsDuplicatePreview is { } preview)
            {
                <div class="status-banner top-gap">
                    <strong>@Model.MergeAdfsDuplicateStatusText(preview.Status)</strong>
                    <div class="muted">
                        @string.Format(
                            System.Globalization.CultureInfo.CurrentCulture,
                            L["{0} ADFS auth link(s) can move. {1} auth link(s) will remain on the duplicate user."].Value,
                            preview.AdfsLinksToMove.Count,
                            preview.SkippedAuthLinkCount)
                    </div>
                </div>

                <div class="field-grid field-grid--2 top-gap">
                    <div class="form-field">
                        <label>@L["Target user"]</label>
                        <input value="@Model.MergeUserSummaryText(preview.TargetUser)" readonly />
                    </div>
                    <div class="form-field">
                        <label>@L["Duplicate user"]</label>
                        <input value="@Model.MergeUserSummaryText(preview.DuplicateUser)" readonly />
                    </div>
                </div>

                <h5 class="top-gap">@L["ADFS auth links to move"]</h5>
                @if (preview.AdfsLinksToMove.Count == 0)
                {
                    <div class="empty-state top-gap">@L["No enabled ADFS auth links can be moved."]</div>
                }
                else
                {
                    <table class="grid compact-grid">
                        <thead>
                            <tr>
                                <th>@L["Provider"]</th>
                                <th>@L["Provider user key"]</th>
                                <th>@L["Status"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var link in preview.AdfsLinksToMove)
                            {
                                <tr>
                                    <td>@link.ProviderDisplayName</td>
                                    <td>@link.ProviderUserKey</td>
                                    <td><span class="pill">@link.AuthStatus</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }

                @if (preview.DuplicateNonAdfsLinks.Count > 0)
                {
                    <h5 class="top-gap">@L["Enabled non-ADFS links blocking repair"]</h5>
                    <p class="muted">@L["These enabled links would remain on the duplicate account. The first repair flow blocks this case so sign-ins are not stranded silently."]</p>
                    <table class="grid compact-grid">
                        <thead>
                            <tr>
                                <th>@L["Provider"]</th>
                                <th>@L["Provider user key"]</th>
                                <th>@L["Status"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var link in preview.DuplicateNonAdfsLinks)
                            {
                                <tr>
                                    <td>@link.ProviderDisplayName</td>
                                    <td>@link.ProviderUserKey</td>
                                    <td><span class="pill">@link.AuthStatus</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }

                @if (preview.DisabledOrDeletedAdfsLinksIgnored.Count > 0)
                {
                    <h5 class="top-gap">@L["Disabled or deleted ADFS links ignored"]</h5>
                    <table class="grid compact-grid">
                        <thead>
                            <tr>
                                <th>@L["Provider"]</th>
                                <th>@L["Provider user key"]</th>
                                <th>@L["Status"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var link in preview.DisabledOrDeletedAdfsLinksIgnored)
                            {
                                <tr>
                                    <td>@link.ProviderDisplayName</td>
                                    <td>@link.ProviderUserKey</td>
                                    <td><span class="pill">@link.AuthStatus</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }

                @if (preview.CanMerge)
                {
                    <form method="post" asp-page-handler="MergeAdfsDuplicate" class="form-grid top-gap">
                        <input type="hidden" asp-for="MergeAdfsDuplicate.TargetUserId" />
                        <label class="checkbox-row">
                            <input asp-for="MergeAdfsDuplicate.ConfirmRepair" type="checkbox" />
                            <span>@L["Move ADFS links to target user and disable this duplicate user. User-owned content will not move."]</span>
                        </label>
                        <span asp-validation-for="MergeAdfsDuplicate.ConfirmRepair" class="field-validation-error"></span>

                        <div class="toolbar">
                            <button type="submit" class="btn-danger-subtle">@L["Run ADFS repair"]</button>
                        </div>
                    </form>
                }
            }
        </div>
    </section>

    <section id="@LocalLoginSectionId" class="card section-card bottom-gap section-navigator-target">
        <div class="eyebrow">@L["Authentication"]</div>
        <h3>@L["Local login"]</h3>

        @if (Model.HasLocalPasswordLogin)
        {
            <p class="muted">
                @L["Local login"]:
                <span class="example-token">@Model.LocalPasswordUserName</span>
            </p>

            <form method="post" asp-page-handler="ResetLocalPassword" class="form-grid">
                <div class="field-grid field-grid--2">
                    <div class="form-field">
                        <label asp-for="LocalPasswordReset.Password"></label>
                        <input asp-for="LocalPasswordReset.Password" type="password" value="" autocomplete="new-password" />
                        <span asp-validation-for="LocalPasswordReset.Password" class="field-validation-error"></span>
                    </div>

                    <div class="form-field">
                        <label asp-for="LocalPasswordReset.ConfirmPassword"></label>
                        <input asp-for="LocalPasswordReset.ConfirmPassword" type="password" value="" autocomplete="new-password" />
                        <span asp-validation-for="LocalPasswordReset.ConfirmPassword" class="field-validation-error"></span>
                    </div>
                </div>

                <div class="toolbar">
                    <button type="submit">@L["Reset local password"]</button>
                </div>
            </form>
        }
        else
        {
            <p class="muted">@ompBranding.ApplyPlatformName(L["Add a local password login linked to this OMP user."].Value)</p>

            <form method="post" asp-page-handler="AddLocalLogin" class="form-grid">
                <div class="field-grid field-grid--3">
                    <div class="form-field">
                        <label asp-for="LocalLogin.UserName"></label>
                        <input asp-for="LocalLogin.UserName" autocomplete="off" />
                        <span asp-validation-for="LocalLogin.UserName" class="field-validation-error"></span>
                    </div>

                    <div class="form-field">
                        <label asp-for="LocalLogin.Password"></label>
                        <input asp-for="LocalLogin.Password" type="password" value="" autocomplete="new-password" />
                        <span asp-validation-for="LocalLogin.Password" class="field-validation-error"></span>
                    </div>

                    <div class="form-field">
                        <label asp-for="LocalLogin.ConfirmPassword"></label>
                        <input asp-for="LocalLogin.ConfirmPassword" type="password" value="" autocomplete="new-password" />
                        <span asp-validation-for="LocalLogin.ConfirmPassword" class="field-validation-error"></span>
                    </div>
                </div>

                <div class="toolbar">
                    <button type="submit">@L["Add local login"]</button>
                </div>
            </form>
        }
    </section>

    <form id="@LinkAdSectionId" method="post" asp-page-handler="LinkAdAccount" class="card form-grid section-navigator-target">
        <div class="eyebrow">@L["Authentication"]</div>
        <h3>@L["Link AD account"]</h3>
        <p class="muted">@L["Use the same AD key format that Windows sign-in resolves, for example DOMAIN\\username, name:DOMAIN\\username or sid:S-1-5-21-..."]</p>

        <div class="field-grid field-grid--2">
            <div class="form-field">
                <label asp-for="NewAdProviderUserKey">@L["AD provider user key"]</label>
                <input asp-for="NewAdProviderUserKey" autocomplete="off" />
                <span asp-validation-for="NewAdProviderUserKey" class="field-validation-error"></span>
            </div>
        </div>

        <div class="toolbar">
            <button type="submit">@L["Link AD account"]</button>
        </div>
    </form>
}

    </div>
</div>
