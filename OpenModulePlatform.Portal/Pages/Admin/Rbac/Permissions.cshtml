@page
@model OpenModulePlatform.Portal.Pages.Admin.Rbac.PermissionsModel

<h2>Permissions</h2>

<table class="grid">
    <thead><tr><th>Name</th><th>Description</th></tr></thead>
    <tbody>
    @foreach (var row in Model.Rows)
    {
        <tr>
            <td>@(row.Name)</td>
            <td>@(row.Description)</td>
        </tr>
    }
    </tbody>
</table>
