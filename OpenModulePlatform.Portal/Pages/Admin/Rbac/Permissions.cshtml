@page
@model OpenModulePlatform.Portal.Pages.Admin.Rbac.PermissionsModel

<section class="page-header">
    <div>
        <div class="eyebrow">Security and access</div>
        <h2>Permissions</h2>
        <p class="lede">
            Permissions are low-level capability names.
            Keep them stable and descriptive so roles remain understandable.
        </p>
    </div>
    <div class="toolbar">
        <a class="action-link" href="~/admin/rbac/permissionedit">Create permission</a>
    </div>
</section>

@if (Model.Rows.Count == 0)
{
    <div class="card empty-state">No permissions have been created yet.</div>
}
else
{
    <table class="grid">
        <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Used by roles</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Model.Rows)
            {
                <tr>
                    <td>@row.Name</td>
                    <td>@row.Description</td>
                    <td><span class="pill">@row.RoleCount</span></td>
                    <td>
                        <a class="action-link" href="~/admin/rbac/permissionedit?id=@row.PermissionId">Edit</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
