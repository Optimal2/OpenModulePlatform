@page
@model OpenModulePlatform.Portal.Pages.Admin.Rbac.PermissionsModel

<section class="page-header">
    <div>
        <div class="eyebrow">@L["Security and access"]</div>
        <h2>@L["Permissions"]</h2>
        <p class="lede">@L["Permissions are low-level capability names. Keep them stable and descriptive so roles remain understandable."]</p>
    </div>
    <div class="toolbar">
        <a class="action-link" href="~/admin/security/permissionedit">@L["Create permission"]</a>
    </div>
</section>

@if (Model.Rows.Count == 0)
{
    <div class="card empty-state">@L["No permissions have been created yet."]</div>
}
else
{
    <div class="toolbar top-gap">
        <input type="search" class="list-search" data-list-search="permissions-list" placeholder="@L["Search rows"]" aria-label="@L["Search rows"]" />
        <span class="list-count" data-list-count="permissions-list" data-template="@L["Showing {0} of {1} rows."]"></span>
    </div>
    <div class="empty-state" data-list-empty="permissions-list" hidden>@L["No rows match the current filters."]</div>
    <table id="permissions-list" class="grid sortable-list" data-sortable-list data-page-size="50">
        <thead>
            <tr>
                <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["Name"]</button></th>
                <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["Description"]</button></th>
                <th scope="col" data-sort-type="number"><button type="button" class="sortable-list__button">@L["Used by roles"]</button></th>
                <th scope="col"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Model.Rows)
            {
                <tr>
                    <td>@row.Name</td>
                    <td>@row.Description</td>
                    <td><span class="pill">@row.RoleCount</span></td>
                    <td class="admin-action-cell">
                        <a class="action-link admin-icon-button admin-icon-button--edit"
                           href="~/admin/security/permissionedit?id=@row.PermissionId"
                           title="@L["Edit"]"
                           aria-label="@L["Edit"]">
                            <span class="visually-hidden">@L["Edit"]</span>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div class="list-show-more">
        <button type="button" class="btn btn-secondary btn-sm" data-list-show-more="permissions-list" hidden>@L["Show more"]</button>
    </div>
}
