@page
@model OpenModulePlatform.Portal.Pages.Admin.Rbac.RoleModel
@{
    var ompBranding = await OmpBrandingService.GetBrandingAsync(ViewContext.HttpContext.RequestAborted);
}

<section class="page-header">
    <div>
        <div class="eyebrow">@L["Security and access"]</div>
        <h2>@(Model.IsCreate ? L["Create role"] : L["Edit role"])</h2>
        <p class="lede">@L["Roles are the main RBAC editing surface. Add permissions and principals here so access remains grouped and auditable."]</p>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="card status-banner">@Model.StatusMessage</div>
}

@if (!ViewContext.ModelState.IsValid)
{
    <div class="card validation-summary-errors" asp-validation-summary="All"></div>
}

<form method="post" class="card form-grid bottom-gap" id="role-details-form">
    <input type="hidden" asp-for="Input.RoleId" />
    <input type="hidden" asp-for="ReturnUrl" />

    <div class="field-grid field-grid--2">
        <div class="form-field">
            <label asp-for="Input.Name"></label>
            <input asp-for="Input.Name" data-original-value="@Model.OriginalName" />
            <div class="field-help">
                @L["Use a stable role name, for example"]
                <span class="example-token">PortalAdmins</span>
                <span class="muted">/</span> <span class="example-token">ExampleServiceAppModule.Operators</span>.
            </div>
            <span asp-validation-for="Input.Name" class="field-validation-error"></span>
        </div>

        <div class="form-field">
            <label asp-for="Input.Description"></label>
            <input asp-for="Input.Description" data-original-value="@Model.OriginalDescription" />
            <div class="field-help">@L["Short explanation of who should receive this role."]</div>
            <span asp-validation-for="Input.Description" class="field-validation-error"></span>
        </div>
    </div>

    <div class="toolbar">
        <button type="submit" id="save-role-button" class="btn btn-primary" disabled>@L["Save role"]</button>
        <a class="action-link" href="~/admin/security/roles">@L["Back to roles"]</a>
    </div>
</form>

<dialog id="unsaved-role-dialog" class="unsaved-dialog">
    <form method="dialog" class="unsaved-dialog__body">
        <h3>@L["Unsaved changes"]</h3>
        <p class="muted">@L["You have unsaved changes to the role name or description."]</p>
        <div class="toolbar">
            <button type="button" id="unsaved-save-button" class="btn btn-primary">@L["Save changes"]</button>
            <button type="button" id="unsaved-discard-button" class="btn">@L["Discard changes"]</button>
            <button type="button" id="unsaved-stay-button" class="btn">@L["Stay on page"]</button>
        </div>
    </form>
</dialog>

<script>
    (() => {
        const form = document.getElementById('role-details-form');
        const saveButton = document.getElementById('save-role-button');
        const roleNameInput = document.getElementById('Input_Name');
        const roleDescriptionInput = document.getElementById('Input_Description');
        const returnUrlInput = document.getElementById('ReturnUrl');
        const dialog = document.getElementById('unsaved-role-dialog');
        const saveAndLeaveButton = document.getElementById('unsaved-save-button');
        const discardButton = document.getElementById('unsaved-discard-button');
        const stayButton = document.getElementById('unsaved-stay-button');

        if (!form || !saveButton || !roleNameInput || !roleDescriptionInput || !returnUrlInput) {
            return;
        }

        const trackedInputs = [roleNameInput, roleDescriptionInput];
        const initialValues = trackedInputs.map(input => input.dataset.originalValue ?? '');
        let isDirty = false;
        let allowUnloadPrompt = true;
        let pendingUrl = null;

        function updateDirtyState() {
            isDirty = trackedInputs.some((input, index) => (input.value ?? '') !== initialValues[index]);
            saveButton.disabled = !isDirty;
            saveButton.setAttribute('aria-disabled', String(!isDirty));
        }

        function isModifiedClick(event) {
            return event.metaKey || event.ctrlKey || event.shiftKey || event.altKey || event.button !== 0;
        }

        function shouldInterceptNavigation(anchor) {
            if (!anchor || !anchor.href) {
                return false;
            }

            if (anchor.target && anchor.target !== '_self') {
                return false;
            }

            const href = anchor.getAttribute('href');
            if (!href || href.startsWith('#')) {
                return false;
            }

            const targetUrl = new URL(anchor.href, window.location.origin);
            return targetUrl.origin === window.location.origin;
        }

        trackedInputs.forEach(input => input.addEventListener('input', updateDirtyState));

        form.addEventListener('submit', () => {
            allowUnloadPrompt = false;
        });

        document.addEventListener('click', event => {
            const anchor = event.target.closest('a');
            if (!anchor || isModifiedClick(event) || !isDirty || !shouldInterceptNavigation(anchor)) {
                return;
            }

            event.preventDefault();
            pendingUrl = anchor.href;

            if (dialog && typeof dialog.showModal === 'function') {
                dialog.showModal();
                return;
            }

            const discard = window.confirm('@L["You have unsaved role changes. Press OK to discard them and leave this page, or Cancel to stay."]');
            if (discard) {
                allowUnloadPrompt = false;
                window.location.href = pendingUrl;
            }
        });

        window.addEventListener('beforeunload', event => {
            if (!isDirty || !allowUnloadPrompt) {
                return;
            }

            event.preventDefault();
            event.returnValue = '';
        });

        if (saveAndLeaveButton) {
            saveAndLeaveButton.addEventListener('click', () => {
                if (!pendingUrl) {
                    dialog?.close();
                    return;
                }

                returnUrlInput.value = pendingUrl;
                allowUnloadPrompt = false;
                dialog?.close();
                form.requestSubmit();
            });
        }

        if (discardButton) {
            discardButton.addEventListener('click', () => {
                if (!pendingUrl) {
                    dialog?.close();
                    return;
                }

                allowUnloadPrompt = false;
                const targetUrl = pendingUrl;
                dialog?.close();
                window.location.href = targetUrl;
            });
        }

        if (stayButton) {
            stayButton.addEventListener('click', () => {
                pendingUrl = null;
                dialog?.close();
            });
        }

        dialog?.addEventListener('cancel', () => {
            pendingUrl = null;
        });

        updateDirtyState();
    })();
</script>

@if (!Model.IsCreate)
{
    <div class="section-grid section-grid--wide bottom-gap">
        <section class="card section-card">
            <div class="eyebrow">@L["Role administration"]</div>
            <h3>@L["Assigned permissions"]</h3>
            <p class="muted">
                @L["These permissions are granted whenever the role is resolved for a user or service identity."]
            </p>

            @if (Model.Permissions.Count == 0)
            {
                <div class="empty-state top-gap">@L["No permissions assigned yet."]</div>
            }
            else
            {
                <table class="grid compact-grid">
                    <thead>
                        <tr>
                            <th>@L["Permission"]</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Permissions)
                        {
                            <tr>
                                <td>@row.PermissionName</td>
                                <td>
                                    <form method="post" asp-page-handler="RemovePermission" class="inline-form">
                                        <input type="hidden" name="Input.RoleId" value="@Model.Input.RoleId" />
                                        <input type="hidden" name="permissionId" value="@row.PermissionId" />
                                        <button type="submit" class="btn btn-danger-subtle">@L["Remove"]</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

            <form method="post" asp-page-handler="AddPermission" class="top-gap form-grid-inline">
                <input type="hidden" name="Input.RoleId" value="@Model.Input.RoleId" />
                <div class="form-field grow">
                    <label for="permissionId">@L["Add permission"]</label>
                    <select id="permissionId" name="permissionId">
                        <option value="">@L["Select permission"]</option>
                        @foreach (var option in Model.AvailablePermissionOptions)
                        {
                            <option value="@option.Value">@option.Label</option>
                        }
                    </select>
                </div>
                <div class="form-field actions">
                    <button type="submit">@L["Add permission"]</button>
                </div>
            </form>
        </section>

        <section class="card section-card">
            <div class="eyebrow">@L["Principals"]</div>
            <h3>@L["Assigned principals"]</h3>
            <p class="muted">@ompBranding.ApplyPlatformName(L["Bind OMP users, AD users or AD groups to the role."].Value)</p>

            @if (Model.Principals.Count == 0)
            {
                <div class="empty-state top-gap">@L["No principals assigned yet."]</div>
            }
            else
            {
                <table class="grid compact-grid">
                    <thead>
                        <tr>
                            <th>@L["Type"]</th>
                            <th>@L["Principal"]</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Principals)
                        {
                            <tr>
                                <td>@L[row.PrincipalType]</td>
                                <td>@row.DisplayPrincipal</td>
                                <td>
                                    <form method="post" asp-page-handler="RemovePrincipal" class="inline-form">
                                        <input type="hidden" name="Input.RoleId" value="@Model.Input.RoleId" />
                                        <input type="hidden" name="principalType" value="@row.PrincipalType" />
                                        <input type="hidden" name="principal" value="@row.Principal" />
                                        <button type="submit" class="btn btn-danger-subtle">@L["Remove"]</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

        </section>
    </div>

    <section class="card section-card role-principal-add-section bottom-gap">
        <div class="eyebrow">@L["Principals"]</div>
        <h3>@L["Add principals"]</h3>
        <p class="muted">@ompBranding.ApplyPlatformName(L["Choose OMP users from the checklist or paste AD users/groups as newline-separated text."].Value)</p>

        <div class="role-principal-add role-principal-add--wide">
            <div class="role-principal-add-grid">
                <form method="post" asp-page-handler="AddPrincipal" class="role-principal-add-card">
                    <input type="hidden" name="Input.RoleId" value="@Model.Input.RoleId" />
                    <input type="hidden" name="principalType" value="OmpUser" />

                    <div class="form-field">
                        <label>@L["OMP users"]</label>
                        @if (Model.OmpUserOptions.Count == 0)
                        {
                            <div class="empty-state">@L["No available OMP users found."]</div>
                        }
                        else
                        {
                            <div class="checkbox-list role-principal-picker__list">
                                @foreach (var option in Model.OmpUserOptions)
                                {
                                    <label class="checkbox-row">
                                        <input type="checkbox" name="selectedOmpUserIds" value="@option.Value" />
                                        <span>@option.Label</span>
                                    </label>
                                }
                            </div>
                        }
                    </div>

                    <div class="form-field actions">
                        <button type="submit">@L["Add selected OMP users"]</button>
                    </div>
                </form>

                <form method="post" asp-page-handler="AddPrincipal" class="role-principal-add-card">
                    <input type="hidden" name="Input.RoleId" value="@Model.Input.RoleId" />
                    <input type="hidden" name="principalType" value="ADUser" />

                    <div class="form-field grow">
                        <label for="adUserPrincipals">@L["AD users"]</label>
                        <textarea id="adUserPrincipals" name="principal" rows="7" autocomplete="off">@Model.NewPrincipal</textarea>
                        <div class="field-help">
                            @ompBranding.ApplyPlatformName(L["Enter one AD user per line. Linked AD accounts are assigned as their OMP user automatically."].Value)
                        </div>
                    </div>

                    <div class="form-field actions">
                        <button type="submit">@L["Add AD users"]</button>
                    </div>
                </form>

                <form method="post" asp-page-handler="AddPrincipal" class="role-principal-add-card">
                    <input type="hidden" name="Input.RoleId" value="@Model.Input.RoleId" />
                    <input type="hidden" name="principalType" value="ADGroup" />

                    <div class="form-field grow">
                        <label for="adGroupPrincipals">@L["AD groups"]</label>
                        <textarea id="adGroupPrincipals" name="principal" rows="7" autocomplete="off"></textarea>
                        <div class="field-help">
                            @L["Enter one AD group SID or DOMAIN\\Group per line. Local group names are resolved to a SID when possible."]
                        </div>
                    </div>

                    <div class="form-field actions">
                        <button type="submit">@L["Add AD groups"]</button>
                    </div>
                </form>
            </div>
        </div>
    </section>

    <form
        method="post"
        asp-page-handler="Delete"
        class="card danger-zone"
        onsubmit="return confirm('@L["Delete this role? Linked role assignments will also be removed."]');">
        <input type="hidden" asp-for="Input.RoleId" />
        <h3>@L["Danger zone"]</h3>
        <p class="muted">@L["Deleting a role removes all principal and permission links for that role."]</p>
        <button type="submit" class="btn btn-danger">@L["Delete role"]</button>
    </form>
}
