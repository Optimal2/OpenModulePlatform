@page
@model OpenModulePlatform.Portal.Pages.Admin.Rbac.RoleModel

<section class="page-header">
    <div>
        <div class="eyebrow">@L["Security and access"]</div>
        <h2>@(Model.IsCreate ? L["Create role"] : L["Edit role"])</h2>
        <p class="lede">@L["Roles are the main RBAC editing surface. Add permissions and principals here so access remains grouped and auditable."]</p>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="card status-banner">@Model.StatusMessage</div>
}

@if (!ViewContext.ModelState.IsValid)
{
    <div class="card validation-summary-errors" asp-validation-summary="All"></div>
}

<form method="post" class="card form-grid bottom-gap">
    <input type="hidden" asp-for="Input.RoleId" />

    <div class="field-grid field-grid--2">
        <div class="form-field">
            <label asp-for="Input.Name"></label>
            <input asp-for="Input.Name" />
            <div class="field-help">
                @L["Use a stable role name, for example"]
                <span class="info-badge">PortalAdmins</span>
                <span class="muted">/</span> <span class="info-badge">ExampleServiceAppModule.Operators</span>.
            </div>
            <span asp-validation-for="Input.Name" class="field-validation-error"></span>
        </div>

        <div class="form-field">
            <label asp-for="Input.Description"></label>
            <input asp-for="Input.Description" />
            <div class="field-help">@L["Short explanation of who should receive this role."]</div>
            <span asp-validation-for="Input.Description" class="field-validation-error"></span>
        </div>
    </div>

    <div class="toolbar">
        <button type="submit">@L["Save role"]</button>
        <a class="action-link" href="~/admin/rbac/roles">@L["Back to roles"]</a>
    </div>
</form>

@if (!Model.IsCreate)
{
    <div class="section-grid section-grid--wide bottom-gap">
        <section class="card section-card">
            <div class="eyebrow">@L["Role administration"]</div>
            <h3>@L["Assigned permissions"]</h3>
            <p class="muted">
                @L["These permissions are granted whenever the role is resolved for a user or service identity."]
            </p>

            @if (Model.Permissions.Count == 0)
            {
                <div class="empty-state top-gap">@L["No permissions assigned yet."]</div>
            }
            else
            {
                <table class="grid compact-grid">
                    <thead>
                        <tr>
                            <th>@L["Permission"]</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Permissions)
                        {
                            <tr>
                                <td>@row.PermissionName</td>
                                <td>
                                    <form method="post" asp-page-handler="RemovePermission" class="inline-form">
                                        <input type="hidden" name="Input.RoleId" value="@Model.Input.RoleId" />
                                        <input type="hidden" name="permissionId" value="@row.PermissionId" />
                                        <button type="submit" class="btn btn-danger-subtle">@L["Remove"]</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

            <form method="post" asp-page-handler="AddPermission" class="top-gap form-grid-inline">
                <input type="hidden" name="Input.RoleId" value="@Model.Input.RoleId" />
                <div class="form-field grow">
                    <label for="permissionId">@L["Add permission"]</label>
                    <select id="permissionId" name="permissionId">
                        <option value="">@L["Select permission"]</option>
                        @foreach (var option in Model.AvailablePermissionOptions)
                        {
                            <option value="@option.Value">@option.Label</option>
                        }
                    </select>
                </div>
                <div class="form-field actions">
                    <button type="submit">@L["Add permission"]</button>
                </div>
            </form>
        </section>

        <section class="card section-card">
            <div class="eyebrow">@L["Principals"]</div>
            <h3>@L["Assigned principals"]</h3>
            <p class="muted">@L["Bind users, groups or service identities to the role. Prefer groups where possible."]</p>

            @if (Model.Principals.Count == 0)
            {
                <div class="empty-state top-gap">@L["No principals assigned yet."]</div>
            }
            else
            {
                <table class="grid compact-grid">
                    <thead>
                        <tr>
                            <th>@L["Type"]</th>
                            <th>@L["Principal"]</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Principals)
                        {
                            <tr>
                                <td>@L[row.PrincipalType]</td>
                                <td>@row.Principal</td>
                                <td>
                                    <form method="post" asp-page-handler="RemovePrincipal" class="inline-form">
                                        <input type="hidden" name="Input.RoleId" value="@Model.Input.RoleId" />
                                        <input type="hidden" name="principalType" value="@row.PrincipalType" />
                                        <input type="hidden" name="principal" value="@row.Principal" />
                                        <button type="submit" class="btn btn-danger-subtle">@L["Remove"]</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

            <form method="post" asp-page-handler="AddPrincipal" class="top-gap form-grid-inline form-grid-inline--triple">
                <input type="hidden" name="Input.RoleId" value="@Model.Input.RoleId" />

                <div class="form-field">
                    <label for="principalType">@L["Principal type"]</label>
                    <select id="principalType" name="principalType">
                        @foreach (var option in Model.PrincipalTypeOptions)
                        {
                            <option value="@option.Value">@option.Label</option>
                        }
                    </select>
                </div>

                <div class="form-field grow">
                    <label for="principal">@L["Principal"]</label>
                    <input id="principal" name="principal" value="@Model.NewPrincipal" />
                    <div class="field-help">
                        @L["Examples:"]
                        <span class="info-badge">DOMAIN\User</span>,
                        <span class="info-badge">DOMAIN\Group</span>,
                        <span class="info-badge">svc-omp-hostagent</span>.
                    </div>
                </div>

                <div class="form-field actions">
                    <button type="submit">@L["Add principal"]</button>
                </div>
            </form>
        </section>
    </div>

    <form
        method="post"
        asp-page-handler="Delete"
        class="card danger-zone"
        onsubmit="return confirm('@L["Delete this role? Linked role assignments will also be removed."]');">
        <input type="hidden" asp-for="Input.RoleId" />
        <h3>@L["Danger zone"]</h3>
        <p class="muted">@L["Deleting a role removes all principal and permission links for that role."]</p>
        <button type="submit" class="btn btn-danger">@L["Delete role"]</button>
    </form>
}
