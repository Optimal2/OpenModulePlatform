@page
@model OpenModulePlatform.Portal.Pages.Admin.Rbac.RolesModel

<section class="page-header">
    <div>
        <div class="eyebrow">@L["Security and access"]</div>
        <h2>@L["Roles"]</h2>
        <p class="lede">@L["Roles bundle permissions and principals. Use roles to keep direct principal management small and predictable."]</p>
    </div>
    <div class="toolbar">
        <a class="action-link" href="~/admin/rbac/role">@L["Create role"]</a>
    </div>
</section>

@if (Model.Rows.Count == 0)
{
    <div class="card empty-state">@L["No roles have been created yet."]</div>
}
else
{
    <table class="grid">
        <thead>
            <tr>
                <th>@L["Name"]</th>
                <th>@L["Description"]</th>
                <th>@L["Permissions"]</th>
                <th>@L["Principals"]</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Model.Rows)
            {
                <tr>
                    <td>
                        <a href="~/admin/rbac/role?roleId=@row.RoleId">@row.Name</a>
                    </td>
                    <td>@row.Description</td>
                    <td><span class="pill">@row.PermissionCount</span></td>
                    <td><span class="pill">@row.PrincipalCount</span></td>
                    <td>
                        <a class="action-link" href="~/admin/rbac/role?roleId=@row.RoleId">@L["Edit"]</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
