@page
@model OpenModulePlatform.Portal.Pages.Admin.BootstrapConfigEditorModel

<section class="page-header">
    <div>
        <div class="eyebrow">@L["Installation"]</div>
        <h2>@L["Bootstrap config editor"]</h2>
        <p class="lede">@L["Use this editor to create or update machine-specific bootstrap configuration JSON files for the installer."]</p>
