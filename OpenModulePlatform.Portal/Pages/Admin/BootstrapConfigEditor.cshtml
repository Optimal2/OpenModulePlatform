<div class="toolbar top-gap">
    <a class="action-link" href="~/admin/instancetemplateedit?id=1">@L["Back to installation"]</a>
</div>

<iframe
    class="module-definition-editor-frame top-gap"
    title="@L["Bootstrap config editor"]"
    src="~/tools/bootstrap-config-editor/index.html"></iframe>
