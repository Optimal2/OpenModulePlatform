@page
@model OpenModulePlatform.Portal.Pages.Admin.InstanceTemplateModuleEditModel

<section class="page-header">
    <div>
        <div class="eyebrow">@L["Desired topology"]</div>
        <h2>@(Model.IsCreate ? L["Add template module instance"] : L["Edit template module instance"])</h2>
        <p class="lede">@L["Template module instances are desired module slots. Desired app rows attach to them before HostAgent creates runtime module instances."]</p>
    </div>
</section>

@if (Model.Template is not null)
{
    <section class="card section-card section-card--wide">
        <div class="detail-grid">
            <div>
                <div class="muted">@L["Instance template"]</div>
                <a class="action-link" href="~/admin/instancetemplateedit?id=@Model.Template.InstanceTemplateId">@Model.Template.DisplayName</a>
            </div>
            <div>
                <div class="muted">@L["Template key"]</div>
                <code>@Model.Template.TemplateKey</code>
            </div>
        </div>
    </section>
}

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="card status-banner">@Model.StatusMessage</div>
}

@if (!ViewContext.ModelState.IsValid)
{
    <div class="card validation-summary-errors" asp-validation-summary="All"></div>
}

<form method="post" class="card form-grid">
    <input type="hidden" asp-for="Input.InstanceTemplateModuleInstanceId" />
    <input type="hidden" asp-for="Input.InstanceTemplateId" />

    <div class="field-grid field-grid--2">
        <div class="form-field">
            <label asp-for="Input.ModuleId"></label>
            <select asp-for="Input.ModuleId">
                <option value="">@L["Select module"]</option>
                @foreach (var option in Model.ModuleOptions)
                {
                    <option value="@option.Value">@option.Label</option>
                }
            </select>
            <span asp-validation-for="Input.ModuleId" class="field-validation-error"></span>
        </div>

        <div class="form-field">
            <label asp-for="Input.ModuleInstanceKey"></label>
            <input asp-for="Input.ModuleInstanceKey" />
            <span asp-validation-for="Input.ModuleInstanceKey" class="field-validation-error"></span>
        </div>
    </div>

    <div class="field-grid field-grid--2">
        <div class="form-field">
            <label asp-for="Input.DisplayName"></label>
            <input asp-for="Input.DisplayName" />
            <span asp-validation-for="Input.DisplayName" class="field-validation-error"></span>
        </div>

        <div class="form-field">
            <label asp-for="Input.SortOrder"></label>
            <input asp-for="Input.SortOrder" type="number" />
        </div>
    </div>

    <div class="form-field">
        <label asp-for="Input.Description"></label>
        <textarea asp-for="Input.Description"></textarea>
    </div>

    <div class="form-field checkbox-row checkbox-row--boxed">
        <input asp-for="Input.IsEnabled" type="checkbox" />
        <label asp-for="Input.IsEnabled"></label>
    </div>

    <div class="toolbar">
        <button type="submit">@L["Save template module instance"]</button>
        <a class="action-link" href="~/admin/instancetemplateedit?id=@Model.Input.InstanceTemplateId">@L["Back to template"]</a>
    </div>
</form>

@if (!Model.IsCreate)
{
    <form
        method="post"
        asp-page-handler="Delete"
        class="card danger-zone"
        onsubmit="return confirm('@L["Remove this template module instance? Desired app rows using it must be removed first."]');">
        <input type="hidden" asp-for="Input.InstanceTemplateModuleInstanceId" />
        <input type="hidden" asp-for="Input.InstanceTemplateId" />
        <h3>@L["Danger zone"]</h3>
        <p class="muted">@L["Removing a template module instance stops future materialization from this template. Existing runtime rows are not removed by this action."]</p>
        <button type="submit" class="btn btn-danger">@L["Remove template module instance"]</button>
    </form>
}
