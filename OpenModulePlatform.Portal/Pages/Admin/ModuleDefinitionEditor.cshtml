@page
@model OpenModulePlatform.Portal.Pages.Admin.ModuleDefinitionEditorModel

<section class="page-header">
    <div>
        <div class="eyebrow">@L["Module definitions"]</div>
        <h2>@L["Module definition editor"]</h2>
        <p class="lede">@L["Use this editor to create or update portable module-definition JSON files. SQL scripts are shown as clear text here and exported as base64 content in the JSON file."]</p>
    </div>
</section>

<div class="toolbar top-gap">
    <a class="action-link" href="~/admin/moduledefinitionupload">@L["Upload module definition"]</a>
    <a class="action-link" href="~/admin/moduledefinitions">@L["Back to module definitions"]</a>
</div>

<iframe
    class="module-definition-editor-frame top-gap"
    title="@L["Module definition editor"]"
    src="~/tools/module-definition-editor/index.html"></iframe>
