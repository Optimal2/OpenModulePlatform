@page
@model OpenModulePlatform.Portal.Pages.Admin.InstanceTemplatesModel

<section class="page-header">
    <div>
        <div class="eyebrow">@L["Installation"]</div>
        <h2>@L["Installation profiles"]</h2>
        <p class="lede">@L["The database can store multiple installation profiles, but the current Portal workflow uses one default installation. Use System > Installation for normal administration."]</p>
    </div>
</section>

@if (Model.Rows.Count == 0)
{
    <div class="empty-state">@L["No installation profiles found."]</div>
}
else
{
    <table class="grid">
        <thead>
            <tr>
                <th>@L["Installation profile key"]</th>
                <th>@L["Display name"]</th>
                <th>@L["Enabled"]</th>
                <th>@L["Description"]</th>
                <th>@L["Actions"]</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var row in Model.Rows)
        {
            <tr>
                <td><code>@row.TemplateKey</code></td>
                <td>@row.DisplayName</td>
                <td><span class="pill">@(row.IsEnabled ? L["Enabled"] : L["Disabled"])</span></td>
                <td>@row.Description</td>
                <td><a class="action-link" href="~/admin/instancetemplateedit?id=@row.InstanceTemplateId">@L["Open installation"]</a></td>
            </tr>
        }
        </tbody>
    </table>
}
