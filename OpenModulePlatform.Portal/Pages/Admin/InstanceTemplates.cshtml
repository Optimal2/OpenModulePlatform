@page
@model OpenModulePlatform.Portal.Pages.Admin.InstanceTemplatesModel

<section class="page-header">
    <div>
        <div class="eyebrow">Automation</div>
        <h2>Instance templates</h2>
        <p class="lede">Instance templates belong to the future automation path. They describe desired topology rather than the manually managed live runtime.</p>
    </div>
</section>

@if (Model.Rows.Count == 0)
{
    <div class="empty-state">No instance templates found.</div>
}
else
{
    <table class="grid">
        <thead>
            <tr>
                <th>Template key</th>
                <th>Display name</th>
                <th>Enabled</th>
                <th>Description</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var row in Model.Rows)
        {
            <tr>
                <td><code>@row.TemplateKey</code></td>
                <td>@row.DisplayName</td>
                <td><span class="pill">@(row.IsEnabled ? "Enabled" : "Disabled")</span></td>
                <td>@row.Description</td>
            </tr>
        }
        </tbody>
    </table>
}
