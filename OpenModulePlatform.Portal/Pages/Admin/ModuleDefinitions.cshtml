@page
@model OpenModulePlatform.Portal.Pages.Admin.ModuleDefinitionsModel

<section class="page-header">
    <div>
        <div class="eyebrow">@L["Modules"]</div>
        <h2>@L["Module definition versions"]</h2>
        <p class="lede">@L["Module definitions describe the database and metadata contract that artifact versions are validated against. Older definition versions remain available for review."]</p>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="card status-banner">@Model.StatusMessage</div>
}

@if (!ViewContext.ModelState.IsValid)
{
    <div class="card validation-summary-errors" asp-validation-summary="All"></div>
}

<div class="toolbar top-gap">
    <a class="action-link" href="~/admin/modulepackageimport">@L["Packages"]</a>
    <a class="action-link" href="~/admin/moduledefinitioneditor">@L["Open editor"]</a>
    <a class="action-link" href="~/admin/instancetemplateedit?id=1">@L["Back to installation"]</a>
</div>

@{
    var integrityRows = Model.IntegrityRows.ToList();
    var repairableActiveRows = integrityRows.Where(row => row.IsApplied).ToList();
    var appliedRows = Model.Rows
        .Where(row => row.IsApplied)
        .OrderBy(row => row.ModuleKey, StringComparer.OrdinalIgnoreCase)
        .ToList();
    var storedVersionCounts = Model.Rows
        .GroupBy(row => row.ModuleKey, StringComparer.OrdinalIgnoreCase)
        .ToDictionary(group => group.Key, group => group.Count(), StringComparer.OrdinalIgnoreCase);
    var activeIntegrityRows = integrityRows
        .Where(row => row.IsApplied)
        .ToDictionary(row => row.ModuleKey, StringComparer.OrdinalIgnoreCase);
}

<section class="card top-gap">
    <div class="section-heading-row">
        <div>
            <h3>@L["Applied module definitions"]</h3>
            <p class="lede">@L["Current module definition versions stored in this OMP database. Use this list to confirm which database and metadata contract is active before troubleshooting artifact behavior."]</p>
        </div>
    </div>

    @if (appliedRows.Count == 0)
    {
        <div class="empty-state">@L["No applied module definitions found."]</div>
    }
    else
    {
        <div class="table-scroll module-definitions-scroll">
            <table class="grid module-definitions-grid">
                <thead>
                    <tr>
                        <th>@L["Module key"]</th>
                        <th>@L["Applied version"]</th>
                        <th>@L["Stored versions"]</th>
                        <th>@L["Integrity"]</th>
                        <th>@L["Applied UTC"]</th>
                        <th>@L["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in appliedRows)
                {
                    var storedCount = storedVersionCounts.TryGetValue(row.ModuleKey, out var count) ? count : 1;
                    var hasIntegrity = activeIntegrityRows.TryGetValue(row.ModuleKey, out var integrity);
                    <tr>
                        <td><code>@row.ModuleKey</code></td>
                        <td>@row.DefinitionVersion</td>
                        <td>@storedCount</td>
                        <td>
                            @if (hasIntegrity && integrity is not null)
                            {
                                <span class="integrity-pill integrity-pill--@integrity.OverallStatus">@L[integrity.OverallStatusLabel]</span>
                                @foreach (var message in integrity.Messages.Take(2))
                                {
                                    <div class="muted small-text">@L[message]</div>
                                }
                            }
                            else
                            {
                                <span class="integrity-pill integrity-pill--neutral">@L["Not checked"]</span>
                            }
                        </td>
                        <td>@(row.AppliedUtc?.ToString("u") ?? L["Unknown"].Value)</td>
                        <td class="admin-action-cell">
                            <a class="action-link admin-icon-button admin-icon-button--clarify"
                               href="~/admin/moduledefinitionedit?id=@row.ModuleDefinitionDocumentId"
                               title="@L["View"]"
                               aria-label="@L["View"]">
                                <span class="visually-hidden">@L["View"]</span>
                            </a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>

<section class="card top-gap">
    <div class="section-heading-row">
        <div>
            <h3>@L["Available package library"]</h3>
            <p class="lede">@L["Install or complete modules from the package library. This applies the module definition, runs safe SQL repairs, registers artifacts, and updates matching desired app versions."]</p>
        </div>
    </div>

    @if (Model.AvailablePackages.Count == 0)
    {
        <div class="empty-state">
            @L["No available module packages found."]
            <div class="muted top-gap">
                @L["Check that ArtifactUpload:AvailableModuleDefinitionsRoot and ArtifactUpload:AvailableArtifactsRoot point to the HostAgent _available package library folders and that the Portal appsettings.json has been redeployed."]
            </div>
        </div>
    }
    else
    {
        <div class="table-scroll module-definitions-scroll">
            <table class="grid module-definitions-grid">
                <thead>
                    <tr>
                        <th>@L["Module key"]</th>
                        <th>@L["Definition version"]</th>
                        <th>@L["Status"]</th>
                        <th>@L["Artifacts"]</th>
                        <th>@L["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var package in Model.AvailablePackages)
                {
                    <tr>
                        <td><code>@package.ModuleKey</code></td>
                        <td>@package.DefinitionVersion</td>
                        <td>
                            <span class="integrity-pill @package.StatusClass">@L[package.StatusLabel]</span>
                            <div class="muted small-text top-gap">
                                @L["Installed definition"]:
                                <strong>@(package.InstalledDefinitionVersion ?? L["None"].Value)</strong>
                            </div>
                            <div class="field-help">@L[package.ImportGuidance]</div>
                        </td>
                        <td>
                            <strong>@package.ArtifactFiles.Count</strong>
                            @if (package.ArtifactFiles.Count > 0)
                            {
                                <div class="muted small-text">
                                    @string.Format(
                                        L["Artifacts: {0} same, {1} newer installed, {2} older installed, {3} missing."].Value,
                                        package.SameArtifactVersionCount,
                                        package.NewerArtifactVersionCount,
                                        package.OlderArtifactVersionCount + package.OtherArtifactVersionCount,
                                        package.MissingArtifactCount)
                                </div>
                                <div class="muted small-text">
                                    @string.Join(", ", package.ArtifactFiles
                                        .Take(4)
                                        .Select(file => $"{file.AppKey} {file.Version}"))
                                    @(package.ArtifactFiles.Count > 4 ? " ..." : string.Empty)
                                </div>
                            }
                        </td>
                        <td class="admin-action-cell">
                            <form method="post" asp-page-handler="ImportAvailable" class="inline-form">
                                <input type="hidden" name="moduleDefinitionFileName" value="@package.ModuleDefinitionFileName" />
                                <button type="submit">@L[package.ActionLabel]</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>

<section class="card top-gap">
    <div class="section-heading-row">
        <div>
            <h3>@L["Module integrity matrix"]</h3>
            <p class="lede">@L["The matrix checks module definitions against current OMP metadata, required database objects, declared module dependencies, and current artifact selections. Stored definitions can be applied from the action column."]</p>
        </div>
        <form method="post" asp-page-handler="RepairAllSql">
            <button type="submit" disabled="@(repairableActiveRows.All(row => row.RepairableSqlScriptCount == 0) ? "disabled" : null)">
                @L["Execute detected SQL repairs for all modules"]
            </button>
        </form>
    </div>

    @if (integrityRows.Count == 0)
    {
        <div class="empty-state">@L["No module definitions found."]</div>
    }
    else
    {
        <div class="table-scroll module-definitions-scroll">
            <table class="grid integrity-grid module-integrity-grid">
                <thead>
                    <tr>
                        <th>@L["Module key"]</th>
                        <th>@L["Definition version"]</th>
                        <th>@L["Overall"]</th>
                        <th>@L["Metadata"]</th>
                        <th>@L["Database"]</th>
                        <th>@L["SQL"]</th>
                        <th>@L["Dependencies"]</th>
                        <th>@L["Artifacts"]</th>
                        <th>@L["Summary"]</th>
                        <th>@L["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in integrityRows)
                {
                    <tr>
                        <td><code>@row.ModuleKey</code></td>
                        <td>@row.DefinitionVersion</td>
                        <td><span class="integrity-pill integrity-pill--@row.OverallStatus">@L[row.OverallStatusLabel]</span></td>
                        <td>
                            <span class="integrity-pill integrity-pill--@row.MetadataStatus">@L[row.MetadataStatusLabel]</span>
                            @if (row.MissingMetadataCount > 0)
                            {
                                <div class="muted">@L["Missing"]: @row.MissingMetadataCount</div>
                            }
                        </td>
                        <td>
                            <span class="integrity-pill integrity-pill--@row.DatabaseStatus">@L[row.DatabaseStatusLabel]</span>
                            @if (row.MissingRequiredObjectCount > 0)
                            {
                                <div class="muted">@L["Missing"]: @row.MissingRequiredObjectCount</div>
                            }
                        </td>
                        <td>
                            <span class="integrity-pill integrity-pill--@row.SqlStatus">@L[row.SqlStatusLabel]</span>
                            @if (row.RepairableSqlScriptCount > 0)
                            {
                                <div class="muted">@L["Repairable"]: @row.RepairableSqlScriptCount</div>
                            }
                            @if (row.NotRecordedSqlScriptCount > 0)
                            {
                                <div class="muted">@L["Not recorded"]: @row.NotRecordedSqlScriptCount</div>
                            }
                        </td>
                        <td>
                            <span class="integrity-pill integrity-pill--@row.DependencyStatus">@L[row.DependencyStatusLabel]</span>
                            @if (row.RequiredDependencyIssueCount > 0 || row.OptionalDependencyIssueCount > 0)
                            {
                                <div class="muted">@L["Issues"]: @(row.RequiredDependencyIssueCount + row.OptionalDependencyIssueCount)</div>
                            }
                        </td>
                        <td>
                            <span class="integrity-pill integrity-pill--@row.ArtifactStatus">@L[row.ArtifactStatusLabel]</span>
                            @if (row.IncompatibleArtifactReferenceCount > 0)
                            {
                                <div class="muted">@L["Incompatible"]: @row.IncompatibleArtifactReferenceCount</div>
                            }
                        </td>
                        <td>
                            <strong>@L[row.SummaryLabel]</strong>
                            @foreach (var message in row.Messages)
                            {
                                <div class="muted">@L[message]</div>
                            }
                        </td>
                        <td class="admin-action-cell">
                            @if (!row.IsApplied)
                            {
                                <form method="post" asp-page-handler="ApplyAndRepair" class="inline-form">
                                    <input type="hidden" name="moduleDefinitionDocumentId" value="@row.ModuleDefinitionDocumentId" />
                                    <button type="submit">@L["Apply + SQL"]</button>
                                </form>
                            }
                            else if (row.RepairableSqlScriptCount > 0)
                            {
                                <form method="post" asp-page-handler="RepairSql" class="inline-form">
                                    <input type="hidden" name="moduleDefinitionDocumentId" value="@row.ModuleDefinitionDocumentId" />
                                    <button type="submit">@L["Run SQL"]</button>
                                </form>
                            }
                            <a class="action-link admin-icon-button admin-icon-button--clarify"
                               href="~/admin/moduledefinitionedit?id=@row.ModuleDefinitionDocumentId"
                               title="@L["View"]"
                               aria-label="@L["View"]">
                                <span class="visually-hidden">@L["View"]</span>
                            </a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>

@if (Model.Rows.Count == 0)
{
    <div class="empty-state">@L["No module definitions found."]</div>
}
else
{
    <div class="table-scroll module-definitions-scroll">
    <table class="grid module-definitions-grid">
        <thead>
            <tr>
                <th>@L["Module key"]</th>
                <th>@L["Definition version"]</th>
                <th>@L["Format"]</th>
                <th>@L["Artifact slots"]</th>
                <th>@L["State"]</th>
                <th>@L["Updated UTC"]</th>
                <th>@L["Actions"]</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var row in Model.Rows)
        {
            <tr>
                <td><code>@row.ModuleKey</code></td>
                <td>@row.DefinitionVersion</td>
                <td>@row.FormatVersion</td>
                <td>@row.CompatibleArtifactSlotCount</td>
                <td><span class="pill">@(row.IsApplied ? L["Applied"] : L["Stored"])</span></td>
                <td>@row.UpdatedUtc.ToString("u")</td>
                <td class="admin-action-cell">
                    <a class="action-link admin-icon-button admin-icon-button--clarify"
                       href="~/admin/moduledefinitionedit?id=@row.ModuleDefinitionDocumentId"
                       title="@L["View"]"
                       aria-label="@L["View"]">
                        <span class="visually-hidden">@L["View"]</span>
                    </a>
                </td>
            </tr>
        }
        </tbody>
    </table>
    </div>
}
