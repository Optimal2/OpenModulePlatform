@page
@model OpenModulePlatform.Portal.Pages.Admin.BannersModel

<section class="page-header">
    <div>
        <div class="eyebrow">@L["Administration"]</div>
        <h2>@L["Banners"]</h2>
        <p class="lede">@L["Create system-controlled banners for all users or selected roles. Users cannot dismiss banners."]</p>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="card status-banner">@Model.StatusMessage</div>
}

@if (!ViewContext.ModelState.IsValid)
{
    <div class="card validation-summary-errors" asp-validation-summary="All"></div>
}

<section class="card top-gap">
    <div class="section-header">
        <div>
            <h3>@(Model.IsEdit ? L["Edit banner"] : L["Create banner"])</h3>
        </div>
        @if (Model.IsEdit)
        {
            <a class="action-link" asp-page="/Admin/Banners">@L["Create banner"]</a>
        }
    </div>

    <form method="post" asp-page-handler="Save" class="settings-form">
        <input asp-for="Input.BannerId" type="hidden" />

        <div class="field-grid field-grid--2">
            <div class="form-field">
                <label asp-for="Input.Title"></label>
                <input asp-for="Input.Title" />
                <span asp-validation-for="Input.Title" class="field-validation-error"></span>
            </div>

            <div class="form-field">
                <label asp-for="Input.Status"></label>
                <select asp-for="Input.Status">
                    <option value="active">@L["Active"]</option>
                    <option value="disabled">@L["Disabled"]</option>
                </select>
            </div>
        </div>

        <div class="form-field">
            <label asp-for="Input.Content"></label>
            <textarea asp-for="Input.Content" rows="3"></textarea>
            <span asp-validation-for="Input.Content" class="field-validation-error"></span>
        </div>

        <div class="field-grid field-grid--3">
            <div class="form-field">
                <label asp-for="Input.Level"></label>
                <select asp-for="Input.Level">
                    <option value="1">@L["Announcement"]</option>
                    <option value="2">@L["Warning"]</option>
                    <option value="3">@L["Critical"]</option>
                </select>
            </div>

            <div class="form-field">
                <label asp-for="Input.StartsAtUtc"></label>
                <input asp-for="Input.StartsAtUtc" type="datetime-local" />
                <span asp-validation-for="Input.StartsAtUtc" class="field-validation-error"></span>
            </div>

            <div class="form-field">
                <label asp-for="Input.ExpiresAtUtc"></label>
                <input asp-for="Input.ExpiresAtUtc" type="datetime-local" />
                <span asp-validation-for="Input.ExpiresAtUtc" class="field-validation-error"></span>
            </div>
        </div>

        <div class="form-field">
            <label asp-for="Input.TargetMode"></label>
            <div class="segmented-control" role="group" aria-label="@L["Banner targets"]">
                <label>
                    <input asp-for="Input.TargetMode" type="radio" value="global" />
                    <span>@L["Global"]</span>
                </label>
                <label>
                    <input asp-for="Input.TargetMode" type="radio" value="roles" />
                    <span>@L["Specific roles"]</span>
                </label>
            </div>
        </div>

        <div class="form-field">
            <label asp-for="Input.SelectedRoleIds"></label>
            <div class="checkbox-list">
                @foreach (var role in Model.RoleOptions)
                {
                    var checkedAttr = Model.Input.SelectedRoleIds.Contains(role.RoleId);
                    <label class="checkbox-row">
                        <input type="checkbox" name="Input.SelectedRoleIds" value="@role.RoleId" checked="@checkedAttr" />
                        <span>@role.Name</span>
                    </label>
                }
            </div>
            <span asp-validation-for="Input.SelectedRoleIds" class="field-validation-error"></span>
        </div>

        <div class="toolbar">
            <button type="submit" class="btn btn-primary">@(Model.IsEdit ? L["Save changes"] : L["Create banner"])</button>
        </div>
    </form>
</section>

<section class="card top-gap">
    <div class="section-header">
        <div>
            <h3>@L["Banners"]</h3>
        </div>
    </div>

    @if (Model.Rows.Count == 0)
    {
        <div class="empty-state">@L["No entries to show"]</div>
    }
    else
    {
        Func<string?, List<string>> parseTargets = value => (value ?? string.Empty)
            .Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(target => target.Trim())
            .Where(target => target.Length > 0)
            .ToList();
        var targetOptions = Model.Rows
            .SelectMany(row => parseTargets(row.TargetSummary))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(target => target, StringComparer.OrdinalIgnoreCase)
            .ToList();

        <div class="toolbar">
            <details class="list-filter" data-list-filter="banners-list">
                <summary class="btn btn-ghost">@L["Filter"]<span class="list-filter__count" data-filter-count hidden></span></summary>
                <div class="list-filter__menu">
                    <fieldset class="list-filter__group" data-filter-group="level">
                        <legend>@L["Level"]</legend>
                        <label class="list-filter__option"><input type="checkbox" data-filter-column="1" data-filter-equals="1" /> @L["Announcement"]</label>
                        <label class="list-filter__option"><input type="checkbox" data-filter-column="1" data-filter-equals="2" /> @L["Warning"]</label>
                        <label class="list-filter__option"><input type="checkbox" data-filter-column="1" data-filter-equals="3" /> @L["Critical"]</label>
                    </fieldset>
                    <fieldset class="list-filter__group" data-filter-group="status">
                        <legend>@L["Status"]</legend>
                        <label class="list-filter__option"><input type="checkbox" data-filter-column="2" data-filter-equals="active" /> @L["Active"]</label>
                        <label class="list-filter__option"><input type="checkbox" data-filter-column="2" data-filter-equals="scheduled" /> @L["Scheduled"]</label>
                        <label class="list-filter__option"><input type="checkbox" data-filter-column="2" data-filter-equals="expired" /> @L["Expired"]</label>
                        <label class="list-filter__option"><input type="checkbox" data-filter-column="2" data-filter-equals="disabled" /> @L["Disabled"]</label>
                    </fieldset>
                    <fieldset class="list-filter__group" data-filter-group="targets">
                        <legend>@L["Targets"]</legend>
                        @foreach (var target in targetOptions)
                        {
                            <label class="list-filter__option"><input type="checkbox" data-filter-column="3" data-filter-includes="@target" /> @target</label>
                        }
                        <label class="list-filter__option"><input type="checkbox" data-filter-column="3" data-filter-equals="none" /> @L["No targets"]</label>
                    </fieldset>
                    <button type="button" class="btn btn-ghost btn-sm" data-filter-clear>@L["Clear filters"]</button>
                </div>
            </details>
            <input type="search" class="list-search" data-list-search="banners-list" placeholder="@L["Search rows"]" aria-label="@L["Search rows"]" />
            <span class="list-count" data-list-count="banners-list" data-template="@L["Showing {0} of {1} rows."]"></span>
        </div>
        <div class="empty-state" data-list-empty="banners-list" hidden>@L["No rows match the current filters."]</div>
        <div class="table-scroll">
            <table id="banners-list" class="grid sortable-list" data-sortable-list data-page-size="50">
                <thead>
                    <tr>
                        <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["Title"]</button></th>
                        <th scope="col" data-sort-type="number"><button type="button" class="sortable-list__button">@L["Level"]</button></th>
                        <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["Status"]</button></th>
                        <th scope="col">@L["Targets"]</th>
                        <th scope="col" data-sort-type="date"><button type="button" class="sortable-list__button">@L["Window"]</button></th>
                        <th scope="col"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.Rows)
                    {
                        var targets = parseTargets(row.TargetSummary);
                        <tr>
                            <td data-sort-value="@row.Title">
                                <strong>@row.Title</strong>
                                <div class="muted small-text">@row.Content</div>
                            </td>
                            <td data-sort-value="@row.Level">@Model.LevelText(row.Level)</td>
                            <td data-sort-value="@row.DisplayState">@Model.StateText(row.DisplayState)</td>
                            <td data-sort-value="@(targets.Count == 0 ? "none" : string.Join(";", targets))">@(string.IsNullOrWhiteSpace(row.TargetSummary) ? L["No targets"] : row.TargetSummary)</td>
                            <td class="small-text" data-sort-value="@(row.StartsAtUtc?.ToString("yyyy-MM-dd'T'HH:mm:ss'Z'", System.Globalization.CultureInfo.InvariantCulture) ?? "")">
                                <div>@L["Starts"]: @(row.StartsAtUtc?.ToLocalTime().ToString("g", System.Globalization.CultureInfo.CurrentCulture) ?? L["None"])</div>
                                <div>@L["Expires"]: @(row.ExpiresAtUtc?.ToLocalTime().ToString("g", System.Globalization.CultureInfo.CurrentCulture) ?? L["None"])</div>
                            </td>
                            <td class="admin-action-cell">
                                <div class="admin-icon-actions">
                                    <a class="admin-icon-button admin-icon-button--edit" asp-page="/Admin/Banners" asp-route-bannerId="@row.BannerId" title="@L["Edit"]" aria-label="@L["Edit"]">
                                        <span class="visually-hidden">@L["Edit"]</span>
                                    </a>
                                    @{
                                        var isEnabled = !string.Equals(row.Status, "disabled", StringComparison.OrdinalIgnoreCase);
                                    }
                                    <form method="post" asp-page-handler="SetEnabled" class="inline-form" data-enhance="false">
                                        <input type="hidden" name="bannerId" value="@row.BannerId" />
                                        <input type="hidden" name="enabled" value="@(!isEnabled)" />
                                        <button type="submit"
                                                class="admin-icon-button @(isEnabled ? "admin-icon-button--visible-off" : "admin-icon-button--visible")"
                                                title="@(isEnabled ? L["Disable banner"] : L["Enable banner"])"
                                                aria-label="@(isEnabled ? L["Disable banner"] : L["Enable banner"])">
                                            <span class="visually-hidden">@(isEnabled ? L["Disable banner"] : L["Enable banner"])</span>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="list-show-more">
            <button type="button" class="btn btn-secondary btn-sm" data-list-show-more="banners-list" hidden>@L["Show more"]</button>
        </div>
    }
</section>
