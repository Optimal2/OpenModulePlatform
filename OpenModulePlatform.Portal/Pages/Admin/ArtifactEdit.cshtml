@page
@model OpenModulePlatform.Portal.Pages.Admin.ArtifactEditModel

<section class="page-header">
    <div>
        <div class="eyebrow">@L["Manual core"]</div>
        <h2>@(Model.IsCreate ? L["Create artifact"] : L["Edit artifact"])</h2>
        <p class="lede">@L["Artifacts are deployable outputs of an app definition. Keep the artifact metadata precise so app instances can reference the right build."]</p>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="card status-banner">@Model.StatusMessage</div>
}

@if (!ViewContext.ModelState.IsValid)
{
    <div class="card validation-summary-errors" asp-validation-summary="All"></div>
}

<form method="post" class="card form-grid">
    <input type="hidden" asp-for="Input.ArtifactId" />

    <div class="field-grid field-grid--2">
        <div class="form-field">
            <label asp-for="Input.AppId"></label>
            <select asp-for="Input.AppId">
                <option value="">@L["Select app"]</option>
                @foreach (var option in Model.AppOptions)
                {
                    <option value="@option.Value">@option.Label</option>
                }
            </select>
            <span asp-validation-for="Input.AppId" class="field-validation-error"></span>
        </div>

        <div class="form-field">
            <label asp-for="Input.PackageType"></label>
            <select asp-for="Input.PackageType">
                @foreach (var option in Model.PackageTypeOptions)
                {
                    <option value="@option.Value">@option.Label</option>
                }
            </select>
            <div class="field-help">
                @L["Use a known package type when possible so later deployment automation can behave predictably."]
            </div>
        </div>
    </div>

    <div class="field-grid field-grid--3">
        <div class="form-field">
            <label asp-for="Input.Version"></label>
            <input asp-for="Input.Version" />
            <span asp-validation-for="Input.Version" class="field-validation-error"></span>
        </div>

        <div class="form-field">
            <label asp-for="Input.TargetName"></label>
            <input asp-for="Input.TargetName" />
            <div class="field-help">@L["Optional RID/target such as win-x64."]</div>
        </div>

        <div class="form-field checkbox-row checkbox-row--boxed">
            <input asp-for="Input.IsEnabled" type="checkbox" />
            <label asp-for="Input.IsEnabled"></label>
        </div>
    </div>

    <div class="form-field">
        <label asp-for="Input.RelativePath"></label>
        <input asp-for="Input.RelativePath" />
        <div class="field-help">@L["Relative path inside your artifact repository or release output."]</div>
    </div>

    <div class="form-field">
        <label asp-for="Input.Sha256"></label>
        <input asp-for="Input.Sha256" />
        <div class="field-help">@L["Optional checksum used for later integrity checks."]</div>
        <span asp-validation-for="Input.Sha256" class="field-validation-error"></span>
    </div>

    <div class="toolbar">
        <button type="submit">@L["Save artifact"]</button>
        @if (!Model.IsCreate)
        {
            <a class="action-link" asp-page-handler="DownloadPackage" asp-route-id="@Model.Input.ArtifactId">@L["Download artifact package"]</a>
        }
        <a class="action-link" href="~/admin/artifacts">@L["Back to artifacts"]</a>
    </div>
</form>

@if (!Model.IsCreate)
{
    <section class="card">
        <div class="section-header">
            <div>
                <h3>@L["Configuration files"]</h3>
                <p class="muted">@L["Optional files that HostAgent writes after deploying this artifact. Use this for site-specific runtime configuration that should not be packaged in the artifact zip."]</p>
            </div>
            <a class="action-link" href="~/admin/artifactconfigfileedit?artifactId=@Model.Input.ArtifactId">@L["Add configuration file"]</a>
        </div>

        @if (Model.ConfigurationFiles.Count == 0)
        {
            <div class="empty-state">@L["No configuration files are defined for this artifact."]</div>
        }
        else
        {
            <table class="grid">
                <thead>
                    <tr>
                        <th>@L["Relative path"]</th>
                        <th>@L["Enabled"]</th>
                        <th>@L["Updated UTC"]</th>
                        <th>@L["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.ConfigurationFiles)
                {
                    <tr>
                        <td><code>@row.RelativePath</code></td>
                        <td><span class="pill">@(row.IsEnabled ? L["Enabled"] : L["Disabled"])</span></td>
                        <td>@row.UpdatedUtc.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td><a class="action-link" href="~/admin/artifactconfigfileedit?id=@row.ArtifactConfigurationFileId">@L["Edit"]</a></td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </section>

    <form
        method="post"
        asp-page-handler="Delete"
        class="card danger-zone"
        onsubmit="return confirm('@L["Delete this artifact? App instances depending on it must be updated first."]');">
        <input type="hidden" asp-for="Input.ArtifactId" />
        <h3>@L["Danger zone"]</h3>
        <p class="muted">@L["Delete is blocked while app instances still point at this artifact."]</p>
        <button type="submit" class="btn btn-danger">@L["Delete artifact"]</button>
    </form>
}
