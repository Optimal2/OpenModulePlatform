@* File: OpenModulePlatform.Portal/Pages/Admin/Workers.cshtml *@
@page
@model OpenModulePlatform.Portal.Pages.Admin.WorkersModel

<section class="page-header">
    <div>
        <div class="eyebrow">@L["Worker runtime"]</div>
        <h2>@L["Workers"]</h2>
        <p class="lede">
            @L["Workers combines app worker definitions with the live worker runtime so you can manage the worker track from one place."]
        </p>
    </div>
</section>

<section class="card bottom-gap" id="worker-definitions-panel">
    <div class="page-header">
        <div>
            <div class="eyebrow">@L["Definitions"]</div>
            <h3>@L["App workers"]</h3>
            <p class="lede">
                @L["App worker definitions opt an app into the manager-driven plugin runtime. They stay app-level so classic service apps can continue to exist beside the new worker track."]
            </p>
        </div>
    </div>

    <div class="toolbar top-gap">
        <a class="action-link" href="~/admin/appworkeredit">@L["Create app worker definition"]</a>
        <a class="action-link" href="#worker-runtime-panel">@L["Open worker runtime"]</a>
    </div>

    @if (Model.AppWorkerRows.Count == 0)
    {
        <div class="empty-state">@L["No app worker definitions found. This can mean that no apps use the worker runtime yet or that the database schema has not been updated."]</div>
    }
    else
    {
        <div class="table-scroll">
        <table class="grid workers-grid">
            <thead>
                <tr>
                    <th>@L["Module"]</th>
                    <th>@L["App key"]</th>
                    <th>@L["Display name"]</th>
                    <th>@L["Type"]</th>
                    <th>@L["Runtime kind"]</th>
                    <th>@L["Worker type"]</th>
                    <th>@L["Plugin path"]</th>
                    <th>@L["Enabled"]</th>
                    <th>@L["Actions"]</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var row in Model.AppWorkerRows)
            {
                <tr>
                    <td><code>@row.ModuleKey</code></td>
                    <td><code>@row.AppKey</code></td>
                    <td>@row.DisplayName</td>
                    <td>@L[row.AppType]</td>
                    <td><code>@row.RuntimeKind</code></td>
                    <td><code>@row.WorkerTypeKey</code></td>
                    <td><code>@row.PluginRelativePath</code></td>
                    <td><span class="pill">@(row.IsEnabled ? L["Enabled"] : L["Disabled"])</span></td>
                    <td><a class="action-link" href="~/admin/appworkeredit?id=@row.AppId">@L["Edit"]</a></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    }
</section>

<section class="card" id="worker-runtime-panel">
    <div class="page-header">
        <div>
            <div class="eyebrow">@L["Runtime"]</div>
            <h3>@L["Worker runtime"]</h3>
            <p class="lede">
                @L["This view shows app instances whose app definition is mapped to the manager-driven worker runtime, together with the latest observed runtime status published by the worker manager."]
            </p>
        </div>
    </div>

    <div class="toolbar top-gap">
        <a class="action-link" href="#worker-definitions-panel">@L["Open app workers"]</a>
        <a class="action-link" href="~/admin/appinstances">@L["Open app instances"]</a>
    </div>

    @if (Model.RuntimeRows.Count == 0)
    {
        <div class="empty-state">@L["No worker-runtime app instances found. This can mean that no app worker definitions exist yet or that the database schema has not been updated."]</div>
    }
    else
    {
        <div class="table-scroll">
        <table class="grid workers-grid">
            <thead>
                <tr>
                    <th>@L["Instance"]</th>
                    <th>@L["Module instance"]</th>
                    <th>@L["App"]</th>
                    <th>@L["App instance key"]</th>
                    <th>@L["Host"]</th>
                    <th>@L["Desired"]</th>
                    <th>@L["Observed"]</th>
                    <th>@L["PID"]</th>
                    <th>@L["Last seen"]</th>
                    <th>@L["Last exit"]</th>
                    <th>@L["Message"]</th>
                    <th>@L["Actions"]</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var row in Model.RuntimeRows)
            {
                <tr>
                    <td><code>@row.InstanceKey</code></td>
                    <td><code>@row.ModuleInstanceKey</code></td>
                    <td>
                        <div><code>@row.AppKey</code></div>
                        <div class="muted small-text">@row.DisplayName</div>
                    </td>
                    <td><code>@row.AppInstanceKey</code></td>
                    <td><code>@row.HostKey</code></td>
                    <td><span class="pill">@Model.GetDesiredStateLabel(row.DesiredState, row.IsAllowed)</span></td>
                    <td>
                        <div><span class="pill">@Model.GetObservedStateLabel(row.ObservedState)</span></div>
                        <div class="muted small-text"><code>@row.RuntimeKind</code> / <code>@row.WorkerTypeKey</code></div>
                    </td>
                    <td>@row.ProcessId</td>
                    <td>
                        <div>@row.LastSeenUtc?.ToString("u")</div>
                        @if (row.StartedUtc.HasValue)
                        {
                            <div class="muted small-text">@L["Started"]: @row.StartedUtc.Value.ToString("u")</div>
                        }
                    </td>
                    <td>
                        <div>@row.LastExitUtc?.ToString("u")</div>
                        @if (row.LastExitCode.HasValue)
                        {
                            <div class="muted small-text">@L["Exit code"]: @row.LastExitCode.Value</div>
                        }
                    </td>
                    <td>
                        <div class="small-text">@row.StatusMessage</div>
                        <div class="muted small-text"><code>@row.PluginRelativePath</code></div>
                    </td>
                    <td><a class="action-link" href="~/admin/appinstanceedit?id=@row.AppInstanceId">@L["Edit"]</a></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    }
</section>
