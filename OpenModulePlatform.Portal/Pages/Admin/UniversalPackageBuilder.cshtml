@page
@using System.Text.Json
@model OpenModulePlatform.Portal.Pages.Admin.UniversalPackageBuilderModel

@{
    var text = new
    {
        noItems = L["No items added."].Value,
        itemReady = L["{0} item(s) ready."].Value,
        duplicate = L["Skipped duplicate package path: {0}"].Value,
        required = L["Package key and package version are required."].Value,
        created = L["Created {0}."].Value,
        remove = L["Remove"].Value
    };
}

<section class="page-header">
    <div>
        <div class="eyebrow">@L["Import/export"]</div>
        <h2>@L["Universal package builder"]</h2>
        <p class="lede">@L["Use this standalone-compatible tool to create a universal OMP package zip from any mix of portable objects."]</p>
    </div>
</section>

<div class="toolbar top-gap">
    <a class="action-link" href="~/admin/modulepackageimport">@L["Back to import/export"]</a>
    <a class="action-link" href="~/tools/universal-package-builder/index.html" target="_blank" rel="noopener">@L["Open standalone builder"]</a>
</div>

<section class="card top-gap universal-package-builder" data-universal-package-builder>
    <h3>@L["Package metadata"]</h3>
    <div class="field-grid field-grid--2">
        <div class="form-field">
            <label for="packageKey">@L["Package key"]</label>
            <input id="packageKey" value="omp-universal" />
        </div>
        <div class="form-field">
            <label for="packageVersion">@L["Package version"]</label>
            <input id="packageVersion" />
        </div>
        <div class="form-field">
            <label for="displayName">@L["Display name"]</label>
            <input id="displayName" value="@L["OpenModulePlatform universal package"]" />
        </div>
        <div class="form-field">
            <label for="targetHostProfile">@L["Target host profile"]</label>
            <input id="targetHostProfile" placeholder="@L["Optional host key/profile"]" />
        </div>
    </div>
    <div class="form-field top-gap">
        <label for="description">@L["Description"]</label>
        <textarea id="description"></textarea>
    </div>
</section>

<section class="card top-gap universal-package-builder" data-universal-package-builder>
    <h3>@L["Add objects"]</h3>
    <div class="field-grid field-grid--2">
        <div class="form-field">
            <label for="objectKind">@L["Object type"]</label>
            <select id="objectKind">
                <option value="module-definition">@L["Module definition JSON"]</option>
                <option value="artifact-package">@L["Artifact package zip"]</option>
                <option value="host-config">@L["Host configuration JSON/zip"]</option>
                <option value="config-overlay">@L["Config overlay JSON/zip"]</option>
                <option value="dashboard-widget">@L["Dashboard widget JSON"]</option>
                <option value="widget-data">@L["Widget runtime data zip"]</option>
            </select>
        </div>
        <div class="form-field">
            <label for="hostFolder">@L["Host-specific folder"]</label>
            <input id="hostFolder" placeholder="@L["Optional host subfolder for host-specific objects"]" />
        </div>
    </div>
    <div class="form-field top-gap">
        <label for="objectFiles">@L["Files"]</label>
        <input id="objectFiles" type="file" multiple />
        <div class="field-help">@L["Choose any number of object files, then add them to the package list. Host-specific folders apply to host configs, config overlays, widgets, and widget runtime data."]</div>
    </div>
    <div class="toolbar">
        <button type="button" id="addFiles">@L["Add files"]</button>
        <button type="button" class="secondary" id="clearFiles">@L["Clear list"]</button>
    </div>
</section>

<section class="card top-gap universal-package-builder" data-universal-package-builder data-labels="@JsonSerializer.Serialize(text)">
    <h3>@L["Package items"]</h3>
    <div class="status" id="status">@L["No items added."]</div>
    <div class="table-scroll">
        <table class="grid">
            <thead>
                <tr>
                    <th>@L["Kind"]</th>
                    <th>@L["Package path"]</th>
                    <th>@L["Version"]</th>
                    <th>@L["Source file"]</th>
                    <th>@L["Actions"]</th>
                </tr>
            </thead>
            <tbody id="itemsBody"></tbody>
        </table>
    </div>
    <div class="toolbar">
        <button type="button" id="createPackage">@L["Create package"]</button>
    </div>
</section>

<script>
(() => {
    const folderByKind = {
        "module-definition": "module-definitions",
        "artifact-package": "artifacts",
        "host-config": "host-configs",
        "config-overlay": "config-overlays",
        "dashboard-widget": "widgets",
        "widget-data": "widget-data"
    };

    const labels = JSON.parse(document.querySelector("[data-labels]").dataset.labels || "{}");
    const items = [];
    const packageVersion = document.getElementById("packageVersion");
    const objectKind = document.getElementById("objectKind");
    const hostFolder = document.getElementById("hostFolder");
    const objectFiles = document.getElementById("objectFiles");
    const itemsBody = document.getElementById("itemsBody");
    const status = document.getElementById("status");
    const encoder = new TextEncoder();
    const decoder = new TextDecoder();

    const pad2 = value => String(value).padStart(2, "0");
    const formatUtcPackageVersion = date =>
        `${date.getUTCFullYear()}${pad2(date.getUTCMonth() + 1)}${pad2(date.getUTCDate())}${pad2(date.getUTCHours())}${pad2(date.getUTCMinutes())}${pad2(date.getUTCSeconds())}`;

    packageVersion.value = formatUtcPackageVersion(new Date());

    const format = (template, value) => String(template || "").replace("{0}", value);
    const sanitizeSegment = value => {
        const text = String(value || "").trim().replace(/[<>:"/\\|?*\u0000-\u001f]/g, "-").replace(/^\.+|\.+$/g, "");
        return text || "item";
    };
    const normalizePath = value => String(value || "")
        .replace(/\\/g, "/")
        .split("/")
        .filter(segment => segment && segment !== "." && segment !== "..")
        .map(sanitizeSegment)
        .join("/");

    const updateStatus = (message, isError = false) => {
        status.textContent = message;
        status.classList.toggle("error", isError);
    };

    const renderItems = () => {
        itemsBody.innerHTML = "";
        items.forEach((item, index) => {
            const row = document.createElement("tr");
            row.innerHTML = `
                <td><code></code></td>
                <td><code></code></td>
                <td><code></code></td>
                <td></td>
                <td><button type="button" class="danger"></button></td>`;
            row.children[0].querySelector("code").textContent = item.kind;
            row.children[1].querySelector("code").textContent = item.path;
            row.children[2].querySelector("code").textContent = item.version || "";
            row.children[3].textContent = item.file.name;
            row.querySelector("button").textContent = labels.remove;
            row.querySelector("button").addEventListener("click", () => {
                items.splice(index, 1);
                renderItems();
            });
            itemsBody.appendChild(row);
        });

        updateStatus(items.length === 0 ? labels.noItems : format(labels.itemReady, items.length));
    };

    const compareVersionText = (left, right) =>
        String(left || "").localeCompare(String(right || ""), undefined, {
            numeric: true,
            sensitivity: "base"
        });

    const inflateRawBytes = async bytes => {
        if (typeof DecompressionStream !== "function") {
            return null;
        }

        try {
            const stream = new Blob([bytes]).stream().pipeThrough(new DecompressionStream("deflate-raw"));
            return new Uint8Array(await new Response(stream).arrayBuffer());
        } catch {
            return null;
        }
    };

    const readZipTextEntry = async (file, entryName) => {
        const bytes = new Uint8Array(await file.arrayBuffer());
        const view = new DataView(bytes.buffer, bytes.byteOffset, bytes.byteLength);
        const getUint16 = offset => view.getUint16(offset, true);
        const getUint32 = offset => view.getUint32(offset, true);
        const eocdSignature = 0x06054b50;
        const centralDirectorySignature = 0x02014b50;
        const localHeaderSignature = 0x04034b50;
        const maxCommentLength = 0xffff;
        const searchStart = Math.max(0, bytes.length - maxCommentLength - 22);
        let eocdOffset = -1;
        for (let offset = bytes.length - 22; offset >= searchStart; offset--) {
            if (getUint32(offset) === eocdSignature) {
                eocdOffset = offset;
                break;
            }
        }

        if (eocdOffset < 0) {
            return "";
        }

        let entryCount = getUint16(eocdOffset + 10);
        let centralOffset = getUint32(eocdOffset + 16);
        while (entryCount-- > 0 && centralOffset + 46 <= bytes.length) {
            if (getUint32(centralOffset) !== centralDirectorySignature) {
                return "";
            }

            const compressionMethod = getUint16(centralOffset + 10);
            const compressedSize = getUint32(centralOffset + 20);
            const fileNameLength = getUint16(centralOffset + 28);
            const extraLength = getUint16(centralOffset + 30);
            const commentLength = getUint16(centralOffset + 32);
            const localHeaderOffset = getUint32(centralOffset + 42);
            const nameStart = centralOffset + 46;
            const name = decoder.decode(bytes.subarray(nameStart, nameStart + fileNameLength));
            if (name === entryName) {
                if (getUint32(localHeaderOffset) !== localHeaderSignature) {
                    return "";
                }

                const localNameLength = getUint16(localHeaderOffset + 26);
                const localExtraLength = getUint16(localHeaderOffset + 28);
                const dataStart = localHeaderOffset + 30 + localNameLength + localExtraLength;
                const compressedBytes = bytes.subarray(dataStart, dataStart + compressedSize);
                if (compressionMethod === 0) {
                    return decoder.decode(compressedBytes);
                }

                if (compressionMethod === 8) {
                    const inflated = await inflateRawBytes(compressedBytes);
                    return inflated ? decoder.decode(inflated) : "";
                }

                return "";
            }

            centralOffset += 46 + fileNameLength + extraLength + commentLength;
        }

        return "";
    };

    const readItemVersion = async (kind, file) => {
        if (kind === "artifact-package") {
            const baseName = file.name.replace(/\.[^.]+$/, "");
            const parts = baseName.split("__");
            return parts.length >= 5 ? String(parts[parts.length - 1]).trim() : "";
        }

        if (kind === "widget-data") {
            try {
                const manifestText = await readZipTextEntry(file, "omp-widget-runtime-data.json");
                const manifest = manifestText ? JSON.parse(manifestText) : null;
                return manifest && manifest.packageVersion ? String(manifest.packageVersion).trim() : "";
            } catch {
                return "";
            }
        }

        try {
            const document = JSON.parse(await file.text());
            if (kind === "module-definition") {
                return document.definitionVersion ? String(document.definitionVersion).trim() : "";
            }

            if (kind === "host-config") {
                return document.configurationVersion ? String(document.configurationVersion).trim() : "";
            }

            if (kind === "config-overlay") {
                return document.overlayVersion ? String(document.overlayVersion).trim() : "";
            }

            if (kind !== "dashboard-widget") {
                return "";
            }

            if (document.packageVersion) {
                return String(document.packageVersion).trim();
            }

            const versions = Array.isArray(document.widgets)
                ? document.widgets
                    .map(widget => widget && widget.widgetVersion ? String(widget.widgetVersion).trim() : "")
                    .filter(Boolean)
                    .sort((left, right) => compareVersionText(right, left))
                : [];
            return versions[0] || "";
        } catch {
            return "";
        }
    };

    const addFiles = async () => {
        const kind = objectKind.value;
        const folder = folderByKind[kind];
        const host = sanitizeSegment(hostFolder.value);
        const useHostFolder = hostFolder.value.trim().length > 0
            && (kind === "host-config" || kind === "config-overlay" || kind === "dashboard-widget" || kind === "widget-data");
        const selectedFiles = Array.from(objectFiles.files || []);
        for (const file of selectedFiles) {
            const path = normalizePath(`${folder}/${useHostFolder ? `${host}/` : ""}${file.name}`);
            if (items.some(item => item.path.toLowerCase() === path.toLowerCase())) {
                updateStatus(format(labels.duplicate, path), true);
                continue;
            }

            const version = await readItemVersion(kind, file);
            items.push({ kind, path, file, version });
        }

        objectFiles.value = "";
        renderItems();
    };

    const makeCrcTable = () => {
        const table = new Uint32Array(256);
        for (let i = 0; i < 256; i++) {
            let c = i;
            for (let k = 0; k < 8; k++) {
                c = (c & 1) ? (0xedb88320 ^ (c >>> 1)) : (c >>> 1);
            }
            table[i] = c >>> 0;
        }
        return table;
    };

    const crcTable = makeCrcTable();
    const crc32 = bytes => {
        let crc = 0xffffffff;
        for (const byte of bytes) {
            crc = crcTable[(crc ^ byte) & 0xff] ^ (crc >>> 8);
        }
        return (crc ^ 0xffffffff) >>> 0;
    };
    const dosDateTime = date => {
        const year = Math.max(1980, date.getFullYear());
        const dosTime = (date.getHours() << 11) | (date.getMinutes() << 5) | Math.floor(date.getSeconds() / 2);
        const dosDate = ((year - 1980) << 9) | ((date.getMonth() + 1) << 5) | date.getDate();
        return { dosTime, dosDate };
    };
    const uint16 = value => {
        const bytes = new Uint8Array(2);
        new DataView(bytes.buffer).setUint16(0, value, true);
        return bytes;
    };
    const uint32 = value => {
        const bytes = new Uint8Array(4);
        new DataView(bytes.buffer).setUint32(0, value >>> 0, true);
        return bytes;
    };
    const concatBytes = parts => {
        const size = parts.reduce((sum, part) => sum + part.length, 0);
        const result = new Uint8Array(size);
        let offset = 0;
        for (const part of parts) {
            result.set(part, offset);
            offset += part.length;
        }
        return result;
    };
    const createZip = async entries => {
        const localParts = [];
        const centralParts = [];
        let offset = 0;
        const now = dosDateTime(new Date());
        for (const entry of entries) {
            const nameBytes = encoder.encode(entry.name);
            const data = entry.bytes;
            const crc = crc32(data);
            const localHeader = concatBytes([
                uint32(0x04034b50), uint16(20), uint16(0x0800), uint16(0),
                uint16(now.dosTime), uint16(now.dosDate), uint32(crc),
                uint32(data.length), uint32(data.length), uint16(nameBytes.length),
                uint16(0), nameBytes
            ]);
            localParts.push(localHeader, data);
            const centralHeader = concatBytes([
                uint32(0x02014b50), uint16(20), uint16(20), uint16(0x0800),
                uint16(0), uint16(now.dosTime), uint16(now.dosDate), uint32(crc),
                uint32(data.length), uint32(data.length), uint16(nameBytes.length),
                uint16(0), uint16(0), uint16(0), uint16(0), uint32(0),
                uint32(offset), nameBytes
            ]);
            centralParts.push(centralHeader);
            offset += localHeader.length + data.length;
        }

        const centralOffset = offset;
        const central = concatBytes(centralParts);
        const end = concatBytes([
            uint32(0x06054b50), uint16(0), uint16(0), uint16(entries.length),
            uint16(entries.length), uint32(central.length), uint32(centralOffset), uint16(0)
        ]);
        return new Blob([concatBytes([...localParts, central, end])], { type: "application/zip" });
    };

    const createPackage = async () => {
        try {
            const packageItems = [...items].sort((a, b) => a.path.localeCompare(b.path));
            const manifest = {
                formatVersion: 1,
                objectType: "universal-module-package",
                packageKey: document.getElementById("packageKey").value.trim(),
                packageVersion: document.getElementById("packageVersion").value.trim(),
                displayName: document.getElementById("displayName").value.trim(),
                description: document.getElementById("description").value.trim() || null,
                targetHostProfile: document.getElementById("targetHostProfile").value.trim() || null,
                createdUtc: new Date().toISOString(),
                items: packageItems.map(item => {
                    const manifestItem = { kind: item.kind, path: item.path };
                    if (item.version) {
                        manifestItem.version = item.version;
                    }

                    return manifestItem;
                })
            };

            if (!manifest.packageKey || !manifest.packageVersion) {
                updateStatus(labels.required, true);
                return;
            }

            const entries = [];
            for (const item of packageItems) {
                entries.push({
                    name: item.path,
                    bytes: new Uint8Array(await item.file.arrayBuffer())
                });
            }
            entries.push({
                name: "omp-universal-package.json",
                bytes: encoder.encode(JSON.stringify(manifest, null, 2))
            });

            const zip = await createZip(entries);
            const fileName = `${sanitizeSegment(manifest.packageKey)}__${sanitizeSegment(manifest.targetHostProfile || "global")}__${sanitizeSegment(manifest.packageVersion)}.zip`;
            const url = URL.createObjectURL(zip);
            const link = document.createElement("a");
            link.href = url;
            link.download = fileName;
            document.body.appendChild(link);
            link.click();
            link.remove();
            URL.revokeObjectURL(url);
            updateStatus(format(labels.created, fileName));
        } catch (error) {
            updateStatus(error instanceof Error ? error.message : String(error), true);
        }
    };

    document.getElementById("addFiles").addEventListener("click", () => {
        addFiles().catch(error => updateStatus(error instanceof Error ? error.message : String(error), true));
    });
    document.getElementById("clearFiles").addEventListener("click", () => {
        items.length = 0;
        renderItems();
    });
    document.getElementById("createPackage").addEventListener("click", createPackage);
    renderItems();
})();
</script>
