@page
@model OpenModulePlatform.Portal.Pages.Admin.AppInstancesModel

<section class="page-header">
    <div>
        <div class="eyebrow">@L["Runtime result"]</div>
        <h2>@L["App instances"]</h2>
        <p class="lede">
            @L["App instances show the materialized runtime state. For template-managed apps, change host placement, version and desired state on the instance template instead."]
        </p>
    </div>
</section>

<div class="toolbar top-gap">
    <a class="action-link" href="~/admin/appinstanceedit">@L["Create manual app instance"]</a>
    <a class="action-link" href="~/admin/instancetemplateedit?id=1">@L["Open installation"]</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="card status-banner">@Model.StatusMessage</div>
}

@if (Model.Rows.Count == 0)
{
    <div class="empty-state">@L["No app instances found."]</div>
}
else
{
    <div class="table-scroll app-instances-scroll">
        <table class="grid app-instances-grid">
        <thead>
            <tr>
                <th>@L["Instance"]</th>
                <th>@L["Module instance"]</th>
                <th>@L["App"]</th>
                <th>@L["App instance key"]</th>
                <th>@L["Host"]</th>
                <th>@L["Route"]</th>
                <th>@L["Installation"]</th>
                <th>@L["Artifact"]</th>
                <th>@L["Allowed"]</th>
                <th>@L["Last seen"]</th>
                <th>@L["Actions"]</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var row in Model.Rows)
        {
            <tr>
                <td><code>@row.InstanceKey</code></td>
                <td><code>@row.ModuleInstanceKey</code></td>
                <td><code>@row.AppKey</code></td>
                <td><code>@row.AppInstanceKey</code></td>
                <td><code>@row.HostKey</code></td>
                <td>@row.RoutePath</td>
                <td>@row.InstallationName</td>
                <td>@row.ArtifactVersion</td>
                <td><span class="pill">@(row.IsAllowed ? L["Allowed"] : L["Blocked"])</span></td>
                <td>@row.LastSeenUtc?.ToString("u")</td>
                <td>
                    <div class="admin-icon-actions">
                        <a class="action-link admin-icon-button admin-icon-button--clarify"
                           href="~/admin/appinstanceedit?id=@row.AppInstanceId"
                           title="@L["View"]"
                           aria-label="@L["View"]">
                            <span class="visually-hidden">@L["View"]</span>
                        </a>
                        <form method="post"
                              asp-page-handler="DeleteRuntime"
                              asp-route-appInstanceId="@row.AppInstanceId"
                              class="inline-form"
                              onsubmit="return confirm('@L["Delete this runtime row? If the instance template still expects it, HostAgent may recreate it."]');">
                            <button type="submit"
                                    class="btn btn-link-danger admin-icon-button admin-icon-button--delete"
                                    title="@L["Delete runtime row"]"
                                    aria-label="@L["Delete runtime row"]">
                                <span class="visually-hidden">@L["Delete runtime row"]</span>
                            </button>
                        </form>
                    </div>
                </td>
            </tr>
        }
        </tbody>
        </table>
    </div>
}
