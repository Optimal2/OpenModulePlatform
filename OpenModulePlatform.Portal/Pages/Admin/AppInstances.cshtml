@page
@model OpenModulePlatform.Portal.Pages.Admin.AppInstancesModel

<section class="page-header">
    <div>
        <div class="eyebrow">@L["Manual core"]</div>
        <h2>@L["App instances"]</h2>
        <p class="lede">
            App instances are the runtime-facing layer. They connect app definitions
            to hosts, artifacts, route or installation data and observed runtime state.
        </p>
    </div>
</section>

<div class="toolbar top-gap">
    <a class="action-link" href="~/admin/appinstanceedit">@L["Create app instance"]</a>
</div>

@if (Model.Rows.Count == 0)
{
    <div class="empty-state">@L["No app instances found."]</div>
}
else
{
    <div class="table-scroll">
        <table class="grid app-instances-grid">
        <thead>
            <tr>
                <th>@L["Instance"]</th>
                <th>@L["Module instance"]</th>
                <th>@L["App"]</th>
                <th>@L["App instance key"]</th>
                <th>@L["Host"]</th>
                <th>@L["Route"]</th>
                <th>@L["Installation"]</th>
                <th>@L["Artifact"]</th>
                <th>@L["Allowed"]</th>
                <th>@L["Last seen"]</th>
                            <th>@L["Actions"]</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var row in Model.Rows)
        {
            <tr>
                <td><code>@row.InstanceKey</code></td>
                <td><code>@row.ModuleInstanceKey</code></td>
                <td><code>@row.AppKey</code></td>
                <td><code>@row.AppInstanceKey</code></td>
                <td><code>@row.HostKey</code></td>
                <td>@row.RoutePath</td>
                <td>@row.InstallationName</td>
                <td>@row.ArtifactVersion</td>
                <td><span class="pill">@(row.IsAllowed ? L["Allowed"] : L["Blocked"])</span></td>
                <td>@row.LastSeenUtc?.ToString("u")</td>
                <td><a class="action-link" href="~/admin/appinstanceedit?id=@row.AppInstanceId">@L["Edit"]</a></td>
            </tr>
        }
        </tbody>
        </table>
    </div>
}
