@page
@model OpenModulePlatform.Portal.Pages.Admin.AppInstancesModel

<section class="page-header">
    <div>
        <div class="eyebrow">Manual core</div>
        <h2>App instances</h2>
        <p class="lede">
            App instances are the runtime-facing layer. They connect app definitions
            to hosts, artifacts, route or installation data and observed runtime state.
        </p>
    </div>
</section>

<div class="toolbar top-gap">
    <a class="action-link" href="~/admin/appinstanceedit">Create app instance</a>
</div>

@if (Model.Rows.Count == 0)
{
    <div class="empty-state">No app instances found.</div>
}
else
{
    <table class="grid">
        <thead>
            <tr>
                <th>Instance</th>
                <th>Module instance</th>
                <th>App</th>
                <th>App instance key</th>
                <th>Host</th>
                <th>Route</th>
                <th>Installation</th>
                <th>Artifact</th>
                <th>Allowed</th>
                <th>Last seen</th>
                            <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var row in Model.Rows)
        {
            <tr>
                <td><code>@row.InstanceKey</code></td>
                <td><code>@row.ModuleInstanceKey</code></td>
                <td><code>@row.AppKey</code></td>
                <td><code>@row.AppInstanceKey</code></td>
                <td><code>@row.HostKey</code></td>
                <td>@row.RoutePath</td>
                <td>@row.InstallationName</td>
                <td>@row.ArtifactVersion</td>
                <td><span class="pill">@(row.IsAllowed ? "Allowed" : "Blocked")</span></td>
                <td>@row.LastSeenUtc?.ToString("u")</td>
                <td><a class="action-link" href="~/admin/appinstanceedit?id=@row.AppInstanceId">Edit</a></td>
            </tr>
        }
        </tbody>
    </table>
}
