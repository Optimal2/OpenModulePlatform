@page
@model OpenModulePlatform.Portal.Pages.Admin.AutomationModel

<section class="page-header">
    <div>
        <div class="eyebrow">@L["Moved"]</div>
        <h2>@L["Template-driven administration"]</h2>
        <p class="lede">@L["Automation pages now live under System so the admin flow follows the current model: one installation, concrete hosts, deployable apps and HostAgent status."]</p>
    </div>
</section>

<section class="card section-card section-card--wide">
    <h3>@L["Where to go"]</h3>
    <p class="muted">@L["Use these direct links if you reached the old automation page from a bookmark."]</p>
    <div class="link-list">
        <a class="action-link" href="~/admin/instancetemplateedit?id=1">@L["Installation"]</a>
        <a class="action-link" href="~/admin/hosts">@L["Hosts"]</a>
        <a class="action-link" href="~/admin/hostdeployments">@L["Deployment log"]</a>
    </div>
</section>
