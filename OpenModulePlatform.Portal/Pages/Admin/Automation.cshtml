@page
@model OpenModulePlatform.Portal.Pages.Admin.AutomationModel

<section class="page-header">
    <div>
        <div class="eyebrow">@L["Moved"]</div>
        <h2>@L["Template-driven administration"]</h2>
        <p class="lede">@L["Template pages now live under System and Hosts so the admin flow follows the actual model: define desired topology, let HostAgent materialize runtime rows, then inspect the result."]</p>
    </div>
</section>

<section class="card section-card section-card--wide">
    <h3>@L["Where to go"]</h3>
    <p class="muted">@L["Use these direct links if you reached the old automation page from a bookmark."]</p>
    <div class="link-list">
        <a class="action-link" href="~/admin/instancetemplates">@L["Instance templates"]</a>
        <a class="action-link" href="~/admin/hosttemplates">@L["Host templates"]</a>
        <a class="action-link" href="~/admin/hostdeploymentassignments">@L["Host deployment assignments"]</a>
        <a class="action-link" href="~/admin/hostdeployments">@L["Host deployments"]</a>
    </div>
</section>
