@page
@model OpenModulePlatform.Portal.Pages.Admin.HostInstallationsModel

<h2>Host installations</h2>

<table class="grid">
    <thead>
        <tr>
            <th>Hostname</th>
            <th>App key</th>
            <th>Installation</th>
            <th>Artifact</th>
            <th>Desired state</th>
            <th>Last seen</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var row in Model.Rows)
    {
        <tr>
            <td>@(row.Hostname)</td>
            <td>@(row.AppKey)</td>
            <td>@(row.InstallationName)</td>
            <td>@(row.ArtifactVersion)</td>
            <td>@(row.DesiredState.ToString())</td>
            <td>@(row.LastSeenUtc?.ToString("u"))</td>
        </tr>
    }
    </tbody>
</table>
