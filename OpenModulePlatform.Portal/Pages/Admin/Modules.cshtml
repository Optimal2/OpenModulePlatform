@page
@model OpenModulePlatform.Portal.Pages.Admin.ModulesModel

<h2>Modules</h2>

<table class="grid">
    <thead>
        <tr>
            <th>Module key</th>
            <th>Display name</th>
            <th>Type</th>
            <th>Schema</th>
            <th>Enabled</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var row in Model.Rows)
    {
        <tr>
            <td>@(row.ModuleKey)</td>
            <td>@(row.DisplayName)</td>
            <td>@(row.ModuleType)</td>
            <td>@(row.SchemaName)</td>
            <td>@(row.IsEnabled ? "Yes" : "No")</td>
        </tr>
    }
    </tbody>
</table>
