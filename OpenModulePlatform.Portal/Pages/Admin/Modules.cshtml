@page
@model OpenModulePlatform.Portal.Pages.Admin.ModulesModel

<section class="page-header">
    <div>
        <div class="eyebrow">@L["Definitions"]</div>
        <h2>@L["Modules"]</h2>
        <p class="lede">@L["Module definitions are reusable building blocks. They do not describe placement or runtime state."]</p>
    </div>
</section>

<div class="toolbar top-gap">
    <a class="action-link" href="~/admin/moduleedit">@L["Create module"]</a>
</div>

@if (Model.Rows.Count == 0)
{
    <div class="empty-state">@L["No modules found."]</div>
}
else
{
    <table class="grid">
        <thead>
            <tr>
                <th>@L["Module key"]</th>
                <th>@L["Display name"]</th>
                <th>@L["Type"]</th>
                <th>@L["Schema"]</th>
                <th>@L["Enabled"]</th>
                            <th>@L["Actions"]</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var row in Model.Rows)
        {
            <tr>
                <td><code>@row.ModuleKey</code></td>
                <td>@row.DisplayName</td>
                <td>@L[row.ModuleType]</td>
                <td><code>@row.SchemaName</code></td>
                <td><span class="pill">@(row.IsEnabled ? L["Enabled"] : L["Disabled"])</span></td>
                <td><a class="action-link" href="~/admin/moduleedit?id=@row.ModuleId">@L["Edit"]</a></td>
            </tr>
        }
        </tbody>
    </table>
}
