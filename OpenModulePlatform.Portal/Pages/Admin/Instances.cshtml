@page
@model OpenModulePlatform.Portal.Pages.Admin.InstancesModel
@{
    var ompBranding = await OmpBrandingService.GetBrandingAsync(ViewContext.HttpContext.RequestAborted);
}

<section class="page-header">
    <div>
        <div class="eyebrow">@L["Manual core"]</div>
        <h2>@L["Instances"]</h2>
        <p class="lede">@ompBranding.ApplyPlatformName(L["The current Portal workflow treats one OMP database/runtime set as one installation. Use System > Installation for desired topology changes."].Value)</p>
    </div>
</section>

<div class="toolbar top-gap">
    <a class="action-link" href="~/admin/instanceedit">@L["Create instance"]</a>
</div>

@if (Model.Rows.Count == 0)
{
    <div class="empty-state">@L["No instances found."]</div>
}
else
{
    <table class="grid">
        <thead>
            <tr>
                <th>@L["Instance key"]</th>
                <th>@L["Display name"]</th>
                <th>@L["Installation profile"]</th>
                <th>@L["Enabled"]</th>
                            <th>@L["Actions"]</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var row in Model.Rows)
        {
            <tr>
                <td><code>@row.InstanceKey</code></td>
                <td>@row.DisplayName</td>
                <td>@row.InstanceTemplateKey</td>
                <td><span class="pill">@(row.IsEnabled ? L["Enabled"] : L["Disabled"])</span></td>
                <td><a class="action-link" href="~/admin/instanceedit?id=@row.InstanceId">@L["Edit"]</a></td>
            </tr>
        }
        </tbody>
    </table>
}
