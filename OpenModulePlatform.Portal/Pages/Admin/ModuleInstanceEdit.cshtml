@page
@model OpenModulePlatform.Portal.Pages.Admin.ModuleInstanceEditModel

<section class="page-header">
    <div>
        <div class="eyebrow">@L["Manual core"]</div>
        <h2>@(Model.IsCreate ? L["Create module instance"] : L["Edit module instance"])</h2>
        <p class="lede">@L["Module instances bind a module definition to a concrete OMP instance. This is where definitions start becoming operational."]</p>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="card status-banner">@Model.StatusMessage</div>
}

@if (!ViewContext.ModelState.IsValid)
{
    <div class="card validation-summary-errors" asp-validation-summary="All"></div>
}

<form method="post" class="card form-grid">
    <input type="hidden" asp-for="Input.ModuleInstanceId" />

    <div class="field-grid field-grid--2">
        <div class="form-field">
            <label asp-for="Input.InstanceId"></label>
            <select asp-for="Input.InstanceId">
                <option value="">@L["Select instance"]</option>
                @foreach (var option in Model.InstanceOptions)
                {
                    <option value="@option.Value">@option.Label</option>
                }
            </select>
            <span asp-validation-for="Input.InstanceId" class="field-validation-error"></span>
        </div>

        <div class="form-field">
            <label asp-for="Input.ModuleId"></label>
            <select asp-for="Input.ModuleId">
                <option value="">@L["Select module"]</option>
                @foreach (var option in Model.ModuleOptions)
                {
                    <option value="@option.Value">@option.Label</option>
                }
            </select>
            <div class="field-help">@L["Choose the module definition this module instance represents."]</div>
            <span asp-validation-for="Input.ModuleId" class="field-validation-error"></span>
        </div>
    </div>

    <div class="field-grid field-grid--3">
        <div class="form-field">
            <label asp-for="Input.ModuleInstanceKey"></label>
            <input asp-for="Input.ModuleInstanceKey" />
            <span asp-validation-for="Input.ModuleInstanceKey" class="field-validation-error"></span>
        </div>

        <div class="form-field">
            <label asp-for="Input.DisplayName"></label>
            <input asp-for="Input.DisplayName" />
            <span asp-validation-for="Input.DisplayName" class="field-validation-error"></span>
        </div>

        <div class="form-field">
            <label asp-for="Input.SortOrder"></label>
            <input asp-for="Input.SortOrder" type="number" />
        </div>
    </div>

    <div class="form-field">
        <label asp-for="Input.Description"></label>
        <textarea asp-for="Input.Description"></textarea>
    </div>

    <div class="form-field checkbox-row checkbox-row--boxed">
        <input asp-for="Input.IsEnabled" type="checkbox" />
        <label asp-for="Input.IsEnabled"></label>
    </div>

    <div class="toolbar">
        <button type="submit">@L["Save module instance"]</button>
        <a class="action-link" href="~/admin/moduleinstances">@L["Back to module instances"]</a>
    </div>
</form>

@if (!Model.IsCreate)
{
    <form
        method="post"
        asp-page-handler="Delete"
        class="card danger-zone"
        onsubmit="return confirm('@L["Delete this module instance? Related app instances must be removed first."]');">
        <input type="hidden" asp-for="Input.ModuleInstanceId" />
        <h3>@L["Danger zone"]</h3>
        <p class="muted">@L["SQL blocks deletion while app instances or template mappings still depend on this row."]</p>
        <button type="submit" class="btn btn-danger">@L["Delete module instance"]</button>
    </form>
}
