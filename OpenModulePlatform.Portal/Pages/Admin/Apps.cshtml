@page
@model OpenModulePlatform.Portal.Pages.Admin.AppsModel

<section class="page-header">
    <div>
        <div class="eyebrow">Definitions</div>
        <h2>Apps</h2>
        <p class="lede">App definitions belong to modules and describe what can be deployed. Routes, artifacts, installation paths and runtime policy belong to app instances instead of app definitions.</p>
    </div>
</section>

<div class="toolbar top-gap">
    <a class="action-link" href="~/admin/appedit">Create app</a>
</div>

@if (Model.Rows.Count == 0)
{
    <div class="empty-state">No app definitions found.</div>
}
else
{
    <table class="grid">
        <thead>
            <tr>
                <th>Module</th>
                <th>App key</th>
                <th>Display name</th>
                <th>Type</th>
                <th>Enabled</th>
                <th>Description</th>
                            <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var row in Model.Rows)
        {
            <tr>
                <td><code>@row.ModuleKey</code></td>
                <td><code>@row.AppKey</code></td>
                <td>@row.DisplayName</td>
                <td>@row.AppType</td>
                <td><span class="pill">@(row.IsEnabled ? "Enabled" : "Disabled")</span></td>
                <td>@row.Description</td>
                <td><a class="action-link" href="~/admin/appedit?id=@row.AppId">Edit</a></td>
            </tr>
        }
        </tbody>
    </table>
}
