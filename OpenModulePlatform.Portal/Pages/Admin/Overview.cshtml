@page
@model OpenModulePlatform.Portal.Pages.Admin.OverviewModel
@{
    var ompBranding = await OmpBrandingService.GetBrandingAsync(ViewContext.HttpContext.RequestAborted);
}

<section class="page-header">
    <div>
        <div class="eyebrow">@L["Administration"]</div>
        <h2>@ompBranding.ApplyPlatformName(L["OMP admin overview"].Value)</h2>
        <p class="lede">
            @ompBranding.ApplyPlatformName(L["The admin area is organized around one OMP installation. Use Installation for desired topology, Hosts for concrete machines, Apps for deployable components and System for configuration and access."].Value)
        </p>
    </div>
</section>


<div class="section-grid section-grid--wide top-gap">
    <section class="card section-card">
        <h3>@L["Core administration"]</h3>
        <p class="muted">
            @ompBranding.ApplyPlatformName(L["These pages are the main workflow when setting up and maintaining the OMP installation."].Value)
        </p>
        <div class="toolbar">
            <a class="action-link" href="~/admin/instancetemplateedit?id=1">@L["Installation"]</a>
            <a class="action-link" href="~/admin/hosts">@L["Hosts"]</a>
            <a class="action-link" href="~/admin/modules">@L["Modules"]</a>
            <a class="action-link" href="~/admin/moduleinstances">@L["Module instances"]</a>
            <a class="action-link" href="~/admin/apps">@L["Apps"]</a>
            <a class="action-link" href="~/admin/appinstances">@L["App instances"]</a>
            <a class="action-link" href="~/admin/workers">@L["Workers"]</a>
            <a class="action-link" href="~/admin/artifacts">@L["Artifacts"]</a>
            <a class="action-link" href="~/admin/configsettings">@L["Config settings"]</a>
        </div>
    </section>

    <section class="card section-card">
        <h3>@L["HostAgent"]</h3>
        <p class="muted">
            @L["HostAgent follows the desired installation state and records deployment attempts for review."]
        </p>
        <div class="toolbar">
            <a class="action-link" href="~/admin/hostdeployments">@L["Open deployment log"]</a>
        </div>
    </section>

    <section class="card section-card">
        <h3>@L["Security and access"]</h3>
        <p class="muted">@L["Manage admin permissions and role assignments separately from topology and runtime data."]</p>
        <div class="toolbar">
            <a class="action-link" href="~/admin/security">@L["Open Security"]</a>
        </div>
    </section>
</div>
