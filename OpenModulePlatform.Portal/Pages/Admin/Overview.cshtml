@page
@model OpenModulePlatform.Portal.Pages.Admin.OverviewModel
@{
    var ompBranding = await OmpBrandingService.GetBrandingAsync(ViewContext.HttpContext.RequestAborted);
}

<section class="page-header">
    <div>
        <div class="eyebrow">@L["Administration"]</div>
        <h2>@ompBranding.ApplyPlatformName(L["OMP admin overview"].Value)</h2>
        <p class="lede">
            @ompBranding.ApplyPlatformName(L["The admin area is organized around one OMP installation. Use Installation for desired topology, Import/export for portable objects, and Operations for HostAgent troubleshooting."].Value)
        </p>
    </div>
</section>


<div class="section-grid section-grid--wide top-gap">
    <section class="card section-card">
        <h3>@L["Installation workflow"]</h3>
        <p class="muted">
            @ompBranding.ApplyPlatformName(L["These are the normal pages for setup, upgrade, import, export and troubleshooting."].Value)
        </p>
        <div class="toolbar">
            <a class="action-link" href="~/admin/instancetemplateedit?id=1">@L["Installation"]</a>
            <a class="action-link" href="~/admin/modulepackageimport">@L["Import/export"]</a>
            <a class="action-link" href="~/admin/hostdeployments">@L["Operations"]</a>
        </div>
    </section>

    <section class="card section-card">
        <h3>@L["Object tools"]</h3>
        <p class="muted">
            @L["Use these standalone-compatible editors when preparing module definitions, artifact packages or machine-specific installer profiles."]
        </p>
        <div class="toolbar">
            <a class="action-link" href="~/admin/moduledefinitioneditor">@L["Module definition editor"]</a>
            <a class="action-link" href="~/admin/artifactpackageeditor">@L["Artifact package editor"]</a>
            <a class="action-link" href="~/admin/configoverlayeditor">@L["Config overlay editor"]</a>
            <a class="action-link" href="~/admin/bootstrapconfigeditor">@L["Bootstrap config editor"]</a>
        </div>
    </section>

    <section class="card section-card">
        <h3>@L["Security and access"]</h3>
        <p class="muted">@L["Manage admin permissions and role assignments separately from topology and runtime data."]</p>
        <div class="toolbar">
            <a class="action-link" href="~/admin/security">@L["Open Security"]</a>
        </div>
    </section>
</div>
