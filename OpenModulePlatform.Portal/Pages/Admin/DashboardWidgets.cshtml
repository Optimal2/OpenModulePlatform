@page
@model OpenModulePlatform.Portal.Pages.Admin.DashboardWidgetsModel

<section class="page-header">
    <div>
        <div class="eyebrow">@L["System"]</div>
        <h2>@L["Dashboard widgets"]</h2>
        <p class="lede">@L["Manage registered Portal dashboard widget definitions and availability."]</p>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="card status-banner">@Model.StatusMessage</div>
}

@if (!ViewContext.ModelState.IsValid)
{
    <div class="card validation-summary-errors" asp-validation-summary="All"></div>
}

@if (Model.EditDescriptionRow is not null)
{
    <section class="card top-gap">
        <h3>@L["Edit description"]</h3>
        <p class="muted">
            @Model.EditDescriptionRow.Title
            <code>@Model.EditDescriptionRow.WidgetKey</code>
        </p>
        <form method="post" asp-page-handler="UpdateDescription" class="form-grid">
            <input type="hidden" name="widgetId" value="@Model.EditDescriptionRow.WidgetId" />
            <div class="form-field">
                <label for="dashboard-widget-description">@L["Description"]</label>
                <textarea id="dashboard-widget-description"
                          name="description"
                          rows="4"
                          maxlength="1000">@Model.EditDescriptionRow.Description</textarea>
                <div class="field-help">@L["Leave empty to clear the widget description."]</div>
            </div>
            <div class="toolbar">
                <button type="submit">@L["Save description"]</button>
                <a class="action-link" href="~/admin/dashboardwidgets">@L["Cancel"]</a>
            </div>
        </form>
    </section>
}

<section class="card top-gap">
    <div class="section-heading-row">
        <div>
            <h3>@L["Existing widgets"]</h3>
            <p class="lede">@L["These widget definitions are currently registered in this OMP installation."]</p>
        </div>
    </div>

    @if (Model.Rows.Count == 0)
    {
        <div class="empty-state">@L["No dashboard widgets found."]</div>
    }
    else
    {
        var widgetTypes = Model.Rows
            .Select(row => row.WidgetType)
            .Where(type => !string.IsNullOrWhiteSpace(type))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(type => type, StringComparer.OrdinalIgnoreCase)
            .ToList();

        <div class="toolbar">
            <details class="list-filter" data-list-filter="dashboard-widgets-list">
                <summary class="btn btn-ghost">@L["Filter"]<span class="list-filter__count" data-filter-count hidden></span></summary>
                <div class="list-filter__menu">
                    <fieldset class="list-filter__group" data-filter-group="status">
                        <legend>@L["Status"]</legend>
                        <label class="list-filter__option"><input type="checkbox" data-filter-column="7" data-filter-equals="1" /> @L["Enabled"]</label>
                        <label class="list-filter__option"><input type="checkbox" data-filter-column="7" data-filter-equals="0" /> @L["Disabled"]</label>
                    </fieldset>
                    <fieldset class="list-filter__group" data-filter-group="widgettype">
                        <legend>@L["Widget type"]</legend>
                        @foreach (var widgetType in widgetTypes)
                        {
                            <label class="list-filter__option"><input type="checkbox" data-filter-column="4" data-filter-equals="@widgetType" /> @widgetType</label>
                        }
                    </fieldset>
                    <fieldset class="list-filter__group" data-filter-group="access">
                        <legend>@L["Access"]</legend>
                        <label class="list-filter__option"><input type="checkbox" data-filter-column="8" data-filter-equals="all" /> @L["All signed-in users"]</label>
                        <label class="list-filter__option"><input type="checkbox" data-filter-column="8" data-filter-equals="restricted" /> @L["Restricted"]</label>
                    </fieldset>
                    <button type="button" class="btn btn-ghost btn-sm" data-filter-clear>@L["Clear filters"]</button>
                </div>
            </details>
            <input type="search" class="list-search" data-list-search="dashboard-widgets-list" placeholder="@L["Search rows"]" aria-label="@L["Search rows"]" />
            <span class="list-count" data-list-count="dashboard-widgets-list" data-template="@L["Showing {0} of {1} rows."]"></span>
        </div>
        <div class="empty-state" data-list-empty="dashboard-widgets-list" hidden>@L["No rows match the current filters."]</div>
        <div class="table-scroll dashboard-widgets-admin-scroll">
            <table id="dashboard-widgets-list" class="grid dashboard-widgets-admin-grid sortable-list" data-sortable-list data-page-size="50">
                <colgroup>
                    <col class="dashboard-widgets-admin-grid__module" />
                    <col class="dashboard-widgets-admin-grid__key" />
                    <col class="dashboard-widgets-admin-grid__title" />
                    <col class="dashboard-widgets-admin-grid__description" />
                    <col class="dashboard-widgets-admin-grid__type" />
                    <col class="dashboard-widgets-admin-grid__payload" />
                    <col class="dashboard-widgets-admin-grid__version" />
                    <col class="dashboard-widgets-admin-grid__status" />
                    <col class="dashboard-widgets-admin-grid__access" />
                    <col class="dashboard-widgets-admin-grid__modified" />
                    <col class="dashboard-widgets-admin-grid__actions" />
                </colgroup>
                <thead>
                    <tr>
                        <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["Module key"]</button></th>
                        <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["Widget key"]</button></th>
                        <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["Title"]</button></th>
                        <th scope="col">@L["Description"]</th>
                        <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["Widget type"]</button></th>
                        <th scope="col">@L["Payload"]</th>
                        <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["Version"]</button></th>
                        <th scope="col" data-sort-type="number"><button type="button" class="sortable-list__button">@L["Status"]</button></th>
                        <th scope="col">@L["Access"]</th>
                        <th scope="col" data-sort-type="date"><button type="button" class="sortable-list__button">@L["Modified"]</button></th>
                        <th scope="col" class="actions-col">@L["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.Rows)
                {
                    <tr class="@(row.IsEnabled ? string.Empty : "dashboard-widget-admin-row--disabled")">
                        <td><code>@row.ModuleKey</code></td>
                        <td><code>@row.WidgetKey</code></td>
                        <td>@row.Title</td>
                        <td class="small-text">
                            @* Packaged widgets may store either a localization key or plain text; IStringLocalizer falls back to the original text when no key exists. *@
                            @(string.IsNullOrWhiteSpace(row.Description) ? L["No description available"] : L[row.Description].Value)
                        </td>
                        <td>@row.WidgetType</td>
                        <td><code>@row.Payload</code></td>
                        <td><code>@row.WidgetVersion</code></td>
                        <td data-sort-value="@(row.IsEnabled ? "1" : "0")">
                            <span class="pill">@(row.IsEnabled ? L["Enabled"] : L["Disabled"])</span>
                        </td>
                        <td data-sort-value="@(row.PermissionNames.Count == 0 && row.RoleNames.Count == 0 ? "all" : "restricted")">
                            @if (row.PermissionNames.Count == 0 && row.RoleNames.Count == 0)
                            {
                                <span class="pill">@L["All signed-in users"]</span>
                            }
                            else
                            {
                                @if (row.PermissionNames.Count > 0)
                                {
                                    <div><strong>@L["Permissions"]:</strong> @string.Join(", ", row.PermissionNames)</div>
                                }
                                @if (row.RoleNames.Count > 0)
                                {
                                    <div><strong>@L["Roles"]:</strong> @string.Join(", ", row.RoleNames)</div>
                                }
                            }
                        </td>
                        <td data-sort-value="@row.ModifiedUtc.ToUniversalTime().ToString("yyyy-MM-dd'T'HH:mm:ss'Z'", System.Globalization.CultureInfo.InvariantCulture)">@row.ModifiedUtc.ToLocalTime().ToString("g")</td>
                        <td class="actions-col">
                            <a class="action-link admin-icon-button admin-icon-button--edit"
                               asp-page="/Admin/DashboardWidgets"
                               asp-route-editWidgetId="@row.WidgetId"
                               title="@L["Edit description"]"
                               aria-label="@L["Edit description"]">
                                <span class="visually-hidden">@L["Edit description"]</span>
                            </a>
                            <form method="post" asp-page-handler="SetEnabled" class="inline-form">
                                <input type="hidden" name="widgetId" value="@row.WidgetId" />
                                <input type="hidden" name="isEnabled" value="@(!row.IsEnabled)" />
                                <button type="submit"
                                        class="admin-icon-button @(row.IsEnabled ? "admin-icon-button--visible-off" : "admin-icon-button--visible")"
                                        title="@(row.IsEnabled ? L["Disable widget"] : L["Enable widget"])"
                                        aria-label="@(row.IsEnabled ? L["Disable widget"] : L["Enable widget"])">
                                    <span class="visually-hidden">@(row.IsEnabled ? L["Disable widget"] : L["Enable widget"])</span>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <div class="list-show-more">
            <button type="button" class="btn btn-secondary btn-sm" data-list-show-more="dashboard-widgets-list" hidden>@L["Show more"]</button>
        </div>
    }
</section>

<div class="toolbar top-gap">
    <a class="action-link" href="~/admin/overview">@L["Back to overview"]</a>
</div>
