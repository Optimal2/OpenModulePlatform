@page
@model OpenModulePlatform.Portal.Pages.Admin.ModulePackageImportModel
@{
    var statusMessage = Model.InlineStatusMessage ?? Model.StatusMessage;
}

<section class="page-header">
    <div>
        <div class="eyebrow">@L["System"]</div>
        <h2>@L["Import/export"]</h2>
        <p class="lede">@L["Import and export OMP installation objects with the universal module package format. Individual legacy package formats are intentionally kept out of this workflow."]</p>
    </div>
</section>

<div class="toolbar top-gap">
    <a class="action-link" href="~/admin/universalpackagebuilder">@L["Create universal package"]</a>
</div>

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="card status-banner">@statusMessage</div>
}

@if (Model.UniversalImportResults.Count > 0)
{
    <section class="card top-gap">
        <h3>@L["Import details"]</h3>
        <p class="muted">
            @string.Format(
                L["Showing {0} import detail rows from the completed import response. These details are rendered in the page and are not stored in cookies."].Value,
                Model.UniversalImportDetailCount)
        </p>
        <div class="table-scroll">
            <table class="grid">
                <thead>
                    <tr>
                        <th>@L["Package"]</th>
                        <th>@L["Kind"]</th>
                        <th>@L["Path"]</th>
                        <th>@L["Status"]</th>
                        <th>@L["Message"]</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var result in Model.UniversalImportResults)
                {
                    foreach (var item in result.Items)
                    {
                        <tr>
                            <td>
                                <code>@result.PackageName</code>
                                <div class="small-text">
                                    @string.Format(
                                        L["Imported/updated: {0}. Skipped: {1}. Failed: {2}."].Value,
                                        result.ImportedCount,
                                        result.SkippedCount,
                                        result.FailedCount)
                                    @if (!string.IsNullOrWhiteSpace(result.TargetHostProfile))
                                    {
                                        <span>@string.Format(L["Target host profile: {0}."].Value, result.TargetHostProfile)</span>
                                    }
                                </div>
                            </td>
                            <td>@item.Kind</td>
                            <td><code>@item.Path</code></td>
                            <td>@item.Status</td>
                            <td>@item.Message</td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </section>
}

@if (!ViewContext.ModelState.IsValid)
{
    <div class="card validation-summary-errors" asp-validation-summary="All"></div>
}

<section class="import-export-tabs top-gap" data-import-export-tabs data-initial-panel="@Model.ActivePanel">
    <div class="tab-list" role="tablist" aria-label="@L["Import/export"]">
        <button type="button" class="tab-button" role="tab" data-package-tab="import-universal" aria-controls="import-universal-panel">
            <span aria-hidden="true">↓</span>
            <span>@L["Import"]</span>
        </button>
        <button type="button" class="tab-button" role="tab" data-package-tab="export-universal" aria-controls="export-universal-panel">
            <span aria-hidden="true">↑</span>
            <span>@L["Export"]</span>
        </button>
    </div>

    <section class="card import-export-panel" id="import-universal-panel" role="tabpanel" data-package-panel="import-universal" hidden>
        <h3>@L["Import universal module package"]</h3>
        <p class="muted">@L["Use this for the new universal package format with omp-universal-package.json and standard object folders. Each object is imported independently so one failed item does not stop the rest."]</p>

        <form method="post" enctype="multipart/form-data" class="form-grid top-gap">
            <div class="form-field">
                <label asp-for="UniversalUploadInput.PackageFiles">@L["Universal module package zip"]</label>
                <div class="file-drop-area" data-file-drop-area tabindex="0" role="button" aria-label="@L["Drop universal package files here or click to browse."]">
                    <input asp-for="UniversalUploadInput.PackageFiles" type="file" accept=".zip,application/zip" multiple data-file-input />
                    <div class="file-drop-area__content">
                        <div class="file-drop-area__icon" aria-hidden="true">↓</div>
                        <div>
                            <strong>@L["Drop universal package files here"]</strong>
                            <div class="muted">@L["or click anywhere in this area to browse for one or more zip files."]</div>
                        </div>
                    </div>
                    <ul class="file-drop-area__list" data-file-list hidden></ul>
                </div>
                <div class="field-help">@L["Preview lets you choose individual items. Import all applies every supported item immediately."]</div>
            </div>

            <div class="option-cluster option-cluster--2">
                <label class="checkbox-row checkbox-row--boxed">
                    <input asp-for="UniversalUploadInput.QuickImport" type="checkbox" data-quick-import-toggle />
                    <span>@L["Quick import"]</span>
                </label>

                <label class="checkbox-row checkbox-row--boxed">
                    <input asp-for="UniversalUploadInput.ApplyModuleDefinitions" type="checkbox" />
                    <span>@L["Apply module definitions"]</span>
                </label>

                <label class="checkbox-row checkbox-row--boxed">
                    <input asp-for="UniversalUploadInput.ExecuteSqlRepairs" type="checkbox" />
                    <span>@L["Execute detected SQL repairs"]</span>
                </label>

                <label class="checkbox-row checkbox-row--boxed">
                    <input asp-for="UniversalUploadInput.UseArtifactsImmediately" type="checkbox" />
                    <span>@L["Use imported artifacts immediately"]</span>
                </label>

                <label class="checkbox-row checkbox-row--boxed">
                    <input asp-for="UniversalUploadInput.CopyConfigurationFilesFromPreviousVersion" type="checkbox" />
                    <span>@L["Copy configuration files from previous version"]</span>
                </label>

                <label class="checkbox-row checkbox-row--boxed">
                    <input asp-for="UniversalUploadInput.AllowTemporaryIncompatibleArtifacts" type="checkbox" />
                    <span>@L["Allow temporary incompatible artifact selections"]</span>
                </label>

                <label class="checkbox-row checkbox-row--boxed">
                    <input asp-for="UniversalUploadInput.ReplaceExistingModuleDefinitions" type="checkbox" data-quick-import-disabled />
                    <span>@L["Replace existing module definitions with same key and version"]</span>
                </label>

                <label class="checkbox-row checkbox-row--boxed">
                    <input asp-for="UniversalUploadInput.ReplaceExistingArtifacts" type="checkbox" data-quick-import-disabled />
                    <span>@L["Replace existing artifacts with same identity"]</span>
                </label>

                <label class="checkbox-row checkbox-row--boxed">
                    <input asp-for="UniversalUploadInput.ReplaceExistingDashboardWidgets" type="checkbox" data-quick-import-disabled />
                    <span>@L["Replace existing dashboard widgets for rollback or repair"]</span>
                </label>

                <label class="checkbox-row checkbox-row--boxed">
                    <input asp-for="UniversalUploadInput.ReplaceExistingConfigObjects" type="checkbox" data-quick-import-disabled />
                    <span>@L["Replace existing host configs and overlays with same key and version"]</span>
                </label>
            </div>

            <div class="toolbar">
                <button type="submit" asp-page-handler="PreviewUniversal">@L["Preview and choose"]</button>
                <button type="submit" asp-page-handler="ImportUniversal">@L["Import all"]</button>
            </div>
        </form>

        @if (Model.UniversalPreview is not null)
        {
            <form method="post" asp-page-handler="ImportStagedUniversal" class="form-grid top-gap">
                <input type="hidden" asp-for="UniversalStagedInput.Token" />
                <input type="hidden" asp-for="UniversalStagedInput.QuickImport" />
                <input type="hidden" asp-for="UniversalStagedInput.ApplyModuleDefinitions" />
                <input type="hidden" asp-for="UniversalStagedInput.ExecuteSqlRepairs" />
                <input type="hidden" asp-for="UniversalStagedInput.UseArtifactsImmediately" />
                <input type="hidden" asp-for="UniversalStagedInput.CopyConfigurationFilesFromPreviousVersion" />
                <input type="hidden" asp-for="UniversalStagedInput.AllowTemporaryIncompatibleArtifacts" />
                <input type="hidden" asp-for="UniversalStagedInput.ReplaceExistingModuleDefinitions" />
                <input type="hidden" asp-for="UniversalStagedInput.ReplaceExistingArtifacts" />
                <input type="hidden" asp-for="UniversalStagedInput.ReplaceExistingDashboardWidgets" />
                <input type="hidden" asp-for="UniversalStagedInput.ReplaceExistingConfigObjects" />

                <div class="section-heading-row">
                    <div>
                        <h4>@L["Package contents"]</h4>
                        <p class="muted">
                            @Model.UniversalPreview.DisplayName
                            @if (!string.IsNullOrWhiteSpace(Model.UniversalPreview.TargetHostProfile))
                            {
                                <span>@string.Format(L["Target host: {0}"].Value, Model.UniversalPreview.TargetHostProfile)</span>
                            }
                        </p>
                    </div>
                </div>

                <div class="table-scroll">
                    <table class="grid">
                        <thead>
                            <tr>
                                <th>@L["Import"]</th>
                                <th>@L["Kind"]</th>
                                <th>@L["Path"]</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model.UniversalPreview.Items)
                        {
                            <tr>
                                <td>
                                    <input type="checkbox" name="UniversalStagedInput.SelectedItemPaths" value="@item.Path" checked />
                                </td>
                                <td>@item.Kind</td>
                                <td><code aria-label="@L["Package item path"]: @item.Path">@item.Path</code></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>

                <div class="toolbar">
                    <button type="submit">@L["Import selected items"]</button>
                </div>
            </form>
        }
    </section>

    <section class="card import-export-panel" id="export-universal-panel" role="tabpanel" data-package-panel="export-universal" hidden>
        <h3>@L["Export universal module package"]</h3>
        <p class="muted">@L["Create one universal zip with any mix of module definitions, artifact packages, host configs, config overlays, widgets, and widget runtime data."]</p>

        <form method="get" asp-page-handler="ExportUniversal" class="form-grid top-gap">
            <div class="field-grid field-grid--2">
                <div class="form-field">
                    <label asp-for="UniversalExportInput.PackageKey">@L["Package key"]</label>
                    <input asp-for="UniversalExportInput.PackageKey" />
                </div>
                <div class="form-field">
                    <label asp-for="UniversalExportInput.PackageVersion">@L["Package version"]</label>
                    <input asp-for="UniversalExportInput.PackageVersion" />
                </div>
                <div class="form-field">
                    <label asp-for="UniversalExportInput.DisplayName">@L["Display name"]</label>
                    <input asp-for="UniversalExportInput.DisplayName" />
                </div>
                <div class="form-field">
                    <label asp-for="UniversalExportInput.TargetHostProfile">@L["Target host profile"]</label>
                    <input asp-for="UniversalExportInput.TargetHostProfile" placeholder="@L["Optional"]" />
                    <div class="field-help">@L["Leave empty for a global/generic package."]</div>
                </div>
            </div>

            <div class="form-field">
                <label asp-for="UniversalExportInput.Description">@L["Description"]</label>
                <input asp-for="UniversalExportInput.Description" />
            </div>

            <div class="option-cluster option-cluster--2">
                <label class="checkbox-row checkbox-row--boxed">
                    <input asp-for="UniversalExportInput.IncludeArtifactsForSelectedModules" type="checkbox" />
                    <span>@L["Include compatible artifacts for selected modules"]</span>
                </label>
                <label class="checkbox-row checkbox-row--boxed">
                    <input asp-for="UniversalExportInput.IncludeAllArtifactVersions" type="checkbox" />
                    <span>@L["Include historical artifact versions for selected modules"]</span>
                </label>
                <label class="checkbox-row checkbox-row--boxed">
                    <input asp-for="UniversalExportInput.IncludeWidgetRuntimeData" type="checkbox" />
                    <span>@L["Include runtime data for selected widgets"]</span>
                </label>
            </div>

            <div class="field-grid field-grid--2">
                <div class="form-field">
                    <h4>@L["Module definitions"]</h4>
                    <div class="selection-list">
                        @foreach (var definition in Model.AppliedDefinitions)
                        {
                            <label class="checkbox-row">
                                <input type="checkbox" name="UniversalExportInput.ModuleKeys" value="@definition.ModuleKey" />
                                <span><code>@definition.ModuleKey</code> @definition.DefinitionVersion</span>
                            </label>
                        }
                    </div>
                </div>

                <div class="form-field">
                    <h4>@L["Artifacts"]</h4>
                    <div class="selection-list">
                        @foreach (var artifact in Model.ArtifactRows)
                        {
                            <label class="checkbox-row">
                                <input type="checkbox" name="UniversalExportInput.ArtifactIds" value="@artifact.ArtifactId" />
                                <span><code>@artifact.ModuleKey/@artifact.AppKey</code> @artifact.PackageType @artifact.Version</span>
                            </label>
                        }
                    </div>
                </div>

                <div class="form-field">
                    <h4>@L["Host configs"]</h4>
                    <div class="selection-list">
                        @foreach (var item in Model.HostConfigurationRows)
                        {
                            <label class="checkbox-row">
                                <input type="checkbox" name="UniversalExportInput.HostConfigurationDocumentIds" value="@item.HostConfigurationDocumentId" />
                                <span><code>@item.HostKey</code> @item.ConfigurationVersion</span>
                            </label>
                        }
                    </div>
                </div>

                <div class="form-field">
                    <h4>@L["Config overlays"]</h4>
                    <div class="selection-list">
                        @foreach (var item in Model.ConfigOverlayRows)
                        {
                            <label class="checkbox-row">
                                <input type="checkbox" name="UniversalExportInput.ConfigOverlayDocumentIds" value="@item.ConfigOverlayDocumentId" />
                                <span><code>@item.HostKey/@item.OverlayKey</code> @item.OverlayVersion</span>
                            </label>
                        }
                    </div>
                </div>

                <div class="form-field">
                    <h4>@L["Widgets"]</h4>
                    <div class="selection-list">
                        @foreach (var widget in Model.WidgetRows)
                        {
                            <label class="checkbox-row">
                                <input type="checkbox" name="UniversalExportInput.WidgetIds" value="@widget.WidgetId" />
                                <span>@widget.Title <code>@widget.WidgetKey</code> @widget.WidgetVersion</span>
                            </label>
                        }
                    </div>
                </div>
            </div>

            <div class="toolbar">
                <button type="submit">@L["Export universal zip"]</button>
            </div>
        </form>
    </section>

</section>

<script>
(() => {
    const root = document.querySelector('[data-import-export-tabs]');
    if (!root) {
        return;
    }

    const tabs = Array.from(root.querySelectorAll('[data-package-tab]'));
    const panels = Array.from(root.querySelectorAll('[data-package-panel]'));
    const dropAreas = Array.from(root.querySelectorAll('[data-file-drop-area]'));

    const setSelected = (activeTab) => {
        tabs.forEach(button => {
            const isActive = button === activeTab;
            button.setAttribute('aria-selected', isActive ? 'true' : 'false');
            button.tabIndex = isActive ? 0 : -1;
        });
    };

    const showPanel = panelName => {
        const panel = panels.find(candidate => candidate.dataset.packagePanel === panelName)
            || panels.find(candidate => candidate.dataset.packagePanel === 'import-universal');
        if (!panel) {
            return;
        }

        const tab = tabs.find(button => button.dataset.packageTab === panel.dataset.packagePanel);
        if (tab) {
            setSelected(tab);
        }

        panels.forEach(candidate => {
            candidate.hidden = candidate !== panel;
        });
    };

    tabs.forEach(button => {
        button.addEventListener('click', () => showPanel(button.dataset.packageTab));
    });

    dropAreas.forEach(area => {
        const input = area.querySelector('[data-file-input]');
        const list = area.querySelector('[data-file-list]');
        if (!input || !list) {
            return;
        }

        const renderFiles = () => {
            list.replaceChildren();
            const files = Array.from(input.files || []);
            list.hidden = files.length === 0;
            files.forEach(file => {
                const item = document.createElement('li');
                item.textContent = file.name;
                list.appendChild(item);
            });
        };

        area.addEventListener('click', event => {
            if (event.target === input) {
                return;
            }
            input.click();
        });

        area.addEventListener('keydown', event => {
            if (event.key === 'Enter' || event.key === ' ') {
                event.preventDefault();
                input.click();
            }
        });

        area.addEventListener('dragover', event => {
            event.preventDefault();
            area.classList.add('is-drag-over');
        });

        area.addEventListener('dragleave', event => {
            if (!area.contains(event.relatedTarget)) {
                area.classList.remove('is-drag-over');
            }
        });

        area.addEventListener('drop', event => {
            event.preventDefault();
            area.classList.remove('is-drag-over');
            if (event.dataTransfer?.files?.length) {
                input.files = event.dataTransfer.files;
                renderFiles();
            }
        });

        input.addEventListener('change', renderFiles);
        renderFiles();
    });

    const quickImportToggle = root.querySelector('[data-quick-import-toggle]');
    const quickImportDisabledOptions = Array.from(root.querySelectorAll('[data-quick-import-disabled]'));
    const syncQuickImportOptions = () => {
        const quickImportEnabled = Boolean(quickImportToggle?.checked);
        quickImportDisabledOptions.forEach(input => {
            if (quickImportEnabled) {
                input.checked = false;
            }

            input.disabled = quickImportEnabled;
            input.closest('.checkbox-row')?.classList.toggle('is-disabled', quickImportEnabled);
        });
    };

    if (quickImportToggle) {
        quickImportToggle.addEventListener('change', syncQuickImportOptions);
        syncQuickImportOptions();
    }

    if (root.dataset.initialPanel) {
        showPanel(root.dataset.initialPanel);
    } else {
        showPanel('import-universal');
    }
})();
</script>
