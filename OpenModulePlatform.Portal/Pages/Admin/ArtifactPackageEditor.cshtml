@page
@model OpenModulePlatform.Portal.Pages.Admin.ArtifactPackageEditorModel

<section class="page-header">
    <div>
        <div class="eyebrow">@L["Artifacts"]</div>
        <h2>@L["Artifact package editor"]</h2>
        <p class="lede">@L["Use this editor to create manifest-based artifact packages with a deployable payload and deployment-owned configuration files."]</p>
    </div>
</section>

<div class="toolbar top-gap">
    <a class="action-link" href="~/admin/artifactupload">@L["Upload artifact"]</a>
    <a class="action-link" href="~/admin/artifacts">@L["Back to artifacts"]</a>
</div>

<iframe
    class="module-definition-editor-frame top-gap"
    title="@L["Artifact package editor"]"
    src="~/tools/artifact-package-editor/index.html"></iframe>
