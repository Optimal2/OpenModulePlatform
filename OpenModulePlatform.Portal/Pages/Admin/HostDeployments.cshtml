@page
@model OpenModulePlatform.Portal.Pages.Admin.HostDeploymentsModel

<section class="page-header">
    <div>
        <div class="eyebrow">@L["System"]</div>
        <h2>@L["Operations"]</h2>
        <p class="lede">@L["Inspect HostAgent app deployments, artifact provisioning history, and runtime identity checks."]</p>
    </div>
</section>

@if (TempData["StatusMessage"] is string statusMessage && !string.IsNullOrWhiteSpace(statusMessage))
{
    <section class="section-card section-card--wide">
        <div class="notice">@statusMessage</div>
    </section>
}

<section class="card section-card section-card--wide">
    <h3>@L["Web app health"]</h3>
    <p class="muted">@L["Shows per-host web app probes written by HostAgent. Portal health should return a non-success status when the app cannot serve real traffic."]</p>

    @if (Model.WebAppHealthStates.Count == 0)
    {
        <div class="empty-state">@L["No web app health state has been recorded yet."]</div>
    }
    else
    {
        <div class="table-scroll">
            <table class="grid app-instances-grid">
                <thead>
                    <tr>
                        <th>@L["Host"]</th>
                        <th>@L["App"]</th>
                        <th>@L["Status"]</th>
                        <th>@L["Probe"]</th>
                        <th>@L["Failures"]</th>
                        <th>@L["Last action"]</th>
                        <th>@L["Message"]</th>
                        <th>@L["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.WebAppHealthStates)
                {
                    <tr>
                        <td>
                            <div><code>@row.HostKey</code></div>
                            @if (!string.IsNullOrWhiteSpace(row.HostDisplayName))
                            {
                                <div class="muted">@row.HostDisplayName</div>
                            }
                        </td>
                        <td>
                            <div>@(string.IsNullOrWhiteSpace(row.DisplayName) ? row.HealthKey : row.DisplayName)</div>
                            <div class="muted"><code>@row.HealthKey</code></div>
                            @if (!string.IsNullOrWhiteSpace(row.AppPoolName))
                            {
                                <div class="muted">@L["App pool"]: <code>@row.AppPoolName</code></div>
                            }
                        </td>
                        <td>
                            <span class="pill">@L[HostDeploymentsModel.FormatWebAppHealthStatus(row.Status)]</span>
                            @if (row.HttpStatusCode.HasValue)
                            {
                                <div class="muted">HTTP @row.HttpStatusCode</div>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(row.ProbeUrl))
                            {
                                <div><code>@row.ProbeUrl</code></div>
                            }
                            @if (row.LastProbeUtc.HasValue)
                            {
                                <div class="muted">@L["Last checked UTC"]: @row.LastProbeUtc.Value.ToString("u")</div>
                            }
                            @if (row.LastSuccessUtc.HasValue)
                            {
                                <div class="muted">@L["Last success UTC"]: @row.LastSuccessUtc.Value.ToString("u")</div>
                            }
                            @if (row.LastFailureUtc.HasValue)
                            {
                                <div class="muted">@L["Last failure UTC"]: @row.LastFailureUtc.Value.ToString("u")</div>
                            }
                        </td>
                        <td>@row.ConsecutiveFailures</td>
                        <td>
                            @if (row.LastActionUtc.HasValue)
                            {
                                <div>@row.LastActionUtc.Value.ToString("u")</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(row.LastActionMessage))
                            {
                                <div class="muted">@row.LastActionMessage</div>
                            }
                            @if (!row.LastActionUtc.HasValue && string.IsNullOrWhiteSpace(row.LastActionMessage))
                            {
                                <span class="muted">@L["None"]</span>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(row.LastError))
                            {
                                <div>@row.LastError</div>
                            }
                            else if (!string.IsNullOrWhiteSpace(row.ResponseSummary))
                            {
                                <div class="muted">@row.ResponseSummary</div>
                            }
                            else
                            {
                                <span class="muted">@L["None"]</span>
                            }
                        </td>
                        <td>
                            <form method="post" asp-page-handler="ProbeWebAppHealth" class="inline-form">
                                <input type="hidden" name="hostId" value="@row.HostId" />
                                <input type="hidden" name="healthKey" value="@row.HealthKey" />
                                <button type="submit" class="btn btn-secondary">@L["Probe now"]</button>
                            </form>
                            <form method="post" asp-page-handler="RecycleWebAppAppPool" class="inline-form">
                                <input type="hidden" name="hostId" value="@row.HostId" />
                                <input type="hidden" name="healthKey" value="@row.HealthKey" />
                                <input type="hidden" name="appPoolName" value="@row.AppPoolName" />
                                <button type="submit" class="btn btn-secondary" disabled="@string.IsNullOrWhiteSpace(row.AppPoolName)">@L["Recycle app pool"]</button>
                            </form>
                            <form method="post" asp-page-handler="CollectWebAppLogs" class="inline-form">
                                <input type="hidden" name="hostId" value="@row.HostId" />
                                <input type="hidden" name="healthKey" value="@row.HealthKey" />
                                <button type="submit" class="btn btn-secondary">@L["Collect logs"]</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>

<section class="card section-card section-card--wide">
    <h3>@L["Template/runtime drift overview"]</h3>
    <p class="muted">@L["Compares desired template app artifacts with the latest HostAgent deployment state per host. Use this first after changing desired versions or host placement."]</p>

    @if (Model.HostDriftSummaries.Count == 0)
    {
        <div class="empty-state">@L["No enabled hosts were found."]</div>
    }
    else
    {
        <div class="table-scroll">
            <table class="grid app-instances-grid">
                <thead>
                    <tr>
                        <th>@L["Host"]</th>
                        <th>@L["Overall"]</th>
                        <th>@L["Desired apps"]</th>
                        <th>@L["Runtime match"]</th>
                        <th>@L["Differences"]</th>
                        <th>@L["HostAgent"]</th>
                        <th>@L["Last checked UTC"]</th>
                        <th>@L["Last applied UTC"]</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.HostDriftSummaries)
                {
                    var hostDriftDetails = Model.HostDriftDetailsByHost.TryGetValue(row.HostId, out var details)
                        ? details
                        : Array.Empty<HostDriftDetailRow>();
                    <tr>
                        <td>
                            <div><code>@row.HostKey</code></div>
                            @if (!string.IsNullOrWhiteSpace(row.DisplayName))
                            {
                                <div class="muted">@row.DisplayName</div>
                            }
                            @if (row.HostLastSeenUtc.HasValue)
                            {
                                <div class="muted">@L["Last seen"]: @row.HostLastSeenUtc.Value.ToString("u")</div>
                            }
                        </td>
                        <td><span class="pill">@L[HostDeploymentsModel.FormatHostDriftStatus(row)]</span></td>
                        <td>@row.DesiredAppCount</td>
                        <td>@(row.DesiredAppCount == 0 ? L["Not set"].Value : $"{row.InSyncAppCount} / {row.DesiredAppCount}")</td>
                        <td>
                            @if (row.DriftAppCount == 0)
                            {
                                <span class="muted">@L["None"]</span>
                            }
                            else
                            {
                                @if (row.MaterializationPendingCount > 0)
                                {
                                    <div>@row.MaterializationPendingCount @L["materialization pending"]</div>
                                }
                                @if (row.MissingRuntimeCount > 0)
                                {
                                    <div>@row.MissingRuntimeCount @L["missing runtime"]</div>
                                }
                                @if (row.VersionMismatchCount > 0)
                                {
                                    <div>@row.VersionMismatchCount @L["version mismatch"]</div>
                                }
                                @if (row.RunningAppCount > 0)
                                {
                                    <div>@row.RunningAppCount @L["Running"]</div>
                                }
                                @if (row.FailedAppCount > 0)
                                {
                                    <div>@row.FailedAppCount @L["Failed"]</div>
                                }
                                @if (row.WarningAppCount > 0)
                                {
                                    <div>@row.WarningAppCount @L["Warning"]</div>
                                }
                            }
                        </td>
                        <td>
                            @if (string.IsNullOrWhiteSpace(row.HostAgentDesiredVersion)
                                && string.IsNullOrWhiteSpace(row.HostAgentCurrentVersion))
                            {
                                <span class="muted">@L["No runtime state"]</span>
                            }
                            else if (row.HostAgentUpgradePending)
                            {
                                <div><span class="pill">@L["Pending"]</span></div>
                                <div class="muted">
                                    @(string.IsNullOrWhiteSpace(row.HostAgentCurrentVersion) ? "?" : row.HostAgentCurrentVersion)
                                    &rarr;
                                    @row.HostAgentDesiredVersion
                                </div>
                            }
                            else
                            {
                                <div><span class="pill">@L["In sync"]</span></div>
                                @if (!string.IsNullOrWhiteSpace(row.HostAgentCurrentVersion))
                                {
                                    <div class="muted">@row.HostAgentCurrentVersion</div>
                                }
                            }
                            @if (row.HostAgentLastSeenUtc.HasValue)
                            {
                                <div class="muted">@L["Last seen"]: @row.HostAgentLastSeenUtc.Value.ToString("u")</div>
                            }
                        </td>
                        <td>@row.LastCheckedUtc?.ToString("u")</td>
                        <td>@row.LastAppliedUtc?.ToString("u")</td>
                    </tr>
                    @if (hostDriftDetails.Count > 0)
                    {
                        <tr>
                            <td colspan="8">
                                <details class="inline-details">
                                    <summary>@L["Show drift details"] (@hostDriftDetails.Count)</summary>
                                    <div class="table-scroll">
                                        <table class="grid app-instances-grid">
                                            <thead>
                                                <tr>
                                                    <th>@L["Reason"]</th>
                                                    <th>@L["App instance"]</th>
                                                    <th>@L["Placement"]</th>
                                                    <th>@L["Desired"]</th>
                                                    <th>@L["Materialized"]</th>
                                                    <th>@L["Runtime"]</th>
                                                    <th>@L["Status"]</th>
                                                    <th>@L["Error"]</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                            @foreach (var detail in hostDriftDetails)
                                            {
                                                <tr>
                                                    <td><span class="pill">@L[detail.DriftReason]</span></td>
                                                    <td>
                                                        <div><code>@detail.AppInstanceKey</code></div>
                                                        <div class="muted">@detail.AppDisplayName</div>
                                                        <div class="muted"><code>@detail.ModuleInstanceKey</code> / <code>@detail.AppKey</code></div>
                                                    </td>
                                                    <td>@(string.IsNullOrWhiteSpace(detail.Placement) ? L["Any host"].Value : detail.Placement)</td>
                                                    <td>
                                                        <div>@(detail.DesiredArtifactVersion ?? L["Not set"].Value)</div>
                                                        <div class="muted">@detail.DesiredPackageType</div>
                                                        <div class="muted">@detail.DesiredTargetName</div>
                                                    </td>
                                                    <td>@(detail.MaterializedArtifactVersion ?? L["Not set"].Value)</td>
                                                    <td>@(detail.RuntimeArtifactVersion ?? L["Not set"].Value)</td>
                                                    <td>
                                                        @if (detail.DeploymentState.HasValue)
                                                        {
                                                            <div>@L[HostDeploymentsModel.FormatHostDeploymentStatus(detail.DeploymentState.Value)]</div>
                                                        }
                                                        else
                                                        {
                                                            <span class="muted">@L["No runtime state"]</span>
                                                        }
                                                        @if (detail.LastCheckedUtc.HasValue)
                                                        {
                                                            <div class="muted">@L["Last checked UTC"]: @detail.LastCheckedUtc.Value.ToString("u")</div>
                                                        }
                                                        @if (detail.LastAppliedUtc.HasValue)
                                                        {
                                                            <div class="muted">@L["Last applied UTC"]: @detail.LastAppliedUtc.Value.ToString("u")</div>
                                                        }
                                                        @if (!string.IsNullOrWhiteSpace(detail.IdentityCheckStatus))
                                                        {
                                                            <div class="muted">@L["Identity"]: @L[detail.IdentityCheckStatus]</div>
                                                        }
                                                    </td>
                                                    <td>@(string.IsNullOrWhiteSpace(detail.LastError) ? L["None"].Value : detail.LastError)</td>
                                                </tr>
                                            }
                                            </tbody>
                                        </table>
                                    </div>
                                </details>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    }
</section>

<section class="card section-card section-card--wide">
    <h3>@L["HostAgent self-upgrade"]</h3>
    <p class="muted">@L["Select the desired HostAgent artifact per host. The active HostAgent installs the selected version and hands over to it during its next cycle."]</p>

    @if (Model.HostAgentRows.Count == 0)
    {
        <div class="empty-state">@L["No enabled hosts were found."]</div>
    }
    else if (Model.HostAgentArtifactOptions.Count == 0)
    {
        <div class="empty-state">@L["No HostAgent artifacts are available. Import a host-agent artifact before requesting a self-upgrade."]</div>
    }
    else
    {
        <div class="table-scroll">
            <table class="grid app-instances-grid">
                <thead>
                    <tr>
                        <th>@L["Host"]</th>
                        <th>@L["Running"]</th>
                        <th>@L["Desired"]</th>
                        <th>@L["Upgrade target"]</th>
                        <th>@L["Status"]</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.HostAgentRows)
                {
                    var selectedArtifactId = Model.GetSelectedHostAgentArtifactId(row);
                    <tr>
                        <td>
                            <div><code>@row.HostKey</code></div>
                            @if (!string.IsNullOrWhiteSpace(row.DisplayName))
                            {
                                <div class="muted">@row.DisplayName</div>
                            }
                        </td>
                        <td>
                            @if (string.IsNullOrWhiteSpace(row.CurrentVersion))
                            {
                                <span class="muted">@L["No runtime state"]</span>
                            }
                            else
                            {
                                <div>@row.CurrentVersion</div>
                                <div class="muted"><code>@row.CurrentServiceName</code></div>
                                @if (!string.IsNullOrWhiteSpace(row.RuntimeMode))
                                {
                                    <div class="muted">@L["Mode"]: @row.RuntimeMode</div>
                                }
                                @if (row.RuntimeLastSeenUtc.HasValue)
                                {
                                    <div class="muted">@L["Last seen"]: @row.RuntimeLastSeenUtc.Value.ToString("u")</div>
                                }
                            }
                        </td>
                        <td>
                            @if (string.IsNullOrWhiteSpace(row.DesiredVersion))
                            {
                                <span class="muted">@L["Not set"]</span>
                            }
                            else
                            {
                                <div>
                                    @row.DesiredVersion
                                    @if (HostDeploymentsModel.IsHostAgentUpgradePending(row))
                                    {
                                        <span class="pill">@L["Pending"]</span>
                                    }
                                </div>
                                <div class="muted"><code>@row.DesiredRelativePath</code></div>
                                @if (!string.IsNullOrWhiteSpace(row.ServiceNamePrefix))
                                {
                                    <div class="muted">@L["Service prefix"]: <code>@row.ServiceNamePrefix</code></div>
                                }
                                @if (!string.IsNullOrWhiteSpace(row.InstallRoot))
                                {
                                    <div class="muted">@L["Install root"]: <code>@row.InstallRoot</code></div>
                                }
                            }
                        </td>
                        <td>
                            <form method="post" asp-page-handler="RequestHostAgentUpgrade" class="inline-form">
                                <input type="hidden" name="hostId" value="@row.HostId" />
                                <select name="artifactId" aria-label="@L["HostAgent artifact"]">
                                    @foreach (var option in Model.HostAgentArtifactOptions)
                                    {
                                        if (option.ArtifactId == selectedArtifactId)
                                        {
                                            <option value="@option.ArtifactId" selected>@option.Version - @option.RelativePath</option>
                                        }
                                        else
                                        {
                                            <option value="@option.ArtifactId">@option.Version - @option.RelativePath</option>
                                        }
                                    }
                                </select>
                                <button type="submit" class="btn btn-secondary">@L["Request upgrade"]</button>
                            </form>
                        </td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(row.RuntimeStatusMessage))
                            {
                                <div>@row.RuntimeStatusMessage</div>
                            }
                            else
                            {
                                <span class="muted">@L["None"]</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(row.TargetServiceName)
                                                            && !string.Equals(row.TargetServiceName, row.CurrentServiceName, StringComparison.OrdinalIgnoreCase))
                            {
                                <div class="muted">
                                    @L["Target service"]: <code>@row.TargetServiceName</code>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(row.TargetRuntimeMode))
                                {
                                    <div class="muted">
                                        @L["Target mode"]: @row.TargetRuntimeMode
                                        @if (!row.TargetIsActive)
                                        {
                                            <span>(@L["inactive"])</span>
                                        }
                                    </div>
                                }
                                @if (row.TargetRuntimeLastSeenUtc.HasValue)
                                {
                                    <div class="muted">@L["Target last seen"]: @row.TargetRuntimeLastSeenUtc.Value.ToString("u")</div>
                                }
                                @if (!string.IsNullOrWhiteSpace(row.TargetRuntimeStatusMessage))
                                {
                                    <div>@row.TargetRuntimeStatusMessage</div>
                                }
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>

<section class="card section-card section-card--wide">
    <h3>@L["App deployment state"]</h3>
    <p class="muted">@L["These rows show the latest HostAgent result for each host and app instance. This is usually the most useful view after a desired version has been selected."]</p>

    @if (Model.AppDeploymentStates.Count == 0)
    {
        <div class="empty-state">@L["No app deployment state has been recorded yet."]</div>
    }
    else
    {
        <div class="table-tools" data-ops-table-controls="app-deployments">
            <div class="form-field">
                <label for="appDeploymentSearch">@L["Filter"]</label>
                <input id="appDeploymentSearch" type="search" data-ops-search placeholder="@L["Search rows"]" />
            </div>
            <div class="form-field">
                <label for="appDeploymentStatus">@L["Status"]</label>
                <select id="appDeploymentStatus" data-ops-status>
                    <option value="">@L["All statuses"]</option>
                    <option value="0">@L["Pending"]</option>
                    <option value="1">@L["Running"]</option>
                    <option value="2">@L["Succeeded"]</option>
                    <option value="3">@L["Failed"]</option>
                    <option value="4">@L["Warning"]</option>
                </select>
            </div>
            <label class="checkbox-row table-tools__check">
                <input type="checkbox" data-ops-interesting />
                <span>@L["Only rows that need attention"]</span>
            </label>
            <span class="muted table-tools__count" data-ops-count></span>
        </div>
        <div class="table-scroll">
            <table class="grid app-instances-grid ops-history-table" data-ops-table="app-deployments">
                <thead>
                    <tr>
                        <th><button type="button" data-sort="text">@L["Host key"]</button></th>
                        <th><button type="button" data-sort="text">@L["App instance"]</button></th>
                        <th><button type="button" data-sort="text">@L["Artifact"]</button></th>
                        <th><button type="button" data-sort="number">@L["Status"]</button></th>
                        <th><button type="button" data-sort="date">@L["Last checked UTC"]</button></th>
                        <th><button type="button" data-sort="date">@L["Last applied UTC"]</button></th>
                        <th><button type="button" data-sort="text">@L["Target path"]</button></th>
                        <th><button type="button" data-sort="text">@L["Runtime"]</button></th>
                        <th><button type="button" data-sort="text">@L["Identity"]</button></th>
                        <th><button type="button" data-sort="text">@L["Error"]</button></th>
                        <th>@L["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.AppDeploymentStates)
                {
                    <tr data-state="@row.DeploymentState"
                        data-interesting="@HostDeploymentsModel.IsInterestingAppDeployment(row).ToString().ToLowerInvariant()"
                        data-search="@($"{row.HostKey} {row.AppInstanceKey} {row.DisplayName} {row.ArtifactVersion} {row.PackageType} {row.TargetPath} {row.RuntimeName} {row.IdentityCheckStatus} {row.DesiredRuntimeIdentity} {row.ActualRuntimeIdentity} {row.LastError}")">
                        <td><code>@row.HostKey</code></td>
                        <td>
                            <div><code>@row.AppInstanceKey</code></div>
                            <div class="muted">@row.DisplayName</div>
                        </td>
                        <td>
                            <div>@row.ArtifactVersion</div>
                            <div class="muted">@row.PackageType</div>
                        </td>
                        <td><span class="pill">@L[HostDeploymentsModel.FormatHostDeploymentStatus(row.DeploymentState)]</span></td>
                        <td>@row.LastCheckedUtc?.ToString("u")</td>
                        <td>@row.LastAppliedUtc?.ToString("u")</td>
                        <td><code>@row.TargetPath</code></td>
                        <td><code>@row.RuntimeName</code></td>
                        <td>
                            @if (string.IsNullOrWhiteSpace(row.IdentityCheckStatus))
                            {
                                <span class="muted">@L["Not checked"]</span>
                            }
                            else
                            {
                                <div><span class="pill">@L[row.IdentityCheckStatus]</span></div>
                                @if (!string.IsNullOrWhiteSpace(row.DesiredRuntimeIdentity))
                                {
                                    <div class="muted">@L["Desired"]: <code>@row.DesiredRuntimeIdentity</code></div>
                                }
                                @if (!string.IsNullOrWhiteSpace(row.ActualRuntimeIdentity))
                                {
                                    <div class="muted">@L["Actual"]: <code>@row.ActualRuntimeIdentity</code></div>
                                }
                                @if (row.IdentityRepairRequestedUtc.HasValue)
                                {
                                    <div class="muted">@L["Repair requested"]: @row.IdentityRepairRequestedUtc.Value.ToString("u")</div>
                                }
                            }
                        </td>
                        <td>@(string.IsNullOrWhiteSpace(row.LastError) ? L["None"].Value : row.LastError)</td>
                        <td>
                            @if (row.CanRequestIdentityRepair)
                            {
                                <form method="post" asp-page-handler="RequestIdentityRepair" class="inline-form">
                                    <input type="hidden" name="hostId" value="@row.HostId" />
                                    <input type="hidden" name="appInstanceId" value="@row.AppInstanceId" />
                                    <button type="submit" class="btn btn-secondary">@L["Request repair"]</button>
                                </form>
                            }
                            else if (string.Equals(row.IdentityCheckStatus, "ManualActionRequired", StringComparison.OrdinalIgnoreCase))
                            {
                                <span class="muted">@L["Manual repair required"]</span>
                            }
                            else
                            {
                                <span class="muted">@L["None"]</span>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>

<section class="card section-card section-card--wide">
    <h3>@L["Artifact provisioning history"]</h3>
    <p class="muted">@L["These rows show the latest HostAgent artifact download and verification result per host. The default view shows rows from the last 24 hours that may need attention."]</p>

    @if (Model.ArtifactStates.Count == 0)
    {
        <div class="empty-state">@L["No artifact provisioning state has been recorded yet."]</div>
    }
    else
    {
        <div class="table-tools" data-ops-table-controls="artifact-history">
            <div class="form-field">
                <label for="artifactStateSearch">@L["Filter"]</label>
                <input id="artifactStateSearch" type="search" data-ops-search placeholder="@L["Search rows"]" />
            </div>
            <div class="form-field">
                <label for="artifactStateStatus">@L["Status"]</label>
                <select id="artifactStateStatus" data-ops-status>
                    <option value="">@L["All statuses"]</option>
                    <option value="0">@L["Unknown"]</option>
                    <option value="1">@L["Pending"]</option>
                    <option value="2">@L["Succeeded"]</option>
                    <option value="3">@L["Failed"]</option>
                    <option value="4">@L["Hash mismatch"]</option>
                </select>
            </div>
            <div class="form-field">
                <label for="artifactStateSince">@L["Time span"]</label>
                <select id="artifactStateSince" data-ops-since>
                    <option value="">@L["All time"]</option>
                    <option value="24" selected>@L["Last 24 hours"]</option>
                    <option value="168">@L["Last 7 days"]</option>
                    <option value="720">@L["Last 30 days"]</option>
                </select>
            </div>
            <div class="table-tools__checks">
                <label class="checkbox-row table-tools__check">
                    <input type="checkbox" data-ops-interesting checked />
                    <span>@L["Only rows that need attention"]</span>
                </label>
                <label class="checkbox-row table-tools__check">
                    <input type="checkbox" data-ops-current checked />
                    <span>@L["Only currently desired artifacts"]</span>
                </label>
            </div>
            <span class="muted table-tools__count" data-ops-count></span>
        </div>
        <div class="table-scroll">
            <table class="grid app-instances-grid ops-history-table" data-ops-table="artifact-history">
                <thead>
                    <tr>
                        <th><button type="button" data-sort="text">@L["Host key"]</button></th>
                        <th><button type="button" data-sort="text">@L["App"]</button></th>
                        <th><button type="button" data-sort="text">@L["Artifact"]</button></th>
                        <th><button type="button" data-sort="number">@L["Status"]</button></th>
                        <th><button type="button" data-sort="date">@L["Last checked UTC"]</button></th>
                        <th><button type="button" data-sort="date">@L["Last provisioned UTC"]</button></th>
                        <th><button type="button" data-sort="text">@L["Local path"]</button></th>
                        <th><button type="button" data-sort="text">@L["Error"]</button></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.ArtifactStates)
                {
                    <tr data-state="@row.ProvisioningState"
                        data-row-time="@HostDeploymentsModel.ToUnixTimeMilliseconds(row.LastCheckedUtc)"
                        data-interesting="@HostDeploymentsModel.IsInterestingArtifactState(row).ToString().ToLowerInvariant()"
                        data-current="@row.IsCurrentlyDesired.ToString().ToLowerInvariant()"
                        data-search="@($"{row.HostKey} {row.AppKey} {row.ArtifactVersion} {row.PackageType} {row.TargetName} {row.LocalPath} {row.LastError}")">
                        <td><code>@row.HostKey</code></td>
                        <td><code>@row.AppKey</code></td>
                        <td>
                            <div>@row.ArtifactVersion</div>
                            <div class="muted">@row.PackageType</div>
                            <div class="muted">@row.TargetName</div>
                        </td>
                        <td><span class="pill">@L[HostDeploymentsModel.FormatArtifactProvisioningStatus(row.ProvisioningState)]</span></td>
                        <td>@row.LastCheckedUtc?.ToString("u")</td>
                        <td>@row.LastProvisionedUtc?.ToString("u")</td>
                        <td><code>@row.LocalPath</code></td>
                        <td>@(string.IsNullOrWhiteSpace(row.LastError) ? L["None"].Value : row.LastError)</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>

<script>
(() => {
    const now = Date.now();

    const normalize = value => (value || '').toString().trim().toLocaleLowerCase();

    const updateTable = tableName => {
        const controls = document.querySelector(`[data-ops-table-controls="${tableName}"]`);
        const table = document.querySelector(`[data-ops-table="${tableName}"]`);
        if (!controls || !table) {
            return;
        }

        const search = normalize(controls.querySelector('[data-ops-search]')?.value);
        const status = controls.querySelector('[data-ops-status]')?.value ?? '';
        const sinceHours = Number(controls.querySelector('[data-ops-since]')?.value || 0);
        const onlyInteresting = controls.querySelector('[data-ops-interesting]')?.checked ?? false;
        const onlyCurrent = controls.querySelector('[data-ops-current]')?.checked ?? false;
        const threshold = sinceHours > 0 ? now - (sinceHours * 60 * 60 * 1000) : 0;
        let visible = 0;
        let total = 0;

        table.querySelectorAll('tbody tr').forEach(row => {
            total++;
            const rowTime = Number(row.dataset.rowTime || 0);
            const matchesSearch = !search || normalize(row.dataset.search).includes(search);
            const matchesStatus = !status || row.dataset.state === status;
            const matchesInteresting = !onlyInteresting || row.dataset.interesting === 'true';
            const matchesCurrent = !onlyCurrent || row.dataset.current === 'true';
            const matchesTime = !sinceHours || (rowTime > 0 && rowTime >= threshold);
            const show = matchesSearch && matchesStatus && matchesInteresting && matchesCurrent && matchesTime;
            row.hidden = !show;
            if (show) {
                visible++;
            }
        });

        const count = controls.querySelector('[data-ops-count]');
        if (count) {
            count.textContent = `${visible} / ${total}`;
        }
    };

    const getCellValue = (row, index, type) => {
        const text = row.cells[index]?.innerText.trim() ?? '';
        if (type === 'number') {
            return Number(row.dataset.state || 0);
        }

        if (type === 'date') {
            const parsed = Date.parse(text);
            return Number.isNaN(parsed) ? 0 : parsed;
        }

        return normalize(text);
    };

    document.querySelectorAll('[data-ops-table-controls]').forEach(controls => {
        const tableName = controls.dataset.opsTableControls;
        controls.querySelectorAll('input, select').forEach(input => {
            input.addEventListener('input', () => updateTable(tableName));
            input.addEventListener('change', () => updateTable(tableName));
        });
        updateTable(tableName);
    });

    document.querySelectorAll('[data-ops-table] th button[data-sort]').forEach(button => {
        button.addEventListener('click', () => {
            const table = button.closest('table');
            const tbody = table?.querySelector('tbody');
            if (!table || !tbody) {
                return;
            }

            const header = button.closest('th');
            const index = Array.from(header.parentElement.children).indexOf(header);
            const type = button.dataset.sort;
            const ascending = button.dataset.direction !== 'asc';
            button.dataset.direction = ascending ? 'asc' : 'desc';

            const rows = Array.from(tbody.rows);
            rows.sort((left, right) => {
                const leftValue = getCellValue(left, index, type);
                const rightValue = getCellValue(right, index, type);
                if (leftValue < rightValue) {
                    return ascending ? -1 : 1;
                }
                if (leftValue > rightValue) {
                    return ascending ? 1 : -1;
                }
                return 0;
            });

            rows.forEach(row => tbody.appendChild(row));
        });
    });
})();
</script>
