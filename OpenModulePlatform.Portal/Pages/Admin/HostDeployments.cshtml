@page
@using OpenModulePlatform.Web.Shared.Navigation
@model OpenModulePlatform.Portal.Pages.Admin.HostDeploymentsModel
@{
    const string StatusSectionId = "hostdeployments-status";
    const string LockSectionId = "hostdeployments-lock";
    const string WebAppHealthSectionId = "hostdeployments-web-app-health";
    const string DriftSectionId = "hostdeployments-drift";
    const string HostAgentUpgradeSectionId = "hostdeployments-hostagent-upgrade";
    const string AppDeploymentSectionId = "hostdeployments-app-deployments";
    const string OmpAuthSectionId = "hostdeployments-ompauth";
    const string ArtifactHistorySectionId = "hostdeployments-artifact-history";

    var statusMessage = TempData["StatusMessage"] as string;
    var deploymentLockStatus = Model.PortalDeploymentLockStatus;
    var sectionNavigatorItems = new List<SectionNavigatorItem>();

    if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        sectionNavigatorItems.Add(new SectionNavigatorItem(L["Status"].Value, StatusSectionId));
    }

    if (deploymentLockStatus is { IsLocked: true })
    {
        sectionNavigatorItems.Add(new SectionNavigatorItem(L["Deployment lock"].Value, LockSectionId));
    }

    sectionNavigatorItems.Add(new SectionNavigatorItem(L["Web app health"].Value, WebAppHealthSectionId));
    sectionNavigatorItems.Add(new SectionNavigatorItem(L["Template/runtime drift overview"].Value, DriftSectionId));
    sectionNavigatorItems.Add(new SectionNavigatorItem(L["HostAgent self-upgrade"].Value, HostAgentUpgradeSectionId));
    sectionNavigatorItems.Add(new SectionNavigatorItem(L["App deployment state"].Value, AppDeploymentSectionId));
    sectionNavigatorItems.Add(new SectionNavigatorItem(L["OmpAuth consistency"].Value, OmpAuthSectionId));
    sectionNavigatorItems.Add(new SectionNavigatorItem(L["Artifact provisioning history"].Value, ArtifactHistorySectionId));

    var sectionNavigator = new SectionNavigatorModel
    {
        Label = L["Page sections"].Value,
        RootText = L["Operations"].Value,
        Items = sectionNavigatorItems
    };
}

<div class="section-navigator-layout">
    <div class="section-navigator-layout__header">
        <section class="page-header">
            <div>
                <div class="eyebrow">@L["System"]</div>
                <h2>@L["Operations"]</h2>
                <p class="lede">@L["Inspect HostAgent app deployments, artifact provisioning history, runtime identity checks, and host resource telemetry."]</p>
            </div>
        </section>
    </div>

    <div class="toolbar top-gap">
        <a class="action-link" href="~/admin/hostresources">@L["Host resources"]</a>
    </div>

    @await Component.InvokeAsync("SectionNavigator", new { model = sectionNavigator })
    <div class="section-navigator-layout__content">

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <section id="@StatusSectionId" class="section-card section-card--wide section-navigator-target">
        <div class="notice">@statusMessage</div>
    </section>
}

@if (deploymentLockStatus is { IsLocked: true } lockStatus)
{
    <section id="@LockSectionId" class="section-card section-card--wide section-navigator-target">
        <div class="notice">
            <strong>@L["A deployment lock is active."]</strong>
            @L["Application-pool recycle is disabled until the active deployment finishes or the lock expires."]
            @if (lockStatus.Document is not null)
            {
                <div class="muted">
                    @L["Owner"]: @lockStatus.Document.Owner
                    |
                    @L["Reason"]: @lockStatus.Document.Reason
                    |
                    @L["Expires UTC"]: @lockStatus.Document.ExpiresUtc.UtcDateTime.ToString("u")
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(lockStatus.Diagnostic))
            {
                <div class="muted">@lockStatus.Diagnostic</div>
            }
        </div>
    </section>
}

<section id="@WebAppHealthSectionId" class="card section-card section-card--wide section-navigator-target">
    <h3>@L["Web app health"]</h3>
    <p class="muted">@L["Shows per-host web app probes written by HostAgent. Portal health should return a non-success status when the app cannot serve real traffic."]</p>

    @if (Model.WebAppHealthStates.Count == 0)
    {
        <div class="empty-state">@L["No web app health state has been recorded yet."]</div>
    }
    else
    {
        <div class="table-scroll">
            <table class="grid app-instances-grid">
                <thead>
                    <tr>
                        <th>@L["Host"]</th>
                        <th>@L["App"]</th>
                        <th>@L["Status"]</th>
                        <th>@L["Probe"]</th>
                        <th>@L["Failures"]</th>
                        <th>@L["Last action"]</th>
                        <th>@L["Message"]</th>
                        <th>@L["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.WebAppHealthStates)
                {
                    <tr>
                        <td>
                            <div><code>@row.HostKey</code></div>
                            @if (!string.IsNullOrWhiteSpace(row.HostDisplayName))
                            {
                                <div class="muted">@row.HostDisplayName</div>
                            }
                        </td>
                        <td>
                            <div>@(string.IsNullOrWhiteSpace(row.DisplayName) ? row.HealthKey : row.DisplayName)</div>
                            <div class="muted"><code>@row.HealthKey</code></div>
                            @if (!string.IsNullOrWhiteSpace(row.AppPoolName))
                            {
                                <div class="muted">@L["App pool"]: <code>@row.AppPoolName</code></div>
                            }
                        </td>
                        <td>
                            <span class="pill">@L[HostDeploymentsModel.FormatWebAppHealthStatus(row.Status)]</span>
                            @if (row.HttpStatusCode.HasValue)
                            {
                                <div class="muted">HTTP @row.HttpStatusCode</div>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(row.ProbeUrl))
                            {
                                <div><code>@row.ProbeUrl</code></div>
                            }
                            @if (row.LastProbeUtc.HasValue)
                            {
                                <div class="muted">@L["Last checked UTC"]: @row.LastProbeUtc.Value.ToString("u")</div>
                            }
                            @if (row.LastSuccessUtc.HasValue)
                            {
                                <div class="muted">@L["Last success UTC"]: @row.LastSuccessUtc.Value.ToString("u")</div>
                            }
                            @if (row.LastFailureUtc.HasValue)
                            {
                                <div class="muted">@L["Last failure UTC"]: @row.LastFailureUtc.Value.ToString("u")</div>
                            }
                        </td>
                        <td>@row.ConsecutiveFailures</td>
                        <td>
                            @if (row.LastActionUtc.HasValue)
                            {
                                <div>@row.LastActionUtc.Value.ToString("u")</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(row.LastActionMessage))
                            {
                                <div class="muted">@row.LastActionMessage</div>
                            }
                            @if (!row.LastActionUtc.HasValue && string.IsNullOrWhiteSpace(row.LastActionMessage))
                            {
                                <span class="muted">@L["None"]</span>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(row.LastError))
                            {
                                <div>@row.LastError</div>
                            }
                            else if (!string.IsNullOrWhiteSpace(row.ResponseSummary))
                            {
                                <div class="muted">@row.ResponseSummary</div>
                            }
                            else
                            {
                                <span class="muted">@L["None"]</span>
                            }
                        </td>
                        <td>
                            <div class="admin-icon-actions">
                                <form method="post" asp-page-handler="ProbeWebAppHealth" class="inline-form">
                                    <input type="hidden" name="hostId" value="@row.HostId" />
                                    <input type="hidden" name="healthKey" value="@row.HealthKey" />
                                    <button type="submit"
                                            class="btn btn-secondary btn-icon btn-leading-icon btn-leading-icon--check"
                                            title="@L["Probe now"]"
                                            aria-label="@L["Probe now"]">
                                        <span class="visually-hidden">@L["Probe now"]</span>
                                    </button>
                                </form>
                                <form method="post"
                                      asp-page-handler="RecycleWebAppAppPool"
                                      class="inline-form"
                                      onsubmit="return confirm('@L["Recycle this application pool? HostAgent will validate the host state before recycling it."]');">
                                    <input type="hidden" name="hostId" value="@row.HostId" />
                                    <input type="hidden" name="healthKey" value="@row.HealthKey" />
                                    <input type="hidden" name="appPoolName" value="@row.AppPoolName" />
                                    <button type="submit"
                                            class="btn btn-secondary btn-icon btn-leading-icon btn-leading-icon--reset"
                                            title="@L["Recycle app pool"]"
                                            aria-label="@L["Recycle app pool"]"
                                            disabled="@(!Model.CanRecyclePortalAppPool || string.IsNullOrWhiteSpace(row.AppPoolName))">
                                        <span class="visually-hidden">@L["Recycle app pool"]</span>
                                    </button>
                                </form>
                                <form method="post" asp-page-handler="CollectWebAppLogs" class="inline-form">
                                    <input type="hidden" name="hostId" value="@row.HostId" />
                                    <input type="hidden" name="healthKey" value="@row.HealthKey" />
                                    <button type="submit"
                                            class="btn btn-secondary btn-icon btn-leading-icon btn-leading-icon--clarify"
                                            title="@L["Collect logs"]"
                                            aria-label="@L["Collect logs"]">
                                        <span class="visually-hidden">@L["Collect logs"]</span>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>

<section id="@DriftSectionId" class="card section-card section-card--wide section-navigator-target">
    <h3>@L["Template/runtime drift overview"]</h3>
    <p class="muted">@L["Compares desired template app artifacts with the latest HostAgent deployment state per host. Use this first after changing desired versions or host placement."]</p>

    @if (Model.HostDriftSummaries.Count == 0)
    {
        <div class="empty-state">@L["No enabled hosts were found."]</div>
    }
    else
    {
        <div class="table-scroll">
            <table class="grid app-instances-grid">
                <thead>
                    <tr>
                        <th>@L["Host"]</th>
                        <th>@L["Overall"]</th>
                        <th>@L["Desired apps"]</th>
                        <th>@L["Runtime match"]</th>
                        <th>@L["Differences"]</th>
                        <th>@L["HostAgent"]</th>
                        <th>@L["Last checked UTC"]</th>
                        <th>@L["Last applied UTC"]</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.HostDriftSummaries)
                {
                    var hostDriftDetails = Model.HostDriftDetailsByHost.TryGetValue(row.HostId, out var details)
                        ? details
                        : Array.Empty<HostDriftDetailRow>();
                    <tr>
                        <td>
                            <div><code>@row.HostKey</code></div>
                            @if (!string.IsNullOrWhiteSpace(row.DisplayName))
                            {
                                <div class="muted">@row.DisplayName</div>
                            }
                            @if (row.HostLastSeenUtc.HasValue)
                            {
                                <div class="muted">@L["Last seen"]: @row.HostLastSeenUtc.Value.ToString("u")</div>
                            }
                        </td>
                        <td><span class="pill">@L[HostDeploymentsModel.FormatHostDriftStatus(row)]</span></td>
                        <td>@row.DesiredAppCount</td>
                        <td>@(row.DesiredAppCount == 0 ? L["Not set"].Value : $"{row.InSyncAppCount} / {row.DesiredAppCount}")</td>
                        <td>
                            @if (row.DriftAppCount == 0)
                            {
                                <span class="muted">@L["None"]</span>
                            }
                            else
                            {
                                @if (row.MaterializationPendingCount > 0)
                                {
                                    <div>@row.MaterializationPendingCount @L["materialization pending"]</div>
                                }
                                @if (row.MissingRuntimeCount > 0)
                                {
                                    <div>@row.MissingRuntimeCount @L["missing runtime"]</div>
                                }
                                @if (row.VersionMismatchCount > 0)
                                {
                                    <div>@row.VersionMismatchCount @L["version mismatch"]</div>
                                }
                                @if (row.RunningAppCount > 0)
                                {
                                    <div>@row.RunningAppCount @L["Running"]</div>
                                }
                                @if (row.FailedAppCount > 0)
                                {
                                    <div>@row.FailedAppCount @L["Failed"]</div>
                                }
                                @if (row.WarningAppCount > 0)
                                {
                                    <div>@row.WarningAppCount @L["Warning"]</div>
                                }
                            }
                        </td>
                        <td>
                            @if (string.IsNullOrWhiteSpace(row.HostAgentDesiredVersion)
                                && string.IsNullOrWhiteSpace(row.HostAgentCurrentVersion))
                            {
                                <span class="muted">@L["No runtime state"]</span>
                            }
                            else if (row.HostAgentUpgradePending)
                            {
                                <div><span class="pill">@L["Pending"]</span></div>
                                <div class="muted">
                                    @(string.IsNullOrWhiteSpace(row.HostAgentCurrentVersion) ? "?" : row.HostAgentCurrentVersion)
                                    &rarr;
                                    @row.HostAgentDesiredVersion
                                </div>
                            }
                            else
                            {
                                <div><span class="pill">@L["In sync"]</span></div>
                                @if (!string.IsNullOrWhiteSpace(row.HostAgentCurrentVersion))
                                {
                                    <div class="muted">@row.HostAgentCurrentVersion</div>
                                }
                            }
                            @if (row.HostAgentLastSeenUtc.HasValue)
                            {
                                <div class="muted">@L["Last seen"]: @row.HostAgentLastSeenUtc.Value.ToString("u")</div>
                            }
                        </td>
                        <td>@row.LastCheckedUtc?.ToString("u")</td>
                        <td>@row.LastAppliedUtc?.ToString("u")</td>
                    </tr>
                    @if (hostDriftDetails.Count > 0)
                    {
                        <tr>
                            <td colspan="8">
                                <details class="inline-details">
                                    <summary>@L["Show drift details"] (@hostDriftDetails.Count)</summary>
                                    <div class="table-scroll">
                                        <table class="grid app-instances-grid">
                                            <thead>
                                                <tr>
                                                    <th>@L["Reason"]</th>
                                                    <th>@L["App instance"]</th>
                                                    <th>@L["Placement"]</th>
                                                    <th>@L["Desired"]</th>
                                                    <th>@L["Materialized"]</th>
                                                    <th>@L["Runtime"]</th>
                                                    <th>@L["Status"]</th>
                                                    <th>@L["Error"]</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                            @foreach (var detail in hostDriftDetails)
                                            {
                                                <tr>
                                                    <td><span class="pill">@L[detail.DriftReason]</span></td>
                                                    <td>
                                                        <div><code>@detail.AppInstanceKey</code></div>
                                                        <div class="muted">@detail.AppDisplayName</div>
                                                        <div class="muted"><code>@detail.ModuleInstanceKey</code> / <code>@detail.AppKey</code></div>
                                                    </td>
                                                    <td>@(string.IsNullOrWhiteSpace(detail.Placement) ? L["Any host"].Value : detail.Placement)</td>
                                                    <td>
                                                        <div>@(detail.DesiredArtifactVersion ?? L["Not set"].Value)</div>
                                                        <div class="muted">@detail.DesiredPackageType</div>
                                                        <div class="muted">@detail.DesiredTargetName</div>
                                                    </td>
                                                    <td>@(detail.MaterializedArtifactVersion ?? L["Not set"].Value)</td>
                                                    <td>@(detail.RuntimeArtifactVersion ?? L["Not set"].Value)</td>
                                                    <td>
                                                        @if (detail.DeploymentState.HasValue)
                                                        {
                                                            <div>@L[HostDeploymentsModel.FormatHostDeploymentStatus(detail.DeploymentState.Value)]</div>
                                                        }
                                                        else
                                                        {
                                                            <span class="muted">@L["No runtime state"]</span>
                                                        }
                                                        @if (detail.LastCheckedUtc.HasValue)
                                                        {
                                                            <div class="muted">@L["Last checked UTC"]: @detail.LastCheckedUtc.Value.ToString("u")</div>
                                                        }
                                                        @if (detail.LastAppliedUtc.HasValue)
                                                        {
                                                            <div class="muted">@L["Last applied UTC"]: @detail.LastAppliedUtc.Value.ToString("u")</div>
                                                        }
                                                        @if (!string.IsNullOrWhiteSpace(detail.IdentityCheckStatus))
                                                        {
                                                            <div class="muted">@L["Identity"]: @L[detail.IdentityCheckStatus]</div>
                                                        }
                                                    </td>
                                                    <td>@(string.IsNullOrWhiteSpace(detail.LastError) ? L["None"].Value : detail.LastError)</td>
                                                </tr>
                                            }
                                            </tbody>
                                        </table>
                                    </div>
                                </details>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    }
</section>

<section id="@HostAgentUpgradeSectionId" class="card section-card section-card--wide section-navigator-target">
    <h3>@L["HostAgent self-upgrade"]</h3>
    <p class="muted">@L["Select the desired HostAgent artifact per host. The active HostAgent installs the selected version and hands over to it during its next cycle."]</p>

    @if (Model.HostAgentRows.Count == 0)
    {
        <div class="empty-state">@L["No enabled hosts were found."]</div>
    }
    else if (Model.HostAgentArtifactOptions.Count == 0)
    {
        <div class="empty-state">@L["No HostAgent artifacts are available. Import a host-agent artifact before requesting a self-upgrade."]</div>
    }
    else
    {
        <div class="table-scroll">
            <table class="grid app-instances-grid">
                <thead>
                    <tr>
                        <th>@L["Host"]</th>
                        <th>@L["Running"]</th>
                        <th>@L["Desired"]</th>
                        <th>@L["Upgrade target"]</th>
                        <th>@L["Status"]</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.HostAgentRows)
                {
                    var selectedArtifactId = Model.GetSelectedHostAgentArtifactId(row);
                    <tr>
                        <td>
                            <div><code>@row.HostKey</code></div>
                            @if (!string.IsNullOrWhiteSpace(row.DisplayName))
                            {
                                <div class="muted">@row.DisplayName</div>
                            }
                        </td>
                        <td>
                            @if (string.IsNullOrWhiteSpace(row.CurrentVersion))
                            {
                                <span class="muted">@L["No runtime state"]</span>
                            }
                            else
                            {
                                <div>@row.CurrentVersion</div>
                                <div class="muted"><code>@row.CurrentServiceName</code></div>
                                @if (!string.IsNullOrWhiteSpace(row.RuntimeMode))
                                {
                                    <div class="muted">@L["Mode"]: @row.RuntimeMode</div>
                                }
                                @if (row.RuntimeLastSeenUtc.HasValue)
                                {
                                    <div class="muted">@L["Last seen"]: @row.RuntimeLastSeenUtc.Value.ToString("u")</div>
                                }
                            }
                        </td>
                        <td>
                            @if (string.IsNullOrWhiteSpace(row.DesiredVersion))
                            {
                                <span class="muted">@L["Not set"]</span>
                            }
                            else
                            {
                                <div>
                                    @row.DesiredVersion
                                    @if (HostDeploymentsModel.IsHostAgentUpgradePending(row))
                                    {
                                        <span class="pill">@L["Pending"]</span>
                                    }
                                </div>
                                <div class="muted"><code>@row.DesiredRelativePath</code></div>
                                @if (!string.IsNullOrWhiteSpace(row.ServiceNamePrefix))
                                {
                                    <div class="muted">@L["Service prefix"]: <code>@row.ServiceNamePrefix</code></div>
                                }
                                @if (!string.IsNullOrWhiteSpace(row.InstallRoot))
                                {
                                    <div class="muted">@L["Install root"]: <code>@row.InstallRoot</code></div>
                                }
                            }
                        </td>
                        <td>
                            <form method="post"
                                  asp-page-handler="RequestHostAgentUpgrade"
                                  class="inline-form"
                                  onsubmit="return confirm('@L["Request HostAgent upgrade for this host? The active HostAgent installs the selected artifact during its next cycle."]');">
                                <input type="hidden" name="hostId" value="@row.HostId" />
                                <select name="artifactId" aria-label="@L["HostAgent artifact"]">
                                    @foreach (var option in Model.HostAgentArtifactOptions)
                                    {
                                        if (option.ArtifactId == selectedArtifactId)
                                        {
                                            <option value="@option.ArtifactId" selected>@option.Version - @option.RelativePath</option>
                                        }
                                        else
                                        {
                                            <option value="@option.ArtifactId">@option.Version - @option.RelativePath</option>
                                        }
                                    }
                                </select>
                                <button type="submit" class="btn btn-secondary">@L["Request upgrade"]</button>
                            </form>
                        </td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(row.RuntimeStatusMessage))
                            {
                                <div>@row.RuntimeStatusMessage</div>
                            }
                            else
                            {
                                <span class="muted">@L["None"]</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(row.TargetServiceName)
                                                            && !string.Equals(row.TargetServiceName, row.CurrentServiceName, StringComparison.OrdinalIgnoreCase))
                            {
                                <div class="muted">
                                    @L["Target service"]: <code>@row.TargetServiceName</code>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(row.TargetRuntimeMode))
                                {
                                    <div class="muted">
                                        @L["Target mode"]: @row.TargetRuntimeMode
                                        @if (!row.TargetIsActive)
                                        {
                                            <span>(@L["inactive"])</span>
                                        }
                                    </div>
                                }
                                @if (row.TargetRuntimeLastSeenUtc.HasValue)
                                {
                                    <div class="muted">@L["Target last seen"]: @row.TargetRuntimeLastSeenUtc.Value.ToString("u")</div>
                                }
                                @if (!string.IsNullOrWhiteSpace(row.TargetRuntimeStatusMessage))
                                {
                                    <div>@row.TargetRuntimeStatusMessage</div>
                                }
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>

<section id="@AppDeploymentSectionId" class="card section-card section-card--wide section-navigator-target">
    <h3>@L["App deployment state"]</h3>
    <p class="muted">@L["These rows show the latest HostAgent result for each host and app instance. This is usually the most useful view after a desired version has been selected."]</p>

    @if (Model.AppDeploymentStates.Count == 0)
    {
        <div class="empty-state">@L["No app deployment state has been recorded yet."]</div>
    }
    else
    {
        <div class="toolbar">
            <details class="list-filter" data-list-filter="app-deployments-list">
                <summary class="btn btn-ghost">@L["Filter"]<span class="list-filter__count" data-filter-count hidden></span></summary>
                <div class="list-filter__menu">
                    <fieldset class="list-filter__group" data-filter-group="status">
                        <legend>@L["Status"]</legend>
                        <label class="list-filter__option"><input type="checkbox" data-filter-column="3" data-filter-equals="0" /> @L["Pending"]</label>
                        <label class="list-filter__option"><input type="checkbox" data-filter-column="3" data-filter-equals="1" /> @L["Running"]</label>
                        <label class="list-filter__option"><input type="checkbox" data-filter-column="3" data-filter-equals="2" /> @L["Succeeded"]</label>
                        <label class="list-filter__option"><input type="checkbox" data-filter-column="3" data-filter-equals="3" /> @L["Failed"]</label>
                        <label class="list-filter__option"><input type="checkbox" data-filter-column="3" data-filter-equals="4" /> @L["Warning"]</label>
                    </fieldset>
                    <button type="button" class="btn btn-ghost btn-sm" data-filter-clear>@L["Clear filters"]</button>
                </div>
            </details>
            <label class="checkbox-row">
                <input type="checkbox" data-list-toggle="app-deployments-list" data-filter-row-attr="interesting" data-filter-equals="true" data-filter-group="interesting" />
                <span>@L["Only rows that need attention"]</span>
            </label>
            <input type="search" class="list-search" data-list-search="app-deployments-list" placeholder="@L["Search rows"]" aria-label="@L["Search rows"]" />
            <span class="list-count" data-list-count="app-deployments-list" data-template="@L["Showing {0} of {1} rows."]"></span>
        </div>
        <div class="empty-state" data-list-empty="app-deployments-list" hidden>@L["No rows match the current filters."]</div>
        <div class="table-scroll">
            <table id="app-deployments-list" class="grid app-instances-grid sortable-list" data-sortable-list data-page-size="50">
                <thead>
                    <tr>
                        <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["Host key"]</button></th>
                        <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["App instance"]</button></th>
                        <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["Artifact"]</button></th>
                        <th scope="col" data-sort-type="number"><button type="button" class="sortable-list__button">@L["Status"]</button></th>
                        <th scope="col" data-sort-type="date"><button type="button" class="sortable-list__button">@L["Last checked UTC"]</button></th>
                        <th scope="col" data-sort-type="date"><button type="button" class="sortable-list__button">@L["Last applied UTC"]</button></th>
                        <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["Target path"]</button></th>
                        <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["Runtime"]</button></th>
                        <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["Identity"]</button></th>
                        <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["Error"]</button></th>
                        <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["Warning"]</button></th>
                        <th scope="col">@L["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.AppDeploymentStates)
                {
                    <tr data-interesting="@HostDeploymentsModel.IsInterestingAppDeployment(row).ToString().ToLowerInvariant()"
                        data-search="@($"{row.HostKey} {row.AppInstanceKey} {row.DisplayName} {row.ArtifactVersion} {row.PackageType} {row.TargetPath} {row.RuntimeName} {row.IdentityCheckStatus} {row.DesiredRuntimeIdentity} {row.ActualRuntimeIdentity} {row.LastError} {row.LastWarning}")">
                        <td><code>@row.HostKey</code></td>
                        <td>
                            <div><code>@row.AppInstanceKey</code></div>
                            <div class="muted">@row.DisplayName</div>
                        </td>
                        <td>
                            <div>@row.ArtifactVersion</div>
                            <div class="muted">@row.PackageType</div>
                        </td>
                        <td data-sort-value="@row.DeploymentState"><span class="pill">@L[HostDeploymentsModel.FormatHostDeploymentStatus(row.DeploymentState)]</span></td>
                        <td>@row.LastCheckedUtc?.ToString("u")</td>
                        <td>@row.LastAppliedUtc?.ToString("u")</td>
                        <td><code>@row.TargetPath</code></td>
                        <td><code>@row.RuntimeName</code></td>
                        <td>
                            @if (string.IsNullOrWhiteSpace(row.IdentityCheckStatus))
                            {
                                <span class="muted">@L["Not checked"]</span>
                            }
                            else
                            {
                                <div><span class="pill">@L[row.IdentityCheckStatus]</span></div>
                                @if (!string.IsNullOrWhiteSpace(row.DesiredRuntimeIdentity))
                                {
                                    <div class="muted">@L["Desired"]: <code>@row.DesiredRuntimeIdentity</code></div>
                                }
                                @if (!string.IsNullOrWhiteSpace(row.ActualRuntimeIdentity))
                                {
                                    <div class="muted">@L["Actual"]: <code>@row.ActualRuntimeIdentity</code></div>
                                }
                                @if (row.IdentityRepairRequestedUtc.HasValue)
                                {
                                    <div class="muted">@L["Repair requested"]: @row.IdentityRepairRequestedUtc.Value.ToString("u")</div>
                                }
                            }
                        </td>
                        <td>@(string.IsNullOrWhiteSpace(row.LastError) ? L["None"].Value : row.LastError)</td>
                        <td>
                            @if (string.IsNullOrWhiteSpace(row.LastWarning))
                            {
                                <span class="muted">@L["None"]</span>
                            }
                            else
                            {
                                <span class="pill pill-warning" title="@row.LastWarning">@(row.LastWarning.Length > 80 ? row.LastWarning[..80] + "…" : row.LastWarning)</span>
                            }
                        </td>
                        <td>
                            @if (row.CanRequestIdentityRepair)
                            {
                                <form method="post" asp-page-handler="RequestIdentityRepair" class="inline-form">
                                    <input type="hidden" name="hostId" value="@row.HostId" />
                                    <input type="hidden" name="appInstanceId" value="@row.AppInstanceId" />
                                    <button type="submit" class="btn btn-secondary">@L["Request repair"]</button>
                                </form>
                            }
                            else if (string.Equals(row.IdentityCheckStatus, "ManualActionRequired", StringComparison.OrdinalIgnoreCase))
                            {
                                <span class="muted">@L["Manual repair required"]</span>
                            }
                            else
                            {
                                <span class="muted">@L["None"]</span>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <div class="list-show-more">
            <button type="button" class="btn btn-secondary btn-sm" data-list-show-more="app-deployments-list" hidden>@L["Show more"]</button>
        </div>
    }
</section>

<section id="@OmpAuthSectionId" class="card section-card section-card--wide section-navigator-target">
    <h3>@L["OmpAuth consistency"]</h3>
    <p class="muted">@L["OmpAuth consistency description"]</p>

    @if (Model.OmpAuthComparisons.Count == 0)
    {
        <div class="empty-state">@L["No OmpAuth comparison data has been recorded yet."]</div>
    }
    else
    {
        <div class="toolbar">
            <label class="checkbox-row">
                <input type="checkbox" data-list-toggle="ompauth-comparison-list" data-filter-row-attr="interesting" data-filter-equals="true" data-filter-group="interesting" />
                <span>@L["Only hosts with mismatches"]</span>
            </label>
            <input type="search" class="list-search" data-list-search="ompauth-comparison-list" placeholder="@L["Search rows"]" aria-label="@L["Search rows"]" />
            <span class="list-count" data-list-count="ompauth-comparison-list" data-template="@L["Showing {0} of {1} rows."]"></span>
        </div>
        <div class="empty-state" data-list-empty="ompauth-comparison-list" hidden>@L["No rows match the current filters."]</div>
        <div class="table-scroll">
            <table id="ompauth-comparison-list" class="grid app-instances-grid" data-page-size="50">
                <thead>
                    <tr>
                        <th>@L["Host"]</th>
                        <th>@L["Reference app"]</th>
                        <th>@L["Compared apps"]</th>
                        <th>@L["Mismatches"]</th>
                        <th>@L["Status"]</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var host in Model.OmpAuthComparisons)
                {
                    var appSearchTerms = string.Join(" ", host.Apps.Select(a => $"{a.AppInstanceKey} {a.AppDisplayName ?? ""} {a.EffectiveOmpAuthCookieName ?? ""} {a.EffectiveOmpAuthApplicationName ?? ""} {a.EffectiveOmpAuthDataProtectionKeyPath ?? ""}"));
                    <tr data-interesting="@host.HasMismatches.ToString().ToLowerInvariant()"
                        data-search="@($"{host.HostKey} {host.HostDisplayName ?? ""} {host.ReferenceAppKey ?? ""} {host.ReferenceAppDisplayName ?? ""} {appSearchTerms}")">
                        <td>
                            <div><code>@host.HostKey</code></div>
                            @if (!string.IsNullOrWhiteSpace(host.HostDisplayName))
                            {
                                <div class="muted">@host.HostDisplayName</div>
                            }
                        </td>
                        <td>
                            @if (string.IsNullOrWhiteSpace(host.ReferenceAppKey))
                            {
                                <span class="muted">@L["No reference app"]</span>
                            }
                            else
                            {
                                <div><code>@host.ReferenceAppKey</code></div>
                                @if (!string.IsNullOrWhiteSpace(host.ReferenceAppDisplayName))
                                {
                                    <div class="muted">@host.ReferenceAppDisplayName</div>
                                }
                            }
                        </td>
                        <td>@host.Apps.Count</td>
                        <td>@host.MismatchAppCount</td>
                        <td>
                            @if (host.HasMismatches)
                            {
                                <span class="integrity-pill integrity-pill--error">@L["Mismatch"]</span>
                            }
                            else
                            {
                                <span class="integrity-pill integrity-pill--ok">@L["Consistent"]</span>
                            }
                        </td>
                    </tr>
                    @if (host.Apps.Count > 0)
                    {
                        <tr data-list-follow>
                            <td colspan="5">
                                <details class="inline-details">
                                    <summary>@L["Show app details"] (@host.Apps.Count)</summary>
                                    <div class="table-scroll">
                                        <table class="grid app-instances-grid">
                                            <thead>
                                                <tr>
                                                    <th>@L["App instance"]</th>
                                                    <th>@L["Cookie name"]</th>
                                                    <th>@L["Application name"]</th>
                                                    <th>@L["Data protection key path"]</th>
                                                    <th>@L["Status"]</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                            @foreach (var app in host.Apps)
                                            {
                                                <tr class="@(app.IsReferenceApp ? "ompauth-reference-row" : null)">
                                                    <td>
                                                        <div><code>@app.AppInstanceKey</code></div>
                                                        @if (!string.IsNullOrWhiteSpace(app.AppDisplayName))
                                                        {
                                                            <div class="muted">@app.AppDisplayName</div>
                                                        }
                                                        @if (!string.IsNullOrWhiteSpace(app.ArtifactVersion))
                                                        {
                                                            <div class="muted">@app.ArtifactVersion</div>
                                                        }
                                                    </td>
                                                    <td>
                                                        <div>@(app.EffectiveOmpAuthCookieName ?? "—")</div>
                                                        @if (!app.IsReferenceApp)
                                                        {
                                                            <span class="integrity-pill @(app.CookieNameMatches ? "integrity-pill--ok" : "integrity-pill--error")">
                                                                @(app.CookieNameMatches ? L["Matches reference"].Value : L["Mismatch"].Value)
                                                            </span>
                                                        }
                                                    </td>
                                                    <td>
                                                        <div>@(app.EffectiveOmpAuthApplicationName ?? "—")</div>
                                                        @if (!app.IsReferenceApp)
                                                        {
                                                            <span class="integrity-pill @(app.ApplicationNameMatches ? "integrity-pill--ok" : "integrity-pill--error")">
                                                                @(app.ApplicationNameMatches ? L["Matches reference"].Value : L["Mismatch"].Value)
                                                            </span>
                                                        }
                                                    </td>
                                                    <td>
                                                        <div>@(app.EffectiveOmpAuthDataProtectionKeyPath ?? "—")</div>
                                                        @if (!app.IsReferenceApp)
                                                        {
                                                            <span class="integrity-pill @(app.DataProtectionKeyPathMatches ? "integrity-pill--ok" : "integrity-pill--error")">
                                                                @(app.DataProtectionKeyPathMatches ? L["Matches reference"].Value : L["Mismatch"].Value)
                                                            </span>
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (app.IsReferenceApp)
                                                        {
                                                            <span class="integrity-pill integrity-pill--neutral">@L["Reference"]</span>
                                                        }
                                                        else if (app.HasMismatch)
                                                        {
                                                            <span class="integrity-pill integrity-pill--error">@L["Mismatch"]</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="integrity-pill integrity-pill--ok">@L["Matches reference"]</span>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                            </tbody>
                                        </table>
                                    </div>
                                </details>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
        <div class="list-show-more">
            <button type="button" class="btn btn-secondary btn-sm" data-list-show-more="ompauth-comparison-list" hidden>@L["Show more"]</button>
        </div>
    }
</section>

<section id="@ArtifactHistorySectionId" class="card section-card section-card--wide section-navigator-target">
    <h3>@L["Artifact provisioning history"]</h3>
    <p class="muted">@L["These rows show the latest HostAgent artifact download and verification result per host. The default view shows rows from the last 24 hours that may need attention."]</p>

    @if (Model.ArtifactStates.Count == 0)
    {
        <div class="empty-state">@L["No artifact provisioning state has been recorded yet."]</div>
    }
    else
    {
        <div class="toolbar">
            <details class="list-filter" data-list-filter="artifact-history-list">
                <summary class="btn btn-ghost">@L["Filter"]<span class="list-filter__count" data-filter-count hidden></span></summary>
                <div class="list-filter__menu">
                    <fieldset class="list-filter__group" data-filter-group="status">
                        <legend>@L["Status"]</legend>
                        <label class="list-filter__option"><input type="checkbox" data-filter-column="3" data-filter-equals="0" /> @L["Unknown"]</label>
                        <label class="list-filter__option"><input type="checkbox" data-filter-column="3" data-filter-equals="1" /> @L["Pending"]</label>
                        <label class="list-filter__option"><input type="checkbox" data-filter-column="3" data-filter-equals="2" /> @L["Succeeded"]</label>
                        <label class="list-filter__option"><input type="checkbox" data-filter-column="3" data-filter-equals="3" /> @L["Failed"]</label>
                        <label class="list-filter__option"><input type="checkbox" data-filter-column="3" data-filter-equals="4" /> @L["Hash mismatch"]</label>
                    </fieldset>
                    <fieldset class="list-filter__group" data-filter-group="timespan">
                        <legend>@L["Time span"]</legend>
                        <label class="list-filter__option"><input type="checkbox" data-filter-column="4" data-filter-max-age-days="1" checked /> @L["Last 24 hours"]</label>
                        <label class="list-filter__option"><input type="checkbox" data-filter-column="4" data-filter-max-age-days="7" /> @L["Last 7 days"]</label>
                        <label class="list-filter__option"><input type="checkbox" data-filter-column="4" data-filter-max-age-days="30" /> @L["Last 30 days"]</label>
                    </fieldset>
                    <button type="button" class="btn btn-ghost btn-sm" data-filter-clear>@L["Clear filters"]</button>
                </div>
            </details>
            <label class="checkbox-row">
                <input type="checkbox" data-list-toggle="artifact-history-list" data-filter-row-attr="interesting" data-filter-equals="true" data-filter-group="interesting" checked />
                <span>@L["Only rows that need attention"]</span>
            </label>
            <label class="checkbox-row">
                <input type="checkbox" data-list-toggle="artifact-history-list" data-filter-row-attr="current" data-filter-equals="true" data-filter-group="current" checked />
                <span>@L["Only currently desired artifacts"]</span>
            </label>
            <input type="search" class="list-search" data-list-search="artifact-history-list" placeholder="@L["Search rows"]" aria-label="@L["Search rows"]" />
            <span class="list-count" data-list-count="artifact-history-list" data-template="@L["Showing {0} of {1} rows."]"></span>
        </div>
        <div class="empty-state" data-list-empty="artifact-history-list" hidden>@L["No rows match the current filters."]</div>
        <div class="table-scroll">
            <table id="artifact-history-list" class="grid app-instances-grid sortable-list" data-sortable-list data-page-size="50">
                <thead>
                    <tr>
                        <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["Host key"]</button></th>
                        <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["App"]</button></th>
                        <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["Artifact"]</button></th>
                        <th scope="col" data-sort-type="number"><button type="button" class="sortable-list__button">@L["Status"]</button></th>
                        <th scope="col" data-sort-type="date"><button type="button" class="sortable-list__button">@L["Last checked UTC"]</button></th>
                        <th scope="col" data-sort-type="date"><button type="button" class="sortable-list__button">@L["Last provisioned UTC"]</button></th>
                        <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["Local path"]</button></th>
                        <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["Error"]</button></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.ArtifactStates)
                {
                    <tr data-interesting="@HostDeploymentsModel.IsInterestingArtifactState(row).ToString().ToLowerInvariant()"
                        data-current="@row.IsCurrentlyDesired.ToString().ToLowerInvariant()"
                        data-search="@($"{row.HostKey} {row.AppKey} {row.ArtifactVersion} {row.PackageType} {row.TargetName} {row.LocalPath} {row.LastError}")">
                        <td><code>@row.HostKey</code></td>
                        <td><code>@row.AppKey</code></td>
                        <td>
                            <div>@row.ArtifactVersion</div>
                            <div class="muted">@row.PackageType</div>
                            <div class="muted">@row.TargetName</div>
                        </td>
                        <td data-sort-value="@row.ProvisioningState"><span class="pill">@L[HostDeploymentsModel.FormatArtifactProvisioningStatus(row.ProvisioningState)]</span></td>
                        <td>@row.LastCheckedUtc?.ToString("u")</td>
                        <td>@row.LastProvisionedUtc?.ToString("u")</td>
                        <td><code>@row.LocalPath</code></td>
                        <td>@(string.IsNullOrWhiteSpace(row.LastError) ? L["None"].Value : row.LastError)</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <div class="list-show-more">
            <button type="button" class="btn btn-secondary btn-sm" data-list-show-more="artifact-history-list" hidden>@L["Show more"]</button>
        </div>
    }
</section>

    </div>
</div>
