@page
@model OpenModulePlatform.Portal.Pages.Admin.HostDeploymentsModel

<h2>Host Deployments</h2>

<table class="grid">
    <thead>
        <tr>
            <th>Host key</th>
            <th>Host template</th>
            <th>Status</th>
            <th>Requested by</th>
            <th>Requested UTC</th>
            <th>Completed UTC</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var row in Model.Rows)
    {
        <tr>
            <td>@(row.HostKey)</td>
            <td>@(row.HostTemplateKey)</td>
            <td>@(row.Status.ToString())</td>
            <td>@(row.RequestedBy)</td>
            <td>@(row.RequestedUtc.ToString("u"))</td>
            <td>@(row.CompletedUtc?.ToString("u"))</td>
        </tr>
    }
    </tbody>
</table>
