@model OpenModulePlatform.Portal.Pages.Admin.ConfigSettingsModel

<div class="column-list-picker__list config-settings-picker__list"
     role="radiogroup"
     aria-label="@L["Select setting"]">
    @foreach (var definition in Model.Definitions)
    {
        var optionId = $"config-setting-option-{definition.ConfigSettingId}";
        var optionLabel = definition.IsEnabled
            ? definition.Key
            : $"{definition.Key} ({L["Disabled"].Value.ToLowerInvariant()})";
        var isSelected = Model.Input.ConfigSettingId == definition.ConfigSettingId;
        var cssClass = isSelected
            ? "column-list-picker__item config-settings-picker__item is-selected"
            : "column-list-picker__item config-settings-picker__item";

        <label class="@cssClass"
               for="@optionId"
               data-config-setting-option-card>
            <input id="@optionId"
                   class="visually-hidden"
                   asp-for="Input.ConfigSettingId"
                   type="radio"
                   value="@definition.ConfigSettingId"
                   data-config-setting-option
                   data-setting-title="@optionLabel"
                   data-setting-description="@definition.Description" />
            <span class="column-list-picker__item-title"><code>@optionLabel</code></span>
            <span class="column-list-picker__item-meta">@definition.ConfigCategory</span>
            @if (!string.IsNullOrWhiteSpace(definition.Description))
            {
                <span class="column-list-picker__item-description">@definition.Description</span>
            }
        </label>
    }
</div>
<span class="field-validation-error config-settings-picker__validation" asp-validation-for="Input.ConfigSettingId"></span>
