@page
@model OpenModulePlatform.Portal.Pages.Admin.HostsModel

<section class="page-header">
    <div>
        <div class="eyebrow">@L["Manual core"]</div>
        <h2>@L["Hosts"]</h2>
        <p class="lede">@L["Hosts represent concrete runtime targets within an OMP instance. App instances attach to hosts for actual placement and observation."]</p>
    </div>
</section>

<div class="toolbar top-gap">
    <a class="action-link" href="~/admin/hostedit">@L["Create host"]</a>
</div>

@if (Model.Rows.Count == 0)
{
    <div class="empty-state">@L["No hosts found."]</div>
}
else
{
    <table class="grid">
        <thead>
            <tr>
                <th>@L["Instance"]</th>
                <th>@L["Host key"]</th>
                <th>@L["Display name"]</th>
                <th>@L["Base URL"]</th>
                <th>@L["Environment"]</th>
                <th>@L["OS"]</th>
                <th>@L["Architecture"]</th>
                <th>@L["Last seen"]</th>
                            <th>@L["Actions"]</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var row in Model.Rows)
        {
            <tr>
                <td><code>@row.InstanceKey</code></td>
                <td><code>@row.HostKey</code></td>
                <td>@row.DisplayName</td>
                <td><code>@row.BaseUrl</code></td>
                <td>@(string.IsNullOrWhiteSpace(row.Environment) ? string.Empty : L[row.Environment].Value)</td>
                <td>@(string.IsNullOrWhiteSpace(row.OsFamily) ? string.Empty : L[row.OsFamily].Value)</td>
                <td>@(string.IsNullOrWhiteSpace(row.Architecture) ? string.Empty : L[row.Architecture].Value)</td>
                <td>@row.LastSeenUtc?.ToString("u")</td>
                <td><a class="action-link" href="~/admin/hostedit?id=@row.HostId">@L["Edit"]</a></td>
            </tr>
        }
        </tbody>
    </table>
}
