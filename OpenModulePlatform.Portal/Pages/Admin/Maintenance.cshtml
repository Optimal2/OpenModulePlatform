@page
@using OpenModulePlatform.Web.Shared.Navigation
@model OpenModulePlatform.Portal.Pages.Admin.MaintenanceModel

@{
    const string StatusSectionId = "maintenance-status";
    const string ScanSectionId = "maintenance-scan";
    const string RetentionSectionId = "maintenance-retention";
    const string JobsSectionId = "maintenance-jobs";
    const string PreviewSectionId = "maintenance-preview";

    var candidateGroups = Model.Preview.Candidates
        .GroupBy(row => row.IdentityKey)
        .OrderBy(group => group.First().ModuleKey)
        .ThenBy(group => group.First().AppKey)
        .ThenBy(group => group.First().PackageType)
        .ThenBy(group => group.First().TargetName);

    var sectionNavigatorItems = new List<SectionNavigatorItem>();
    if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        sectionNavigatorItems.Add(new SectionNavigatorItem(L["Status"].Value, StatusSectionId));
    }

    sectionNavigatorItems.Add(new SectionNavigatorItem(L["OMP scan"].Value, ScanSectionId));
    sectionNavigatorItems.Add(new SectionNavigatorItem(L["Artifact retention"].Value, RetentionSectionId));
    sectionNavigatorItems.Add(new SectionNavigatorItem(L["HostAgent job queue"].Value, JobsSectionId));
    sectionNavigatorItems.Add(new SectionNavigatorItem(L["Artifact cleanup preview"].Value, PreviewSectionId));

    var sectionNavigator = new SectionNavigatorModel
    {
        Label = L["Page sections"].Value,
        RootText = L["Maintenance"].Value,
        Items = sectionNavigatorItems
    };
}

<div class="section-navigator-layout">
    <div class="section-navigator-layout__header">
        <section class="page-header">
            <div>
                <div class="eyebrow">@L["System"]</div>
                <h2>@L["Maintenance"]</h2>
                <p class="lede">@L["Use maintenance tasks to remove old platform data that is intentionally kept in multiple versions. Artifact cleanup keeps the newest registered versions per artifact identity and only deletes older versions that are not referenced by desired runtime configuration."]</p>
            </div>
        </section>
    </div>

    @await Component.InvokeAsync("SectionNavigator", new { model = sectionNavigator })
    <div class="section-navigator-layout__content">

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div id="@StatusSectionId" class="card status-banner section-navigator-target">@Model.StatusMessage</div>
}

@if (!ViewContext.ModelState.IsValid)
{
    <div class="card validation-summary-errors" asp-validation-summary="All"></div>
}

<section id="@ScanSectionId" class="card top-gap section-navigator-target">
    <div class="split-header">
        <div>
            <h3>@L["OMP scan"]</h3>
            <p class="muted">@L["Scan the shared installation and every enabled host for stale HostAgent runtime rows, stopped old HostAgent services, stopped old WorkerManager services, and leftover HostAgent folders. The scan only reports candidates; cleanup is queued separately after review."]</p>
        </div>
        <form method="post">
            <button type="submit" asp-page-handler="QueueMaintenanceScan">@L["Start OMP scan"]</button>
        </form>
    </div>

    @if (Model.MaintenanceFindings.Count == 0)
    {
        <div class="empty-state top-gap">@L["No open maintenance findings. Start a scan to collect new findings."]</div>
    }
    else
    {
        <form method="post" class="top-gap">
            <div class="toolbar">
                <button type="submit"
                        asp-page-handler="CleanupMaintenanceFindings"
                        class="btn btn-danger"
                        onclick="return confirm('@L["Queue cleanup jobs for the selected maintenance findings? HostAgents will revalidate each target before deleting anything."]');">
                    @L["Queue cleanup"]
                </button>
                <button type="submit"
                        asp-page-handler="IgnoreMaintenanceFindings"
                        class="btn btn-secondary">
                    @L["Ignore selected"]
                </button>
            </div>

            <div class="table-scroll top-gap">
                <table class="grid">
                    <thead>
                        <tr>
                            <th>
                                <input type="checkbox"
                                       id="select-maintenance-findings"
                                       aria-label="@L["Select all maintenance findings"]" />
                            </th>
                            <th>@L["Target"]</th>
                            <th>@L["Host"]</th>
                            <th>@L["Status"]</th>
                            <th>@L["Safety"]</th>
                            <th>@L["Last seen UTC"]</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var row in Model.MaintenanceFindings)
                    {
                        <tr>
                            <td>
                                <input type="checkbox"
                                       name="SelectedMaintenanceFindingIds"
                                       value="@row.MaintenanceFindingId"
                                       class="maintenance-finding-checkbox"
                                       aria-label="@L["Select maintenance finding {0}", row.MaintenanceFindingId]" />
                            </td>
                            <td>
                                <strong>@row.Title</strong>
                                <div class="muted">@row.Category / @row.TargetKind</div>
                                <code>@row.TargetIdentifier</code>
                                @if (!string.IsNullOrWhiteSpace(row.Detail))
                                {
                                    <details class="top-gap-sm">
                                        <summary>@L["Details"]</summary>
                                        <div>@row.Detail</div>
                                        @if (!string.IsNullOrWhiteSpace(row.RecommendedAction))
                                        {
                                            <div class="top-gap-sm"><strong>@L["Recommended action"]:</strong> @row.RecommendedAction</div>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(row.SafetyNotes))
                                        {
                                            <div class="top-gap-sm"><strong>@L["Why this is considered safe"]:</strong> @row.SafetyNotes</div>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(row.ResultMessage))
                                        {
                                            <div class="top-gap-sm"><strong>@L["Result"]:</strong> @row.ResultMessage</div>
                                        }
                                    </details>
                                }
                            </td>
                            <td>
                                @if (string.IsNullOrWhiteSpace(row.HostKey))
                                {
                                    <span class="muted">@L["Shared"]</span>
                                }
                                else
                                {
                                    <code>@row.HostKey</code>
                                    @if (!string.IsNullOrWhiteSpace(row.HostDisplayName))
                                    {
                                        <div class="muted">@row.HostDisplayName</div>
                                    }
                                }
                            </td>
                            <td><span class="pill">@L[MaintenanceModel.FormatMaintenanceFindingStatus(row.Status)]</span></td>
                            <td>
                                <div>@L["Severity"]: @row.Severity</div>
                                <div>@L["Confidence"]: @row.Confidence%</div>
                            </td>
                            <td>@row.LastSeenUtc.ToString("u")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </form>
    }
</section>

<section id="@RetentionSectionId" class="card top-gap section-navigator-target">
    <h3>@L["Artifact retention"]</h3>
    <p class="muted">@L["The cleanup groups artifacts by app, package type, and target. If a group contains more versions than the limit, the oldest registered versions become candidates. Candidates still referenced by desired app, worker, HostAgent, template, or host requirement rows are protected."]</p>

    <form method="post" class="form-grid top-gap">
        <div class="form-field">
            <label asp-for="Input.MaxVersionsToKeep">@L["Versions to keep"]</label>
            <input asp-for="Input.MaxVersionsToKeep" type="number" min="1" max="100" />
            <span asp-validation-for="Input.MaxVersionsToKeep"></span>
            <div class="field-help">@L["For example, 5 keeps the five newest registered versions for each artifact identity."]</div>
        </div>

        <div class="form-field">
            <label>@L["Artifact store cleanup"]</label>
            <input value="@L["Queued for HostAgent"]" readonly />
            <div class="field-help">@L["The HostAgent that claims the global retention job deletes database rows and central ArtifactStore payloads, then queues host-specific cache cleanup jobs. Portal only creates the job request."]</div>
        </div>

        <div class="toolbar">
            <button type="submit" asp-page-handler="Preview">@L["Preview cleanup"]</button>
            <button type="submit"
                    asp-page-handler="CleanupArtifacts"
                    class="btn btn-danger"
                    onclick="return confirm('@L["Queue a HostAgent job to delete unreferenced old artifact versions?"]');">
                @L["Queue artifact cleanup"]
            </button>
        </div>
    </form>
</section>

<section id="@JobsSectionId" class="card top-gap section-navigator-target">
    <h3>@L["HostAgent job queue"]</h3>
    <p class="muted">@L["HostAgent jobs are queued in the database and picked up by the matching host during its next cycle."]</p>

    @if (Model.RecentHostAgentJobs.Count == 0)
    {
        <div class="empty-state">@L["No HostAgent jobs have been queued yet."]</div>
    }
    else
    {
        <div class="table-scroll">
            <table class="grid">
                <thead>
                    <tr>
                        <th>@L["Job"]</th>
                        <th>@L["Host"]</th>
                        <th>@L["Status"]</th>
                        <th>@L["Requested UTC"]</th>
                        <th>@L["Attempts"]</th>
                        <th>@L["Claimed by"]</th>
                        <th>@L["Completed UTC"]</th>
                        <th>@L["Message"]</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.RecentHostAgentJobs)
                {
                    <tr>
                        <td>
                            <code>@row.HostAgentJobId</code>
                            <div class="muted">@row.JobType</div>
                        </td>
                        <td>
                            <code>@(string.IsNullOrWhiteSpace(row.HostKey) ? L["Any HostAgent"].Value : row.HostKey)</code>
                            @if (!string.IsNullOrWhiteSpace(row.HostDisplayName))
                            {
                                <div class="muted">@row.HostDisplayName</div>
                            }
                        </td>
                        <td><span class="pill">@L[MaintenanceModel.FormatHostAgentJobStatus(row.Status)]</span></td>
                        <td>
                            <div>@row.RequestedUtc.ToString("u")</div>
                            @if (!string.IsNullOrWhiteSpace(row.RequestedBy))
                            {
                                <div class="muted">@row.RequestedBy</div>
                            }
                        </td>
                        <td>@row.AttemptCount / @row.MaxAttempts</td>
                        <td>
                            @if (string.IsNullOrWhiteSpace(row.ClaimedByServiceName))
                            {
                                <span class="muted">@L["None"]</span>
                            }
                            else
                            {
                                <code>@row.ClaimedByServiceName</code>
                                @if (row.ClaimedUtc.HasValue)
                                {
                                    <div class="muted">@row.ClaimedUtc.Value.ToString("u")</div>
                                }
                            }
                        </td>
                        <td>@(row.CompletedUtc.HasValue ? row.CompletedUtc.Value.ToString("u") : L["None"].Value)</td>
                        <td>@(string.IsNullOrWhiteSpace(row.LastError) ? L["None"].Value : row.LastError)</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>

<section id="@PreviewSectionId" class="section-navigator-target top-gap" aria-label="@L["Artifact cleanup preview"]">
    <div class="card maintenance-preview-summary" aria-label="@L["Artifact cleanup preview"]">
        <div class="card-grid portal-admin-metrics">
            <div class="metric-card maintenance-preview-summary__metric">
                <span class="metric">@Model.Preview.AffectedArtifactIdentityCount</span>
                <span class="metric-card__label">@L["Affected artifact identities"]</span>
            </div>
            <div class="metric-card maintenance-preview-summary__metric">
                <span class="metric">@Model.Preview.CandidateCount</span>
                <span class="metric-card__label">@L["Old version candidates"]</span>
            </div>
            <div class="metric-card maintenance-preview-summary__metric">
                <span class="metric">@Model.Preview.DeletableCandidateCount</span>
                <span class="metric-card__label">@L["Can be deleted"]</span>
            </div>
            <div class="metric-card maintenance-preview-summary__metric">
                <span class="metric">@Model.Preview.ProtectedCandidateCount</span>
                <span class="metric-card__label">@L["Protected by references"]</span>
            </div>
        </div>
    </div>

@if (Model.Preview.Candidates.Count == 0)
{
    <div class="empty-state top-gap">@L["No artifact cleanup candidates found."]</div>
}
else
{
    <div class="table-scroll top-gap">
        <table class="grid">
            <thead>
                <tr>
                    <th>@L["Artifact identity"]</th>
                    <th>@L["Version"]</th>
                    <th>@L["Registered"]</th>
                    <th>@L["Rank"]</th>
                    <th>@L["Status"]</th>
                    <th>@L["Relative path"]</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var group in candidateGroups)
            {
                var first = group.First();
                <tr>
                    <td colspan="6">
                        <strong>@first.ModuleKey / @first.AppKey</strong>
                        <span class="muted">@first.PackageType</span>
                        @if (!string.IsNullOrWhiteSpace(first.TargetName))
                        {
                            <code>@first.TargetName</code>
                        }
                    </td>
                </tr>

                @foreach (var row in group)
                {
                    <tr>
                        <td><code>@row.ArtifactId</code></td>
                        <td>@row.Version</td>
                        <td>@row.CreatedUtc.ToLocalTime().ToString("g", System.Globalization.CultureInfo.CurrentCulture)</td>
                        <td>@row.RetentionRank / @row.TotalVersions</td>
                        <td>
                            @if (row.IsProtected)
                            {
                                <span class="pill">@L["Protected"] (@row.ProtectedReferenceCount)</span>
                            }
                            else
                            {
                                <span class="pill">@L["Can be deleted"]</span>
                            }
                        </td>
                        <td><code>@row.RelativePath</code></td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
}
</section>

    </div>
</div>

<script>
(() => {
    const selector = document.getElementById('select-maintenance-findings');
    if (!selector) {
        return;
    }

    const boxes = Array.from(document.querySelectorAll('.maintenance-finding-checkbox'));
    selector.addEventListener('change', () => {
        for (const box of boxes) {
            box.checked = selector.checked;
        }
    });
})();
</script>
