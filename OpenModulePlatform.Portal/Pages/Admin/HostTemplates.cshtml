@page
@model OpenModulePlatform.Portal.Pages.Admin.HostTemplatesModel

<section class="page-header">
    <div>
        <div class="eyebrow">@L["Installation"]</div>
        <h2>@L["Host roles"]</h2>
        <p class="lede">@L["Host roles classify hosts inside the installation topology. They are retained as a lookup, not as a separate visible template workflow."]</p>
    </div>
</section>

<div class="toolbar top-gap">
    <a class="action-link" href="~/admin/hostdeploymentassignments">@L["Open template assignments"]</a>
    <a class="action-link" href="~/admin/hostdeployments">@L["Open deployment log"]</a>
</div>

@if (Model.Rows.Count == 0)
{
    <div class="empty-state">@L["No host roles found."]</div>
}
else
{
    <table class="grid">
        <thead>
            <tr>
                <th>@L["Host role key"]</th>
                <th>@L["Display name"]</th>
                <th>@L["Enabled"]</th>
                <th>@L["Description"]</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var row in Model.Rows)
        {
            <tr>
                <td><code>@row.TemplateKey</code></td>
                <td>@row.DisplayName</td>
                <td><span class="pill">@(row.IsEnabled ? L["Enabled"] : L["Disabled"])</span></td>
                <td>@row.Description</td>
            </tr>
        }
        </tbody>
    </table>
}
