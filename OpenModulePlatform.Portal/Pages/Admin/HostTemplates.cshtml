@page
@model OpenModulePlatform.Portal.Pages.Admin.HostTemplatesModel

<section class="page-header">
    <div>
        <div class="eyebrow">@L["Automation"]</div>
        <h2>@L["Host templates"]</h2>
        <p class="lede">@L["Host templates describe reusable host-level desired state for template-driven rollout."]</p>
    </div>
</section>

@if (Model.Rows.Count == 0)
{
    <div class="empty-state">@L["No host templates found."]</div>
}
else
{
    <table class="grid">
        <thead>
            <tr>
                <th>@L["Template key"]</th>
                <th>@L["Display name"]</th>
                <th>@L["Enabled"]</th>
                <th>@L["Description"]</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var row in Model.Rows)
        {
            <tr>
                <td><code>@row.TemplateKey</code></td>
                <td>@row.DisplayName</td>
                <td><span class="pill">@(row.IsEnabled ? L["Enabled"] : L["Disabled"])</span></td>
                <td>@row.Description</td>
            </tr>
        }
        </tbody>
    </table>
}
