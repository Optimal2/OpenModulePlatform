@model OpenModulePlatform.Portal.Pages.Admin.ConfigSettingsModel

@{
    var selectedDefinition = Model.Definitions.FirstOrDefault(definition => definition.ConfigSettingId == Model.Input.ConfigSettingId);
    var hasSelection = selectedDefinition is not null;
    var selectedTitle = selectedDefinition?.Key ?? L["Select setting"].Value;
    var selectedDescription = selectedDefinition?.Description;
}

<div class="empty-state config-settings-picker__empty" data-config-setting-empty hidden="@hasSelection">
    @L["Select setting"]
</div>

<div class="config-settings-picker__details form-grid" data-config-setting-details hidden="@(!hasSelection)">
    <div class="config-settings-picker__summary">
        <p class="eyebrow">@L["Setting"]</p>
        <h4 data-config-setting-detail-title>@selectedTitle</h4>
        <p class="muted" data-config-setting-detail-description>
            @(string.IsNullOrWhiteSpace(selectedDescription) ? L["No description available"].Value : selectedDescription)
        </p>
    </div>

    <div class="config-settings-picker__scope-row">
        <div class="form-field form-field--compact config-settings-picker__priority-field">
            <div class="config-settings-picker__label-row">
                <label asp-for="Input.ConfigPriority"></label>
                <span class="info-badge"
                      tabindex="0"
                      role="img"
                      title="@L["Higher priority wins within permission or role scoped rows."]"
                      aria-label="@L["Higher priority wins within permission or role scoped rows."]">i</span>
            </div>
            <input asp-for="Input.ConfigPriority" type="number" />
        </div>

        <div class="form-field config-settings-picker__scope-field">
            <div class="config-settings-picker__label-row">
                <label asp-for="Input.ScopeType"></label>
                <span class="info-badge"
                      tabindex="0"
                      role="img"
                      title="@L["Global rows apply to everyone. User scope wins over permission, permission wins over role."]"
                      aria-label="@L["Global rows apply to everyone. User scope wins over permission, permission wins over role."]">i</span>
            </div>
            <select asp-for="Input.ScopeType" data-scope-select>
                @foreach (var option in Model.ScopeOptions)
                {
                    <option value="@option.Value">@option.Label</option>
                }
            </select>
        </div>

        <div class="form-field config-settings-picker__target-field" data-scope-field="User">
            @if (Model.IsEdit)
            {
                <label asp-for="Input.ConfigUsr"></label>
                <select asp-for="Input.ConfigUsr">
                    <option value="">@L["Select user"]</option>
                    @foreach (var option in Model.UserOptions)
                    {
                        <option value="@option.Value">@option.Label</option>
                    }
                </select>
                <span class="field-validation-error" asp-validation-for="Input.ConfigUsr"></span>
            }
            else
            {
                var selectedUserIds = Model.Input.ConfigUsers
                    .Select(userId => userId.ToString(System.Globalization.CultureInfo.InvariantCulture))
                    .ToHashSet(StringComparer.Ordinal);

                <label asp-for="Input.ConfigUsers"></label>
                <details class="config-settings-user-multiselect" data-config-user-multiselect>
                    <summary class="config-settings-user-multiselect__summary">
                        <span data-config-user-multiselect-summary data-placeholder="@L["Select users"]">@L["Select users"]</span>
                    </summary>
                    <div class="config-settings-user-multiselect__panel">
                        @foreach (var option in Model.UserOptions)
                        {
                            <label class="config-settings-user-multiselect__option">
                                <span class="config-settings-user-multiselect__label">@option.Label</span>
                                <input type="checkbox"
                                       name="Input.ConfigUsers"
                                       value="@option.Value"
                                       checked="@selectedUserIds.Contains(option.Value)"
                                       data-config-user-checkbox
                                       data-config-user-label="@option.Label" />
                            </label>
                        }
                    </div>
                </details>
                <div class="field-help">@L["Select one or more users. Saving creates one config row per selected user."]</div>
                <span class="field-validation-error" asp-validation-for="Input.ConfigUsers"></span>
            }
        </div>

        <div class="form-field config-settings-picker__target-field" data-scope-field="Permission">
            <label asp-for="Input.ConfigPermission"></label>
            <select asp-for="Input.ConfigPermission">
                <option value="">@L["Select permission"]</option>
                @foreach (var option in Model.PermissionOptions)
                {
                    <option value="@option.Value">@option.Label</option>
                }
            </select>
        </div>

        <div class="form-field config-settings-picker__target-field" data-scope-field="Role">
            <label asp-for="Input.ConfigRole"></label>
            <select asp-for="Input.ConfigRole">
                <option value="">@L["Select role"]</option>
                @foreach (var option in Model.RoleOptions)
                {
                    <option value="@option.Value">@option.Label</option>
                }
            </select>
        </div>
    </div>

    <div class="form-field">
        <label asp-for="Input.ConfigValue"></label>
        <textarea asp-for="Input.ConfigValue" rows="5"></textarea>
        <div class="field-help">@L["Values are stored as text and may contain scalar values, JSON, XML, or other serialized configuration data."]</div>
    </div>
</div>
