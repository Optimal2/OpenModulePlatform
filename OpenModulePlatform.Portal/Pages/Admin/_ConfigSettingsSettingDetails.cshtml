@model OpenModulePlatform.Portal.Pages.Admin.ConfigSettingsModel

@{
    var selectedDefinition = Model.Definitions.FirstOrDefault(definition => definition.ConfigSettingId == Model.Input.ConfigSettingId);
    var hasSelection = selectedDefinition is not null;
    var selectedTitle = selectedDefinition?.Key ?? L["Select setting"].Value;
    var selectedDescription = selectedDefinition?.Description;
    var selectedExamples = selectedDefinition?.ExampleValues;
    var hasSelectedExamples = !string.IsNullOrWhiteSpace(selectedExamples);
}

<div class="empty-state config-settings-picker__empty" data-config-setting-empty hidden="@hasSelection">
    @L["Select setting"]
</div>

<div class="config-settings-picker__details form-grid" data-config-setting-details hidden="@(!hasSelection)">
    <div class="config-settings-picker__summary">
        <p class="eyebrow">@L["Setting"]</p>
        <h4 data-config-setting-detail-title>@selectedTitle</h4>
        <p class="muted" data-config-setting-detail-description>
            @(string.IsNullOrWhiteSpace(selectedDescription) ? L["No description available"].Value : selectedDescription)
        </p>
    </div>

    <div class="config-settings-picker__scope-row">
        <div class="form-field form-field--compact config-settings-picker__priority-field">
            <div class="config-settings-picker__label-row">
                <label asp-for="Input.ConfigPriority"></label>
                <span class="info-badge"
                      tabindex="0"
                      role="img"
                      title="@L["Higher priority wins within permission or role scoped rows."]"
                      aria-label="@L["Higher priority wins within permission or role scoped rows."]">i</span>
            </div>
            <input asp-for="Input.ConfigPriority" type="number" />
        </div>

        <div class="form-field config-settings-picker__scope-field">
            <div class="config-settings-picker__label-row">
                <label asp-for="Input.ScopeType"></label>
                <span class="info-badge"
                      tabindex="0"
                      role="img"
                      title="@L["Global rows apply to everyone. User scope wins over permission, permission wins over role."]"
                      aria-label="@L["Global rows apply to everyone. User scope wins over permission, permission wins over role."]">i</span>
            </div>
            <select asp-for="Input.ScopeType" data-scope-select>
                @foreach (var option in Model.ScopeOptions)
                {
                    <option value="@option.Value">@option.Label</option>
                }
            </select>
        </div>

        <div class="form-field config-settings-picker__target-field" data-scope-field="User">
            @if (Model.IsEdit)
            {
                <label asp-for="Input.ConfigUsr"></label>
                <select asp-for="Input.ConfigUsr">
                    <option value="">@L["Select user"]</option>
                    @foreach (var option in Model.UserOptions)
                    {
                        <option value="@option.Value">@option.Label</option>
                    }
                </select>
                <span class="field-validation-error" asp-validation-for="Input.ConfigUsr"></span>
            }
            else
            {
                var selectedUserIds = Model.Input.ConfigUsers
                    .Select(userId => userId.ToString(System.Globalization.CultureInfo.InvariantCulture))
                    .ToHashSet(StringComparer.Ordinal);

                <div class="config-settings-picker__label-row">
                    <label asp-for="Input.ConfigUsers"></label>
                    <span class="info-badge"
                          tabindex="0"
                          role="img"
                          title="@L["Select one or more users. Saving creates one config row per selected user."]"
                          aria-label="@L["Select one or more users. Saving creates one config row per selected user."]">i</span>
                </div>
                <details class="config-settings-multiselect" data-config-multiselect>
                    <summary class="config-settings-multiselect__summary">
                        <span data-config-multiselect-summary data-placeholder="@L["Select users"]">@L["Select users"]</span>
                    </summary>
                    <div class="config-settings-multiselect__panel">
                        @foreach (var option in Model.UserOptions)
                        {
                            <label class="config-settings-multiselect__option">
                                <span class="config-settings-multiselect__label">@option.Label</span>
                                <input type="checkbox"
                                       name="Input.ConfigUsers"
                                       value="@option.Value"
                                       checked="@selectedUserIds.Contains(option.Value)"
                                       data-config-multiselect-checkbox
                                       data-config-multiselect-label="@option.Label" />
                            </label>
                        }
                    </div>
                </details>
                <span class="field-validation-error" asp-validation-for="Input.ConfigUsers"></span>
            }
        </div>

        <div class="form-field config-settings-picker__target-field" data-scope-field="Permission">
            @if (Model.IsEdit)
            {
                <label asp-for="Input.ConfigPermission"></label>
                <select asp-for="Input.ConfigPermission">
                    <option value="">@L["Select permission"]</option>
                    @foreach (var option in Model.PermissionOptions)
                    {
                        <option value="@option.Value">@option.Label</option>
                    }
                </select>
                <span class="field-validation-error" asp-validation-for="Input.ConfigPermission"></span>
            }
            else
            {
                var selectedPermissionIds = Model.Input.ConfigPermissions
                    .Select(permissionId => permissionId.ToString(System.Globalization.CultureInfo.InvariantCulture))
                    .ToHashSet(StringComparer.Ordinal);

                <div class="config-settings-picker__label-row">
                    <label asp-for="Input.ConfigPermissions"></label>
                    <span class="info-badge"
                          tabindex="0"
                          role="img"
                          title="@L["Select one or more permissions. Saving creates one config row per selected permission."]"
                          aria-label="@L["Select one or more permissions. Saving creates one config row per selected permission."]">i</span>
                </div>
                <details class="config-settings-multiselect" data-config-multiselect>
                    <summary class="config-settings-multiselect__summary">
                        <span data-config-multiselect-summary data-placeholder="@L["Select permissions"]">@L["Select permissions"]</span>
                    </summary>
                    <div class="config-settings-multiselect__panel">
                        @foreach (var option in Model.PermissionOptions)
                        {
                            <label class="config-settings-multiselect__option">
                                <span class="config-settings-multiselect__label">@option.Label</span>
                                <input type="checkbox"
                                       name="Input.ConfigPermissions"
                                       value="@option.Value"
                                       checked="@selectedPermissionIds.Contains(option.Value)"
                                       data-config-multiselect-checkbox
                                       data-config-multiselect-label="@option.Label" />
                            </label>
                        }
                    </div>
                </details>
                <span class="field-validation-error" asp-validation-for="Input.ConfigPermissions"></span>
            }
        </div>

        <div class="form-field config-settings-picker__target-field" data-scope-field="Role">
            @if (Model.IsEdit)
            {
                <label asp-for="Input.ConfigRole"></label>
                <select asp-for="Input.ConfigRole">
                    <option value="">@L["Select role"]</option>
                    @foreach (var option in Model.RoleOptions)
                    {
                        <option value="@option.Value">@option.Label</option>
                    }
                </select>
                <span class="field-validation-error" asp-validation-for="Input.ConfigRole"></span>
            }
            else
            {
                var selectedRoleIds = Model.Input.ConfigRoles
                    .Select(roleId => roleId.ToString(System.Globalization.CultureInfo.InvariantCulture))
                    .ToHashSet(StringComparer.Ordinal);

                <div class="config-settings-picker__label-row">
                    <label asp-for="Input.ConfigRoles"></label>
                    <span class="info-badge"
                          tabindex="0"
                          role="img"
                          title="@L["Select one or more roles. Saving creates one config row per selected role."]"
                          aria-label="@L["Select one or more roles. Saving creates one config row per selected role."]">i</span>
                </div>
                <details class="config-settings-multiselect" data-config-multiselect>
                    <summary class="config-settings-multiselect__summary">
                        <span data-config-multiselect-summary data-placeholder="@L["Select roles"]">@L["Select roles"]</span>
                    </summary>
                    <div class="config-settings-multiselect__panel">
                        @foreach (var option in Model.RoleOptions)
                        {
                            <label class="config-settings-multiselect__option">
                                <span class="config-settings-multiselect__label">@option.Label</span>
                                <input type="checkbox"
                                       name="Input.ConfigRoles"
                                       value="@option.Value"
                                       checked="@selectedRoleIds.Contains(option.Value)"
                                       data-config-multiselect-checkbox
                                       data-config-multiselect-label="@option.Label" />
                            </label>
                        }
                    </div>
                </details>
                <span class="field-validation-error" asp-validation-for="Input.ConfigRoles"></span>
            }
        </div>
    </div>

    <div class="form-field">
        <div class="config-settings-picker__label-row">
            <label asp-for="Input.ConfigValue"></label>
            <span class="info-badge"
                  tabindex="0"
                  role="img"
                  title="@L["Values are stored as text and may contain scalar values, JSON, XML, or other serialized configuration data."]"
                  aria-label="@L["Values are stored as text and may contain scalar values, JSON, XML, or other serialized configuration data."]">i</span>
        </div>
        <textarea asp-for="Input.ConfigValue" rows="5" data-config-setting-value-input></textarea>
        <div class="field-help config-settings-picker__examples"
             data-config-setting-detail-examples>
            <span data-config-setting-detail-examples-label>
                @(hasSelectedExamples ? L["Example values:"].Value : L["No examples available."].Value)
            </span>
            <span class="config-settings-picker__example-chip-list"
                  data-config-setting-detail-example-chips
                  hidden="@(!hasSelectedExamples)"></span>
        </div>
    </div>
</div>
