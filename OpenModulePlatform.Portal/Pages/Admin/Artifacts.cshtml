@page
@model OpenModulePlatform.Portal.Pages.Admin.ArtifactsModel

<section class="page-header">
    <div>
        <div class="eyebrow">Definitions</div>
        <h2>Artifacts</h2>
        <p class="lede">Artifacts are deployable builds for app definitions. App instances select which artifact version to use at runtime.</p>
    </div>
</section>

<div class="toolbar top-gap">
    <a class="action-link" href="~/admin/artifactedit">Create artifact</a>
</div>

@if (Model.Rows.Count == 0)
{
    <div class="empty-state">No artifacts found.</div>
}
else
{
    <table class="grid">
        <thead>
            <tr>
                <th>App key</th>
                <th>Version</th>
                <th>Package type</th>
                <th>Target</th>
                <th>Relative path</th>
                <th>Enabled</th>
                            <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var row in Model.Rows)
        {
            <tr>
                <td><code>@row.AppKey</code></td>
                <td>@row.Version</td>
                <td>@row.PackageType</td>
                <td>@row.TargetName</td>
                <td><code>@row.RelativePath</code></td>
                <td><span class="pill">@(row.IsEnabled ? "Enabled" : "Disabled")</span></td>
                <td><a class="action-link" href="~/admin/artifactedit?id=@row.ArtifactId">Edit</a></td>
            </tr>
        }
        </tbody>
    </table>
}
