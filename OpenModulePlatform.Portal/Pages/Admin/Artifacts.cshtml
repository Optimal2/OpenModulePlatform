@page
@model OpenModulePlatform.Portal.Pages.Admin.ArtifactsModel
@using System.Globalization

<section class="page-header">
    <div>
        <div class="eyebrow">@L["System"]</div>
        <h2>@L["Artifacts"]</h2>
        <p class="lede">@L["Artifacts are deployable outputs of an app definition. Keep artifact metadata and HostAgent-managed configuration files precise so app instances can reference the right build."]</p>
    </div>
</section>

<div class="toolbar top-gap">
    <a class="btn btn-primary" href="~/admin/artifactedit">@L["Create artifact"]</a>
    <a class="btn btn-secondary" href="~/admin/artifactupload">@L["Upload artifact"]</a>
    <a class="btn btn-secondary" href="~/admin/modulepackageimport">@L["Import/export module package"]</a>
</div>

@if (Model.Rows.Count == 0)
{
    <div class="empty-state">@L["No artifacts found."]</div>
}
else
{
    <table class="grid sortable-list" data-sortable-list>
        <thead>
            <tr>
                <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["App key"]</button></th>
                <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["Version"]</button></th>
                <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["Package type"]</button></th>
                <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["Target"]</button></th>
                <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["Relative path"]</button></th>
                <th scope="col" data-sort-type="number"><button type="button" class="sortable-list__button">@L["Enabled"]</button></th>
                <th scope="col" data-sort-type="date"><button type="button" class="sortable-list__button">@L["Created UTC"]</button></th>
                <th scope="col">@L["Actions"]</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var row in Model.Rows)
        {
            <tr>
                <td><code>@row.AppKey</code></td>
                <td>@row.Version</td>
                <td>@row.PackageType</td>
                <td>@row.TargetName</td>
                <td><code>@row.RelativePath</code></td>
                <td data-sort-value="@(row.IsEnabled ? "1" : "0")"><span class="pill">@(row.IsEnabled ? L["Enabled"] : L["Disabled"])</span></td>
                <td data-sort-value="@row.CreatedUtc.ToUniversalTime().ToString("yyyy-MM-dd'T'HH:mm:ss.fff'Z'", CultureInfo.InvariantCulture)">@row.CreatedUtc.ToUniversalTime().ToString("u", CultureInfo.InvariantCulture)</td>
                <td class="admin-action-cell">
                    <a class="action-link admin-icon-button admin-icon-button--edit"
                       href="~/admin/artifactedit?id=@row.ArtifactId"
                       title="@L["Edit"]"
                       aria-label="@L["Edit"]">
                        <span class="visually-hidden">@L["Edit"]</span>
                    </a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
