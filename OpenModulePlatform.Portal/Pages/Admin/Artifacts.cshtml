@page
@model OpenModulePlatform.Portal.Pages.Admin.ArtifactsModel

<h2>Artifacts</h2>

<table class="grid">
    <thead>
        <tr>
            <th>App key</th>
            <th>Version</th>
            <th>Package type</th>
            <th>Target</th>
            <th>Relative path</th>
            <th>Enabled</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var row in Model.Rows)
    {
        <tr>
            <td>@(row.AppKey)</td>
            <td>@(row.Version)</td>
            <td>@(row.PackageType)</td>
            <td>@(row.TargetName)</td>
            <td>@(row.RelativePath)</td>
            <td>@(row.IsEnabled ? "Yes" : "No")</td>
        </tr>
    }
    </tbody>
</table>
