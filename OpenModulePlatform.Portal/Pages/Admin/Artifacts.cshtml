@page
@model OpenModulePlatform.Portal.Pages.Admin.ArtifactsModel
@using System.Globalization

<section class="page-header">
    <div>
        <div class="eyebrow">@L["System"]</div>
        <h2>@L["Artifacts"]</h2>
        <p class="lede">@L["Artifacts are deployable outputs of an app definition. Keep artifact metadata and HostAgent-managed configuration files precise so app instances can reference the right build."]</p>
    </div>
</section>

<div class="toolbar top-gap">
    <a class="btn btn-primary" href="~/admin/artifactedit">@L["Create artifact"]</a>
    <a class="btn btn-secondary" href="~/admin/artifactupload">@L["Upload artifact"]</a>
    <a class="btn btn-secondary" href="~/admin/modulepackageimport">@L["Import/export module package"]</a>
    @if (Model.Rows.Count > 0)
    {
        <details class="list-filter" data-list-filter="artifacts-list">
            <summary class="btn btn-ghost">@L["Filter"]<span class="list-filter__count" data-filter-count hidden></span></summary>
            <div class="list-filter__menu">
                <fieldset class="list-filter__group" data-filter-group="status">
                    <legend>@L["Status"]</legend>
                    <label class="list-filter__option"><input type="checkbox" data-filter-column="5" data-filter-equals="1" /> @L["Enabled"]</label>
                    <label class="list-filter__option"><input type="checkbox" data-filter-column="5" data-filter-equals="0" /> @L["Disabled"]</label>
                </fieldset>
                <fieldset class="list-filter__group" data-filter-group="created">
                    <legend>@L["Created"]</legend>
                    <label class="list-filter__option"><input type="checkbox" data-filter-column="6" data-filter-max-age-days="7" /> @L["Last 7 days"]</label>
                    <label class="list-filter__option"><input type="checkbox" data-filter-column="6" data-filter-max-age-days="30" /> @L["Last 30 days"]</label>
                    <label class="list-filter__option"><input type="checkbox" data-filter-column="6" data-filter-min-age-days="30" /> @L["Older than 30 days"]</label>
                </fieldset>
                <button type="button" class="btn btn-ghost btn-sm" data-filter-clear>@L["Clear filters"]</button>
            </div>
        </details>
        <input type="search" class="list-search" data-list-search="artifacts-list" placeholder="@L["Search rows"]" aria-label="@L["Search rows"]" />
        <span class="list-count" data-list-count="artifacts-list" data-template="@L["Showing {0} of {1} rows."]"></span>
    }
</div>

@if (Model.Rows.Count == 0)
{
    <div class="empty-state">@L["No artifacts found."]</div>
}
else
{
    <div class="empty-state" data-list-empty="artifacts-list" hidden>@L["No rows match the current filters."]</div>
    <table id="artifacts-list" class="grid sortable-list" data-sortable-list data-page-size="50">
        <thead>
            <tr>
                <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["App key"]</button></th>
                <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["Version"]</button></th>
                <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["Package type"]</button></th>
                <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["Target"]</button></th>
                <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["Relative path"]</button></th>
                <th scope="col" data-sort-type="number"><button type="button" class="sortable-list__button">@L["Enabled"]</button></th>
                <th scope="col" data-sort-type="date" data-sort-default="descending"><button type="button" class="sortable-list__button">@L["Created UTC"]</button></th>
                <th scope="col">@L["Actions"]</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var row in Model.Rows)
        {
            <tr>
                <td><code>@row.AppKey</code></td>
                <td>@row.Version</td>
                <td>@row.PackageType</td>
                <td>@row.TargetName</td>
                <td><code>@row.RelativePath</code></td>
                <td data-sort-value="@(row.IsEnabled ? "1" : "0")"><span class="pill">@(row.IsEnabled ? L["Enabled"] : L["Disabled"])</span></td>
                <td data-sort-value="@row.CreatedUtc.ToUniversalTime().ToString("yyyy-MM-dd'T'HH:mm:ss.fff'Z'", CultureInfo.InvariantCulture)">@row.CreatedUtc.ToUniversalTime().ToString("u", CultureInfo.InvariantCulture)</td>
                <td class="admin-action-cell">
                    <a class="action-link admin-icon-button admin-icon-button--edit"
                       href="~/admin/artifactedit?id=@row.ArtifactId"
                       title="@L["Edit"]"
                       aria-label="@L["Edit"]">
                        <span class="visually-hidden">@L["Edit"]</span>
                    </a>
                </td>
            </tr>
        }
        </tbody>
    </table>
    <div class="list-show-more">
        <button type="button" class="btn btn-secondary btn-sm" data-list-show-more="artifacts-list" hidden>@L["Show more"]</button>
    </div>
}
