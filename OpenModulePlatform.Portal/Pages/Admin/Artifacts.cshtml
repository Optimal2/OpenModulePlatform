@page
@model OpenModulePlatform.Portal.Pages.Admin.ArtifactsModel

<section class="page-header">
    <div>
        <div class="eyebrow">@L["System"]</div>
        <h2>@L["Artifacts"]</h2>
        <p class="lede">@L["Artifacts are deployable outputs of an app definition. Keep artifact metadata and HostAgent-managed configuration files precise so app instances can reference the right build."]</p>
    </div>
</section>

<div class="toolbar top-gap">
    <a class="action-link" href="~/admin/artifactedit">@L["Create artifact"]</a>
    <a class="action-link" href="~/admin/artifactupload">@L["Upload artifact"]</a>
    <a class="action-link" href="~/admin/modulepackageimport">@L["Import/export module package"]</a>
    <a class="action-link" href="~/admin/artifactpackageeditor">@L["Open package editor"]</a>
</div>

@if (Model.Rows.Count == 0)
{
    <div class="empty-state">@L["No artifacts found."]</div>
}
else
{
    <table class="grid">
        <thead>
            <tr>
                <th>@L["App key"]</th>
                <th>@L["Version"]</th>
                <th>@L["Package type"]</th>
                <th>@L["Target"]</th>
                <th>@L["Relative path"]</th>
                <th>@L["Enabled"]</th>
                            <th>@L["Actions"]</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var row in Model.Rows)
        {
            <tr>
                <td><code>@row.AppKey</code></td>
                <td>@row.Version</td>
                <td>@row.PackageType</td>
                <td>@row.TargetName</td>
                <td><code>@row.RelativePath</code></td>
                <td><span class="pill">@(row.IsEnabled ? L["Enabled"] : L["Disabled"])</span></td>
                <td class="admin-action-cell">
                    <a class="action-link admin-icon-button admin-icon-button--edit"
                       href="~/admin/artifactedit?id=@row.ArtifactId"
                       title="@L["Edit"]"
                       aria-label="@L["Edit"]">
                        <span class="visually-hidden">@L["Edit"]</span>
                    </a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
