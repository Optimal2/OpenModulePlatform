@page
@model OpenModulePlatform.Portal.Pages.Admin.HostDeploymentAssignmentsModel

<section class="page-header">
    <div>
        <div class="eyebrow">@L["Automation"]</div>
        <h2>@L["HostDeploymentAssignments.Title"]</h2>
        <p class="lede">@L["HostDeploymentAssignments.Lede"]</p>
    </div>
</section>

@if (Model.Rows.Count == 0)
{
    <div class="empty-state">@L["No host deployment assignments found."]</div>
}
else
{
    <table class="grid">
        <thead>
            <tr>
                <th>@L["Host key"]</th>
                <th>@L["Host template"]</th>
                <th>@L["Active"]</th>
                <th>@L["Assigned by"]</th>
                <th>@L["Assigned UTC"]</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var row in Model.Rows)
        {
            <tr>
                <td><code>@row.HostKey</code></td>
                <td><code>@row.HostTemplateKey</code></td>
                <td><span class="pill">@(row.IsActive ? L["Active"] : L["Inactive"])</span></td>
                <td>@row.AssignedBy</td>
                <td>@row.AssignedUtc.ToString("u")</td>
            </tr>
        }
        </tbody>
    </table>
}
