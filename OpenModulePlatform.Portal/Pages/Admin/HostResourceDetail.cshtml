@page
@using OpenModulePlatform.Web.Shared.Navigation
@model OpenModulePlatform.Portal.Pages.Admin.HostResourceDetailModel
@{
    const string TimeRangeSectionId = "hostresourcedetail-time-range";
    const string ChartsSectionId = "hostresourcedetail-charts";
    const string BucketsSectionId = "hostresourcedetail-buckets";

    var chartTitles = new List<string> { Model.PrimaryChart.Title };
    if (Model.CounterpartChart is not null)
    {
        chartTitles.Add(Model.CounterpartChart.Title);
    }

    var sectionNavigatorItems = new List<SectionNavigatorItem>
    {
        new(L["Time range"].Value, TimeRangeSectionId),
        new(string.Join(" / ", chartTitles), ChartsSectionId),
        new(L["Sample buckets"].Value, BucketsSectionId)
    };

    var sectionNavigator = new SectionNavigatorModel
    {
        Label = L["Page sections"].Value,
        RootText = L["Resource detail"].Value,
        Items = sectionNavigatorItems
    };
}

<div class="section-navigator-layout">
    <div class="section-navigator-layout__header">
        <section class="page-header">
            <div>
                <div class="eyebrow">@L["Operations"]</div>
                <h2>@L["Resource detail"]</h2>
                <p class="lede">
                    @L["Host"]: <code>@Model.HostKey</code>
                    @if (!string.IsNullOrWhiteSpace(Model.HostDisplayName))
                    {
                        <span class="muted">(@Model.HostDisplayName)</span>
                    }
                    &middot; @Model.RuntimeKind: <code>@Model.RuntimeName</code>
                    &middot; @L["Sample key"]: <code>@Model.SampleKey</code>
                </p>
            </div>
        </section>
    </div>

    @await Component.InvokeAsync("SectionNavigator", new { model = sectionNavigator })
    <div class="section-navigator-layout__content">

<div class="toolbar top-gap">
    <a class="action-link" href="~/admin/hostresources">@L["Back to host resources"]</a>
</div>

<section id="@TimeRangeSectionId" class="card section-card section-card--wide top-gap section-navigator-target">
    <div class="split-header">
        <h3>@L["Time range"]</h3>
        <div class="host-resource-time-filter">
            @foreach (var hours in Model.AvailableHours)
            {
                var isActive = Model.EffectiveHours == hours;
                <a class="action-link @(isActive ? "host-resource-time-filter__active" : "")"
                   href="~/admin/hostresourcedetail?hostId=@Model.HostId&sampleKey=@Uri.EscapeDataString(Model.SampleKey)&hours=@hours">@L["{0}h", hours]</a>
            }
        </div>
    </div>
    <p class="muted">
        @L["Showing {0} samples over the last {1} hours.", Model.PrimaryChart.Stats.SampleCount, Model.EffectiveHours]
    </p>
</section>

<div id="@ChartsSectionId" class="host-resource-charts top-gap section-navigator-target">
    @await Html.PartialAsync("_HostResourceChart", Model.PrimaryChart)
    @if (Model.CounterpartChart is not null)
    {
        @await Html.PartialAsync("_HostResourceChart", Model.CounterpartChart)
    }
</div>

<section id="@BucketsSectionId" class="card section-card section-card--wide top-gap host-resource-buckets section-navigator-target">
    <h3>@L["Sample buckets"]</h3>
    <p class="muted">@L["Each row is one bucketed interval for the selected sample key."]</p>

    @if (Model.PrimaryRows.Count == 0)
    {
        <div class="empty-state">@L["No historical data for the selected time range."]</div>
    }
    else
    {
        <div class="table-scroll">
            <table class="grid app-instances-grid">
                <thead>
                    <tr>
                        <th>@L["Sample bucket UTC"]</th>
                        <th>@L["Sample value"]</th>
                        <th>@L["Sample count"]</th>
                        <th>@L["Min value"]</th>
                        <th>@L["Max value"]</th>
                        <th>@L["First sampled UTC"]</th>
                        <th>@L["Last sampled UTC"]</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.PrimaryRows.OrderByDescending(r => r.SampleBucketUtc))
                {
                    <tr>
                        <td>@row.SampleBucketUtc.ToString("u")</td>
                        <td>@Model.FormatValue(row.SampleValue)</td>
                        <td>@row.SampleCount</td>
                        <td>@(row.MinValue.HasValue ? Model.FormatValue(row.MinValue.Value) : "—")</td>
                        <td>@(row.MaxValue.HasValue ? Model.FormatValue(row.MaxValue.Value) : "—")</td>
                        <td>@row.FirstSampledUtc.ToString("u")</td>
                        <td>@row.LastSampledUtc.ToString("u")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>

    </div>
</div>
