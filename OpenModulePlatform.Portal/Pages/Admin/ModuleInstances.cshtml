@page
@model OpenModulePlatform.Portal.Pages.Admin.ModuleInstancesModel

<h2>Module Instances</h2>

<table class="grid">
    <thead>
        <tr>
            <th>Instance</th>
            <th>Module</th>
            <th>Module instance key</th>
            <th>Display name</th>
            <th>Enabled</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var row in Model.Rows)
    {
        <tr>
            <td>@(row.InstanceKey)</td>
            <td>@(row.ModuleKey)</td>
            <td>@(row.ModuleInstanceKey)</td>
            <td>@(row.DisplayName)</td>
            <td>@(row.IsEnabled ? "Yes" : "No")</td>
        </tr>
    }
    </tbody>
</table>
