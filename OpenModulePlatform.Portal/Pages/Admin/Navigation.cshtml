@page
@using OpenModulePlatform.Portal.Services
@model OpenModulePlatform.Portal.Pages.Admin.NavigationModel

<section class="page-header">
    <div>
        <div class="eyebrow">@L["Manual core"]</div>
        <h2>@L["Navigation"]</h2>
        <p class="lede">@L["Curate the links shown in the platform's link boxes. Links and boxes can be limited to a permission; labels and titles that match a translation key are localized, anything else is shown as written."]</p>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="card status-banner">@Model.StatusMessage</div>
}

@if (!ViewContext.ModelState.IsValid)
{
    <div class="card validation-summary-errors" asp-validation-summary="All"></div>
}

@if (Model.Boxes.Count > 1)
{
    <div class="toolbar top-gap">
        @foreach (var box in Model.Boxes)
        {
            if (string.Equals(box.BoxKey, Model.SelectedBoxKey, StringComparison.OrdinalIgnoreCase))
            {
                <span class="pill">@L[box.Title]</span>
            }
            else
            {
                <a class="action-link" href="~/admin/navigation?box=@Uri.EscapeDataString(box.BoxKey)">@L[box.Title]</a>
            }
        }
    </div>
}

<section class="card top-gap">
    <h3>@L[Model.SelectedBox?.Title ?? Model.SelectedBoxKey]</h3>
    <p class="field-help">@L["Box key"]: <code>@Model.SelectedBoxKey</code></p>

    <h4>@L["Box settings"]</h4>
    <form method="post" asp-page-handler="SaveBox" asp-route-box="@Model.SelectedBoxKey" class="form-grid">
        <div class="field-grid field-grid--2">
            <div class="form-field">
                <label asp-for="BoxInput.Title">@L["Title"]</label>
                <input asp-for="BoxInput.Title" />
                <span asp-validation-for="BoxInput.Title" class="field-validation-error"></span>
            </div>
            <div class="form-field">
                <label asp-for="BoxInput.RequiredPermission">@L["Required permission"]</label>
                <select asp-for="BoxInput.RequiredPermission">
                    <option value="">@L["Visible to everyone"]</option>
                    @foreach (var permission in Model.PermissionNames)
                    {
                        <option value="@permission">@permission</option>
                    }
                </select>
                <div class="field-help">@L["Only users holding the permission see the box at all."]</div>
                <span asp-validation-for="BoxInput.RequiredPermission" class="field-validation-error"></span>
            </div>
        </div>
        <div class="toolbar">
            <button type="submit" class="action-link">@L["Save box"]</button>
        </div>
    </form>

    <h4 class="top-gap">@L["Links"]</h4>
    @if (Model.Links.Count == 0)
    {
        <div class="empty-state">@L["This box has no links yet."]</div>
    }
    else
    {
        <table class="grid">
            <thead>
                <tr>
                    <th>@L["Label"]</th>
                    <th>@L["URL"]</th>
                    <th>@L["Group"]</th>
                    <th>@L["Required permission"]</th>
                    <th>@L["Actions"]</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var link in Model.Links)
            {
                <tr>
                    <td>@L[link.Label]</td>
                    <td><code>@link.Url</code></td>
                    <td>@(string.IsNullOrWhiteSpace(link.GroupKey) ? "-" : link.GroupKey)</td>
                    <td>@(string.IsNullOrWhiteSpace(link.RequiredPermission) ? L["Visible to everyone"] : link.RequiredPermission)</td>
                    <td>
                        <form method="post"
                              asp-page-handler="Delete"
                              asp-route-box="@Model.SelectedBoxKey"
                              asp-route-id="@link.LinkBoxItemId"
                              data-omp-confirm="@L["Remove this link?"]"
                              data-omp-confirm-ok="@L["Remove"]"
                              data-omp-confirm-cancel="@L["Cancel"]">
                            <button type="submit" class="action-link">@L["Remove"]</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }

    <h4 class="top-gap">@L["Add link"]</h4>
    <form method="post" asp-page-handler="Add" asp-route-box="@Model.SelectedBoxKey" class="form-grid">
        <div class="field-grid field-grid--2">
            <div class="form-field">
                <label asp-for="Input.Label">@L["Label"]</label>
                <input asp-for="Input.Label" />
                <span asp-validation-for="Input.Label" class="field-validation-error"></span>
            </div>
            <div class="form-field">
                <label asp-for="Input.Url">@L["URL"]</label>
                <input asp-for="Input.Url" placeholder="/admin/hosts" />
                <div class="field-help">@L["Only relative URLs within this site are allowed, e.g. /admin/hosts."]</div>
                <span asp-validation-for="Input.Url" class="field-validation-error"></span>
            </div>
        </div>
        <div class="field-grid field-grid--2">
            <div class="form-field">
                <label asp-for="Input.Group">@L["Group"]</label>
                <input asp-for="Input.Group" />
                <div class="field-help">@L["Optional. Links sharing a group key share a tint; matching a built-in group reuses its tint."]</div>
                <span asp-validation-for="Input.Group" class="field-validation-error"></span>
            </div>
            <div class="form-field">
                <label asp-for="Input.RequiredPermission">@L["Required permission"]</label>
                <select asp-for="Input.RequiredPermission">
                    <option value="">@L["Visible to everyone"]</option>
                    @foreach (var permission in Model.PermissionNames)
                    {
                        <option value="@permission">@permission</option>
                    }
                </select>
                <div class="field-help">@L["Only users holding the permission see the link."]</div>
                <span asp-validation-for="Input.RequiredPermission" class="field-validation-error"></span>
            </div>
        </div>
        <div class="toolbar">
            <button type="submit" class="action-link">@L["Add link"]</button>
        </div>
    </form>
</section>
