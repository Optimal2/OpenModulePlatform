@page
@using OpenModulePlatform.Web.Shared.Navigation
@model OpenModulePlatform.Portal.Pages.Admin.InstanceTemplateEditModel

@if (Model.Template is null)
{
    <div class="empty-state">@L["Installation topology was not found."]</div>
    return;
}

@{
    const string StatusSectionId = "instancetemplate-status";
    const string HostsSectionId = "instancetemplate-hosts";
    const string ModulesSectionId = "instancetemplate-modules";
    const string AppsSectionId = "instancetemplate-apps";

    var sectionNavigatorItems = new List<SectionNavigatorItem>();
    if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        sectionNavigatorItems.Add(new SectionNavigatorItem(L["Status"].Value, StatusSectionId));
    }

    sectionNavigatorItems.Add(new SectionNavigatorItem(L["Hosts"].Value, HostsSectionId));
    sectionNavigatorItems.Add(new SectionNavigatorItem(L["Module instances"].Value, ModulesSectionId));
    sectionNavigatorItems.Add(new SectionNavigatorItem(L["Desired apps"].Value, AppsSectionId));

    var sectionNavigator = new SectionNavigatorModel
    {
        Label = L["Page sections"].Value,
        RootText = L["Installation"].Value,
        Items = sectionNavigatorItems
    };
}

<partial name="_AdminQuickLinks" />

<div class="section-navigator-layout">
    <div class="section-navigator-layout__header">
        <section class="page-header">
            <div>
                <div class="eyebrow">@L["Installation"]</div>
                <h2>@L["Installation"]</h2>
                <p class="lede">
                    @L["This page is the desired state for the current OMP installation. HostAgent materializes these rows into concrete hosts, module instances and app instances."]
                </p>
            </div>
        </section>
    </div>

    @await Component.InvokeAsync("SectionNavigator", new { model = sectionNavigator })
    <div class="section-navigator-layout__content">

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <section id="@StatusSectionId" class="card status-banner section-navigator-target">@Model.StatusMessage</section>
}

<section id="@HostsSectionId" class="card section-card section-card--wide section-navigator-target">
    <div class="section-heading-row">
        <div>
            <h3>@L["Hosts"]</h3>
            <p class="muted">@L["Hosts define the host keys that belong to this installation. Concrete machines report in with matching host keys."]</p>
        </div>
        <a class="action-link admin-add-button"
           href="~/admin/instancetemplatehostedit?templateId=@Model.Template.InstanceTemplateId"
           title="@L["Add host"]"
           aria-label="@L["Add host"]">
            <span aria-hidden="true">+</span>
            <span class="visually-hidden">@L["Add host"]</span>
        </a>
    </div>

    @if (Model.Hosts.Count == 0)
    {
        <div class="empty-state">@L["No hosts found."]</div>
    }
    else
    {
        <table class="grid">
            <thead>
                <tr>
                    <th>@L["Host key"]</th>
                    <th>@L["Host role"]</th>
                    <th>@L["Display name"]</th>
                    <th>@L["Environment"]</th>
                    <th>@L["Enabled"]</th>
                    <th>@L["Actions"]</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var row in Model.Hosts)
            {
                <tr>
                    <td><code>@row.HostKey</code></td>
                    <td><code>@row.HostTemplateKey</code></td>
                    <td>@row.DisplayName</td>
                    <td>@row.Environment</td>
                    <td><span class="pill">@(row.IsEnabled ? L["Enabled"] : L["Disabled"])</span></td>
                    <td class="admin-action-cell">
                        <a class="action-link admin-icon-button admin-icon-button--edit"
                           href="~/admin/instancetemplatehostedit?id=@row.InstanceTemplateHostId"
                           title="@L["Edit"]"
                           aria-label="@L["Edit"]">
                            <span class="visually-hidden">@L["Edit"]</span>
                        </a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
</section>

<section id="@ModulesSectionId" class="card section-card section-card--wide section-navigator-target">
    <div class="section-heading-row">
        <div>
            <h3>@L["Module instances"]</h3>
            <p class="muted">@L["Module instances are desired module slots for this installation. Desired apps attach to them before HostAgent creates runtime module instances."]</p>
        </div>
        <a class="action-link admin-add-button"
           href="~/admin/instancetemplatemoduleedit?templateId=@Model.Template.InstanceTemplateId"
           title="@L["Add module instance"]"
           aria-label="@L["Add module instance"]">
            <span aria-hidden="true">+</span>
            <span class="visually-hidden">@L["Add module instance"]</span>
        </a>
    </div>

    @if (Model.Modules.Count == 0)
    {
        <div class="empty-state">@L["No module instances found."]</div>
    }
    else
    {
        <table class="grid">
            <thead>
                <tr>
                    <th>@L["Module"]</th>
                    <th>@L["Module instance"]</th>
                    <th>@L["Display name"]</th>
                    <th>@L["Enabled"]</th>
                    <th>@L["Actions"]</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var row in Model.Modules)
            {
                <tr>
                    <td><code>@row.ModuleKey</code></td>
                    <td><code>@row.ModuleInstanceKey</code></td>
                    <td>@row.DisplayName</td>
                    <td><span class="pill">@(row.IsEnabled ? L["Enabled"] : L["Disabled"])</span></td>
                    <td class="admin-action-cell">
                        <a class="action-link admin-icon-button admin-icon-button--edit"
                           href="~/admin/instancetemplatemoduleedit?id=@row.InstanceTemplateModuleInstanceId"
                           title="@L["Edit"]"
                           aria-label="@L["Edit"]">
                            <span class="visually-hidden">@L["Edit"]</span>
                        </a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
</section>

<section id="@AppsSectionId" class="card section-card section-card--wide section-navigator-target">
    <div class="section-heading-row">
        <div>
            <h3>@L["Desired apps"]</h3>
            <p class="muted">@L["Change versions, placement and desired runtime policy here. HostAgent updates the concrete app instances after its next cycle."]</p>
        </div>
        <a class="action-link admin-add-button"
           href="~/admin/instancetemplateappedit?templateId=@Model.Template.InstanceTemplateId"
           title="@L["Add desired app"]"
           aria-label="@L["Add desired app"]">
            <span aria-hidden="true">+</span>
            <span class="visually-hidden">@L["Add desired app"]</span>
        </a>
    </div>

    @if (Model.Apps.Count == 0)
    {
        <div class="empty-state">@L["No desired apps found."]</div>
    }
    else
    {
        var appTypes = Model.Apps
            .Select(row => row.AppType)
            .Where(type => !string.IsNullOrWhiteSpace(type))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(type => type, StringComparer.OrdinalIgnoreCase)
            .ToList();
        var desiredStates = Model.Apps
            .Select(row => row.DesiredState)
            .Distinct()
            .OrderBy(state => state)
            .ToList();

        <div class="toolbar">
            <details class="list-filter" data-list-filter="desired-apps-list">
                <summary class="btn btn-ghost">@L["Filter"]<span class="list-filter__count" data-filter-count hidden></span></summary>
                <div class="list-filter__menu">
                    <fieldset class="list-filter__group" data-filter-group="apptype">
                        <legend>@L["App type"]</legend>
                        @foreach (var appType in appTypes)
                        {
                            <label class="list-filter__option"><input type="checkbox" data-filter-column="3" data-filter-equals="@appType" /> @L[appType]</label>
                        }
                    </fieldset>
                    <fieldset class="list-filter__group" data-filter-group="allowed">
                        <legend>@L["Allowed"]</legend>
                        <label class="list-filter__option"><input type="checkbox" data-filter-column="8" data-filter-equals="1" /> @L["Allowed"]</label>
                        <label class="list-filter__option"><input type="checkbox" data-filter-column="8" data-filter-equals="0" /> @L["Blocked"]</label>
                    </fieldset>
                    <fieldset class="list-filter__group" data-filter-group="desiredstate">
                        <legend>@L["Desired state"]</legend>
                        @foreach (var desiredState in desiredStates)
                        {
                            <label class="list-filter__option"><input type="checkbox" data-filter-column="9" data-filter-equals="@desiredState" /> @desiredState</label>
                        }
                    </fieldset>
                    <button type="button" class="btn btn-ghost btn-sm" data-filter-clear>@L["Clear filters"]</button>
                </div>
            </details>
            <input type="search" class="list-search" data-list-search="desired-apps-list" placeholder="@L["Search rows"]" aria-label="@L["Search rows"]" />
            <span class="list-count" data-list-count="desired-apps-list" data-template="@L["Showing {0} of {1} rows."]"></span>
        </div>
        <div class="empty-state" data-list-empty="desired-apps-list" hidden>@L["No rows match the current filters."]</div>
        <div class="table-scroll">
            <table id="desired-apps-list" class="grid app-instances-grid sortable-list" data-sortable-list data-page-size="50">
                <thead>
                    <tr>
                        <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["Module instance"]</button></th>
                        <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["Host"]</button></th>
                        <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["App"]</button></th>
                        <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["App type"]</button></th>
                        <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["App instance key"]</button></th>
                        <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["Artifact"]</button></th>
                        <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["Route"]</button></th>
                        <th scope="col" data-sort-type="text"><button type="button" class="sortable-list__button">@L["Installation"]</button></th>
                        <th scope="col" data-sort-type="number"><button type="button" class="sortable-list__button">@L["Allowed"]</button></th>
                        <th scope="col" data-sort-type="number"><button type="button" class="sortable-list__button">@L["Desired state"]</button></th>
                        <th scope="col">@L["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.Apps)
                {
                    <tr>
                        <td><code>@row.ModuleInstanceKey</code></td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(row.HostKey))
                            {
                                <code>@row.HostKey</code>
                            }
                            else if (!string.IsNullOrWhiteSpace(row.TargetHostTemplateKey))
                            {
                                <code>@L["Host role"]: @row.TargetHostTemplateKey</code>
                            }
                            else
                            {
                                <code>@L["Any host"]</code>
                            }
                        </td>
                        <td><code>@row.AppKey</code></td>
                        <td data-sort-value="@row.AppType">@L[row.AppType]</td>
                        <td><code>@row.AppInstanceKey</code></td>
                        <td data-sort-value="@(row.ArtifactVersion ?? "")">
                            <div class="artifact-version-cell">
                                <span>@(row.ArtifactVersion ?? L["None"].Value)</span>
                                @if (row.HasNewerArtifact)
                                {
                                    var latestArtifactVersion = row.LatestArtifactVersion ?? string.Empty;
                                    <form method="post"
                                          asp-page-handler="UpgradeAppArtifact"
                                          asp-route-id="@row.InstanceTemplateAppInstanceId"
                                          asp-route-templateId="@Model.Template.InstanceTemplateId"
                                          asp-route-artifactId="@row.LatestArtifactId"
                                          class="artifact-upgrade-form">
                                        <button type="submit"
                                                class="artifact-upgrade-button"
                                                title="@L["Upgrade to latest compatible artifact version {0}", latestArtifactVersion]"
                                                aria-label="@L["Upgrade to latest compatible artifact version {0}", latestArtifactVersion]">
                                            <span aria-hidden="true">↑</span>
                                        </button>
                                    </form>
                                    <span class="artifact-upgrade-label">@L["Newer: {0}", latestArtifactVersion]</span>
                                }
                            </div>
                        </td>
                        <td>@row.RoutePath</td>
                        <td>@row.InstallationName</td>
                        <td data-sort-value="@(row.IsAllowed ? "1" : "0")"><span class="pill">@(row.IsAllowed ? L["Allowed"] : L["Blocked"])</span></td>
                        <td data-sort-value="@row.DesiredState"><span class="pill">@row.DesiredState</span></td>
                        <td>
                            <div class="admin-icon-actions">
                                <a class="action-link admin-icon-button admin-icon-button--edit"
                                   href="~/admin/instancetemplateappedit?id=@row.InstanceTemplateAppInstanceId"
                                   title="@L["Edit desired state"]"
                                   aria-label="@L["Edit desired state"]">
                                    <span class="visually-hidden">@L["Edit desired state"]</span>
                                </a>
                                <form method="post"
                                      asp-page-handler="DeleteApp"
                                      asp-route-id="@row.InstanceTemplateAppInstanceId"
                                      asp-route-templateId="@Model.Template.InstanceTemplateId"
                                      class="inline-form"
                                      data-confirm-submit="@L["Remove this desired app from the installation?"]">
                                    <button type="submit"
                                            class="btn-link-danger admin-icon-button admin-icon-button--delete"
                                            title="@L["Remove desired app"]"
                                            aria-label="@L["Remove desired app"]">
                                        <span class="visually-hidden">@L["Remove desired app"]</span>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <div class="list-show-more">
            <button type="button" class="btn btn-secondary btn-sm" data-list-show-more="desired-apps-list" hidden>@L["Show more"]</button>
        </div>
    }
</section>

    </div>
</div>

<script>
    document.addEventListener("submit", event => {
        const form = event.target.closest("[data-confirm-submit]");
        if (!form) {
            return;
        }

        const message = form.dataset.confirmSubmit || "";
        if (message && !window.confirm(message)) {
            event.preventDefault();
        }
    });
</script>
