@page
@model OpenModulePlatform.Portal.Pages.Admin.InstanceTemplateEditModel

@if (Model.Template is null)
{
    <div class="empty-state">@L["Instance template was not found."]</div>
    return;
}

<section class="page-header">
    <div>
        <div class="eyebrow">@L["Desired topology"]</div>
        <h2>@Model.Template.DisplayName</h2>
        <p class="lede">
            @L["This template is the desired state for OMP instances that use it. HostAgent materializes these rows into concrete hosts, module instances and app instances."]
        </p>
    </div>
</section>

<section class="card section-card section-card--wide">
    <div class="detail-grid">
        <div>
            <div class="muted">@L["Template key"]</div>
            <code>@Model.Template.TemplateKey</code>
        </div>
        <div>
            <div class="muted">@L["Enabled"]</div>
            <span class="pill">@(Model.Template.IsEnabled ? L["Enabled"] : L["Disabled"])</span>
        </div>
        <div>
            <div class="muted">@L["Description"]</div>
            <span>@Model.Template.Description</span>
        </div>
    </div>
</section>

<section class="card section-card section-card--wide">
    <div class="section-heading-row">
        <div>
            <h3>@L["Template hosts"]</h3>
            <p class="muted">@L["Template hosts define the host keys that should exist inside each OMP instance using this template. Concrete hosts report in with the same host key."]</p>
        </div>
        <a class="action-link" href="~/admin/instancetemplatehostedit?templateId=@Model.Template.InstanceTemplateId">@L["Add template host"]</a>
    </div>

    @if (Model.Hosts.Count == 0)
    {
        <div class="empty-state">@L["No template hosts found."]</div>
    }
    else
    {
        <table class="grid">
            <thead>
                <tr>
                    <th>@L["Host key"]</th>
                    <th>@L["Host template"]</th>
                    <th>@L["Display name"]</th>
                    <th>@L["Environment"]</th>
                    <th>@L["Enabled"]</th>
                    <th>@L["Actions"]</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var row in Model.Hosts)
            {
                <tr>
                    <td><code>@row.HostKey</code></td>
                    <td><code>@row.HostTemplateKey</code></td>
                    <td>@row.DisplayName</td>
                    <td>@row.Environment</td>
                    <td><span class="pill">@(row.IsEnabled ? L["Enabled"] : L["Disabled"])</span></td>
                    <td><a class="action-link" href="~/admin/instancetemplatehostedit?id=@row.InstanceTemplateHostId">@L["Edit"]</a></td>
                </tr>
            }
            </tbody>
        </table>
    }
</section>

<section class="card section-card section-card--wide">
    <div class="section-heading-row">
        <div>
            <h3>@L["Template module instances"]</h3>
            <p class="muted">@L["Module instances are materialized before desired app rows, so apps have a stable module slot to attach to."]</p>
        </div>
        <a class="action-link" href="~/admin/instancetemplatemoduleedit?templateId=@Model.Template.InstanceTemplateId">@L["Add template module instance"]</a>
    </div>

    @if (Model.Modules.Count == 0)
    {
        <div class="empty-state">@L["No template module instances found."]</div>
    }
    else
    {
        <table class="grid">
            <thead>
                <tr>
                    <th>@L["Module"]</th>
                    <th>@L["Module instance"]</th>
                    <th>@L["Display name"]</th>
                    <th>@L["Enabled"]</th>
                    <th>@L["Actions"]</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var row in Model.Modules)
            {
                <tr>
                    <td><code>@row.ModuleKey</code></td>
                    <td><code>@row.ModuleInstanceKey</code></td>
                    <td>@row.DisplayName</td>
                    <td><span class="pill">@(row.IsEnabled ? L["Enabled"] : L["Disabled"])</span></td>
                    <td><a class="action-link" href="~/admin/instancetemplatemoduleedit?id=@row.InstanceTemplateModuleInstanceId">@L["Edit"]</a></td>
                </tr>
            }
            </tbody>
        </table>
    }
</section>

<section class="card section-card section-card--wide">
    <div class="section-heading-row">
        <div>
            <h3>@L["Desired apps"]</h3>
            <p class="muted">@L["Change versions, placement and desired runtime policy here. HostAgent updates the concrete app instances after its next cycle."]</p>
        </div>
        <a class="action-link" href="~/admin/instancetemplateappedit?templateId=@Model.Template.InstanceTemplateId">@L["Add desired app"]</a>
    </div>

    @if (Model.Apps.Count == 0)
    {
        <div class="empty-state">@L["No desired apps found."]</div>
    }
    else
    {
        <div class="table-scroll">
            <table class="grid app-instances-grid">
                <thead>
                    <tr>
                        <th>@L["Module instance"]</th>
                        <th>@L["Host"]</th>
                        <th>@L["App"]</th>
                        <th>@L["App instance key"]</th>
                        <th>@L["Artifact"]</th>
                        <th>@L["Route"]</th>
                        <th>@L["Installation"]</th>
                        <th>@L["Allowed"]</th>
                        <th>@L["Desired state"]</th>
                        <th>@L["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.Apps)
                {
                    <tr>
                        <td><code>@row.ModuleInstanceKey</code></td>
                        <td><code>@(row.HostKey ?? L["Any host"].Value)</code></td>
                        <td><code>@row.AppKey</code></td>
                        <td><code>@row.AppInstanceKey</code></td>
                        <td>@row.ArtifactVersion</td>
                        <td>@row.RoutePath</td>
                        <td>@row.InstallationName</td>
                        <td><span class="pill">@(row.IsAllowed ? L["Allowed"] : L["Blocked"])</span></td>
                        <td><span class="pill">@row.DesiredState</span></td>
                        <td><a class="action-link" href="~/admin/instancetemplateappedit?id=@row.InstanceTemplateAppInstanceId">@L["Edit desired state"]</a></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>

<div class="toolbar">
    <a class="action-link" href="~/admin">@L["Back to admin overview"]</a>
    <a class="action-link" href="~/admin/appinstances">@L["View materialized app instances"]</a>
</div>
