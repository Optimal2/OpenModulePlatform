@page
@model OpenModulePlatform.Portal.Pages.Admin.HostResourcesModel
@{
    var ompBranding = await OmpBrandingService.GetBrandingAsync(ViewContext.HttpContext.RequestAborted);
}

<section class="page-header">
    <div>
        <div class="eyebrow">@L["Operations"]</div>
        <h2>@L["Host resources"]</h2>
        <p class="lede">@L["Latest CPU and memory telemetry per host runtime target. Values are written by HostAgent and refreshed on each collector cycle."]</p>
    </div>
</section>

<div class="toolbar top-gap">
    <a class="action-link" href="~/admin/hostdeployments">@L["Back to operations"]</a>
</div>

<div class="section-grid section-grid--wide top-gap">
    <section class="card section-card">
        <h3>@L["Summary"]</h3>
        <div class="metric-row">
            <div>
                <div class="metric__value">@Model.TotalHosts</div>
                <div class="metric__label">@L["Hosts"]</div>
            </div>
            <div>
                <div class="metric__value">@Model.HostsWithData</div>
                <div class="metric__label">@L["With telemetry"]</div>
            </div>
            <div>
                <div class="metric__value">@Model.StaleCount</div>
                <div class="metric__label">@L["Stale"]</div>
            </div>
        </div>
        <p class="muted">
            @L["Stale means the latest sample is older than"]
            @((int)Model.StaleThreshold.TotalMinutes)
            @L["minutes."]
        </p>
    </section>
</div>

<section class="card section-card section-card--wide top-gap host-resources-latest">
    <h3>@L["Per-host summary"]</h3>
    <p class="muted">@L["Total CPU and memory per host across all OMP runtime targets with telemetry."]</p>

    @if (Model.HostSummaries.Count == 0)
    {
        <div class="empty-state">@L["No enabled hosts were found."]</div>
    }
    else
    {
        <div class="section-grid section-grid--4 top-gap">
            @foreach (var host in Model.HostSummaries)
            {
                <div class="card section-card">
                    <div class="section-heading-row">
                        <div>
                            <h4><code>@host.HostKey</code></h4>
                            @if (!string.IsNullOrWhiteSpace(host.HostDisplayName))
                            {
                                <div class="muted">@host.HostDisplayName</div>
                            }
                        </div>
                        @if (!host.HasData)
                        {
                            <span class="pill">@L["No data"]</span>
                        }
                        else if (Model.IsStale(host.LastSampledUtc))
                        {
                            <span class="pill">@L["Stale"]</span>
                        }
                        else
                        {
                            <span class="pill">@L["Current"]</span>
                        }
                    </div>
                    <div class="metric-row">
                        <div>
                            <div class="metric__value">@Model.FormatCpu(host.TotalCpu)</div>
                            <div class="metric__label">@L["Total CPU"]</div>
                        </div>
                        <div>
                            <div class="metric__value">@Model.FormatMemory(host.TotalMemory)</div>
                            <div class="metric__label">@L["Total memory"]</div>
                        </div>
                        <div>
                            <div class="metric__value">@host.ComponentCount</div>
                            <div class="metric__label">@L["Components"]</div>
                        </div>
                    </div>
                    @if (host.HostLastSeenUtc.HasValue)
                    {
                        <div class="muted top-gap-sm">@L["Host last seen"]: @host.HostLastSeenUtc.Value.ToString("u")</div>
                    }
                </div>
            }
        </div>
    }
</section>

<section class="card section-card section-card--wide top-gap host-resources-latest">
    <h3>@L["Latest telemetry"]</h3>
    <p class="muted">@L["Each row shows the most recent CPU and memory value for one host runtime target. Use the historical chart link for per-sample detail."]</p>

    @if (Model.HostSummaries.Count == 0)
    {
        <div class="empty-state">@L["No enabled hosts were found."]</div>
    }
    else
    {
        @foreach (var host in Model.HostSummaries)
        {
            var components = Model.Groups.Where(g => g.HostId == host.HostId && g.HasData).ToList();
            <div class="card section-card top-gap">
                <div class="section-heading-row">
                    <div>
                        <h4><code>@host.HostKey</code></h4>
                        @if (!string.IsNullOrWhiteSpace(host.HostDisplayName))
                        {
                            <div class="muted">@host.HostDisplayName</div>
                        }
                    </div>
                    @if (!host.HasData)
                    {
                        <span class="pill">@L["No data"]</span>
                    }
                    else if (Model.IsStale(host.LastSampledUtc))
                    {
                        <span class="pill">@L["Stale"]</span>
                    }
                    else
                    {
                        <span class="pill">@L["Current"]</span>
                    }
                </div>

                @if (components.Count == 0)
                {
                    <div class="empty-state top-gap-sm">@L["No telemetry for this host."]</div>
                }
                else
                {
                    <div class="table-scroll top-gap-sm">
                        <table class="grid app-instances-grid">
                            <thead>
                                <tr>
                                    <th><a class="@Model.SortClass("runtimeKind")" href="@Url.Content(Model.SortLink("runtimeKind"))">@L["Runtime kind"] <span aria-hidden="true">@Model.SortIndicator("runtimeKind")</span></a></th>
                                    <th><a class="@Model.SortClass("runtimeName")" href="@Url.Content(Model.SortLink("runtimeName"))">@L["Runtime name"] <span aria-hidden="true">@Model.SortIndicator("runtimeName")</span></a></th>
                                    <th><a class="@Model.SortClass("cpu")" href="@Url.Content(Model.SortLink("cpu"))">@L["CPU"] <span aria-hidden="true">@Model.SortIndicator("cpu")</span></a></th>
                                    <th><a class="@Model.SortClass("memory")" href="@Url.Content(Model.SortLink("memory"))">@L["Memory"] <span aria-hidden="true">@Model.SortIndicator("memory")</span></a></th>
                                    <th><a class="@Model.SortClass("samples")" href="@Url.Content(Model.SortLink("samples"))">@L["Samples"] <span aria-hidden="true">@Model.SortIndicator("samples")</span></a></th>
                                    <th><a class="@Model.SortClass("lastSampledUtc")" href="@Url.Content(Model.SortLink("lastSampledUtc"))">@L["Last sampled UTC"] <span aria-hidden="true">@Model.SortIndicator("lastSampledUtc")</span></a></th>
                                    <th><a class="@Model.SortClass("state")" href="@Url.Content(Model.SortLink("state"))">@L["State"] <span aria-hidden="true">@Model.SortIndicator("state")</span></a></th>
                                    <th>@L["Actions"]</th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var group in components)
                            {
                                var stateClass = HostResourcesModel.StateClass(group, Model);
                                <tr class="@stateClass">
                                    <td>
                                        @if (string.IsNullOrWhiteSpace(group.RuntimeKind))
                                        {
                                            <span class="muted">@L["No runtime target"]</span>
                                        }
                                        else
                                        {
                                            @group.RuntimeKind
                                        }
                                    </td>
                                    <td>
                                        @if (string.IsNullOrWhiteSpace(group.RuntimeName))
                                        {
                                            <span class="muted">@L["None"]</span>
                                        }
                                        else
                                        {
                                            <code>@group.RuntimeName</code>
                                        }
                                    </td>
                                    <td>
                                        @if (group.CpuValue.HasValue)
                                        {
                                            <span>@Model.FormatCpu(group.CpuValue)</span>
                                        }
                                        else
                                        {
                                            <span class="muted">@L["No data"]</span>
                                        }
                                    </td>
                                    <td>
                                        @if (group.MemoryValue.HasValue)
                                        {
                                            <span>@Model.FormatMemory(group.MemoryValue)</span>
                                        }
                                        else
                                        {
                                            <span class="muted">@L["No data"]</span>
                                        }
                                    </td>
                                    <td>
                                        @if (group.HasData)
                                        {
                                            @group.SampleCount
                                        }
                                        else
                                        {
                                            <span class="muted">@L["None"]</span>
                                        }
                                    </td>
                                    <td>
                                        @if (group.LastSampledUtc.HasValue)
                                        {
                                            @group.LastSampledUtc.Value.ToString("u")
                                        }
                                        else
                                        {
                                            <span class="muted">@L["Never"]</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!group.HasData)
                                        {
                                            <span class="pill">@L["No data"]</span>
                                        }
                                        else if (Model.IsStale(group.LastSampledUtc))
                                        {
                                            <span class="pill">@L["Stale"]</span>
                                        }
                                        else if (group.IsRunning.HasValue)
                                        {
                                            <span class="pill">@(group.IsRunning.Value ? L["Running"] : L["Stopped"])</span>
                                        }
                                        else
                                        {
                                            <span class="pill">@L["Current"]</span>
                                        }
                                    </td>
                                    <td>
                                        @if (group.HasData && !string.IsNullOrWhiteSpace(group.CpuSampleKey))
                                        {
                                            <a class="action-link" href="~/admin/hostresourcedetail?hostId=@group.HostId&sampleKey=@Uri.EscapeDataString(group.CpuSampleKey)">@L["Chart"]</a>
                                        }
                                        else if (group.HasData && !string.IsNullOrWhiteSpace(group.MemorySampleKey))
                                        {
                                            <a class="action-link" href="~/admin/hostresourcedetail?hostId=@group.HostId&sampleKey=@Uri.EscapeDataString(group.MemorySampleKey)">@L["Chart"]</a>
                                        }
                                        else
                                        {
                                            <span class="muted">@L["No chart"]</span>
                                        }
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        }
    }
</section>
