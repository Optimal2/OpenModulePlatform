@page
@model OpenModulePlatform.Web.ExampleWorkerAppModule.Pages.IndexModel

<div class="page-header">
    <div>
        <div class="eyebrow">@L["Example module"]</div>
        <h1>@L["Example Worker App Module"]</h1>
        <p class="lede">
            @L["Reference module for combined web and manager-driven worker flows in OMP. The page shows module configuration, worker instances, and job queue status at a glance."]
        </p>
    </div>
</div>

<div class="section-grid section-grid--wide">
    <section class="card section-card">
        <h3>@L["Overview"]</h3>
        <div class="mini-metrics top-gap">
            <div><span>@L["Module key"]</span><code>@Model.Overview.ModuleKey</code></div>
            <div><span>@L["Schema"]</span><code>@Model.Overview.SchemaName</code></div>
            <div><span>@L["Active configurations"]</span><span class="metric-inline">@Model.Overview.ActiveConfigurationCount</span></div>
            <div><span>@L["Worker app instances"]</span><span class="metric-inline">@Model.Overview.WorkerAppInstanceCount</span></div>
            <div><span>@L["Running workers"]</span><span class="metric-inline">@Model.Overview.RunningWorkerCount</span></div>
            <div><span>@L["Open jobs"]</span><span class="metric-inline">@Model.Overview.OpenJobCount</span></div>
        </div>
    </section>

    <section class="card section-card">
        <h3>@L["Manage"]</h3>
        <p class="muted small-text">@L["Continue with worker app instances, configurations, or the job queue through the module's administration pages."]</p>
        <div class="toolbar">
            <a class="action-link" href="~/appinstances">@L["App Instances"]</a>
            <a class="action-link" href="~/configurations">@L["Configurations"]</a>
            <a class="action-link" href="~/jobs">@L["Jobs"]</a>
        </div>
    </section>
</div>
