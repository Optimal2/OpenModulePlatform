{
  "WorkerProcess": {
    "AppInstanceId": "00000000-0000-0000-0000-000000000000",
    "WorkerTypeKey": "",
    "PluginAssemblyPath": "",
    "ShutdownEventName": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "NLog": {
    "autoReload": true,
    "throwConfigExceptions": true,
    "variables": {
      "appName": "OpenModulePlatform.WorkerProcessHost",
      "logDirectory": "${basedir}/logs"
    },
    "targets": {
      "logfile": {
        "type": "File",
        "fileName": "${var:logDirectory}/${var:appName}-${shortdate}.log",
        "layout": "${longdate}|${uppercase:${level}}|${logger}|${message}${onexception:inner= ${exception:format=tostring}}"
      },
      "console": {
        "type": "Console",
        "layout": "${longdate}|${uppercase:${level}}|${logger}|${message}${onexception:inner= ${exception:format=tostring}}"
      }
    },
    "rules": [
      {
        "logger": "Microsoft.Hosting.Lifetime",
        "minLevel": "Info",
        "writeTo": "console,logfile",
        "final": true
      },
      {
        "logger": "Microsoft.*",
        "maxLevel": "Info",
        "final": true
      },
      {
        "logger": "*",
        "minLevel": "Info",
        "writeTo": "console,logfile"
      }
    ]
  }
}
