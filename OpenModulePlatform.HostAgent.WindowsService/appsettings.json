{
  "ConnectionStrings": {
    "OmpDb": ""
  },
  "HostAgent": {
    "ServiceName": "OMP.HostAgent",
    "HostKey": "",
    "HostName": "",
    "RefreshSeconds": 30,
    "CentralArtifactRoot": "",
    "LocalArtifactCacheRoot": "",
    "MaterializeTemplates": true,
    "ProcessHostDeployments": true,
    "ProvisionAppInstanceArtifacts": true,
    "ProvisionExplicitRequirements": true,
    "ProcessHostAgentJobs": true,
    "MaxHostAgentJobsPerCycle": 5,
    "PortalHealthCheck": {
      "Enabled": true,
      "HealthKey": "portal",
      "DisplayName": "OMP Portal",
      "Path": "/health/ready",
      "TimeoutSeconds": 10,
      "FailureThreshold": 3,
      "AutoRecycleAppPool": false,
      "AutoRecycleCooldownMinutes": 15,
      "AllowInvalidTlsCertificate": false
    },
    "ArtifactZipImport": {
      "IsEnabled": false,
      "ImportPath": "",
      "ProcessedPath": "",
      "FailedPath": "",
      "MaxFilesPerCycle": 10,
      "CopyConfigurationFilesFromPreviousVersion": true
    },
    "CredentialStore": {
      "AutomationMode": "Disabled",
      "FilePath": "",
      "ProtectionScope": "LocalMachine",
      "EntropyPurpose": "OpenModulePlatform.HostAgent.CredentialStore.v1"
    },
    "ServiceAppUserName": "",
    "ServiceAppPasswordCredentialKey": "",
    "ServiceAppIdentityOverrides": {},
    "MaxArtifactsPerCycle": 100,
    "EnableRpc": true,
    "RpcPipeName": "",
    "RpcRequestTimeoutSeconds": 60
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "NLog": {
    "autoReload": true,
    "throwConfigExceptions": true,
    "variables": {
      "appName": "OpenModulePlatform.HostAgent.WindowsService",
      "logDirectory": "${basedir}/logs"
    },
    "targets": {
      "logfile": {
        "type": "File",
        "fileName": "${var:logDirectory}/${var:appName}-${shortdate}.log",
        "layout": "${longdate}|${uppercase:${level}}|${logger}|${message}${onexception:inner= ${exception:format=tostring}}"
      },
      "console": {
        "type": "Console",
        "layout": "${longdate}|${uppercase:${level}}|${logger}|${message}${onexception:inner= ${exception:format=tostring}}"
      }
    },
    "rules": [
      {
        "logger": "Microsoft.Hosting.Lifetime",
        "minLevel": "Info",
        "writeTo": "console,logfile",
        "final": true
      },
      {
        "logger": "Microsoft.*",
        "maxLevel": "Info",
        "final": true
      },
      {
        "logger": "*",
        "minLevel": "Info",
        "writeTo": "console,logfile"
      }
    ]
  }
}
