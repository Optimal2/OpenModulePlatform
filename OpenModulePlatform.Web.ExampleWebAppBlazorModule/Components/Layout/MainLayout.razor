@inherits LayoutComponentBase
@inject Microsoft.Extensions.Options.IOptions<OpenModulePlatform.Web.Shared.Options.WebAppOptions> Options

<div class="page-shell">
    <header class="app-header">
        <PortalTopBar />
        <div class="topbar">
            <div class="brand-wrap">
                <div class="brand">@PortalTitle</div>
                <div class="brand-subtitle">Example Web App Blazor Module</div>
            </div>
            <nav class="nav nav--primary">
                <NavLink href="/" Match="NavLinkMatch.All">Overview</NavLink>
                <NavLink href="/configurations">Configurations</NavLink>
            </nav>
        </div>
    </header>

    <main class="content-shell">
        @Body
    </main>
</div>

@code {
    private string PortalTitle => string.IsNullOrWhiteSpace(Options.Value.Title)
        ? "OpenModulePlatform"
        : Options.Value.Title;
}
