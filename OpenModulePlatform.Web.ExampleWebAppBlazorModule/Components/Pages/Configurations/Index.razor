@page "/configurations"
@inherits ExampleWebAppBlazorModuleComponentBase
@inject ExampleWebAppBlazorModuleAdminRepository Repo

<PageTitle>@PageTitle</PageTitle>

@if (!AuthorizationResolved)
{
    <div class="empty-state">@L["Loading configurations..."]</div>
}
else if (!IsAuthorized)
{
    <div class="empty-state">@AccessDeniedMessage</div>
}
else
{
    <div class="page-header">
        <div>
            <div class="eyebrow">@L["Example module"]</div>
            <h1>@L["Configurations"]</h1>
            <p class="lede">
                @L["Configurations for Example Web App Blazor Module. These values are used by the example module and can be edited without leaving the module interface."]
            </p>
        </div>
    </div>

    @if (Rows.Count == 0)
    {
        <div class="empty-state">@L["No configurations were found."]</div>
    }
    else
    {
        <table class="grid">
            <thead>
                <tr>
                    <th>@L["ConfigId"]</th>
                    <th>@L["Comment"]</th>
                    <th>@L["Created UTC"]</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var row in Rows)
            {
                <tr>
                    <td><span class="pill">@row.ConfigId</span></td>
                    <td>@row.Comment</td>
                    <td>@row.CreatedUtc.ToString("u")</td>
                    <td>
                        <NavLink class="action-link" href='@($"configurations/edit/{row.ConfigId}")'>@L["Edit"]</NavLink>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
}

@code {
    private IReadOnlyList<ConfigurationRow> Rows { get; set; } = [];

    protected override async Task OnInitializedAsync()
    {
        SetPageTitle(L["Configurations"]);

        if (await EnsureAnyPermissionAsync(
                CancellationToken.None,
                ExampleWebAppBlazorModulePermissions.View,
                ExampleWebAppBlazorModulePermissions.Admin))
        {
            Rows = await Repo.GetConfigurationsAsync(CancellationToken.None);
        }
    }
}
