@page "/"
@inherits ExampleWebAppBlazorModuleComponentBase
@inject ExampleWebAppBlazorModuleAdminRepository Repo

<PageTitle>@PageTitle</PageTitle>

@if (!AuthorizationResolved)
{
    <div class="empty-state">@T("Loading overview...")</div>
}
else if (!IsAuthorized)
{
    <div class="empty-state">@AccessDeniedMessage</div>
}
else
{
    <div class="page-header">
        <div>
            <div class="eyebrow">@T("Example module")</div>
            <h1>@T("Example Web App Blazor Module")</h1>
            <p class="lede">
                @T("Neutral reference module for web flows in OMP. The page shows a module overview and links onward to the module's configurations.")
            </p>
        </div>
    </div>

    <div class="section-grid section-grid--wide">
        <section class="card section-card">
            <h3>@T("Overview")</h3>
            <div class="mini-metrics top-gap">
                <div><span>@T("Module key")</span><code>@OverviewData.ModuleKey</code></div>
                <div><span>@T("Schema")</span><code>@OverviewData.SchemaName</code></div>
                <div><span>@T("Active configurations")</span><span class="metric-inline">@OverviewData.ActiveConfigurationCount</span></div>
            </div>
        </section>

        <section class="card section-card">
            <h3>@T("Next step")</h3>
            <p class="muted small-text">
                @T("Continue to the configuration view to review or update the module's current sample configurations.")
            </p>
            <div class="toolbar">
                <NavLink class="action-link" href="configurations">@T("Open configurations")</NavLink>
            </div>
        </section>
    </div>
}

@code {
    private OverviewRow OverviewData { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        SetPageTitle("Overview");

        if (await EnsureAnyPermissionAsync(
                CancellationToken.None,
                ExampleWebAppBlazorModulePermissions.View,
                ExampleWebAppBlazorModulePermissions.Admin))
        {
            OverviewData = await Repo.GetOverviewAsync(CancellationToken.None);
        }
    }
}
