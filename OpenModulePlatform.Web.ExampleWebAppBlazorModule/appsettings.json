// File: OpenModulePlatform.Web.ExampleWebAppBlazorModule/appsettings.json
{
  "Portal": {
    "Title": "Example WebApp Blazor Module",
    "DefaultCulture": "sv-SE",
    "SupportedCultures": [
      "sv-SE",
      "en-US"
    ],
    "AllowAnonymous": false,
    "UseForwardedHeaders": false,
    "PermissionMode": "Any"
  },
  "ConnectionStrings": {
    "OmpDb": "Server=localhost;Database=OpenModulePlatform;Integrated Security=true;TrustServerCertificate=true;"
  },
  "NLog": {
    "autoReload": true,
    "throwConfigExceptions": true,
    "variables": {
      "appName": "OpenModulePlatform.Web.ExampleWebAppBlazorModule",
      "logDirectory": "${basedir}/logs"
    },
    "targets": {
      "logfile": {
        "type": "File",
        "fileName": "${var:logDirectory}/${var:appName}-${shortdate}.log",
        "layout": "${longdate}|${uppercase:${level}}|${logger}|${message}${onexception:inner= ${exception:format=tostring}}"
      },
      "console": {
        "type": "Console",
        "layout": "${longdate}|${uppercase:${level}}|${logger}|${message}${onexception:inner= ${exception:format=tostring}}"
      }
    },
    "rules": [
      {
        "logger": "Microsoft.Hosting.Lifetime",
        "minLevel": "Info",
        "writeTo": "console,logfile",
        "final": true
      },
      {
        "logger": "Microsoft.*",
        "maxLevel": "Info",
        "final": true
      },
      {
        "logger": "*",
        "minLevel": "Info",
        "writeTo": "console,logfile"
      }
    ]
  }
}
