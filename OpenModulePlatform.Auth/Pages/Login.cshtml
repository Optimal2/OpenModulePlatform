@page "/login"
@using System.Globalization
@model LoginModel
@inject OpenModulePlatform.Web.Shared.Services.OmpBrandingService OmpBrandingService
@{
    var ompBranding = await OmpBrandingService.GetBrandingAsync(ViewContext.HttpContext.RequestAborted);
    var signInLabel = L["Sign in"].Value;
    var signInTitle = string.Format(L["Sign in to {0}"].Value, ompBranding.PlatformName);
    var signInLead = string.Format(L["Choose an authentication provider for this {0} instance."].Value, ompBranding.PlatformName);
    ViewData["Title"] = signInLabel;
}
<!doctype html>
<html lang="@CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@signInLabel - @ompBranding.PlatformName</title>
    <style>
        :root { color-scheme: light dark; }
        *, *::before, *::after { box-sizing: border-box; }
        body { margin: 0; font-family: Arial, Helvetica, sans-serif; background: #f5f7fa; color: #16202a; }
        main { min-height: 100vh; display: grid; place-items: center; padding: 2rem; }
        .panel { width: min(28rem, 100%); background: #fff; border: 1px solid #d7dde5; border-radius: 8px; padding: 1.5rem; box-shadow: 0 12px 36px rgba(15, 23, 42, 0.08); }
        h1 { margin: 0 0 1rem; font-size: 1.7rem; }
        .muted { color: #586173; line-height: 1.5; }
        .stack { display: grid; gap: 1rem; }
        .windows-actions { display: grid; gap: .5rem; align-items: stretch; }
        .auth-options { display: grid; gap: .75rem; }
        .auth-options > summary { cursor: pointer; list-style: none; }
        .auth-options > summary::-webkit-details-marker { display: none; }
        .auth-options:not([open]) .auth-options-list { display: none; }
        .auth-options-heading { display: flex; align-items: center; gap: .75rem; color: #586173; font-size: .86rem; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; }
        .auth-options-heading::before,
        .auth-options-heading::after { content: ""; height: 1px; background: #e2e8f0; flex: 1; }
        .auth-options-list { display: grid; gap: .5rem; }
        .register-action { display: flex; justify-content: center; padding-top: .15rem; }
        label { display: block; margin-bottom: .3rem; font-weight: 700; }
        input { box-sizing: border-box; width: 100%; min-height: 2.5rem; padding: .5rem .65rem; border: 1px solid #c8d1dc; border-radius: 6px; font: inherit; }
        button, .button { display: inline-flex; justify-content: center; align-items: center; min-height: 2.5rem; padding: .55rem .8rem; border: 1px solid #2f5fb3; border-radius: 6px; background: #2f5fb3; color: #fff; font: inherit; font-weight: 700; text-decoration: none; cursor: pointer; }
        .button.block { width: 100%; }
        .button.secondary { background: #fff; color: #223044; border-color: #c8d1dc; }
        .button.subtle-link { min-height: auto; padding: .2rem .25rem; border: 0; background: transparent; color: #2f5fb3; font-weight: 700; text-decoration: underline; text-underline-offset: 3px; }
        .button.subtle-link:hover,
        .button.subtle-link:focus-visible { color: #193f82; background: transparent; }
        .error { padding: .75rem; border: 1px solid #f1a9a9; border-radius: 6px; background: #fff0f0; color: #8a1f1f; }
        dialog { border: 1px solid #c8d1dc; border-radius: 8px; padding: 0; width: min(25rem, calc(100% - 2rem)); box-shadow: 0 18px 48px rgba(15, 23, 42, .18); }
        dialog::backdrop { background: rgba(15, 23, 42, .35); }
        .dialog-body { padding: 1.25rem; }
        .dialog-actions { display: flex; justify-content: flex-end; gap: .5rem; flex-wrap: wrap; }
        .auth-options-indicator { width: 0; height: 0; border-top: .32rem solid transparent; border-bottom: .32rem solid transparent; border-left: .44rem solid currentColor; transition: transform .12s ease; }
        .auth-options[open] .auth-options-indicator { transform: rotate(90deg); }
        @@media (prefers-color-scheme: dark) {
            body { background: #0f172a; color: #e5edf7; }
            .panel, dialog { background: #111c2d; border-color: #334155; box-shadow: 0 18px 48px rgba(0, 0, 0, .35); }
            .muted, .auth-options-heading { color: #b6c3d5; }
            .auth-options-heading::before,
            .auth-options-heading::after { background: #334155; }
            input { background: #0b1220; border-color: #475569; color: #e5edf7; }
            .button.secondary { background: #111c2d; color: #e5edf7; border-color: #475569; }
            .button.subtle-link { color: #8bb7ff; }
            .button.subtle-link:hover,
            .button.subtle-link:focus-visible { color: #b8d3ff; }
            .error { background: #3a1518; border-color: #9f3a3f; color: #ffd4d7; }
            dialog::backdrop { background: rgba(0, 0, 0, .55); }
        }
    </style>
</head>
<body>
<main>
    <section class="panel">
        <div class="stack">
            <div>
                <h1>@signInTitle</h1>
                <p class="muted">@signInLead</p>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage) && !Model.HasOpenPrompt)
            {
                <div class="error">@Model.ErrorMessage</div>
            }

            <div class="windows-actions">
                <a class="button block" href="@Model.WindowsLoginUrl">@L["Sign in with Windows / AD"]</a>
            </div>

            <details class="auth-options" @(Model.ShowOtherSignInOptions || Model.HasOpenPrompt ? "open" : null)>
                <summary
                    class="auth-options-heading"
                    id="other-signin-options-heading"
                    aria-controls="other-signin-options-list"
                    aria-expanded="@((Model.ShowOtherSignInOptions || Model.HasOpenPrompt).ToString().ToLowerInvariant())">
                    <span class="auth-options-indicator" aria-hidden="true"></span>
                    <span>@L["Other sign-in options"]</span>
                </summary>
                <div class="auth-options-list" id="other-signin-options-list">
                    <button
                        type="button"
                        class="button secondary block"
                        data-dialog-target="alternate-windows-dialog"
                        title="@L["Sign in with another Windows / AD account"]">
                        @L["Other Windows / AD account"]
                    </button>
                    <button
                        type="button"
                        class="button secondary block"
                        data-dialog-target="local-account-dialog">
                        @L["Local account"]
                    </button>
                </div>
            </details>

            @if (Model.SelfRegistrationEnabled)
            {
                <div class="register-action">
                    <button type="button" class="button subtle-link" data-dialog-target="register-account-dialog">
                        @L["Create account"]
                    </button>
                </div>
            }

            <dialog id="alternate-windows-dialog" aria-labelledby="alternate-windows-dialog-title" data-open-on-load="@Model.ShowAlternateWindowsPrompt.ToString().ToLowerInvariant()">
                <form method="post" asp-page-handler="AlternateWindows" class="stack dialog-body">
                    <input type="hidden" asp-for="ReturnUrl" />
                    <div>
                        <h2 id="alternate-windows-dialog-title" style="margin: 0 0 .35rem; font-size: 1.25rem;">@L["Other Windows / AD account"]</h2>
                        <p class="muted" style="margin: 0;">@L["Use DOMAIN\\user, .\\user, user@domain, or a local account name."]</p>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage) && Model.ShowAlternateWindowsPrompt)
                    {
                        <div class="error">@Model.ErrorMessage</div>
                    }
                    <div>
                        <label asp-for="AlternateWindowsUserName">@L["Windows account"]</label>
                        <input asp-for="AlternateWindowsUserName" autocomplete="username" />
                    </div>
                    <div>
                        <label asp-for="AlternateWindowsPassword">@L["Password"]</label>
                        <input asp-for="AlternateWindowsPassword" type="password" autocomplete="current-password" />
                    </div>
                    <div class="dialog-actions">
                        <button type="button" class="button secondary" data-dialog-cancel>@L["Cancel"]</button>
                        <button type="submit">@L["Sign in"]</button>
                    </div>
                </form>
            </dialog>

            <dialog id="local-account-dialog" aria-labelledby="local-account-dialog-title" data-open-on-load="@Model.ShowLocalAccountPrompt.ToString().ToLowerInvariant()">
                <form method="post" asp-page-handler="Local" class="stack dialog-body">
                    <input type="hidden" asp-for="ReturnUrl" />
                    <div>
                        <h2 id="local-account-dialog-title" style="margin: 0 0 .35rem; font-size: 1.25rem;">@L["Local account"]</h2>
                        <p class="muted" style="margin: 0;">@L["Sign in with a local OMP user name and password."]</p>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage) && Model.ShowLocalAccountPrompt)
                    {
                        <div class="error">@Model.ErrorMessage</div>
                    }
                    <div>
                        <label asp-for="UserName">@L["User name"]</label>
                        <input asp-for="UserName" autocomplete="username" />
                    </div>
                    <div>
                        <label asp-for="Password">@L["Password"]</label>
                        <input asp-for="Password" type="password" autocomplete="current-password" />
                    </div>
                    <div class="dialog-actions">
                        <button type="button" class="button secondary" data-dialog-cancel>@L["Cancel"]</button>
                        <button type="submit">@L["Sign in"]</button>
                    </div>
                </form>
            </dialog>

            @if (Model.SelfRegistrationEnabled)
            {
                <dialog id="register-account-dialog" aria-labelledby="register-account-dialog-title" data-open-on-load="@Model.ShowRegisterAccountPrompt.ToString().ToLowerInvariant()">
                    <form method="post" asp-page-handler="Register" class="stack dialog-body">
                        <input type="hidden" asp-for="ReturnUrl" />
                        <div>
                            <h2 id="register-account-dialog-title" style="margin: 0 0 .35rem; font-size: 1.25rem;">@L["Create account"]</h2>
                            <p class="muted" style="margin: 0;">@L["Create a local OMP account with a user name and password."]</p>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage) && Model.ShowRegisterAccountPrompt)
                        {
                            <div class="error">@Model.ErrorMessage</div>
                        }
                        <div>
                            <label asp-for="RegisterUserName">@L["User name"]</label>
                            <input asp-for="RegisterUserName" autocomplete="username" />
                        </div>
                        <div>
                            <label asp-for="RegisterPassword">@L["Password"]</label>
                            <input asp-for="RegisterPassword" type="password" autocomplete="new-password" />
                        </div>
                        <div>
                            <label asp-for="RegisterConfirmPassword">@L["Confirm password"]</label>
                            <input asp-for="RegisterConfirmPassword" type="password" autocomplete="new-password" />
                        </div>
                        <div class="dialog-actions">
                            <button type="button" class="button secondary" data-dialog-cancel>@L["Cancel"]</button>
                            <button type="submit">@L["Create account"]</button>
                        </div>
                    </form>
                </dialog>
            }
        </div>
    </section>
</main>
<script>
    (() => {
        const openDialog = (dialog) => {
            if (!dialog) {
                return;
            }

            if (typeof dialog.showModal === 'function') {
                dialog.showModal();
                return;
            }

            dialog.setAttribute('open', '');
        };

        document.querySelectorAll('[data-dialog-target]').forEach((button) => {
            button.addEventListener('click', () => {
                openDialog(document.getElementById(button.dataset.dialogTarget));
            });
        });

        document.querySelectorAll('dialog').forEach((dialog) => {
            if (dialog.dataset.openOnLoad === 'true') {
                openDialog(dialog);
            }

            dialog.querySelectorAll('[data-dialog-cancel]').forEach((button) => {
                button.addEventListener('click', () => {
                    dialog.close();
                });
            });
        });

        document.querySelectorAll('details.auth-options').forEach((details) => {
            const summary = details.querySelector('summary[aria-expanded]');
            const updateExpanded = () => {
                if (summary) {
                    summary.setAttribute('aria-expanded', details.open ? 'true' : 'false');
                }
            };

            updateExpanded();
            details.addEventListener('toggle', updateExpanded);
        });
    })();
</script>
</body>
</html>
