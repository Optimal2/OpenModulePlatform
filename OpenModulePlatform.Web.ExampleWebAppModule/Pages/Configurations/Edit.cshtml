@page
@model OpenModulePlatform.Web.ExampleWebAppModule.Pages.Configurations.EditModel

<div class="page-header">
    <div>
        <div class="eyebrow">Example module</div>
        <h1>Edit configuration</h1>
        <p class="lede">Uppdatera kommentar och JSON-innehåll för vald konfiguration.</p>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="card status-banner">@Model.StatusMessage</div>
}

<form method="post" class="card form-grid">
    <input type="hidden" asp-for="Input.ConfigId" />

    <div class="form-field">
        <label asp-for="Input.Comment"></label>
        <input asp-for="Input.Comment" type="text" />
    </div>

    <div class="form-field">
        <label asp-for="Input.ConfigJson"></label>
        <textarea asp-for="Input.ConfigJson"></textarea>
    </div>

    <div class="toolbar">
        <button type="submit">Save</button>
        <a class="action-link" href="~/configurations">Back to configurations</a>
    </div>
</form>
