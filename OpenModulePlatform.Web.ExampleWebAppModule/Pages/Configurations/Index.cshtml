@page
@model OpenModulePlatform.Web.ExampleWebAppModule.Pages.Configurations.IndexModel

<div class="page-header">
    <div>
        <div class="eyebrow">@L["Example module"]</div>
        <h1>@L["Configurations"]</h1>
        <p class="lede">
            @L["Configurations for Example Web App Module. These values are used by the example module and can be edited without leaving the module interface."]
        </p>
    </div>
</div>

@if (Model.Rows.Count == 0)
{
    <div class="empty-state">@L["No configurations were found."]</div>
}
else
{
    <table class="grid">
        <thead><tr><th>@L["ConfigId"]</th><th>@L["Comment"]</th><th>@L["Created UTC"]</th><th></th></tr></thead>
        <tbody>
        @foreach (var row in Model.Rows)
        {
            <tr>
                <td><span class="pill">@row.ConfigId</span></td>
                <td>@row.Comment</td>
                <td>@row.CreatedUtc.ToString("u")</td>
                <td><a class="action-link" href="~/configurations/edit?configId=@row.ConfigId">@L["Edit"]</a></td>
            </tr>
        }
        </tbody>
    </table>
}
