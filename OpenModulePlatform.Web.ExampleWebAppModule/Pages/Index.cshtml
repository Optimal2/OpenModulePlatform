@page
@model OpenModulePlatform.Web.ExampleWebAppModule.Pages.IndexModel

<div class="page-header">
    <div>
        <div class="eyebrow">@L["Example module"]</div>
        <h1>@L["Example Web App Module"]</h1>
        <p class="lede">
            @L["Neutral reference module for web flows in OMP. The page shows a module overview and links onward to the module's configurations."]
        </p>
    </div>
</div>

<div class="section-grid section-grid--wide">
    <section class="card section-card">
        <h3>@L["Overview"]</h3>
        <div class="mini-metrics top-gap">
            <div><span>@L["Module key"]</span><code>@Model.Overview.ModuleKey</code></div>
            <div><span>@L["Schema"]</span><code>@Model.Overview.SchemaName</code></div>
            <div><span>@L["Active configurations"]</span><span class="metric-inline">@Model.Overview.ActiveConfigurationCount</span></div>
        </div>
    </section>

    <section class="card section-card">
        <h3>@L["Next step"]</h3>
        <p class="muted small-text">
            @L["Continue to the configuration view to review or update the module's current sample configurations."]
        </p>
        <div class="toolbar">
            <a class="action-link" href="~/configurations">@L["Open configurations"]</a>
        </div>
    </section>
</div>
