@* File: OpenModulePlatform.Web.ExampleWebAppModule/Pages/Shared/_Layout.cshtml *@
@using OpenModulePlatform.Web.Shared.Navigation
@inject Microsoft.Extensions.Options.IOptions<OpenModulePlatform.Web.Shared.Options.WebAppOptions> WebAppOptionsAccessor
@{
    var portalTopBar = PortalTopBarModelFactory.Create(WebAppOptionsAccessor.Value);
    var returnUrl = $"{Context.Request.PathBase}{Context.Request.Path}{Context.Request.QueryString}";
    var currentCulture = System.Globalization.CultureInfo.CurrentUICulture.Name;
}
<!doctype html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header class="app-header">
        @if (portalTopBar.IsVisible)
        {
            <div class="portal-topbar">
                <nav class="portal-topbar__nav" aria-label="@L["Portal"]" data-portal-topbar>
                    <div class="portal-topbar__links" data-portal-topbar-links>
                        @for (var i = 0; i < portalTopBar.Links.Count; i++)
                        {
                            var link = portalTopBar.Links[i];
                            var cssClass = i == 0 ? "portal-topbar__link portal-topbar__link--root" : "portal-topbar__link";
                            <a class="@cssClass" href="@link.Href" data-portal-topbar-item data-index="@i">@L[link.TextKey]</a>
                        }
                    </div>

                    <details class="portal-topbar__overflow" data-portal-topbar-overflow hidden>
                        <summary>@L[portalTopBar.OverflowToggleTextKey]</summary>
                        <div class="portal-topbar__menu" data-portal-topbar-menu></div>
                    </details>
                </nav>
            </div>
        }
        <div class="topbar">
        <div class="brand-wrap">
            <div class="brand">@ViewData["PortalTitle"]</div>
            <div class="brand-subtitle">@L["Example Web App Module"]</div>
        </div>
        <nav class="nav nav--primary">
            <a href="~/">@L["Overview"]</a>
            <a href="~/configurations">@L["Configurations"]</a>
        </nav>
        <div class="toolbar toolbar--header">
            <form method="get" action="~/localization/set-language" class="language-switcher">
                <input type="hidden" name="returnUrl" value="@returnUrl" />
                <label class="visually-hidden" for="example-language-selector">@L["Language"]</label>
                <select id="example-language-selector" name="culture" onchange="this.form.submit()">
                    @if (currentCulture == "sv-SE")
                    {
                        <option value="sv-SE" selected>@L["Swedish"]</option>
                        <option value="en-US">@L["English"]</option>
                    }
                    else
                    {
                        <option value="sv-SE">@L["Swedish"]</option>
                        <option value="en-US" selected>@L["English"]</option>
                    }
                </select>
            </form>
            <div class="user">@User?.Identity?.Name</div>
        </div>
        </div>
    </header>
    <main class="content-shell">
        @RenderBody()
    </main>
    <script>
        (() => {
            const topbars = document.querySelectorAll('[data-portal-topbar]');

            function sortByIndex(nodes) {
                return [...nodes].sort((left, right) => Number(left.dataset.index) - Number(right.dataset.index));
            }

            function rebalance(topbar) {
                const linksHost = topbar.querySelector('[data-portal-topbar-links]');
                const overflow = topbar.querySelector('[data-portal-topbar-overflow]');
                const menu = topbar.querySelector('[data-portal-topbar-menu]');
                const summary = overflow?.querySelector('summary');

                if (!linksHost || !overflow || !menu || !summary) {
                    return;
                }

                const allLinks = sortByIndex([
                    ...linksHost.querySelectorAll('[data-portal-topbar-item]'),
                    ...menu.querySelectorAll('[data-portal-topbar-item]')
                ]);

                for (const link of allLinks) {
                    linksHost.appendChild(link);
                }

                overflow.open = false;
                overflow.hidden = true;
                overflow.classList.remove('portal-topbar__overflow--measuring');
                menu.replaceChildren();

                if (linksHost.scrollWidth <= linksHost.clientWidth) {
                    return;
                }

                overflow.hidden = false;
                overflow.classList.add('portal-topbar__overflow--measuring');

                while (linksHost.children.length > 1 && linksHost.scrollWidth > linksHost.clientWidth) {
                    const linkToMove = linksHost.lastElementChild;
                    if (!linkToMove) {
                        break;
                    }

                    menu.prepend(linkToMove);
                }

                overflow.classList.remove('portal-topbar__overflow--measuring');

                if (menu.children.length === 0) {
                    overflow.hidden = true;
                }
            }

            function registerOutsideClose(topbar) {
                const overflow = topbar.querySelector('[data-portal-topbar-overflow]');
                if (!overflow) {
                    return;
                }

                document.addEventListener('click', event => {
                    if (!overflow.open) {
                        return;
                    }

                    if (!overflow.contains(event.target)) {
                        overflow.open = false;
                    }
                });
            }

            for (const topbar of topbars) {
                const rebalanceTopbar = () => rebalance(topbar);
                rebalanceTopbar();
                registerOutsideClose(topbar);

                if (typeof ResizeObserver !== 'undefined') {
                    const resizeObserver = new ResizeObserver(rebalanceTopbar);
                    resizeObserver.observe(topbar);
                }

                window.addEventListener('resize', rebalanceTopbar);
                window.addEventListener('load', rebalanceTopbar);
            }
        })();
    </script>
</body>
</html>
