@* File: OpenModulePlatform.Web.ExampleWebAppModule/Pages/Shared/_Layout.cshtml *@
<!doctype html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header class="topbar">
        <div class="brand-wrap">
            <div class="brand">@ViewData["PortalTitle"]</div>
            <div class="brand-subtitle">Example Web App Module</div>
        </div>
        <nav class="nav nav--primary">
            <a href="~/">Overview</a>
            <a href="~/configurations">Configurations</a>
        </nav>
        <div class="user">@User?.Identity?.Name</div>
    </header>
    <main class="content-shell">
        @RenderBody()
    </main>
</body>
</html>
