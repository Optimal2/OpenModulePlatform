// File: OpenModulePlatform.Web.ContentWebAppModule/appsettings.json
{
  "ConnectionStrings": {
    "OmpDb": "Server=localhost;Database=OpenModulePlatform;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Portal": {
    "Title": "Content",
    "DefaultCulture": "sv-SE",
    "SupportedCultures": [ "sv-SE", "en-US" ],
    "PortalTopBar": {
      "Enabled": true,
      "PortalBaseUrl": "/"
    },
    "AllowAnonymous": false,
    "PermissionMode": "Any"
  },
  "ContentWebAppModule": {
    "AppInstanceId": "11111111-1111-1111-1111-111111111232",
    "HomeSlug": "home",
    "ServerReportsPath": "App_Data/ContentReports",
    "ServerReportDefaultMaxRows": 100,
    "ServerReportMaxRowsLimit": 1000,
    "ServerReportQueryTimeoutSeconds": 30
  },
  "OmpAuth": {
    "CookieName": ".OpenModulePlatform.Auth",
    "LoginPath": "/auth/login",
    "LogoutPath": "/auth/logout",
    "AccessDeniedPath": "/status/403",
    "ApplicationName": "OpenModulePlatform"
  },
  "NLog": {
    "autoReload": true,
    "throwConfigExceptions": true,
    "variables": {
      "appName": "OpenModulePlatform.Web.ContentWebAppModule",
      "logDirectory": "${basedir}/logs"
    },
    "targets": {
      "logfile": {
        "type": "File",
        "fileName": "${var:logDirectory}/${var:appName}-${shortdate}.log",
        "layout": "${longdate}|${uppercase:${level}}|${logger}|${message}${onexception:inner= ${exception:format=tostring}}"
      },
      "console": {
        "type": "Console",
        "layout": "${longdate}|${uppercase:${level}}|${logger}|${message}${onexception:inner= ${exception:format=tostring}}"
      }
    },
    "rules": [
      {
        "logger": "Microsoft.Hosting.Lifetime",
        "minLevel": "Info",
        "writeTo": "console,logfile",
        "final": true
      },
      {
        "logger": "Microsoft.*",
        "maxLevel": "Info",
        "final": true
      },
      {
        "logger": "*",
        "minLevel": "Info",
        "writeTo": "console,logfile"
      }
    ]
  }
}
