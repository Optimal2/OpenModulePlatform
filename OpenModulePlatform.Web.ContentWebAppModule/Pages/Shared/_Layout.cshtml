@* File: OpenModulePlatform.Web.ContentWebAppModule/Pages/Shared/_Layout.cshtml *@
<!doctype html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/_content/OpenModulePlatform.Web.Shared/css/portal-topbar.css" />
    <link rel="stylesheet" href="~/_content/OpenModulePlatform.Web.Shared/css/omp-error-view.css" />
    @await RenderSectionAsync("Styles", required: false)
    @if (ViewData["OmpPreventBackCache"] is true)
    {
        <meta name="omp-prevent-back-cache" content="true" />
    }
</head>
<body>
    <header class="app-header">
        @await Component.InvokeAsync("PortalTopBar")
        <div class="topbar">
            <a class="brand-wrap brand-wrap--link" href="~/" aria-label="@L["Content home"]">
                <div class="brand">@ViewData["PortalTitle"]</div>
                <div class="brand-subtitle">@L["Content"]</div>
            </a>
            <nav class="topbar-nav" aria-label="@L["Content navigation"]">
                @if (ViewData["ContentManageHref"] is string contentManageHref && !string.IsNullOrWhiteSpace(contentManageHref))
                {
                    var contentManageLabel = ViewData["ContentManageLabel"]?.ToString() ?? "Manage pages";
                    <a href="@contentManageHref">@L[contentManageLabel]</a>
                }
                else if (ViewData["CanManageContent"] is true)
                {
                    <a href="~/admin">@L["Manage pages"]</a>
                }
                @if (IsSectionDefined("ModuleNav"))
                {
                    @RenderSection("ModuleNav", required: false)
                }
            </nav>
        </div>
    </header>
    <main class="content-shell">
        @RenderBody()
    </main>
    <script src="~/_content/OpenModulePlatform.Web.Shared/js/portal-topbar.js"></script>
    <script src="~/_content/OpenModulePlatform.Web.Shared/js/omp-secure-page-navigation.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
