@* File: OpenModulePlatform.Web.ContentWebAppModule/Pages/Admin/Index.cshtml *@
@page
@model OpenModulePlatform.Web.ContentWebAppModule.Pages.Admin.IndexModel

<div class="page-header">
    <div>
        <div class="eyebrow">@L["Content"]</div>
        <h1>@L["Manage pages"]</h1>
        <p class="lede">@L["Create and edit content pages for this app instance."]</p>
    </div>
    @if (Model.CanCreatePages)
    {
        <div class="toolbar">
            <form method="post" asp-page-handler="LoadContentFiles">
                <button type="submit">@L["Load content files"]</button>
            </form>
            <a class="button button--primary" href="~/admin/create">@L["New page"]</a>
        </div>
    }
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="card status-banner">@Model.StatusMessage</div>
}

@if (Model.CanCreatePages)
{
    <section class="card content-file-summary">
        <div>
            <h2>@L["Available file-backed content"]</h2>
            <p class="muted">@L["Load content files creates missing pages from HTML files and JSON server reports in the configured directories."]</p>
        </div>
        <div class="toolbar">
            <span class="pill">@L["HTML files"]: @Model.AvailableHtmlFileKeys.Count</span>
            <span class="pill">@L["Server reports"]: @Model.AvailableServerReportKeys.Count</span>
        </div>
    </section>
}

@if (Model.Rows.Count == 0)
{
    <div class="empty-state">@L["No content pages were found."]</div>
}
else
{
    <table class="grid">
        <thead>
            <tr>
                <th>@L["Title"]</th>
                <th>@L["Slug"]</th>
                <th>@L["State"]</th>
                <th>@L["Access"]</th>
                <th>@L["Updated"]</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var row in Model.Rows)
        {
            var publicHref = Url.Content(string.IsNullOrWhiteSpace(row.Slug) ? "~/" : "~/" + row.Slug);
            <tr>
                <td>
                    <strong>@row.Title</strong>
                    <div class="muted">
                        @row.ContentType
                        @if (!string.IsNullOrWhiteSpace(row.ServerReportKey))
                        {
                            <span>
                                @(row.ContentType == "html_file" ? L["HTML file"] : L["Server report"]):
                                @row.ServerReportKey
                            </span>
                        }
                        @if (row.SortOrder is not null)
                        {
                            <span>@L["Sort order"]: @row.SortOrder</span>
                        }
                    </div>
                </td>
                <td><code>@(string.IsNullOrEmpty(row.Slug) ? "/" : row.Slug)</code></td>
                <td>
                    @if (row.IsEnabled)
                    {
                        <span class="pill pill--ok">@L["Enabled"]</span>
                    }
                    else
                    {
                        <span class="pill">@L["Disabled"]</span>
                    }
                </td>
                <td>@(string.IsNullOrWhiteSpace(row.AccessSummary) ? L["No role access"].Value : row.AccessSummary)</td>
                <td>
                    <div>@row.UpdatedAtUtc.ToString("u")</div>
                    <div class="muted">@row.UpdatedBy</div>
                </td>
                <td class="grid-actions">
                    <a class="action-link" href="~/admin/edit/@row.ContentId">@L["Edit"]</a>
                    <a class="action-link" href="~/admin/preview?contentId=@row.ContentId">@L["Preview"]</a>
                    @if (row.IsEnabled)
                    {
                        <a class="action-link" href="@publicHref">@L["Open"]</a>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
}
