@* File: OpenModulePlatform.Web.ContentWebAppModule/Pages/Admin/Edit.cshtml *@
@page "{contentId:guid?}"
@model OpenModulePlatform.Web.ContentWebAppModule.Pages.Admin.EditModel

@section Styles {
    <link rel="stylesheet" href="https://uicdn.toast.com/editor/3.2.2/toastui-editor.min.css" />
}

<div class="page-header">
    <div>
        <div class="eyebrow">@L["Content"]</div>
        <h1>@(Model.IsCreate ? L["New page"] : L["Edit page"])</h1>
        <p class="lede">@L["Choose a content type first. Markdown, HTML, and server reports each use a dedicated editor."]</p>
    </div>
    <div class="toolbar">
        <a class="button" href="~/admin">@L["Back to pages"]</a>
        @if (!Model.IsCreate)
        {
            <a class="button" href="~/admin/preview?contentId=@Model.Input.ContentId">@L["Preview"]</a>
        }
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="card status-banner">@Model.StatusMessage</div>
}

<form method="post" class="card form-grid" id="content-edit-form">
    <input type="hidden" asp-for="Input.ContentId" />
    <input type="hidden" asp-for="Input.IsEnabled" />
    <input type="hidden" asp-for="Input.CreatedAtUtc" />
    <input type="hidden" asp-for="Input.CreatedBy" />
    <input type="hidden" asp-for="Input.UpdatedAtUtc" />
    <input type="hidden" asp-for="Input.UpdatedBy" />

    <div asp-validation-summary="ModelOnly" class="field-validation-error"></div>

    <div class="form-row">
        <div class="form-field">
            <label asp-for="Input.Title"></label>
            <input asp-for="Input.Title" />
            <span asp-validation-for="Input.Title" class="field-validation-error"></span>
        </div>
        <div class="form-field">
            <label asp-for="Input.Slug"></label>
            <input asp-for="Input.Slug" placeholder="help/faq" />
            <span class="field-hint">@L["Slugs are normalized when saved."]</span>
            <span asp-validation-for="Input.Slug" class="field-validation-error"></span>
        </div>
    </div>

    <div class="form-row">
        <div class="form-field">
            <label asp-for="Input.ContentType"></label>
            <select asp-for="Input.ContentType">
                <option value="markdown">@L["Markdown"]</option>
                <option value="html">@L["HTML"]</option>
                <option value="server_report">@L["Server report"]</option>
            </select>
        </div>
        <div class="form-field">
            <label asp-for="Input.SortOrder"></label>
            <input asp-for="Input.SortOrder" type="number" />
        </div>
    </div>

    @{
        var currentServerReportKey = Model.Input.ServerReportKey;
        var currentReportKeyMissing = !string.IsNullOrWhiteSpace(currentServerReportKey)
            && !Model.AvailableServerReportKeys.Contains(currentServerReportKey, StringComparer.OrdinalIgnoreCase);
    }

    <div class="form-field" data-server-report-field hidden="@(Model.Input.ContentType != "server_report")">
        <label asp-for="Input.ServerReportKey"></label>
        <select asp-for="Input.ServerReportKey">
            <option value="">@L["Choose a server report"]</option>
            @foreach (var reportKey in Model.AvailableServerReportKeys)
            {
                <option value="@reportKey">@reportKey</option>
            }
            @if (currentReportKeyMissing)
            {
                <option value="@currentServerReportKey">@currentServerReportKey (@L["missing"])</option>
            }
        </select>
        <span class="field-hint">@L["Server reports are JSON files in the server report directory. SQL is not edited here."]</span>
        <span asp-validation-for="Input.ServerReportKey" class="field-validation-error"></span>
    </div>

    <div class="form-field content-editor-field" data-content-editor-field hidden="@(Model.Input.ContentType == "server_report")">
        <label asp-for="Input.Body"></label>
        <div id="content-editor" class="content-editor" hidden></div>
        <textarea asp-for="Input.Body" rows="18" class="content-editor__source"></textarea>
        <span class="field-hint" data-editor-hint="markdown">@L["Write Markdown content. Server report shortcodes such as DB_JSON are supported."]</span>
        <span class="field-hint" data-editor-hint="html" hidden>@L["Write trusted HTML directly. Server report shortcodes such as DB_JSON are supported."]</span>
        <span class="field-hint">@L["Changing content type changes the editor but does not convert existing content."]</span>
        <span asp-validation-for="Input.Body" class="field-validation-error"></span>
    </div>

    @if (Model.CanManageAll)
    {
        <section class="access-panel">
            <div>
                <h2>@L["Role access"]</h2>
                <p class="muted">@L["Roles with read access can view the page. Roles with write access can edit it."]</p>
            </div>
            @if (Model.Input.RoleAccesses.Count == 0)
            {
                <div class="empty-state">@L["No roles are configured."]</div>
            }
            else
            {
                <table class="grid access-grid">
                    <thead>
                        <tr>
                            <th>@L["Role"]</th>
                            <th>@L["Read"]</th>
                            <th>@L["Write"]</th>
                        </tr>
                    </thead>
                    <tbody>
                    @for (var i = 0; i < Model.Input.RoleAccesses.Count; i++)
                    {
                        <tr>
                            <td>
                                <input type="hidden" asp-for="Input.RoleAccesses[i].RoleId" />
                                <input type="hidden" asp-for="Input.RoleAccesses[i].RoleName" />
                                @Model.Input.RoleAccesses[i].RoleName
                            </td>
                            <td>
                                <input asp-for="Input.RoleAccesses[i].CanRead" type="checkbox" />
                            </td>
                            <td>
                                <input asp-for="Input.RoleAccesses[i].CanWrite" type="checkbox" />
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            }
        </section>
    }
    else
    {
        @for (var i = 0; i < Model.Input.RoleAccesses.Count; i++)
        {
            <input type="hidden" asp-for="Input.RoleAccesses[i].RoleId" />
            <input type="hidden" asp-for="Input.RoleAccesses[i].RoleName" />
            <input type="hidden" asp-for="Input.RoleAccesses[i].CanRead" />
            <input type="hidden" asp-for="Input.RoleAccesses[i].CanWrite" />
        }
    }

    <div class="toolbar">
        <button type="submit" asp-page-handler="Save" class="button--primary">@L["Save page"]</button>
        @if (!Model.IsCreate && Model.CanManageAll)
        {
            @if (Model.Input.IsEnabled)
            {
                <button type="submit" asp-page-handler="Disable" class="button--danger" formnovalidate>@L["Disable"]</button>
            }
            else
            {
                <button type="submit" asp-page-handler="Enable" class="button--secondary" formnovalidate>@L["Enable"]</button>
            }
        }
    </div>
</form>

@if (!Model.IsCreate)
{
    <section class="card content-metadata">
        <h2>@L["Metadata"]</h2>
        <dl>
            <dt>@L["Content ID"]</dt>
            <dd><code>@Model.Input.ContentId</code></dd>
            <dt>@L["Created"]</dt>
            <dd>@Model.Input.CreatedAtUtc?.ToString("u") <span class="muted">@Model.Input.CreatedBy</span></dd>
            <dt>@L["Updated"]</dt>
            <dd>@Model.Input.UpdatedAtUtc?.ToString("u") <span class="muted">@Model.Input.UpdatedBy</span></dd>
        </dl>
    </section>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://uicdn.toast.com/editor/3.2.2/toastui-editor-all.min.js"></script>
    <script>
        (() => {
            const source = document.getElementById('Input_Body');
            const host = document.getElementById('content-editor');
            const form = document.getElementById('content-edit-form');
            const contentType = document.getElementById('Input_ContentType');
            const editorField = document.querySelector('[data-content-editor-field]');
            const reportField = document.querySelector('[data-server-report-field]');
            const markdownHint = document.querySelector('[data-editor-hint="markdown"]');
            const htmlHint = document.querySelector('[data-editor-hint="html"]');
            let markdownEditor = null;
            let previousType = contentType?.value || 'markdown';

            const pullMarkdownEditorValue = () => {
                if (markdownEditor) {
                    source.value = markdownEditor.getMarkdown();
                }
            };

            const ensureMarkdownEditor = () => {
                if (!source || !host || !window.toastui?.Editor) {
                    return;
                }

                if (!markdownEditor) {
                    markdownEditor = new toastui.Editor({
                        el: host,
                        height: '520px',
                        initialEditType: 'markdown',
                        previewStyle: 'vertical',
                        initialValue: source.value || ''
                    });
                }
                else if (previousType !== 'markdown') {
                    markdownEditor.setMarkdown(source.value || '');
                }

                host.hidden = false;
                source.classList.add('is-enhanced');
            };

            const showRawSourceEditor = () => {
                if (!source || !host) {
                    return;
                }

                if (previousType === 'markdown') {
                    pullMarkdownEditorValue();
                }

                host.hidden = true;
                source.classList.remove('is-enhanced');
            };

            const syncContentType = () => {
                const type = contentType?.value || 'markdown';
                const isServerReport = type === 'server_report';
                const isHtml = type === 'html';

                if (editorField) {
                    editorField.hidden = isServerReport;
                }

                if (reportField) {
                    reportField.hidden = !isServerReport;
                }

                if (markdownHint) {
                    markdownHint.hidden = isServerReport || isHtml;
                }

                if (htmlHint) {
                    htmlHint.hidden = isServerReport || !isHtml;
                }

                if (isServerReport) {
                    showRawSourceEditor();
                }
                else if (isHtml) {
                    showRawSourceEditor();
                    source?.classList.add('content-editor__source--html');
                }
                else {
                    source?.classList.remove('content-editor__source--html');
                    ensureMarkdownEditor();
                }

                previousType = type;
            };

            contentType?.addEventListener('change', syncContentType);
            syncContentType();

            if (!source || !form || !contentType) {
                return;
            }

            form.addEventListener('submit', () => {
                if (contentType.value === 'server_report') {
                    source.value = '';
                    return;
                }

                if (contentType.value === 'markdown') {
                    pullMarkdownEditorValue();
                }
            });
        })();
    </script>
}
