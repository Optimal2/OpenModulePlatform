@* File: OpenModulePlatform.Web.ContentWebAppModule/Pages/Admin/Preview.cshtml *@
@page
@model OpenModulePlatform.Web.ContentWebAppModule.Pages.Admin.PreviewModel

@if (Model.PageContent is not null)
{
    <div class="page-header">
        <div>
            <div class="eyebrow">@L["Preview"]</div>
            <h1>@Model.PageContent.Title</h1>
            <p class="lede">
                @if (Model.PageContent.IsEnabled)
                {
                    @L["This page is enabled."]
                }
                else
                {
                    @L["This page is disabled and is only visible in content administration."]
                }
            </p>
        </div>
        <div class="toolbar">
            <a class="button" href="~/admin/edit/@Model.PageContent.ContentId">@L["Edit"]</a>
            <a class="button" href="~/admin">@L["Back to pages"]</a>
        </div>
    </div>

    <article class="content-page content-page--preview">
        <div class="content-page__body">
            @Html.Raw(Model.RenderedHtml)
        </div>
    </article>
}
