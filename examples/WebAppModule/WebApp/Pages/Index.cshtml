@page
@model OpenModulePlatform.Web.ExampleWebAppModule.Pages.IndexModel
@{
    var ompBranding = await OmpBrandingService.GetBrandingAsync(ViewContext.HttpContext.RequestAborted);
}

<div class="page-header">
    <div>
        <div class="eyebrow">@L["Example module"]</div>
        <h1>@L["Example Web App Module"]</h1>
        <p class="lede">
            @ompBranding.ApplyTerms(L["Neutral reference module for web flows in OMP. The page shows a module overview and links onward to the module's configurations."].Value)
        </p>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="notice notice--success" role="status">@Model.StatusMessage</div>
}
@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="notice notice--warning" role="status">@Model.ErrorMessage</div>
}

<div class="section-grid section-grid--wide">
    <section class="card section-card">
        <h3>@L["Overview"]</h3>
        <div class="mini-metrics top-gap">
            <div><span>@L["Module key"]</span><code>@Model.Overview.ModuleKey</code></div>
            <div><span>@L["Schema"]</span><code>@Model.Overview.SchemaName</code></div>
            <div><span>@L["Active configurations"]</span><span class="metric-inline">@Model.Overview.ActiveConfigurationCount</span></div>
        </div>
    </section>

    <section class="card section-card">
        <h3>@L["Next step"]</h3>
        <p class="muted small-text">
            @L["Continue to the configuration view to review or update the module's current sample configurations."]
        </p>
        <div class="toolbar">
            <a class="action-link" href="~/configurations">@L["Open configurations"]</a>
        </div>
    </section>

    <section class="card section-card">
        <h3>@L["Notifications"]</h3>
        <p class="muted small-text">
            @L["Send a personal test notification to the current OMP user."]
        </p>
        <div class="toolbar">
            <form method="post" asp-page-handler="SendTestNotification" data-enhance="false">
                <button type="submit" class="action-link">@L["Send test notification"]</button>
            </form>
            <form method="post" asp-page-handler="SendLevel1Banner" data-enhance="false">
                <button type="submit" class="action-link">@L["Send level 1 banner"]</button>
            </form>
            <form method="post" asp-page-handler="SendLevel2Banner" data-enhance="false">
                <button type="submit" class="action-link">@L["Send level 2 banner"]</button>
            </form>
            <form method="post" asp-page-handler="SendLevel3Banner" data-enhance="false">
                <button type="submit" class="action-link">@L["Send level 3 banner"]</button>
            </form>
            <form method="post" asp-page-handler="SendAdminBanner" data-enhance="false">
                <button type="submit" class="action-link">@L["Send admin banner"]</button>
            </form>
        </div>
    </section>
</div>
