@page
@model OpenModulePlatform.Web.ExampleWorkerAppModule.Pages.Configurations.IndexModel

<div class="page-header">
    <div>
        <div class="eyebrow">@L["Example module"]</div>
        <h1>@L["Configurations"]</h1>
        <p class="lede">@L["Configurations that can be assigned to the worker app's app instances."]</p>
    </div>
</div>

@if (Model.Rows.Count == 0)
{
    <div class="empty-state">@L["No configurations were found."]</div>
}
else
{
    <table class="grid">
        <thead><tr><th>@L["ConfigId"]</th><th>@L["Assigned app instances"]</th><th>@L["Comment"]</th><th></th></tr></thead>
        <tbody>
        @foreach (var row in Model.Rows)
        {
            <tr>
                <td><span class="pill">@row.ConfigId</span></td>
                <td>@row.AssignedInstallations</td>
                <td>@row.Comment</td>
                <td><a class="action-link" href="~/configurations/edit?configId=@row.ConfigId">@L["Edit"]</a></td>
            </tr>
        }
        </tbody>
    </table>
}
