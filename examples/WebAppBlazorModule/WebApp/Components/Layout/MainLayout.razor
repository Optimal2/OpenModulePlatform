@inherits LayoutComponentBase
@using OpenModulePlatform.Web.ExampleWebAppBlazorModule.Localization
@using OpenModulePlatform.Web.Shared.Services
@inject Microsoft.Extensions.Options.IOptions<OpenModulePlatform.Web.Shared.Options.WebAppOptions> Options
@inject Microsoft.Extensions.Localization.IStringLocalizer<ExampleWebAppBlazorModuleResource> L
@inject OmpBrandingService OmpBrandingService

<div class="page-shell">
    <header class="app-header">
        <OpenModulePlatform.Web.Shared.Components.Layout.PortalTopBar />
        <div class="topbar">
            <NavLink class="brand-wrap brand-wrap--link" href="" Match="NavLinkMatch.All" aria-label="@L["Overview"]">
                <div class="brand">@PortalTitle</div>
                <div class="brand-subtitle">@L["Example Web App Blazor Module"]</div>
            </NavLink>
            <nav class="nav nav--primary">
                <NavLink href="" Match="NavLinkMatch.All">@L["Overview"]</NavLink>
                <NavLink href="configurations">@L["Configurations"]</NavLink>
                <NavLink href="opendocviewer-demo">@L["OpenDocViewer"]</NavLink>
            </nav>
        </div>
    </header>

    <main class="content-shell">
        @Body
    </main>
</div>

@code {
    private OmpBranding _branding = OmpBranding.Default;

    private string PortalTitle => string.IsNullOrWhiteSpace(Options.Value.Title)
        ? _branding.PlatformName
        : Options.Value.Title;

    protected override async Task OnInitializedAsync()
        => _branding = await OmpBrandingService.GetBrandingAsync(CancellationToken.None);
}
