@page "/"
@inherits ExampleWebAppBlazorModuleComponentBase
@inject ExampleWebAppBlazorModuleAdminRepository Repo

<PageTitle>@PageTitle</PageTitle>

@if (!AuthorizationResolved)
{
    <div class="empty-state">@L["Loading overview..."]</div>
}
else if (PageError is not null)
{
    <OmpErrorView Model="@PageError" />
}
else
{
    <div class="page-header">
        <div>
            <div class="eyebrow">@L["Example module"]</div>
            <h1>@L["Example Web App Blazor Module"]</h1>
            <p class="lede">
                @L["Neutral reference module for web flows in OMP. The page shows a module overview and links onward to the module's configurations."]
            </p>
        </div>
    </div>

    <div class="section-grid section-grid--wide">
        <section class="card section-card">
            <h3>@L["Overview"]</h3>
            <div class="mini-metrics top-gap">
                <div><span>@L["Module key"]</span><code>@OverviewData.ModuleKey</code></div>
                <div><span>@L["Schema"]</span><code>@OverviewData.SchemaName</code></div>
                <div><span>@L["Active configurations"]</span><span class="metric-inline">@OverviewData.ActiveConfigurationCount</span></div>
            </div>
        </section>

        <section class="card section-card">
            <h3>@L["Next step"]</h3>
            <p class="muted small-text">
                @L["Continue to the configuration view to review or update the module's current sample configurations."]
            </p>
            <div class="toolbar">
                <NavLink class="action-link" href="configurations">@L["Open configurations"]</NavLink>
            </div>
        </section>
    </div>
}

@code {
    private OverviewRow OverviewData { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        SetPageTitle(L["Overview"]);

        if (await EnsureAnyPermissionAsync(
                CancellationToken.None,
                ExampleWebAppBlazorModulePermissions.View,
                ExampleWebAppBlazorModulePermissions.Admin))
        {
            OverviewData = await Repo.GetOverviewAsync(CancellationToken.None);
        }
    }
}
