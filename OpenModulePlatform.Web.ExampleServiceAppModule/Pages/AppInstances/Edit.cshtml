@page
@model OpenModulePlatform.Web.ExampleServiceAppModule.Pages.AppInstances.EditModel

<div class="page-header">
    <div>
        <div class="eyebrow">Example module</div>
        <h1>Edit app instance</h1>
        <p class="lede">Uppdatera styrande värden för vald appinstans.</p>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="card status-banner">@Model.StatusMessage</div>
}

<form method="post" class="card form-grid">
    <input type="hidden" asp-for="Input.AppInstanceId" />

    <div class="form-field checkbox-row">
        <input asp-for="Input.IsAllowed" type="checkbox" />
        <label asp-for="Input.IsAllowed"></label>
    </div>

    <div class="form-field">
        <label asp-for="Input.DesiredState"></label>
        <input asp-for="Input.DesiredState" type="text" />
    </div>

    <div class="form-field">
        <label asp-for="Input.ConfigId"></label>
        <input asp-for="Input.ConfigId" type="text" />
    </div>

    <div class="form-field">
        <label asp-for="Input.ArtifactId"></label>
        <input asp-for="Input.ArtifactId" type="text" />
    </div>

    <div class="toolbar">
        <button type="submit">Save</button>
        <a class="action-link" href="~/appinstances">Back to app instances</a>
    </div>
</form>
