@page
@model OpenModulePlatform.Web.ExampleServiceAppModule.Pages.AppInstances.IndexModel

<div class="page-header">
    <div>
        <div class="eyebrow">@L["Example module"]</div>
        <h1>@L["App Instances"]</h1>
        <p class="lede">
            @L["Runtime layer for the service app. Manage whether the instance is allowed, its desired state, artifact and configuration assignment."]
        </p>
    </div>
</div>

@if (Model.Rows.Count == 0)
{
    <div class="empty-state">@L["No app instances were found."]</div>
}
else
{
    <table class="grid">
        <thead>
            <tr>
                <th>@L["Host"]</th>
                <th>@L["App instance"]</th>
                <th>@L["Installation name"]</th>
                <th>@L["Allowed"]</th>
                <th>@L["Desired state"]</th>
                <th>@L["Artifact"]</th>
                <th>@L["ConfigId"]</th>
                <th>@L["Last seen"]</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var row in Model.Rows)
        {
            <tr>
                <td><span class="pill">@row.HostKey</span></td>
                <td>@row.AppInstanceKey</td>
                <td>@row.InstallationName</td>
                <td>@(row.IsAllowed ? L["Yes"] : L["No"])</td>
                <td>@row.DesiredState</td>
                <td>@row.ArtifactVersion</td>
                <td>@row.ConfigId</td>
                <td>@row.LastSeenUtc?.ToString("u")</td>
                <td><a class="action-link" href="~/appinstances/edit?appInstanceId=@row.AppInstanceId">@L["Edit"]</a></td>
            </tr>
        }
        </tbody>
    </table>
}
