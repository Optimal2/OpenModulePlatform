@page
@model OpenModulePlatform.Web.ExampleServiceAppModule.Pages.Configurations.IndexModel

<h2>Configurations</h2>

<table class="grid">
    <thead><tr><th>ConfigId</th><th>Assigned app instances</th><th>Comment</th><th></th></tr></thead>
    <tbody>
    @foreach (var row in Model.Rows)
    {
        <tr>
            <td>@(row.ConfigId)</td>
            <td>@(row.AssignedInstallations)</td>
            <td>@(row.Comment)</td>
            <td><a href="~/configurations/edit?configId=@row.ConfigId">Edit</a></td>
        </tr>
    }
    </tbody>
</table>
