@page
@model OpenModulePlatform.Web.ExampleServiceAppModule.Pages.IndexModel

<div class="page-header">
    <div>
        <div class="eyebrow">Example module</div>
        <h1>Example Service App Module</h1>
        <p class="lede">Referensmodul för kombinerad webb- och service-app i OMP. Här visas modulens konfiguration, instanser och köläge på en översiktlig nivå.</p>
    </div>
</div>

<div class="section-grid section-grid--wide">
    <section class="card section-card">
        <h3>Overview</h3>
        <div class="mini-metrics top-gap">
            <div><span>Module key</span><code>@Model.Overview.ModuleKey</code></div>
            <div><span>Schema</span><code>@Model.Overview.SchemaName</code></div>
            <div><span>Active configurations</span><span class="metric-inline">@Model.Overview.ActiveConfigurationCount</span></div>
            <div><span>Service app instances</span><span class="metric-inline">@Model.Overview.ServiceAppInstanceCount</span></div>
            <div><span>Open jobs</span><span class="metric-inline">@Model.Overview.OpenJobCount</span></div>
        </div>
    </section>

    <section class="card section-card">
        <h3>Manage</h3>
        <p class="muted small-text">Arbeta vidare med appinstanser, konfigurationer eller jobbkö via modulens egna administrationssidor.</p>
        <div class="toolbar">
            <a class="action-link" href="~/appinstances">App instances</a>
            <a class="action-link" href="~/configurations">Configurations</a>
            <a class="action-link" href="~/jobs">Jobs</a>
        </div>
    </section>
</div>
