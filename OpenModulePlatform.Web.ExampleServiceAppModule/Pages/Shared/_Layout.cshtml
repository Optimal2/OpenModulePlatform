@* File: OpenModulePlatform.Web.ExampleServiceAppModule/Pages/Shared/_Layout.cshtml *@
<!doctype html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/_content/OpenModulePlatform.Web.Shared/css/portal-topbar.css" />
</head>
<body>
    <header class="app-header">
        @await Component.InvokeAsync("PortalTopBar")
        <div class="topbar">
            <div class="brand-wrap">
                <div class="brand">@ViewData["PortalTitle"]</div>
                <div class="brand-subtitle">Example Service App Module</div>
            </div>
            <nav class="nav nav--primary">
                <a href="~/">Overview</a>
                <a href="~/appinstances">App Instances</a>
                <a href="~/configurations">Configurations</a>
                <a href="~/jobs">Jobs</a>
            </nav>
            <div class="user">@User?.Identity?.Name</div>
        </div>
    </header>
    <main class="content-shell">
        @RenderBody()
    </main>
    <script src="~/_content/OpenModulePlatform.Web.Shared/js/portal-topbar.js"></script>
</body>
</html>
