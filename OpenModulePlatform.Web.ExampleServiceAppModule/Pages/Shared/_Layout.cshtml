@* File: OpenModulePlatform.Web.ExampleServiceAppModule/Pages/Shared/_Layout.cshtml *@
@using OpenModulePlatform.Web.Shared.Navigation
@inject Microsoft.Extensions.Options.IOptions<OpenModulePlatform.Web.Shared.Options.WebAppOptions> WebAppOptionsAccessor
@inject Microsoft.Extensions.Localization.IStringLocalizer<OpenModulePlatform.Web.Shared.Localization.SharedResource> L
@inject PortalTopBarService PortalTopBarService
@{
    var portalTopBar = await PortalTopBarService.CreateAsync(
        WebAppOptionsAccessor.Value,
        Context.Request,
        User,
        Context.RequestAborted);
}
<!doctype html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/portal-topbar.css" />
</head>
<body>
    <header class="app-header">
        @if (portalTopBar.IsVisible && portalTopBar.PortalLink is not null)
        {
            <div class="portal-topbar" data-portal-topbar-root>
                <nav class="portal-topbar__nav" aria-label="@L["Portal"]" data-portal-topbar>
                    <a class="portal-topbar__portal-link" href="@portalTopBar.PortalLink.Href">@L[portalTopBar.PortalLink.TextKey]</a>

                    @if (portalTopBar.ModuleLinks.Count > 0)
                    {
                        <span class="portal-topbar__pipe" aria-hidden="true">|</span>

                        <div class="portal-topbar__modules" data-portal-topbar-modules>
                            @for (var i = 0; i < portalTopBar.ModuleLinks.Count; i++)
                            {
                                var link = portalTopBar.ModuleLinks[i];
                                <a class="portal-topbar__module-link" href="@link.Href" data-portal-topbar-item data-index="@i">@link.TextKey</a>
                            }
                        </div>

                        <details class="portal-topbar__collapsed" data-portal-topbar-overlay>
                            <summary title="@L[portalTopBar.CollapsedToggleTextKey]" aria-label="@L[portalTopBar.CollapsedToggleTextKey]">
                                @L[portalTopBar.CollapsedToggleTextKey]
                            </summary>
                            <div class="portal-topbar__collapsed-menu">
                                @foreach (var link in portalTopBar.ModuleLinks)
                                {
                                    <a class="portal-topbar__collapsed-link" href="@link.Href">@link.TextKey</a>
                                }
                            </div>
                        </details>

                        <details class="portal-topbar__overflow" data-portal-topbar-overflow data-portal-topbar-overlay hidden>
                            <summary>@L[portalTopBar.OverflowToggleTextKey]</summary>
                            <div class="portal-topbar__menu" data-portal-topbar-menu></div>
                        </details>
                    }
                </nav>

                @if (portalTopBar.IsPortalAdmin && portalTopBar.PortalAdminLinks.Count > 0)
                {
                    <div class="portal-topbar__tools">
                        <details class="portal-topbar__admin" data-portal-topbar-overlay>
                            <summary title="@L[portalTopBar.PortalAdminToggleTextKey]" aria-label="@L[portalTopBar.PortalAdminToggleTextKey]">
                                <span aria-hidden="true">&#9881;</span>
                                <span class="visually-hidden">@L[portalTopBar.PortalAdminToggleTextKey]</span>
                            </summary>
                            <div class="portal-topbar__admin-menu">
                                @foreach (var link in portalTopBar.PortalAdminLinks)
                                {
                                    <a class="portal-topbar__admin-link" href="@link.Href">@L[link.TextKey]</a>
                                }
                            </div>
                        </details>
                    </div>
                }
            </div>
        }
        <div class="topbar">
            <div class="brand-wrap">
                <div class="brand">@ViewData["PortalTitle"]</div>
                <div class="brand-subtitle">Example Service App Module</div>
            </div>
            <nav class="nav nav--primary">
                <a href="~/">Overview</a>
                <a href="~/appinstances">App Instances</a>
                <a href="~/configurations">Configurations</a>
                <a href="~/jobs">Jobs</a>
            </nav>
            <div class="user">@User?.Identity?.Name</div>
        </div>
    </header>
    <main class="content-shell">
        @RenderBody()
    </main>
    <script src="~/js/portal-topbar.js"></script>
</body>
</html>
