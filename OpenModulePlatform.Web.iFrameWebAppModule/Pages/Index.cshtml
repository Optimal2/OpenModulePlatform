@page "{setKey?}"
@model OpenModulePlatform.Web.iFrameWebAppModule.Pages.IndexModel

@section ModuleNav {
<div class="iframe-toolbar" role="toolbar" aria-label="@L["Select URL"]">
@foreach (var button in Model.UrlButtons)
{
    var css = button.IsSelected ? "iframe-toolbar__link iframe-toolbar__link--active" : "iframe-toolbar__link";
    if (!button.IsAvailable)
    {
        css += " iframe-toolbar__link--disabled";
    }

    <a class="@css" href="@Url.Page("/Index", new { setKey = Model.CurrentSetKey, urlId = button.Id })" aria-current="@(button.IsSelected ? "page" : null)">@button.Label</a>
}
</div>
}

<partial name="_IFrameDisplay" model="Model.Display" />
